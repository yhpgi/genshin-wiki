                  }
                ],
                "talent_img": "",
                "title": "Yaratılış: Güneş Çiçeği"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span></p><p>4<span style=\"color: rgb(255, 230, 153)\"> Toprak Hasarı</span> verir. Eğer <span style=\"color: #FFFFFF\">Güneş Çiçeği </span>alandaysa, bu Hasar 2 artar.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/23/25073864/42d2ae5af0169e6938febe18de57d31a_3887048143617460330.png",
                "id": "talent73130",
                "key": "Varoluş Ayini: Tektonik Dalga",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Varoluş Ayini: Tektonik Dalga"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Minyon</span></p><p><span style=\"color: rgb(255, 255, 255)\">Son Aşama:</span> 1 <span style=\"color: rgb(255, 230, 153)\">Toprak Hasarı </span>verir.</p><p><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı: 3</span></p><p><span style=\"color: rgb(255, 255, 255)\">Bu Minyon savaş alanındayken: </span>Karakterin 1 adet daha az <span style=\"color: rgb(255, 255, 255)\">Nötr Element </span>harcayarak <span style=\"color: rgb(255, 255, 255)\">Havadan Saldırı </span>yapar. (Her Turda bir defa)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/23/25073864/db13288db6b90ec33f8adc2656d2019f_6097547942095947435.png",
                "id": "talent48204",
                "key": "Güneş Çiçeği",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/23/25073864/02297af9d3309f3e4e40eca8911a19f6_345299715883568547.png",
                "title": "Güneş Çiçeği"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Zaten uygulanmış olan Elementlerle tepkimeye girer:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 230, 153)\">Toprak </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Buz</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Buz Kristalleşmesi:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 1 artar ve aktif karakterin 1 Kalkan puanı kazanır. (üst üste birikebilir ve maksimum 2 puan).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 230, 153)\">Toprak </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Su Kristalleşmesi: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve aktif karakterin 1 Kalkan puanı kazanır. (üst üste birikebilir ve maksimum 2 puan).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 230, 153)\">Toprak </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Ateş Kristalleşmesi: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve aktif karakterin 1 Kalkan puanı kazanır. (üst üste birikebilir ve maksimum 2 puan).</span></p><ol><li><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 230, 153)\">Toprak </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Elektrik Kristalleşmesi: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve aktif karakterin 1 Kalkan puanı kazanır. (üst üste birikebilir ve maksimum 2 puan).</span></p></li></ol>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/23/25073864/fd37cbfdd3b1b2c16e6e83fb0aa96889_9180947787255988489.png",
                "id": "talent26040",
                "key": "Toprak Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Toprak Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Fiziksel Hasar</span></strong></p><p>Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleştiremez.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Kullanım Hakkı</span></strong></p><p>Bu kartın etkisi tetiklendikten sonra 1 <span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı </span>harcanır.</p><p><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı </span>0 olduktan sonra bu kart hemen atılır.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nötr Element</span></strong></p><p>Bu tür bir maliyeti ödemek için herhangi bir elementin Element Zarını kullanabilirsin.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Havadan Saldırı</span></strong></p><p>Karakter, Aktif Karakter olarak değiştirildikten sonra bu Turdaki bir sonraki Savaş Hamlesi Normal Saldırı olursa bu, Havadan Saldırı olarak sayılır.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/23/25073864/245c229cf6f7364c7c9a7aea3db1a1ad_659143058651313958.png",
