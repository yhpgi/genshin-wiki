                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Becerisi</span></p><p><span style=\"color: #FFFFFF\">Güneş Çiçeği</span> çağırır.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/23/25073864/4c999a92de43cfba640c30b45c782fc9_973836039501512037.png",
                "id": "talent16703",
                "key": "Yaratılış: Güneş Çiçeği",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
