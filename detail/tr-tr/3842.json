              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">1 </span><span style=\"color: rgb(153, 255, 255)\">Buz Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/145542732/1ce09211f025bf5470682189e0837732_327417018838394111.png",
