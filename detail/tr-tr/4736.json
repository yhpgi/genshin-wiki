                "title": "Alevli Darbe"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Element Patlaması</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2</span> <span style=\"color: rgb(255, 153, 153)\">Ateş Hasarı</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Alamet Ruhu: Ateş Akrebi</span><strong><span style=\"color: rgb(255, 255, 255)\"> </span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">çağırır.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/11/138687708/6d7f53f97097de5265ca596461e914b1_336072846222951045.png",
                "id": "talent84322",
