                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Alamet Ruhunun Uyanışı: Ateş Akrebi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Pasif Beceri</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">(Pasif)</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Bu karakter Hasar aldıktan sonra</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">7 veya daha az Cana sahipse 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Enerji</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kazanır. (Her Düelloda bir defa)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/11/138687708/eb96a0e1f4fd6ddf6d0975dfcf1fed10_1071766623840142122.png",
                "id": "talent54120",
                "key": "Alamet Ruhunun Gücü",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Alamet Ruhunun Gücü"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Minyon<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1 </span><span style=\"color: rgb(255, 153, 153)\">Ateş Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: 2</span><br><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Oyuna girdikten sonra Hamle Aşaması başladığında</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Münzevi Alevli Hikayeci karakterine Ateş Akrebi: Muhafız Duruşu eklenir. (Alamet Ruhu: Ateş Akrebi oyundayken her Turda bir defa, bu karakterin aldığı Hasar 1 azalır.)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/11/138687708/db13288db6b90ec33f8adc2656d2019f_6087906373125986653.png",
                "id": "talent58631",
                "key": "Alamet Ruhu: Ateş Akrebi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/11/138687708/f7f4fe5b41d7d7267cc09061873660cc_4320928489828679213.png",
                "title": "Alamet Ruhu: Ateş Akrebi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Ateş Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir:</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Buz</span><span style=\"color: rgba(255, 255, 255, 0.45)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Erime:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 2 artar.</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Buharlaşma:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 2 artar.</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgb(255, 255, 255)\">Yüksek Voltaj:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 2 artar ve hedef, bir sonraki karakterle zorla değiştirilir.</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Doğa</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgb(255, 255, 255)\">Yanma:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve Turun sonunda 1 Ateş Hasarı verecek olan bir [</span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Yakıcı Alev</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur (Bir defa tetiklenir, 2 kademeye kadar birikir.)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/11/138687708/d714b3b669cc08d1d8e34464fd7a3630_2078282104774406594.png",
                "id": "talent84640",
                "key": "Ateş Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Ateş Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">Kullanım Hakkı</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1</span> <span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">harcanır.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">0 olduktan sonra bu kart hemen atılır.</span><br></p><p><strong><span style=\"color: #ECE5D8\">Enerji</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Karakterlerin Element Patlamasını kullanmaları için Enerji harcaması gerekir.<br>Karakterler bir Element Becerisi veya Normal Saldırı kullandıklarında, 1 Enerji kazanırlar.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/11/138687708/245c229cf6f7364c7c9a7aea3db1a1ad_6277235376957175924.png",
