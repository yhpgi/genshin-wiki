          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Saldırı</span></p><p>2 Fiziksel Hasar verir. </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/10316b5178d5109d597f415d6e7903dc_7597794524846042368.png",
                "id": "talent8002",
                "key": "Akkor Kılıç",
                "materials": [],
                "points": [
