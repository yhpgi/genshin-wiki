                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Akkor Kılıç"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Becerisi </span></p><p>3 <span style=\"color: rgb(255, 153, 153)\">Ateş Hasarı</span> verir. Bu becerinin 3. defa kullanıldığı her Turda Hasar 2 artar. </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/d0e27bc7054292e95c673e6f491ff677_3729784084901709977.png",
                "id": "talent61859",
                "key": "Dağlayan Taaruz",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Dağlayan Taaruz"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span></p><p>8 <span style=\"color: rgb(255, 153, 153)\">Ateş Hasarı</span> verir ve bu karakter Ateş Tesiri kazanır. </p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Ateş Tesiri</span></strong><br><span style=\"color: rgb(255, 215, 128)\">Durum</span><br>Bunun eklendiği karakterin verdiği Fiziksel Hasar<span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 153, 153)\">Ateş Hasarı</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> olarak değiştirilir. </span></p><p><span style=\"color: rgb(255, 255, 255)\">Tur Süresi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/7f35364dc83b6694a3200aae53f6670f_6972509467247254536.png",
                "id": "talent50184",
                "key": "Şafak",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Şafak"
              },
              {
                "attributes": [],
                "desc": "<p>Ateş etkisi uygular ve şu Element Tepkimelerini tetikleyebilir: </p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Buz</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Erime</span>: Bu seferki Hasar 2 artar. </p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Buharlaşma</span>: Bu seferki Hasar 2 artar. </p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Yüksek Voltaj</span>: Bu seferki Hasar 2 artar ve hedef bir sonraki karakterle zorla değiştirilir. </p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Doğa</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Yanma</span>: Bu seferki Hasar 1 artar ve Turun sonunda 1 Ateş Hasarı verecek olan bir [<strong>Yakıcı Alev</strong>] oluşturulur. (Bir defa tetiklenir, 2 kademeye kadar birikir.) </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/05/77454259/d714b3b669cc08d1d8e34464fd7a3630_3135645163697502884.png",
                "id": "talent15289",
                "key": "Ateş Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Ateş Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Fiziksel Hasar</span></strong></p><p>Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleştiremez. </p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Kullanım Hakkı</span></strong></p><p>Bu kartın etkisi tetiklendikten sonra 1 <span style=\"color: #FFFFFF\">Kullanım Hakkı</span> harcanır. </p><p><span style=\"color: #FFFFFF\">Kullanım Hakkı</span> 0 olduktan sonra bu kart hemen atılır. </p><p><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_2735958786086240694.png",
