                  }
                ],
                "talent_img": "",
                "title": "Taşların Efendisi: Hüküm Taşı"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Element Patlaması</span></p><p>4<span style=\"color: #FFE699\"> Toprak Hasarı</span> verir ve hedef karaktere <span style=\"color: #FFFFFF\">Taşlaşma</span> eklenir.</p><p></p><p><strong><span style=\"color: #ECE5D8\">Taşlaşma </span></strong></p><p><span style=\"color: #FFD780\">Durum</span></p><p><span style=\"color: #FFFFFF\">Karakter, Becerilerini kullanamaz. </span>(Bu Tur sona erene kadar sürer.)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/25073864/c701cbbd15b971aaee458b19e71b4ced_8528347166678441074.png",
