    {
      "id": "39",
      "name": "Önerilen Karakterler",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "• Kurdun Mezartaşı, sağladığı yüksek Saldırı Bonusları sayesinde neredeyse tüm Çift Elli Kılıç kullanıcıları için iyi bir seçenektir. Aşağıdaki karakterler, bu Saldırı Bonusunu daha verimli şekilde kullanabildiği için seçilmiştir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 43,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Diluc_icon.png",
                      "name": "Diluc",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "• Diluc, Ana Hasar Karakteri olarak bu silahı kullandığında halihazırda yüksek olan Temel Saldırısını çok yüksek seviyelere çıkararak becerilerinin çok daha fazla Hasar vermesini sağlar. Bu silah ile birlikte özellikle",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Buharlaşma",
                      "type": "text"
                    },
                    {
                      "text": "ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Erime",
                      "type": "text"
                    },
                    {
                      "text": "takımları için",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Element Ustalığı",
                      "type": "text"
                    },
                    {
                      "text": "Kadim Kum Taneleri parçası kullanabilir ve Element Tepkimesi Hasarını fazlaca artırır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 6,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Eula_icon.png",
                      "name": "Eula",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "• Eula, Ana Hasar Karakteri olarak becerilerinin çok yüksel Saldırı oranları vardır. Eula bir",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Buz",
                      "type": "text"
                    },
                    {
                      "text": "karakteri olsa da",
                      "type": "text"
                    },
                    {
                      "text": "Fiziksel Hasar",
                      "type": "text"
                    },
                    {
                      "text": "Karakteri olduğu için Element Ustalığına ihtiyaç duymaz ve çok yüksek Saldırı değerlerine ulaşarak becerilerinin Hasarını çok yüksek değerlere ulaştırabilir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 11,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Beidou_icon.png",
                      "menu_id": 2,
                      "name": "Beidou",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "• Beidou, Ana Hasar Karakteri olmasa bile bu silah ile birlikte Saldırı değerini oldukça yükseltebilir ve Savaş Alanında olmadan Element Patlaması ile birlikte yüksek Hasar verebilir. Ayrıca, Silahın pasifi takım arkadaşlarına da Saldırı değeri sağladığı için Beidou; bu silahı kullanarak Takım Arkadaşlarını bu şekilde destekleyebilir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
