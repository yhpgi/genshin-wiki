                ],
                "talent_img": "",
                "title": "Dolu Fırtınası Ayazı"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Becerisi</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(153, 255, 255)\">Buz Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve hedef karaktere</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Dondurucu Soğuk</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">eklenir.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Dondurucu Soğuk</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Eklenen karaktere 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(153, 255, 255)\">Buz Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: 1</span><br><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Eklenen karakter</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kavurucu Sıcak</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kuşanınca bu etki kaldırılır.</span><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/10/138687708/289913e1d0feaab0fa03891032b086c0_6138100678805568735.png",
                "id": "talent6812",
                "key": "Dondurucu Parçalar",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Dondurucu Parçalar"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">4</span> <span style=\"color: rgb(153, 255, 255)\">Buz Hasarı</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">verir, bu karakter için 2 Can yeniler.</span> <span style=\"color: rgba(255, 255, 255, 0.85)\">Buz Mühürlü Kızıl Alev Cadısı</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">kaldırılır. Bu karakter kalıcı olarak</span> <span style=\"color: rgb(255, 255, 255)\">Kızıl Alev Cadısı</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">durumuna geçer.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Buz Mühürlü Kızıl Alev Cadısı</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Hamle Aşaması başladığında</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">eklenen karakter 4 veya daha az Cana sahipse bu etki kaldırılır.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Eklenen karakter yenildiğinde</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">bu etki kaldırılır, karakter</span> <span style=\"color: rgba(255, 255, 255, 0.85)\">yenilemez</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, Canı 1 olacak şekilde Can yeniler.<br></span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Bu etki kaldırıldığında</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">eklenen karakter</span> <span style=\"color: rgba(255, 255, 255, 0.85)\">Kızıl Alev Cadısı</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">durumuna dönüşür.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Yenilmez</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bazı etkiler karakterlere</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">ölümsüzlük vererek yenilmemelerini sağlar</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">ve Canları 0 olduğunda onları belirli bir miktar iyileştirir.<br>Bu durumda karakterler</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">yenilmiş</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">olarak görülmez. (Dolayısıyla onlara ekli ekipman ve durumlar kaldırılmaz, enerjileri silinmez.)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Kızıl Alev Cadısı</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Sinyora, kalıcı olarak \"Kızıl Alev Cadısı\" durumuna geçiş yapabilir.<br>Geçiş yaptıktan sonra Sinyora'nın Element Türü</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(153, 255, 255)\">Buzdan</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(255, 153, 153)\">Ateşe</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">dönüşür.<br>Ardından bu karakter Kızıl Alev Cadısının becerilerini kullanabilir ama Sinyora'nın asıl becerilerini artık kullanamaz.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/10/138687708/f819c287507962ff41ad86e68661a707_3297545760476243094.png",
