                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(153, 255, 255)\">Buz Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/10/138687708/1ce09211f025bf5470682189e0837732_8637295754252150879.png",
                "id": "talent30271",
                "key": "Dolu Fırtınası Ayazı",
                "materials": [],
                "points": [
