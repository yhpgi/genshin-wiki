    {
      "id": "39",
      "name": "Önerilen Karakterler",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 34,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Hu Tao_icon.png",
                      "name": "Hu Tao",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ejder Laneti'nin sağladığı Element Ustalığı, Hu Tao'nun en güçlü stratejisi olan Buharlaşma Tepkimesinin Hasarını artırır. Ayrıca Pasifi sayesinde Su veya Ateşten etkilenen düşmanlara verilen Hasarı artıracağı için verdiği Buharlaşma Hasarı ve  Toplam Hasarı oldukça artar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 50,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Xiangling_icon.png",
                      "name": "Xiangling",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ejder Laneti'nin sağladığı Element Ustalığı, Xiangling'in en güçlü stratejisi olan Buharlaşma Tepkimesinin Hasarını artırır. Ayrıca Pasifi sayesinde Su veya Ateşten etkilenen düşmanlara verilen Hasarı artıracağı için verdiği Buharlaşma Hasarı ve  Toplam Hasarı oldukça artar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ek olarak, Aşırı Çiçeklenme veya Filizlenme gibi tamamen Element Ustalığı ile güçlenen tepkimeleri tetikleyen karakterler, en iyi takımları veya stratejileri olmasa bile bu silahı kullanarak Element Ustalığını artırabilir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "(Örneğin Aşırı Çiçeklenme için",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 49,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Raiden Shogun_icon.png",
                      "name": "Şogun Raiden",
                      "type": "custom_entry"
                    },
                    {
                      "text": ", Filizlenme için",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 16,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Thoma_icon.png",
                      "name": "Thoma",
                      "type": "custom_entry"
                    },
                    {
                      "text": "...)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
