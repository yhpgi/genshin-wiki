              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Çağrı</span><br><span style=\"color: rgb(255, 255, 255)\">Son Aşama</span>:1 <span style=\"color: rgb(255, 172, 255)\">Elekrtik Hasarı </span><span style=\"color: #FFFFFF\">verir. </span><br><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/db13288db6b90ec33f8adc2656d2019f_1432474800779831613.png",
