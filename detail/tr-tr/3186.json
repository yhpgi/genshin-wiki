          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Fiziksel Hasar </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/26b9736a2d14fc4162b2448963f45695_4719150569776066802.png",
                "id": "talent21065",
                "key": "Yunlai Kılıç Tekniği",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Yunlai Kılıç Tekniği"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Becerisi</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2</span> <span style=\"color: #FFACFF\">Elektrik Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yıldırım Hançeri </span><span style=\"color: rgba(255, 255, 255, 0.45)\">oluşturur.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/855f8d96be42fe05d7f7d66b60fad1a6_6366848529116509629.png",
                "id": "talent35296",
                "key": "Yıldızların Düzeni",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Yıldızların Düzeni"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">4 </span><span style=\"color: #FFACFF\">Elektrik Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve rakibin hazırdaki tüm karakterlerine 3 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Delme Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/9950bc530ec62d8e01daf47fe1229216_6996121677534947275.png",
                "id": "talent27089",
                "key": "Yıldız Çarpışması",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Yıldız Çarpışması"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Etkinlik Kartı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Savaş Hamlesi: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Aktif karakter olarak Keqing seçtiğinde hemen bir defa Yıldızların Düzeni kullanır. Yıldızların Düzeni becerisi başka bir Yıldırım Hançeri oluşturmadan Keqing karakterine </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Elektrik Tesiri </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">(Keqing elindeki kartla birlikte Yıldızların Düzeni kullandığında, başka bir Yıldırım Hançeri oluşturmadan bu kart atılır ve Keqing </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Elektrik Tesiri </span><span style=\"color: rgba(255, 255, 255, 0.45)\">elde eder.)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Elektrik Tesiri</span></strong></p><p><span style=\"color: #FFD780\">Durum</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bunun eklendiği karakterin verdiği </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Fiziksel Hasar, </span><span style=\"color: #FFACFF\">Elektrik Hasarına </span><span style=\"color: rgba(255, 255, 255, 0.45)\">dönüşür.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Tur Süresi: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/db13288db6b90ec33f8adc2656d2019f_1840725084548997174.png",
                "id": "talent34599",
                "key": "Yıldırım Hançeri",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/d6793b3314d1b255f49f2ba1ec500b38_7315783418333362182.png",
                "title": "Yıldırım Hançeri"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Elektrik etkisi uygular ve şu Element Tepkimelerini tetikleyebilir: <br>[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yüksek Voltaj</span>:<span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 2 artar ve hedef, bir sonraki karakterle zorla değiştirilir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Buz</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Süper İletim</span>: <span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakip karakterler 1 Delme Hasarı verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Elektrik Yüklenme: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakiplere 1 Delme Hasarı verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Doğa</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Hızlanma:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 1 artar ve sonraki 2 Doğa veya Elektrik Hasarını 1 artıran bir [</span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Dönüştürme Alanı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/11ea6117480145a30b7893f1e8bd7115_4828322067096551325.png",
                "id": "talent60261",
                "key": "Elektrik Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Elektrik Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleşmez.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Delme Hasarı</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> <br></span><span style=\"color: rgba(255, 255, 255, 0.45)\">Delme Hasarı herhangi bir bonusla artırılmaz ama Kalkan veya Hasar Bağışıklığı kullanımına karşı da savunulamaz. <br></span></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Savaş Hamlesi</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Sen 1 Savaş Hamlesi yaptıktan sonra, sıra rakibine geçer. Bu kurala göre elindeki bir kartı oynamak, Hızlı Hamleden ziyade bir Savaş Hamlesidir.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır. </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> 0 olduktan sonra bu kart hemen atılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_496952867129860645.png",
