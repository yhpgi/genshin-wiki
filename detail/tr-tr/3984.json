                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Temel Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "niteliğine sahip ve kuşanılan karaktere ikincil nitelik olarak",
                      "type": "text"
                    },
                    {
