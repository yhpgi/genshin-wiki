              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p>Summons 1 <span style=\"color: rgb(255, 255, 255)\">Shadowsword: Galloping Frost</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/c3c234c2ef7f4886cf9e3f66a9d7c7af_3386411454419342550.png",
                "id": "talent7396",
