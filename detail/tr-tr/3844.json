                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Saldırı</span></p><p>1 <span style=\"color: rgb(255, 172, 255)\">Elektrik Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/03/145542732/1ce09211f025bf5470682189e0837732_3059978625855933644.png",
                "id": "talent85023",
