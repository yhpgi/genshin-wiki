                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Becerisi</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">1</span> <span style=\"color: rgba(255, 255, 255, 0.85)\">Yuegui: Fırlatma</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Modu çağırır.</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/24/138687708/c587e90a155d07517365218aff66911c_3399176660350642532.png",
