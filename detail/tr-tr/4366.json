                  }
                ],
                "talent_img": "",
                "title": "Kızıl Gök Turpu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(126, 194, 54)\">Doğa Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Adeptus Mirası</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">oluşturur.</span></p><p></p><p><strong><span style=\"color: rgb(236, 228, 217)\">Adeptus Mirası</span></strong><br><span style=\"color: rgb(255, 215, 128)\">Durum</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Karakter değiştirdikten sonra</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(126, 194, 54)\">Doğa Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir, aktif karakterin için 1 Can yeniler.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/24/138687708/37972e3c3e9c9134cd6b1357f57aa711_1265107153258539193.png",
                "id": "talent7936",
                "key": "Ay Yeşiminin İnişi",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ay Yeşiminin İnişi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Minyon</span></p><p><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(126, 194, 54)\">Doğa Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve takımındaki en fazla hasar alan karakter için 1 Can yeniler.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/24/138687708/db13288db6b90ec33f8adc2656d2019f_5858959896955232090.png",
                "id": "talent1036",
                "key": "Minyon - Yuegui: Fırlatma Modu",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/24/138687708/0f3a979856a1d439f1f85900b98bf648_1855230248353192850.png",
                "title": "Minyon - Yuegui: Fırlatma Modu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Doğa Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir:</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(153, 255, 136)\">Doğa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Çiçeklenme:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve bir sonraki Ateş veya Elektrik hasarını 2 artıran bir [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Doğa Çekirdeği</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur.</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(153, 255, 136)\">Doğa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yanma:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve Turun sonunda 1 Ateş Hasarı verecek olan bir [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yakıcı Alev</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur. (Bir defa tetiklenir, 2 kademeye kadar birikir.)</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(153, 255, 136)\">Doğa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Hızlanma:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve sonraki 2 Doğa veya Elektrik Hasarını 1 artıran bir [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Dönüştürme Alanı</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/24/138687708/e8cff941b5a0ff248efde360ec9e91fe_4559245890673846650.png",
                "id": "talent739",
                "key": "Doğa Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Doğa Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">Fiziksel Hasar</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleştirmez.<br></span></p><p><strong><span style=\"color: #ECE5D8\">Kullanım Hakkı</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">harcanır.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">0 olduktan sonra bu kart hemen atılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/24/138687708/245c229cf6f7364c7c9a7aea3db1a1ad_4810789088116107669.png",
