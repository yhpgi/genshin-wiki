                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Yaprak Kesen Işık, 5 yıldızlı silahlar arasında en fazla",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Kritik Hasar",
                      "type": "text"
                    },
                    {
                      "text": "veren silahtır. Ama bunun yanında, düşük",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Temel Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "'ya sahiptir. Pasif özelliği bir miktar",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Kritik Oran",
                      "type": "text"
                    },
                    {
                      "text": "sağlar, ve Ayaka'nın",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Normal Saldırıları, Element Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "verebildiğinden dolayı, bu pasifi aktif hale getirebilir ve bunu",
                      "type": "text"
                    },
                    {
                      "styles": [
