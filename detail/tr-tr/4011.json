    {
      "id": "48",
      "name": "Beceri",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(255, 172, 255)\">Elektrik Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu Beceri</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yüklü Saldırı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">olarak kullanıldığında rakibin aktif karakterine</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">İletken</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">eklenir.</span></p><p></p><p><span style=\"color: rgb(236, 229, 216)\">İletken</span></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu durum 2 kademe İletken ile başlar. Üst üste eklendiğinde 1 kademe kazanılır. İletken 4 kademeye kadar birikebilir.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1 kademe İletken birikir.</span><br><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Eklenen karakter Mor Akım tarafından Hasar aldığında: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu durum kalkar ve her İletken kademesi için fazladan 1 Hasar verir.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/06/138687708/ead1e5139681f49400a80a2ebb10fb2a_5925605166066581809.png",
                "id": "talent65213",
                "key": "Yıldırım Dokunuşu",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Yıldırım Dokunuşu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Becerisi</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">2</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(255, 172, 255)\">Elektrik Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir. Rakibin aktif karakterine</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">İletken</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">eklenmediyse eklenir.</span></p><p></p><p><span style=\"color: rgb(236, 229, 216)\">İletken</span></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu durum 2 kademe İletken ile başlar. Üst üste eklendiğinde 1 kademe kazanılır. İletken 4 kademeye kadar birikebilir.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1 kademe İletken birikir.</span><br><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Eklenen karakter Mor Akım tarafından Hasar aldığında: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu durum kalkar ve her İletken kademesi için fazladan 1 Hasar verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/06/138687708/af99fb6b223af8aab53e4447b06483ba_1662892245175427401.png",
                "id": "talent82474",
                "key": "Mor Akım",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Mor Akım"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">2 </span><strong><span style=\"color: rgb(255, 172, 255)\">Elektrik Hasarı</span></strong><span style=\"color: rgb(236, 228, 217)\"> verir ve </span><strong><span style=\"color: rgb(255, 255, 255)\">Şimşek Gülü</span></strong><span style=\"color: rgb(236, 228, 217)\"> çağırır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/06/138687708/e225f8fa5e9a435290d33b7b93b4e376_6545154295828293955.png",
                "id": "talent76650",
                "key": "Şimşek Gülü",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Şimşek Gülü"
              },
              {
                "attributes": [],
                "desc": "<p><br><span style=\"color: rgb(255, 215, 128)\">Minyon</span><br><span style=\"color: rgb(255, 255, 255)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> 2 </span><span style=\"color: rgb(255, 172, 255)\">Elektrik Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> verir.</span><br><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı</span>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/10/138687708/db13288db6b90ec33f8adc2656d2019f_1974206491486718506.png",
                "id": "talent99",
                "key": "Minyon - Şimşek Gülü",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/10/138687708/2b3f9718f47e31a775816000450f000e_6174336043800321071.png",
                "title": "Minyon - Şimşek Gülü"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Elektrik Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir:<br>[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: #FFFFFF\">Yüksek Voltaj:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 2 artar ve hedef, bir sonraki karakterle zorla değiştirilir.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Buz</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: #FFFFFF\">Süper İletim:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakip karakterlere 1 Delme Hasarı verir.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: #FFFFFF\">Elektrik Yüklü:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakip karakterlere 1 Delme Hasarı verir.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Doğa</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: #FFFFFF\">Hızlanma:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 1 artar ve sonraki 2 Doğa veya Elektrik Hasarını 1 artıran bir [Dönüştürme Alanı] oluşturur.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/10/138687708/11ea6117480145a30b7893f1e8bd7115_6873871160489579739.png",
                "id": "talent47812",
                "key": "Elektrik Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Elektrik Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Yüklü Saldırı</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Hamle Aşamasından önce toplam Element Zarı sayısı bir çift sayı olduğunda Normal Saldırı, Yüklü Saldırı olarak sayılır.</span><br></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Kullanım Hakkı</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1 </span><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır.<br></span><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 0 olduktan sonra bu kart hemen atılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/10/138687708/245c229cf6f7364c7c9a7aea3db1a1ad_4061327412658017159.png",
