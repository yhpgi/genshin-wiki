    {
      "id": "37",
      "name": "Konum ve Öğretici",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Inazuma - Jakotsu Madeni",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/18/145542732/619540b93f50dfd3788e9d90c422316e_7928610865705200126.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Öğretici",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/18/145542732/46195de085255da3ce08af116188d5b1_6295328323423746902.png"
                    },
                    {
                      "text": "• Maguu Kenki'nin iki savaş safhası vardır. İlk safhada,",
                      "type": "text"
                    },
                    {
                      "text": "Fiziksel",
                      "type": "text"
                    },
                    {
                      "text": "ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 255, 215)"
                      ],
                      "text": "Rüzgar",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#80ffd7"
                      ],
                      "text": "Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "veren saldırılar yapar. Maguu Kenki'nin Canını belirli miktar indirdikten sonra ikinci safhaya geçer.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/18/145542732/dc490983bb9bffc8aa497351ac1845ee_4511181965002777354.png"
                    },
                    {
                      "text": "• İkinci safhaya geçerken Maguu Kenki bir saldırıya hazırlanır ve Hasar almaz. Hazırlanması bitince büyük bir alana",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Alan Buz Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "verir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/18/145542732/9c0d637651f3846083b0cf9f00c34270_6743913528417981636.png"
                    },
                    {
                      "text": "• Bu safhada saldırıları güçlenir ve tüm saldırıları",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 255, 215)"
                      ],
                      "text": "Rüzgar Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "vermeye başlar. Ayrıca, bazı saldırıları bir klon çıkartarak saldırıyı kopyalar ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Buz Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "verir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/18/145542732/741f09d13fa1236494121264ecab63fe_3991559303505039824.png"
                    },
                    {
                      "text": "• Ayrıca her iki safhada da Maguu Kenki'ye isabet eden",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Menzilli Saldırılar",
                      "type": "text"
                    },
                    {
                      "text": "belirli bir şansla Maguu Kenki tarafından tamamen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "bloklanır",
                      "type": "text"
                    },
                    {
                      "text": "ve Hasarı sıfırlanır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
