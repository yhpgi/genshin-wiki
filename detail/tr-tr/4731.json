          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/04/138687708/94aa30ae75b8c7c6a9c64ab05bd5dda7_4809116516761728594.png",
                "id": "talent86322",
                "key": "Seri Tören Kılıcı",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Seri Tören Kılıcı"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Becerisi</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">3</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(128, 255, 215)\">Rüzgar Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir. Bu Beceri bu Turda ilk defa kullanıldığında karakterin 8'den daha az Canı varsa onun için 2 Can yeniler ama söz konusu karaktere </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Tehditkar Saldırı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Tehditkar Saldırı</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu karakterin Canı en az 6 olduğunda 2 Delme Hasarı alır.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Tur Süresi: 1</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/04/138687708/42bfd225eedc984bb1d4a4af99e3dcae_9192542447808460670.png",
                "id": "talent99408",
                "key": "Gizemli Aldatmaca",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Gizemli Aldatmaca"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(128, 255, 215)\">Rüzgar Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Şaşırtıcı Kedi Kutusu</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">çağırır.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/04/138687708/b718fd9ceee2d78fdf5d76f345458f71_4825620997769539227.png",
                "id": "talent59403",
                "key": "Sihir Numarası: Şaşırtıcı Değişim",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Sihir Numarası: Şaşırtıcı Değişim"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Minyon</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(128, 255, 215)\">Rüzgar Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">2</span><br><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Aktif karakterin Hasar aldığında</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">alınan Hasar 1 azalır. (Her Turda bir defa)</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Karakterlerin</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Buz</span>/<span style=\"color: rgb(128, 192, 255)\">Su</span>/<span style=\"color: rgb(255, 153, 153)\">Ateş</span>/<span style=\"color: rgb(255, 172, 255)\">Elektrik</span> Hasarı <span style=\"color: rgba(255, 255, 255, 0.45)\">aldığında bu kartın Element Türü, alınan hasarın elementine göre değişir. (Oyundan ayrılmadan önce sadece bir defa)</span><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/04/138687708/db13288db6b90ec33f8adc2656d2019f_556831346795217897.png",
                "id": "talent11842",
                "key": "Şaşırtıcı Kedi Kutusu",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/04/138687708/bc84abe7e3d8d79c9b75a0de329313dc_8689943671686596992.png",
                "title": "Şaşırtıcı Kedi Kutusu"
              },
              {
                "attributes": [],
                "desc": "<p>Zaten uygulanmış olan Elementlerle tepkimeye girer:</p><p>[<span style=\"color: rgb(128, 255, 215)\">Rüzgar</span><span style=\"color: rgb(153, 255, 136)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Buz</span>] <span style=\"color: rgb(255, 255, 255)\">Buz Girdabı</span>: Hedef dışındaki tüm rakiplere 1 Buz Hasarı verir ve Buz etkisi uygular.</p><p>[<span style=\"color: rgb(128, 255, 215)\">Rüzgar</span><span style=\"color: rgb(153, 255, 136)\"> </span>+ <span style=\"color: rgb(255, 153, 153)\">Ateş</span>] <span style=\"color: rgb(255, 255, 255)\">Ateş Girdabı</span>: Hedef dışındaki tüm rakiplere 1 Ateş Hasarı verir ve Ateş etkisi uygular.</p><p>[<span style=\"color: rgb(128, 255, 215)\">Rüzgar</span><span style=\"color: rgb(153, 255, 136)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Elektrik</span>]<span style=\"color: rgb(255, 255, 255)\"> Elektrik Girdabı</span>: Hedef dışındaki tüm rakiplere 1 Elektrik Hasarı verir ve Elektrik etkisi uygular.</p><p>[<span style=\"color: rgb(128, 255, 215)\">Rüzgar</span><span style=\"color: rgb(153, 255, 136)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Su</span>] <span style=\"color: rgb(255, 255, 255)\">Su Girdabı</span>: Hedef dışındaki tüm rakiplere 1 Su Hasarı verir ve Su etkisi uygular.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/04/138687708/c97292d96456bfe4abeca16bfce801e4_9113267623220907649.png",
                "id": "talent74311",
                "key": "Rüzgar Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Rüzgar Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Fiziksel Hasar</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleştirmez.</span><br></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Delme Hasarı</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Delme Hasarı herhangi bir bonusla artırılamaz ama Kalkan veya Hasar Bağışıklığı kullanımına karşı da savunulamaz.<br></span></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Tur Süresi</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Her turun Son Aşamasında </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Tur Süresi</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">1 azalır;</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Tur Süresi</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">tükendikten sonra bu kart hemen atılır.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Kullanım Hakkı</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">harcanır.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">0 olduktan sonra bu kart hemen atılır.</span><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/04/138687708/245c229cf6f7364c7c9a7aea3db1a1ad_5481804165667322391.png",
