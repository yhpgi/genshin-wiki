      "name": "Beceri",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Fiziksel Hasar </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/145542732/10316b5178d5109d597f415d6e7903dc_5970218674261562753.png",
                "id": "talent3635",
                "key": "Favonius Kılıç Tekniği - Edel",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Favonius Kılıç Tekniği - Edel"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Element Becerisi</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: rgb(153, 255, 255)\">Buz Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve bu karakter henüz </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Buz Yürek </span><span style=\"color: rgba(255, 255, 255, 0.45)\">elde etmediyse </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Buz Yürek </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kazanır.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Buz Yürek</span></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartı kuşanmış karakter </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Buz Dalgası Girdabı</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> kullandıktan sonra bu durum kaldırılır ve Hasar 2 artar.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/145542732/78b526224710dda639b49972145339a9_149555516164781486.png",
                "id": "talent19356",
                "key": "Buz Dalgası Girdabı",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Buz Dalgası Girdabı"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Element Patlaması</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: #99FFFF\">Buz Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Işıksaçan Kılıcı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">çağırır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/145542732/72b7716be67efac4ec94efde16957180_8144073666437199635.png",
                "id": "talent75148",
                "key": "Buzul Aydınlık",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Buzul Aydınlık"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Minyon</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Eula, bir Normal Saldırı ya da Element Becerisi kullandığında bu kart 2 kademe Azim biriktirir ancak Eula Enerji kazanmaz. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartı atarak 2 </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Fiziksel Hasar </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verebilirsin. Her bir Azim kademesi bu seferki Hasarı 1 artırır. (Bu kartın </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">üzerindeki etkiler </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Azim </span><span style=\"color: rgba(255, 255, 255, 0.45)\">için uygulanır.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/145542732/db13288db6b90ec33f8adc2656d2019f_1723620378979510282.png",
                "id": "talent5679",
                "key": "Işıksaçan Kılıcı",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/145542732/3f07051befd3fcb50000df92021710d6_8555354713899684679.png",
                "title": "Işıksaçan Kılıcı"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Buz Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir: <br>[</span><span style=\"color: rgb(153, 255, 255)\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">]</span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Erime</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">: Bu seferki Hasar 2 artar.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(153, 255, 255)\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">]</span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Süper İletim</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">: Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakip karakterlere 1 Delme Hasarı verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(153, 255, 255)\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">]</span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Donma</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">: Bu seferki Hasar 1 artar ve hedef bu turda hamle yapamaz. (Hedef, Fiziksel Hasar ve Ateş Hasarı alınca kaldırılır, fazladan 2 Hasar alır.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/145542732/4bcc4b82a9d7ee22770f60afa54e9919_6349983170382992867.png",
                "id": "talent90260",
                "key": "Buz Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Buz Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleşmez.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır. </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> 0 olduktan sonra bu kart hemen atılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/145542732/245c229cf6f7364c7c9a7aea3db1a1ad_9116918961804113358.png",
