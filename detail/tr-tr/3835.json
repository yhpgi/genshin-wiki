                  }
                ],
                "talent_img": "",
                "title": "Patlayıcı Kukla"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: #FF9999\">Ateş Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve rakibin hazırdaki karakterlerine 2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Delme Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/26/145542732/c1cb087219594f5a54c4fafb433536f7_1151887814390045714.png",
                "key": "Ateş Yağmuru",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ateş Yağmuru"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Minyon</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Aktif karakterin hasar aldığında alınan Hasar 2 azalır.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1. Kullanım Hakkı bittiğinde bu kart atılmaz. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Son Aşama, Kullanım Hakkı tamamen tükendiyse bu kartı atarak 2 </span><span style=\"color: #FF9999\">Ateş Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verebilirsin. </span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/26/145542732/db13288db6b90ec33f8adc2656d2019f_4193082038358928007.png",
                "key": "Minyon - Baron Tavşanı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/26/145542732/73a2f9790672a39cb2f9a87b5f09ed6b_9089865437535129315.png",
                "title": "Minyon - Baron Tavşanı"
              },
              {
                "attributes": [],
                "desc": "<p>Ateş Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Buz</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Erime</span>: Bu seferki Hasar 2 artar.</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Buharlaşma</span>: Bu seferki Hasar 2 artar.</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Yüksek Voltaj</span>: Bu seferki Hasar 2 artar ve hedef, bir sonraki karakterle zorla değiştirilir.</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Doğa</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Yanma</span>: Bu seferki Hasar 1 artar ve Turun sonunda 1 Ateş Hasarı verecek olan bir [Yakıcı Alev] oluşturur. (Bir defa tetiklenir, 2 kademeye kadar birikir.)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/26/145542732/d714b3b669cc08d1d8e34464fd7a3630_4019289824821684783.png",
                "key": "Ateş Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Ateş Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Delme Hasarı</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Delme Hasarı herhangi bir bonusla artırılmaz ama Kalkan veya Hasar Bağışıklığı kullanımına karşı da savunulamaz.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır. </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> 0 olduktan sonra bu kart hemen atılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/26/145542732/245c229cf6f7364c7c9a7aea3db1a1ad_1240825332021485035.png",
