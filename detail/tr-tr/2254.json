                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "daha da artar. Yelan'ın yetenekleri",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "ile güçlenmediği için silahın nispeten düşük",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Saldırısı",
                      "type": "text"
                    },
                    {
                      "text": "Yelan için bir şey ifade etmez.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
