                      ],
                      "text": "Maks. Can",
                      "type": "text"
                    },
                    {
                      "text": "ile güçlendiği için pasifi Yelan'a fazladan",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "sağlar. Ayrıca verdiği yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Kritik Hasar",
                      "type": "text"
                    },
                    {
                      "text": "sayesinde Yelan'ın",
