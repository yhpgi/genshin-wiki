                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasarını",
                      "type": "text"
                    },
                    {
                      "text": "artırabilir. Aynı zamanda silahın sağladığı",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Can",
                      "type": "text"
                    },
                    {
                      "text": "değeri sayesinde sağladığı",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "İyileştirme",
                      "type": "text"
                    },
                    {
                      "text": "ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Kalkan",
                      "type": "text"
                    },
                    {
                      "text": "değerlerini artırır. Bu silah, Baizhu'nun imza silahıdır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 25,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Sangonomiya Kokomi_icon.png",
                      "name": "Sangonomiya Kokomi",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
