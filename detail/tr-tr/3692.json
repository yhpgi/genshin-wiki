                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Enerji Yenileme",
                      "type": "text"
                    },
                    {
                      "text": "ve sahip olduğu",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Can",
                      "type": "text"
                    },
                    {
                      "text": "değerine oranla",
