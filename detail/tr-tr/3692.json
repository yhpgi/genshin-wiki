                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3609,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/28/145542732/05599650d7f42e1c4adde373de6b297d_2841207865565455085.png",
                      "name": "Baizhu",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Baizhu, silahın pasifini çok iyi kullanabilir ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Enerji",
                      "type": "text"
                    },
                    {
                      "text": "yenileyerek kişisel",
