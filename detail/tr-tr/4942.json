            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> verir.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/05/145542732/241eba6e4c00020975cf91170050f435_5070079903400792994.png",
                "key": "Hızlı Mızrak Saldırısı",
