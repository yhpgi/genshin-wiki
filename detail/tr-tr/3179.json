            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Saldırı</span></p><p>2 <span style=\"color: rgb(255, 255, 255)\">Fiziksel Hasar </span>verir.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/26b9736a2d14fc4162b2448963f45695_9205167933365023055.png",
                "id": "talent28258",
                "key": "Guhua Style",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
