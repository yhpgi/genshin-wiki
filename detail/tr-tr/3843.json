              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFE699\">Element Becerisi</span></p><p>3 <span style=\"color: #FF9999\">Ateş Hasarı </span>verir. </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/213387213/5472faa96cc230f0c6a742c278748e91_2613228250794192070.png",
