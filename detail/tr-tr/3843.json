                "desc": "<p><span style=\"color: #FFE699\">Normal Saldırı</span></p><p>1 <span style=\"color: #FF9999\">Ateş Hasarı</span> verir. </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/213387213/1ce09211f025bf5470682189e0837732_8076755954907923091.png",
