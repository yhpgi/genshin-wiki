                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Yakan Kaide"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFE699\">Element Patlaması</span></p><p>3 <span style=\"color: #FF9999\">Ateş Hasarı</span> verir ve 1 <span style=\"color: #ECE5D8\">Karanlık Ateş</span> Çağırır. </p><p></p><p><strong><span style=\"color: #ECE5D8\">Karanlık Ateş</span></strong></p><p>Son Aşama: 1 <span style=\"color: #FF9999\">Ateş Hasarı</span> verir, rakibin tüm hazırdaki karakterlerine 1 Delme Hasarı verir.</p><p>Kullanım Hakkı: 2 </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/213387213/1cfb4a644ede1096bcf61f228e14be0a_8850828242949442221.png",
                "id": "talent90405",
                "key": "Uğursuz Yıldız",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Uğursuz Yıldız"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFE699\">Pasif Beceri</span></p><p>(Pasif) Savaş başladığında bu karakter <span style=\"color: #ECE5D8\">Ateşle Yeniden Doğan</span> etkisi kazanır. </p><p></p><p><strong><span style=\"color: #ECE5D8\">Ateşle Yeniden Doğan</span></strong></p><p><span style=\"color: #ECE5D8\">Bu kartı kuşanan karakter yenildiğinde</span> bu etki kaldırılır, karakter <strong><span style=\"color: #ECE5D8\">yenilmez</span></strong>. Canı 3 olacak şekilde Can yeniler. </p><p></p><p><span style=\"color: #FFE699\">Pasif Beceri</span></p><p>(Pasif) Bu karakter <span style=\"color: #ECE5D8\">Ateşle Yeniden Doğan</span> tetiklendiğinde: <span style=\"color: #ECE5D8\">Kavuran Ateş Kalkanı</span> kartını kuşanır.</p><p></p><p><strong><span style=\"color: #ECE5D8\">Kavuran Ateş Kalkanı</span></strong></p><p>Bu kartı kuşanan karakter <span style=\"color: #ECE5D8\">hiç Hasar almaz. </span></p><p>Bu durum 2 defa <span style=\"color: #FF9999\">Ateş Tesiri</span> sağlar (Element Tepkimeleri kullanılarak tüketilebilir). Ateş Tesirleri tüketildiğinde bu etki ortadan kalkar, bu kartı kuşanan karakter <strong><span style=\"color: #ECE5D8\">Beceri kullanamaz</span></strong> ve son Aşamada 6 <span style=\"color: #ECE5D8\">Delme Hasarı</span> alır.</p><p>Bu etki devam ederken karakter fazladan 1 <span style=\"color: #FF9999\">Ateş Hasarı</span> verir. </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/213387213/241466b9ccdefb6219ef6bf74cd493e2_4839137938274850873.png",
                "id": "talent47817",
                "key": "Ateşle Yeniden Doğan",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Ateşle Yeniden Doğan"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFE699\">Minyon</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span> 1 <span style=\"color: #FF9999\">Ateş Hasarı</span> verir, rakibin tüm hazırdaki karakterlerine 1 Delme Hasarı verir.</p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı:</span> 2 </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/213387213/db13288db6b90ec33f8adc2656d2019f_8185224434265128474.png",
                "id": "talent11498",
                "key": "Minyon - Karanlık Ateş",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/213387213/2cce1877020bad6ed9476a8bb8db436c_33089938257159578.png",
                "title": "Minyon - Karanlık Ateş"
              },
              {
                "attributes": [],
                "desc": "<p>Ateş Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir:</p><p>[<span style=\"color: rgb(255, 153, 153)\">Ateş </span>+ <span style=\"color: rgb(153, 255, 255)\">Buz</span>] <strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Erime</span></strong>: Bu seferki Hasar 2 artar.</p><p>[<span style=\"color: rgb(255, 153, 153)\">Ateş</span> + <span style=\"color: rgb(128, 192, 255)\">Su</span>] <strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Buharlaşma</span></strong>: Bu seferki Hasar 2 artar.</p><p>[<span style=\"color: rgb(255, 153, 153)\">Ateş</span> + <span style=\"color: rgb(255, 172, 255)\">Elektrik</span>] <strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Yüksek Voltaj</span></strong>: Bu seferki Hasar 2 artar ve hedef, sonraki karakterle zorla değiştirilir.</p><p>[<span style=\"color: rgb(255, 153, 153)\">Ateş</span> + <span style=\"color: rgb(153, 255, 136)\">Doğa</span>] <strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Yanma</span></strong>: Bu seferki Hasar 1 artar ve Turun sonunda 1 Ateş Hasarı verecek olan bir [Yakıcı Alev] oluşturur (Bir defa tetiklenir, 2 kademeye kadar birikir).</p>",
                "icon_url": "",
                "id": "talent72729",
                "key": "Ateş Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Ateş Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Delme Hasarı</span></strong></p><p>Delme Hasarı herhangi bir bonusla artırılamaz ama Kalkan veya Hasar Bağışıklığı kullanımına karşı da savunulamaz. </p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span></strong></p><p>Bu kartın etkisi tetiklendikten sonra 1 <span style=\"color: #ECE5D8\">Kullanım Hakkı</span> harcanır. </p><p><span style=\"color: #ECE5D8\">Kullanım Hakkı</span> 0 olduktan sonra bu kart hemen atılır. </p>",
