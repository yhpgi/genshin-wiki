                  }
                ],
                "talent_img": "",
                "title": "Bütüncül İyileştirme"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Minyon</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgb(126, 194, 54)\">Doğa Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir, aktif karakterin için 1 Can yeniler.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/db13288db6b90ec33f8adc2656d2019f_9112800448331071237.png",
                "id": "talent55975",
                "key": "Minyon - Yılan Ruhu",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/a3d29e698acee488ea48e7cd36af0835_6488272230999921419.png",
                "title": "Minyon - Yılan Ruhu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Doğa Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir:</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(153, 255, 136)\">Doğa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Çiçeklenme:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve bir sonraki Ateş veya Elektrik hasarını 2 artıran bir [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Doğa Çekirdeği</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur.</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(153, 255, 136)\">Doğa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yanma:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve Turun sonunda 1 Ateş Hasarı verecek olan bir [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yakıcı Alev</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur. (Bir defa tetiklenir, 2 kademeye kadar birikir.)</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(153, 255, 136)\">Doğa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Hızlanma:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve sonraki 2 Doğa veya Elektrik Hasarını 1 artıran bir [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Dönüştürme Alanı</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/e8cff941b5a0ff248efde360ec9e91fe_8126246813277514944.png",
                "id": "talent30080",
                "key": "Doğa Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Doğa Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Kullanım Hakkı</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra</span> 1 <span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır.</span><br><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">0 olduktan sonra bu kart hemen atılır.</span><br></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Kalkan</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu Kalkan, onu kuşanan karakteri Hasardan korumak için harcanır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/245c229cf6f7364c7c9a7aea3db1a1ad_7735146155136571819.png",
