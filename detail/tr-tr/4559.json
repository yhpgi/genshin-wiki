                "talent_img": "",
                "title": "Kapsamlı Teşhis"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Güçlü Nabız </span><span style=\"color: rgba(255, 255, 255, 0.45)\">ve </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kusursuz Kalkan</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">oluşturur.</span></p><p></p><p><span style=\"color: rgb(236, 229, 216)\">Güçlü Nabız</span></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Hamle Aşaması Başlangıcı: Kusursuz Kalkan</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">oluşturur.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: 2</span></p><p><br><span style=\"color: rgb(236, 229, 216)\">Kusursuz Kalkan</span><br><span style=\"color: rgb(255, 215, 128)\">Durum</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Aktif karakterini koruyarak</span> <span style=\"color: rgb(255, 255, 255)\">1 Kalkan</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> sağlar.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Bu etki kaldırıldığında veya tekrarlandığında</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 1</span> <span style=\"color: rgb(126, 194, 54)\">Doğa Hasarı</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve aktif karakterine 1 Can yeniler.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/ed10b8e3def17c518055b3421bfcb94a_2420974297172000560.png",
                "id": "talent29444",
                "key": "Bütüncül İyileştirme",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
