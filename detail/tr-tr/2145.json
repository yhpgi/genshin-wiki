      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Konum:",
                      "type": "text"
                    },
                    {
                      "text": "Mondstadt - Bin Rüzgar Tapınağı",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/145542732/6be85a7e434c8eceea171ef2222c4a97_7692700652064909482.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kurt Tapınağı zindanına ışınlandıktan sonra arkanıza dönün.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/145542732/c66266069e0b8f4eebdb934c9a7880fe_8015611467140293749.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Daha sonra ilerleyerek uçurumdan atlayın. Savaş alanına ulaşacaksınız.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/145542732/5f542eaa9a73d4f0f13723aad8b6e31d_5184895303118227872.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Öğretici",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/145542732/ff9fdaee69cd2e7dad880b6203d2c93a_2831526474056659605.png"
                    },
                    {
                      "text": "• Yalancı Buz Ağacı, yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ffff"
                      ],
                      "text": "Buz Hasarı Direncine",
                      "type": "text"
                    },
                    {
                      "text": "sahiptir.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ffff"
                      ],
                      "text": "Buz",
                      "type": "text"
                    },
                    {
                      "text": "saldırıları yaparak",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "verir ve yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasarlı Alan Saldırılarına",
                      "type": "text"
                    },
                    {
                      "text": "sahiptir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/145542732/2b90e4bec5ac0d4d4d77143b7f0b671c_6023921457060780072.png"
                    },
                    {
                      "text": "• Yalancı Buz Ağacı'nın köklerinde",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ffff"
                      ],
                      "text": "Buz Tohumu",
                      "type": "text"
                    },
                    {
                      "text": "bulunur. Bu",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ffff"
                      ],
                      "text": "Buz Tohumunu",
                      "type": "text"
                    },
                    {
                      "text": "uygun",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Element Tepkimeleriyle",
                      "type": "text"
                    },
                    {
                      "text": "kırarak Yalancı Buz Ağacı'nı sersemletebilirsiniz. (En uygun Element",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ff9999"
                      ],
                      "text": "Ateştir",
                      "type": "text"
                    },
                    {
                      "text": ".)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/145542732/21f0fb142773a6b1acb329e8339fb5be_5042460441434240615.png"
                    },
                    {
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ffff"
                      ],
                      "text": "Buz Tohumu",
                      "type": "text"
                    },
                    {
                      "text": "kırıldıktan sonra Yalancı Buz Ağacı sersemler ve aldığı",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "artar. Bu durumu lehine kullanarak Yalancı Buz Ağacı'na olabildiğince",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "ver!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/28/145542732/6a9e0e22518b32287bbb67117053a656_5850172179565440509.png"
                    },
                    {
                      "text": "• Eğer sersemlemişken Yalancı Buz Ağacı'nı defedemezseniz",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ffff"
                      ],
                      "text": "Buz Tohumu",
                      "type": "text"
                    },
                    {
                      "text": "tekrardan ortaya çıkar, ancak bu sefer çiçeğin taç kısmında bulunur.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
