          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Saldırı</span></p><p>2 <span style=\"color: #FFFFFF\">Fiziksel Hasar</span> verir.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/25073864/c369b96fc6417e8fc2bb607e37297ad4_2690949012862620252.png",
                "id": "talent64245",
                "key": "Kutsal Nişancı",
                "materials": [],
