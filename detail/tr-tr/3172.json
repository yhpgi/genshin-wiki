                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Göklerin Görkemi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Minyon</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Son Aşama: 1 </span><span style=\"color: #99FFFF\">Buz Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir, rakibin tüm hazırdaki karakterlerine 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Delme Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/35428890/db13288db6b90ec33f8adc2656d2019f_929897109187337777.png",
                "id": "talent1020",
                "key": "Kutsal Buz İncisi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/35428890/5768b83a04afeb8e581b0f7864fd39d9_2020195863022109967.png",
                "title": "Kutsal Buz İncisi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #99FFFF\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir: <br>[</span><span style=\"color: #99FFFF\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #FF9999\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Erime: </span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 2 artar.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: #99FFFF\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #FFACFF\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Süper İletim: </span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakip karakterlere 1 Delme Hasarı verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: #99FFFF\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #80C0FF\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Donma: </span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve hedef bu turda hamle yapamaz. (Hedef, Fiziksel Hasar ve Ateş Hasarı alınca kaldırılır, fazladan 2 Hasar alır.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/35428890/4bcc4b82a9d7ee22770f60afa54e9919_927810827928561880.png",
                "id": "talent71109",
                "key": "Buz Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Buz Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleşmez.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Delme Hasarı</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Delme Hasarı herhangi bir bonusla artırılmaz ama Kalkan veya Hasar Bağışıklığı kullanımına karşı da savunulamaz.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır. </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> 0 olduktan sonra bu kart hemen atılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_4667047790094514977.png",
