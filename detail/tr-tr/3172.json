              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span></p><p>2 <span style=\"color: rgb(153, 255, 255)\">Buz Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir, rakibin tüm hazırdaki karakterlerine 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Delme Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kutsal Buz İncisi </span><span style=\"color: rgba(255, 255, 255, 0.45)\">çağırır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/30/35428890/6b78c979575a782c1625dce67992cf90_6743611143073519014.png",
