                ],
                "talent_img": "",
                "title": "Thrust"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elemental Skill</span></p><p>Deals 1 <span style=\"color: #FF9999\">Pyro DMG</span>. This character gains <span style=\"color: #FFFFFF\">Stealth</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Stealth</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Status</span><br>The character to which this is attached takes -1 DMG and deals +1 DMG.<br><span style=\"color: rgb(255, 255, 255)\">Usage(s): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/2fc519b5fd90708c67fd63a2da75d2d6_1280424189329452306.png",
                "id": "talent17109",
                "key": "Prowl",
