    {
      "id": "39",
      "name": "Önerilen Karakterler",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dalgaların Gölgesi, ikincil özelliği ve pasifi ile çok yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "değeri sağlayan bir çift elli kılıçtır. Bu silah, Fontaine'i keşfederken Demirci Estelle'den planı satın alınarak üretilebilir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Bu silah, yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "değerine ihtiyaç olan karakterler için iyi bir seçenektir. Ancak pasifinin aktif olabilmesi için karakterin",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "İyileştirme",
                      "type": "text"
                    },
                    {
                      "text": "alması da gerekir, bu yüzden takımınıza",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "İyileştirici",
                      "type": "text"
                    },
                    {
                      "text": "bir karakter koymayı unutmayın. Aşağıda bazı önerilen karakterler verilmiştir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 6,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Eula_icon.png",
                      "name": "Eula",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 43,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Diluc_icon.png",
                      "name": "Diluc",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 45,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Chongyun_icon.png",
                      "name": "Chongyun",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Örnek verilen karakterlerin hepsi yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "değeri ile güçlenir ve takımında bir",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "İyileştirici",
                      "type": "text"
                    },
                    {
                      "text": "karakter ile sinerji halindedir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
