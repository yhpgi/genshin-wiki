    {
      "id": "48",
      "name": "Beceri",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/06/145542732/26b9736a2d14fc4162b2448963f45695_3162094314080459707.png",
                "id": "talent1721",
                "key": "Garyuu Kılıç Tekniği",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Garyuu Kılıç Tekniği"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Element Becerisi</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">3 </span><span style=\"color: #80FFD7\">Rüzgar Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir, bu karakter </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Midare Ranzan </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kuşanır.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu beceri Girdap tetiklerse </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Midare Ranzan</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, Girdaba alınan elemente dönüşür.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Beceri Hasarı sona erdikten sonra </span><span style=\"color: rgba(255, 255, 255, 0.45)\">takımın sonraki karaktere geçer.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Midare Ranzan</span></p><p><span style=\"color: #FFD780\">Durum</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Bunu kuşanan karakter Havadan Saldırı kullandığında </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verilen </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar, </span><span style=\"color: #80FFD7\">Rüzgar Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">olarak değişir ve verdiği Hasar 1 artar. </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Karakter bir beceri kullandıktan sonra </span><span style=\"color: rgba(255, 255, 255, 0.45)\">bu etki kaldırılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/06/145542732/33d0a2ad4ba893402e879d35ab6ce233_4990462016056367122.png",
                "id": "talent35788",
                "key": "Chihayaburu",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Chihayaburu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Element Patlaması</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">3 </span><span style=\"color: #80FFD7\">Rüzgar Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Güz Kasırgası </span><span style=\"color: rgba(255, 255, 255, 0.45)\">çağırır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/06/145542732/3b2e6b2c4ffbc7d13d7f2461cb4497e9_6792526300531130138.png",
                "id": "talent58237",
                "key": "Bin Yaprak darbesi",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Bin Yaprak darbesi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Minyon</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1 </span><span style=\"color: #80FFD7\">Rüzgar Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı: 3</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Karakterlerin veya Minyonların Girdap tepkimesi tetiklediğinde </span><span style=\"color: rgba(255, 255, 255, 0.45)\">bu kartın Element Türü değişir ve verdiği Hasar, Girdap tepkimesi tetiklediği elemente dönüşür. (Alanı terk etmeden önce bir defa kullanılabilir.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/06/145542732/db13288db6b90ec33f8adc2656d2019f_2773907926925338447.png",
                "id": "talent29313",
                "key": "Minyon - Güz Kasırgası",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/06/145542732/692a68ca67cd7fa11e0c225fb1540804_5796754588797820182.png",
                "title": "Minyon - Güz Kasırgası"
              },
              {
                "attributes": [],
                "desc": "<p>Zaten uygulanmış olan Elementlerle tepkimeye girer:</p><p>[<span style=\"color: rgb(128, 255, 215)\">Rüzgar</span><span style=\"color: rgb(153, 255, 136)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Buz</span>] <span style=\"color: rgb(255, 255, 255)\">Buz Girdabı</span>: Hedef dışındaki tüm rakiplere 1 Buz Hasarı verir ve Buz etkisi uygular.</p><p>[<span style=\"color: rgb(128, 255, 215)\">Rüzgar</span><span style=\"color: rgb(153, 255, 136)\"> </span>+ <span style=\"color: rgb(255, 153, 153)\">Ateş</span>] <span style=\"color: rgb(255, 255, 255)\">Ateş Girdabı</span>: Hedef dışındaki tüm rakiplere 1 Ateş Hasarı verir ve Ateş etkisi uygular.</p><p>[<span style=\"color: rgb(128, 255, 215)\">Rüzgar</span><span style=\"color: rgb(153, 255, 136)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Elektrik</span>]<span style=\"color: rgb(255, 255, 255)\"> Elektrik Girdabı</span>: Hedef dışındaki tüm rakiplere 1 Elektrik Hasarı verir ve Elektrik etkisi uygular.</p><p>[<span style=\"color: rgb(128, 255, 215)\">Rüzgar</span><span style=\"color: rgb(153, 255, 136)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Su</span>] <span style=\"color: rgb(255, 255, 255)\">Su Girdabı</span>: Hedef dışındaki tüm rakiplere 1 Su Hasarı verir ve Su etkisi uygular.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/06/145542732/c97292d96456bfe4abeca16bfce801e4_1995877732420955831.png",
                "id": "talent47658",
                "key": "Rüzgar Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Rüzgar Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span>Kullanım Hakkı</span></strong><span style=\"color: rgb(219, 222, 225)\"> </span></p><p><span style=\"color: rgb(219, 222, 225)\">Bu kartın etkisi tetiklendikten sonra 1 </span><strong><span>Kullanım Hakkı</span></strong><span style=\"color: rgb(219, 222, 225)\"> harcanır. </span><strong><span>Kullanım Hakkı</span></strong><span style=\"color: rgb(219, 222, 225)\"> 0 olduktan sonra bu kart hemen atılır.</span></p><p></p><p><strong><span style=\"color: rgb(219, 222, 225)\">Havadan Saldırı</span></strong></p><p><span style=\"color: rgb(219, 222, 225)\">Karakter, Aktif Karakter olarak değiştirildikten sonra bu Turdaki bir sonraki Savaş Hamlesi Normal Saldırı olursa bu, Havadan Saldırı olarak sayılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/06/145542732/245c229cf6f7364c7c9a7aea3db1a1ad_1424841811508922933.png",
                "id": "talent78916",
                "key": "Ayrıntılı Kurallar",
