                "name": "Yükselen Göl"
              },
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Yükselen Sular baloncuğunun Hareket Hızı %30 azalır ve süresi 3 saniye artar.<br></span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/18/145542732/0221216be990b2c2bbbff8b7fa6a5986_8899260527873804147.png",
                "id": "summaryList92103",
                "name": "Süzülen Sandık"
