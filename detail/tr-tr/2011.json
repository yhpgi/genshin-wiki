      "name": "Hikaye",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "This was a story from long ago...</br>Unborn life, unfulfilled wishes,</br>Tragic dreams at the edge of the universal darkness that could never come true,</br>Indwell my body, and descend unto this world.</br>Then, my lovely children,</br>Like rainwater flowing into creeks, and plants growing towards the sun,</br>Go unto a lovely place, and display your own beauty there with pride.</br>This is a memory, a memory that a child named Durin had of his mother...</br>\"Thank you, Mother, thank you.\"</br>\"You gave me wings to soar and a mighty form.\"</br>\"Mother, I wish to go to a land of lovely songs,\"</br>\"I will tell them about you, Mother, and about everyone else.\"</br>\"I shall tell them that the place where I was born is beautiful.\"</br>",
                "title": ""
              }
            ]
          }
        }
      ]
