    {
      "id": "39",
      "name": "Silah Hakkında",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "Önerilen Karakterler",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Homa'nın Asası, yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Temel Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "niteliğine sahip ve ikincil özelliği ile kuşanan karaktere",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Kritik Hasar",
                      "type": "text"
                    },
                    {
                      "text": "veren bir mızraktır. Pasifi sayesinde kuşanan karakterin",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Can",
                      "type": "text"
                    },
                    {
                      "text": "değeri ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Can",
                      "type": "text"
                    },
                    {
                      "text": "değerine oranla",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "değeri artar. Ayrıca kuşanan karakterin",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Mevcut Canı",
                      "type": "text"
                    },
                    {
                      "text": "%50'nin altında olduğunda kazandığı",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "değeri daha da artar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Bu silah, genel olarak",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "vermek isteyen tüm",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Mızrak",
                      "type": "text"
                    },
                    {
                      "text": "kullanan karakterler için iyi bir tercihtir. Pasifin ikinci kısmını tüm karakterler efektif olarak kullanamasa da halihazırda yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Kritik Hasar",
                      "type": "text"
                    },
                    {
                      "text": "sağlar. Aşağıda bazı önerilen karakterler verilmiştir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 34,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Hu Tao_icon.png",
                      "name": "Hu Tao",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Hu Tao, silahın sağladığı tüm özellikleri çok etkili kullanabilen bir ana",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "karakteridir. Hu Tao,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Element Becerisi",
                      "type": "text"
                    },
                    {
                      "text": "sayesinde",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Can",
                      "type": "text"
                    },
                    {
                      "text": "değerini %50'nin altında tutabilir ve silahın pasif etkilerinin tamamını efektif olarak kullanabilir. Homa'nın Asası, Hu Tao'nun imza silahıdır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 51,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Xiao_icon.png",
                      "menu_id": 2,
                      "name": "Xiao",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Xiao,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Element Patlaması",
                      "type": "text"
                    },
                    {
                      "text": "kullandığı zaman sürekli kendine",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "verir, bu özelliğini kullanarak doğru takımlar hazırlarsanız silahın tüm özelliklerini etkili olarak kullanabilirsiniz. %50",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Can",
                      "type": "text"
                    },
                    {
                      "text": "altına düşmeseniz bile silahın çok güçlü",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Temel Nitelikleri",
                      "type": "text"
                    },
                    {
                      "text": "sayesinde bu silahı rahatlıkla kullanabilirsiniz.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2813,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/28/77454259/e09e2bda5e022611fad0dea1bb6518bb_6757667565719577204.png",
                      "name": "Cyno",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Cyno herhangi bir şekilde kendi",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Canını",
                      "type": "text"
                    },
                    {
                      "text": "harcamasa ve silahın pasifinin ikinci kısmını kullanamasa bile güçlü",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Temel Nitelikleri",
                      "type": "text"
                    },
                    {
                      "text": "sayesinde birçok diğer silahtan daha iyi bir tercih haline gelir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 33,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Rosaria_icon.png",
                      "name": "Rosaria",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
