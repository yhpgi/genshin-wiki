    {
      "id": "37",
      "name": "Öğretici ve Konum",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Konum:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Enkonomiya - Dainichi Mikoshi",
                      "type": "text"
                    },
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/145542732/ae967bb19a688696e2ea3f327c4b23e8_5234290812688516118.png"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Dainchi Mikoshi Işınlanma Portalı'na ışınlandıktan sonra hemen ilerideki binaya doğru ilerleyin.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/145542732/4b5acffa1e50a986db6314b3d158e3b2_3209179219556762498.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Binanın içine ulaştığınızda, gözüken delikten içeriye atlayın. Savaş Alanına ulaşacaksınız.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/145542732/2ccec436ab44fe00b90b6d66a7620d6f_1495438742726817200.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Öğretici",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/145542732/63514b744d2f565c5846816ae51b54cb_8579891527843246552.png"
                    },
                    {
                      "text": "• Su Ejderi Sürüsü, bir",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2176,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/enemy/Rimebiter Bathysmal Vishap_icon.png",
                      "name": "Buzkıran Su Ejderi",
                      "type": "custom_entry"
                    },
                    {
                      "text": "bir de",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2175,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/enemy/Bolteater Bathysmal Vishap_icon.png",
                      "name": "Yıldırımyutan Su Ejderi",
                      "type": "custom_entry"
                    },
                    {
                      "text": "'nden oluşan bir düşmandır. Saldırıları, karakterlerin",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Enerjilerini ve Dayanıklılıklarını",
                      "type": "text"
                    },
                    {
                      "text": "azaltmak üzere yaparlar.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Buz",
                      "type": "text"
                    },
                    {
                      "text": "ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 172, 255)"
                      ],
                      "text": "Elektrik",
                      "type": "text"
                    },
                    {
                      "text": "Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "verirler.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/145542732/78d4d6686c90e58b14cc6ae12dcc8f70_7842177072749480286.png"
                    },
                    {
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2175,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/enemy/Bolteater Bathysmal Vishap_icon.png",
                      "name": "Yıldırımyutan Su Ejderi",
                      "type": "custom_entry"
                    },
                    {
                      "text": "bir süre sonra duvarın üstüne çıkarak",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Enerji ve Dayanıklılık",
                      "type": "text"
                    },
                    {
                      "text": "çalan yıldırım nefesi ile saldırmaya başlar. Bu durumda, duvar yıkılabilir ve",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2175,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/enemy/Bolteater Bathysmal Vishap_icon.png",
                      "name": "Yıldırımyutan Su Ejderi",
                      "type": "custom_entry"
                    },
                    {
                      "text": "sersemletilebilir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/145542732/2062cb812f48b0c6f16294c3be4104e1_9129217561071672717.png"
                    },
                    {
                      "text": "• Duvar yıkıldıktan sonra",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2175,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/enemy/Bolteater Bathysmal Vishap_icon.png",
                      "name": "Yıldırımyutan Su Ejderi",
                      "type": "custom_entry"
                    },
                    {
                      "text": "sersemler ve saldırılara açık hale gelir. Bu durumu avantajına kullan!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/145542732/e8bf92159d13f5d9d6b81a6b55aada68_112346892915247832.png"
                    },
                    {
                      "text": "• Eğer Su Ejderlerinden birinin Can seviyesi 0'a düşerse ve diğeri hala Canlı ise, Savaş Alanının ortasında birleşerek koordine bir saldırıya başlarlar. İki Su Ejderi de ölmedikçe savaş bitmez.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/145542732/d3967444bfde991c1b7938b503757be5_2146450628468249299.png"
                    },
                    {
                      "text": "• Su Ejderi Sürüsü'nün koordine saldırısı.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
