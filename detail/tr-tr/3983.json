    {
      "id": "39",
      "name": "Önerilen Karakterler",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "• Bu silah, yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Kritik Hasar Bonusu",
                      "type": "text"
                    },
                    {
                      "text": "sağlar ve yüksek Temel Saldırı değerine sahiptir. Sadece verdiği nitelikler için de kullanılabilecek değere sahiptir, ancak pasifi çoğunlukla 2 ve daha fazla aynı Elemente sahip üyelerden oluşan takımlar için daha büyük bir güç sağlar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3963,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/04/25073864/56f8617276010e0e3c08713c3f4df80a_7627572885257097937.png",
                      "name": "Lyney (Yakında)",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "• Lyney, pasifi sayesinde",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ff9999"
                      ],
                      "text": "Yalnız Ateş takımlarında",
                      "type": "text"
                    },
                    {
                      "text": "daha iyi performans gösterir. Bu silah da takımınızı bir elemente odaklanarak kurduğunuz zaman daha yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "oranı sağlar. Ayrıca",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Yüklü Saldırı Hasarını",
                      "type": "text"
                    },
                    {
                      "text": "da artırır, bu da Lyney'in ana Hasar kaynağıdır. Özet olarak İlk Büyük Sihir, Lyney'in imza silahıdır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 28,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Ganyu_icon.png",
                      "name": "Ganyu",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ganyu'nun ana",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "kaynağı",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
