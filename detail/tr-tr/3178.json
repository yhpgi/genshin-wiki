              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Becerisi</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">1 </span><span style=\"color: #80C0FF\">Su Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yansıma </span><span style=\"color: rgba(255, 255, 255, 0.45)\">çağırır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/248396191/a0074558f99c36e32c2a642c89000de2_4486464436888383988.png",
                "id": "talent89438",
                "key": "Kıyamet Yansıması",
                "materials": [],
