          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "A reliable and balanced sword made of fine steel.</br>The one downside is that the partial-tang design renders it less durable than its full-tang counterparts.</br>That said, the partial tang creates space in the hilt for hidden knives, scissors, tinder, and other objects.</br>Hence the name, Traveler's Handy Sword. It contains all sorts of handy items for travelers.</br>",
                "title": ""
              }
            ]
          }
        }
