    {
      "id": "39",
      "name": "Önerilen Karakterler",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Kırık Çamların Şarkısı, sadece ağırlıklı olarak Fiziksel Hasar veren karakterlerde oldukça iyi bir seçenektir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 6,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Eula_icon.png",
                      "name": "Eula",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "• Bu silah, Eula için gerekli olan her bonus özelliği sağlar.",
                      "type": "text"
                    },
                    {
                      "text": "Fiziksel Hasar Bonusu",
                      "type": "text"
                    },
                    {
                      "text": "sayesinde verdiği tüm Hasar artar. Ayrıca silahın pasifinin sağladığı",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Normal Saldırı Hızı",
                      "type": "text"
                    },
                    {
                      "text": "sayesinde Element Patlaması için daha fazla kademe biriktirebilir ve daha fazla Hasar vermesini sağlar. Bu silah, Eula'nın imza silahıdır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 48,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Razor_icon.png",
                      "name": "Razor",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "• Razor'un Element Patlaması halihazırda Razor için",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Normal Saldırı Hızı",
                      "type": "text"
                    },
                    {
                      "text": "sağlar, silahın pasifiyle birleştiğinde Razor çok daha hızlı saldırarak daha fazla Hasar verir. Ayrıca, sağladığı",
                      "type": "text"
                    },
                    {
                      "text": "Fiziksel Hasarı Bonusu",
                      "type": "text"
                    },
                    {
                      "text": "sayesinde genel olarak Hasarı artar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
