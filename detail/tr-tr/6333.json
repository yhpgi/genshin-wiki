    {
      "id": "43",
      "name": "Açıklama\n",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:#ece5d8"
                      ],
                      "text": "HAYALİ YANKILAR",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Kulisin bir köşesinde önceden boş olan bir tuvalde parlak renkler ortaya çıktı. Birisi tuvale dokunduğunda o kişiyi alıp yaşadığı farklı deneyimlere göre farklı zindanlara gönderiyor...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Resmin içinde yer alan dünyaları belirli yoldaşlarla keşfet. Belki değerli anıları eşsiz resimlere dönüşebilir...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ece5d8"
                      ],
                      "text": "Oynanış Detayları",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Her Hayali Yankılar mücadelesi belirli bir karaktere aittir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Mücadele yarışmalarına katılmak için karakterlerin 2 şartı sağlamaları gerekir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "1. Karakterin",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ece5d8"
                      ],
                      "text": "Seviyesi 90",
                      "type": "text"
                    },
                    {
                      "text": "olmalıdır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "2. Karakterin",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ece5d8"
                      ],
                      "text": "Arkadaşlık Seviyesi",
                      "type": "text"
                    },
                    {
                      "text": "en az",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ece5d8"
                      ],
                      "text": "8",
                      "type": "text"
                    },
                    {
                      "text": "olmalıdır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Bir karakterin mücadele aşamalarının kilidini açmak için 2 adet",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 6279,
                      "icon_url": "",
                      "name": "Yankı Anahtarı",
                      "type": "custom_entry"
                    },
                    {
                      "text": "gerekir. Daha sonrasında aynı aşamaya girmek için tekrardan anahtar kullanmak gerekmez. Başlangıçta 2 Anahtarın olur.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/06/147527911/6ec67bd50f33b319b012225819e92a8a_4720104322897284698.png"
                    },
                    {
                      "text": "Yankı Anahtarı 2 farklı şekilde elde edilebilir.                                                                                                                                                                       1.",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 5832,
                      "icon_url": "",
                      "name": "Hayal Dünyası Tiyatrosu",
                      "type": "custom_entry"
                    },
                    {
                      "text": "her sezonunda 6. Perde ve üzerinde tamamlayarak 1 adet Anahtar elde edebilirsin.                                                                          2.",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 5832,
                      "icon_url": "",
                      "name": "Hayal Dünyası Tiyatrosu",
                      "type": "custom_entry"
                    },
                    {
                      "text": "her sezonunda 10. Perde ve üzerinde tamamlayarak 1 adet Anahtar elde edebilirsin.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Bulunan Sezon yenilenmeden önce Anahtarları almayı unutma. Alınmayan anahtarlar silinir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Aynı anda en fazla 4 adet Yankı Anahtarına sahip olabilirsin ve sınıra ulaştığında daha fazla anahtar elde edemezsin.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
