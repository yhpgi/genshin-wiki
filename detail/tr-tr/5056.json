              {
                "item_values": [],
                "key": "Eğitim",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Savaştayken aynı anda hem Su hem de Rüzgar elementlerini kullanabilen ve dağların derinliklerinde yaşayan bir Aydınlanmış Yaratık. Su tesirli Adeptus enerjisi toplarken ona Donma etkisi uygula, daha sonra Tuzla Buz, Erime veya diğer Element Tepkimelerini kullanarak buzu kır ve onu hareketsiz bırak. Rüzgar tesirli Adeptus enerjisi toplarken aynı avantajı elde etmek için ise Rüzgar ile tepkimeye girebilen elementlerin saldırısını kullan ve bu sırada çağrılan Ruh Rüzgarı İncilerini yok et.</span></p>"
                ]
              }
            ]
          }
        }
      ]
