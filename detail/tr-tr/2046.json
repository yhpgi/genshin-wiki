                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 27,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Jean_icon.png",
                      "name": "Jean",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Jean,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Temel Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "'sına göre önemli miktarda",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffe699"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "verebilen ve müttefiklerini iyileştirebilen çok yönlü bir karakterdir. Favonia Kartalı yüksek oranda",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Temel Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "istatistiklerine de sahip olduğu için Jean'e güzel iyileştirme oranı artışı sağlamaktadır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 10,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Keqing_icon.png",
                      "name": "Keqing",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Keqing için alternatif bir oynanış sunan bir silah.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Elemental Hasar",
                      "type": "text"
                    },
                    {
                      "text": "'dan çok",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Fiziksel Hasar",
                      "type": "text"
                    },
                    {
                      "text": "'a yönelik oynamak istiyorsanız bu silah en iyi tercihler arasındadır. Hem ikincil özelliği, hem de pasif özelliği Keqing'in saldırı gücünü arttırmak için çok önemli role sahiptir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
