                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Öz",
                      "type": "text"
                    },
                    {
                      "text": "olarak değiştirebilir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Saflaştırma Kademeleri",
