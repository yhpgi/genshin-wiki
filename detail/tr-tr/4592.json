      "name": "Silah Hakkında",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Önerilen Karakterler",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Nergis Haçı'nın Kılıcı, kuşanan karaktere",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "sağlar ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Arkhe'si",
                      "type": "text"
                    },
                    {
                      "text": "yoksa silahın türüne göre Arkhe",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "verir. Bu silah, eğer",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Arkhe Hasarına",
                      "type": "text"
                    },
                    {
                      "text": "ihtiyacınız varsa Fontaine'den olmayan karakterler için uygun olabilir. Bu sayede bazı bulmacaları ve düşman mekaniklerini alt edebilirsiniz. Aşağıdaki karakterlere ve daha fazlasına, Arkhe Hasarına ihtiyacınız olduğunda kullanabilirsiniz.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
