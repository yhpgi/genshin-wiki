    {
      "id": "10",
      "name": "Hikaye",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Seyahatler, genelde kavuşmalar ve ayrılıklarla doludur.<br>Bir Gezginin en güvenilir ve ayrılmaz yoldaşları,<br>elindeki kılıcı ve gönlündeki hayalidir belki de.<br><br>O ebedi Gezgin yaşlanmadan önce farklı dünyalar gezecek.<br>Ardında ise yalnızca sayısız hikaye ve daha parlak bir gelecek bırakacak.</span></p>",
                "title": "Arşiv"
              }
            ]
          }
        }
      ]
    },
