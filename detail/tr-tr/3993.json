                      ],
                      "text": "verir. Coppelius,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Arkhe: Öz",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#bfbfbf"
                      ],
                      "text": "ile vurulursa oluşturduğu Buz Kalkanı anında kırılır.",
