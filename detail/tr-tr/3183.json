            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Saldırı</span></p><p>2 Fiziksel Hasar verir. </p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/c369b96fc6417e8fc2bb607e37297ad4_5278613839938701311.png",
                "id": "talent58971",
                "key": "Havai Fişek Patlaması",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
