    {
      "id": "37",
      "name": "Ek Bilgi",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Eğitim",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Aşama 1",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "İlk Aşamadayken Shouki no Kami, farklı elementleri kullanarak büyük etki alanına sahip Saldırıları yapar ve aynı zamanda Enerji Blokları oluşturur.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/fa7a89afe75a703849097380b3bba0c6_5396866780563694673.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Bununla beraber savaş alanında farklı Element Matrisleri bulunmaktadır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Yeni Akaşa Terminalini yüklemek için oluşan blokları topla.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Yeni Akaşa Terminali yeterince enerjiye sahip olduğunda karakterini Element Matrislerinden birinin üzerine getirip üzerinde durduğun Matrisin etkisini aktifleştirirsin.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Element Matrislerinin etkileri şu şekildedir:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "-",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Ateş",
                      "type": "text"
                    },
                    {
                      "text": ": Yerdeki Saf Buzu ortadan kaldırır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "-",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Buz",
                      "type": "text"
                    },
                    {
                      "text": ": Yerdeki Baki Alev etkisini ortadan kaldırır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "-",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(128, 255, 215)"
                      ],
                      "text": "Rüzgar",
                      "type": "text"
                    },
                    {
                      "text": ": Shouki no Kami'nin saldırılarından kaçman için bir Dikey rüzgar akımı oluşturur.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "-",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "Su",
                      "type": "text"
                    },
                    {
                      "text": ": Sürekli iyileştiren bir etki oluşturur.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "-",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 172, 255)"
                      ],
                      "text": "Elektrik",
                      "type": "text"
                    },
                    {
                      "text": ": Shouki no Kami'yi baskılar. Baskı etkisi devam ederken tekrar etkinleştirilirse aşırı yüklenir ve Shouki no Kami'yi felç eder.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/63c1f7ce65a1da43192719eed3579402_2292378566674930044.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "*Element Matrislerini doğru bir şekilde kullanman savaşını kolaylaştırır!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/980729c3b8a376341f977450afcec78d_1659231130655048693.gif"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Aşama 2",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "İkinci Aşamanın başında Shouki no Kami bir kalkan yaratır ve bu da Direncini artırır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/fd1dd3f4770d8a120fa5ae84e7c5508d_4006952947897005544.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Shouki no Kami saldırdıktan sonra Enerji Blokları ortaya çıkar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/b93ae33c7b77785a7b41c9c403df618d_1254607635596514517.gif"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Oluşan Enerji Bloklarını toplayıp Yeni Akaşa Terminalini tam yükleyerek Shouki no Kami'ye daha güçlü bir hedefli saldırı yapabilirsin. Bu da Shouki no Kami'nin kalkanına zarar verir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "*Yeni Akaşa Terminalinin enerjisi tam dolduğunda hedefli saldırı yapmak için Yeni Akaşa Terminalinin butonuna basılı tutman yeterlidir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "*Shouki no Kami'nin çağırdığı minyonları Element Tepkimeleriyle yok etmek ve Shouki no Kami'ye saldırmak da Yeni Akaşa Terminalinin enerjisinin dolmasına yardımcı olur.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/b28435807a9e2b133e295f036a0a1390_5569045565389607354.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/10/35428890/8cfad94d9240966a5559462f672677c4_7053910199481662706.gif"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Kalkanı ilk defa yıkıldığında Shouki no Kami, aynı anda hem Setsuna Shoumetsu'yu salmak hem de bir Nirvana Motoru oluşturmak için enerji toplamaya başlar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/9e6ed13c7acbdb167a1fca2cf1a09a4d_1113074260436659221.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/19fff3e6254a05c1d2ce85344ea8ca10_9172111063519384691.gif"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Bu süreç içerisinde Element Tepkimeleri ile Nirvana Motorunu yok edip Enerji Blokları oluşturmaya çalış. Oluşan Enerji Blokları Yeni Akaşa Terminalininin enerjisini yenilemen için işine yarayacaktır.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/bc4594d7e8d0121510c45ee3ad0f7c49_3897638574451900675.gif"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Enerjisi tamamen dolduğunda, Yeni Akaşa Terminalini Shouki no Kami'ye hedefli saldırı yapmak için kullan. Bu, Shouki no Kami'nin hareketsiz kalmasını sağlar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/66c6dedf5352ac48f6288d0db4f2de63_8056870910893381205.gif"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Etraftaki Dört Yaprak Mühürlerinden yararlanarak Shouki no Kami'nin önündeki platforma hızlıca çık ve doğrudan vücuduna saldır. Bu senin saldırılarının daha verimli olmasını sağlar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/4c87f4de9a95ffcc190b24b83755c585_8215691764785161986.gif"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Başarımlar",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Başarım",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Açıklama",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Metot",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Ödül",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Taklaya Geldi",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kategori: Dünyanın Harikaları",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Shouki no Kami'yi aşırı yükleyerek hareketsiz kılmak için Element Matrislerini kullan.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "İlk Aşamada, Enerji Bloklarını kullanarak Yeni Akaşa Terminalinin enerjisini doldur. Sonra da onu kullanarak üst üste iki Elektrik Matrisini etkinleştir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "10x Köken Taşı",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Doğum ve Yok Oluşun Doğası",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kategori: Dünyanın Harikaları",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Yok oluşun eşiğinden bile geri dönüş mümkündür...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "İkinci Aşamadayken Shouki no Kami'nin yaptığı Setsuna Shoumetsu saldırısı sırasında karakterin yere serilsin.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "10x Köken Taşı",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Seksek Gibi mi?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kategori: Mücadeleci: VII. Seri",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Shouki no Kami ile yaptığın bir savaşta tüm Element Matrislerini etkinleştir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "İlk Aşamada, Enerji Bloklarını kullanarak Yeni Akaşa Terminalinin enerjisini doldur ve tek bir savaş içinde tüm Element Matrislerini etkinleştir. Hangi sırayla etkinleştirdiğinin bir önemi yoktur.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "5x Köken Taşı",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Ödeşme Zamanı",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kategori: Mücadeleci: VII. Seri",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Shouki no Kami bir güçlü saldırı yaparken onun kalkanını yok et.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "İkinci Aşamada, Shouki no Kami saldırılarından birini yaparken Yeni Akaşa Terminali yardımıyla kalkanını yok et.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "10x Köken Taşı",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
