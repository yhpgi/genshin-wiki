          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Saldırı</span></p><p>1 <span style=\"color: #80FFD7\">Rüzgar Hasarı </span>verir.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/10/25073864/1ce09211f025bf5470682189e0837732_4038870417830913687.png",
                "key": "Yuuban Meigen",
                "materials": [],
