                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Maks. Can",
                      "type": "text"
                    },
                    {
                      "text": "değeri ile güçlenen,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Enerji",
                      "type": "text"
                    },
                    {
                      "text": "ihtiyacı olan ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Can",
                      "type": "text"
                    },
                    {
                      "text": "yenileyen karakterlerle iyi olan karakterler için önerilir. Aşağıda birkaç karakter örneği verilmiştir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
