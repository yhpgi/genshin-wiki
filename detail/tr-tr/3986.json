          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Meşru Mükafat, yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Temel Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "niteliği olan ve ikincil niteliği ile",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Can Oranı",
                      "type": "text"
                    },
                    {
                      "text": "sağlayan bir mızraktır. Bu silah, Fontaine'i keşfederken Demirci Estelle'den planı satın alınarak üretilebilir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Bu silah,",
                      "type": "text"
