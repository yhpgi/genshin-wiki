      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Saldırı</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: #BFBFBF\">Fiziksel Hasar</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/02/145542732/240a7dfccb5e733342507e896ab68a90_3138478237665058696.png",
                "id": "talent63236",
                "key": "Kamisato Sanatı: Marobashi",
                "materials": [],
                "points": [
                  {
