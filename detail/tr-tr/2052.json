      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Önerilen Karakterler",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Şafak Habercisi 3 Yıldız bir silah olmasına rağmen oldukça kullanışlı ve iyi bir silahtır. Özellikle oynadığınız karakterin yanında",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Kalkan",
                      "type": "text"
                    },
                    {
                      "text": "kullanıyorsanız ya da karakteriniz saha dışında hasar veren bir karakter ise çok daha kullanışlıdır. Sağladığı",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Kritik Hasar ve Kritik Oranı",
                      "type": "text"
                    },
                    {
                      "text": "gayet iyi düzeydedir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 31,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Kamisato Ayato_icon.png",
                      "menu_id": 2,
                      "name": "Kamisato Ayato",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4946,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/23/10344346/ad3a90bf1fdd85da18bc2d9bad69acb8_538727710496166982.png",
                      "menu_id": 2,
                      "name": "Chiori",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 47,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Albedo_icon.png",
