                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Keqing_icon.png",
                      "name": "Keqing",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Keqing yükseltildiği zaman",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Kritik Oranı",
                      "type": "text"
                    },
                    {
                      "text": "kazandığı için bu silah ile iyi bir sinerji içerisindedir, ek olarak yadigarlardan",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Kritik Oranı",
                      "type": "text"
                    },
                    {
                      "text": "bulma gereksiniminizi bir nebze de olsa azaltacaktır. Ayrıca",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Yüklü Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "'lar için çok iyi bir tercihtir. Bu silah Keqing için en iyi 4 yıldız tercihlerinden birisidir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 27,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Jean_icon.png",
                      "name": "Jean",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Jean eğer ikincil bir destek karakter olarak ayrıca hasar desteği olarak kullanılıyor ise Kara Kılıç çok iyi bir tercihtir. Sebebi ise",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Kritik Oranı",
                      "type": "text"
                    },
                    {
                      "text": "'nı dengelemeyi kolaylaştırması karakterin dizilimini rahatlatacaktır. Ayrıca silahın pasifi sayesinde karakter ile güzel bir sinerji içerisindedir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 31,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Kamisato Ayato_icon.png",
                      "name": "Kamisato Ayato",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ayato hem",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Kritik Oranı",
                      "type": "text"
                    },
                    {
                      "text": "hem de",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "Normal Saldırı Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "'na bağlı bir karakter olduğu için, bu silah 4 yıldız olarak en uyumlu silahlardan birisidir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
