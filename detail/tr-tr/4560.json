                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/4dc11b7dc5d87f85d5124e37b423a947_8677606787161930320.png",
                "title": "Minyon - Satış Sonrası Hizmet Mermisi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Minyon</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Aktif karakterin için 2 Can yeniler ve ona 1 </span><span style=\"color: rgb(255, 255, 255)\">Enerji</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kazandırır.</span><br><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı</span>: <span style=\"color: rgba(255, 255, 255, 0.45)\">2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/db13288db6b90ec33f8adc2656d2019f_5262836036381910263.png",
                "id": "talent26538",
                "key": "Minyon - Cin",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/67b7fdfa996e64de9630aa9be8af9b7b_6779915639067341808.png",
                "title": "Minyon - Cin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Elektrik etkisi uygular ve şu Element Tepkimelerini tetikleyebilir: <br>[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Yüksek Voltaj</span>:<span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 2 artar ve hedef, bir sonraki karakterle zorla değiştirilir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Buz</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Süper İletim</span>: <span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakip karakterler 1 Delme Hasarı verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Elektrik Yüklenme: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakiplere 1 Delme Hasarı verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 172, 255)\">Elektrik </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Doğa</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Hızlanma:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 1 artar ve sonraki 2 Doğa veya Elektrik Hasarını 1 artıran bir [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Dönüştürme Alanı</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] oluşturur.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/11ea6117480145a30b7893f1e8bd7115_1606031227364052798.png",
                "id": "talent41766",
                "key": "Elektrik Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Elektrik Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Fiziksel Hasar</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleştirmez.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Kullanım Hakkı</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 0 olduktan sonra bu kart hemen atılır.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Enerji</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Karakterlerin Element Patlamasını kullanmaları için Enerji harcaması gerekir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Karakterler bir Element Becerisi veya Normal Saldırı kullandıklarında, 1 Enerji kazanırlar.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/245c229cf6f7364c7c9a7aea3db1a1ad_648466508473437570.png",
