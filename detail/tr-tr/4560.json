              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Minyon</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Son Aşama:</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">1 </span><span style=\"color: rgb(255, 172, 255)\">Elektrik Hasarı</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span><br><span style=\"color: rgb(255, 255, 255)\">Kullanım Hakkı</span>: <span style=\"color: rgba(255, 255, 255, 0.45)\">1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/11/10344346/db13288db6b90ec33f8adc2656d2019f_7382998984032508040.png",
