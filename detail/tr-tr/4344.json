                ]
              },
              {
                "item_values": [],
                "key": "Eğitim",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Olağanüstü bir canavar formunda ve neredeyse diğer tüm Fontemer Sapkınlarını gölgede bırakan yalnız bir denizatı lordu. Kafasının altındaki Tuhaf Deniz İncisi, daha güçlü element saldırıları yapmasını ve daha sağlam savunma yeteneklerine sahip olmasını sağlayan bir Elektrik kristalleşmesidir. Tuhaf Deniz İncisini yok etmek için Element Tepkimelerini kullanmanın yanı sıra, Fontemer Tufanını yönlendirirken oluşan Yankılanan Mercan Küreleri de yok ederek söz konusu İnciye etkili bir Hasar verebilirsin.</span></p>"
                ]
              }
            ]
          }
        }
      ]
