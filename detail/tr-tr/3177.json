                ],
                "talent_img": "",
                "title": "Kamisato Sanatı: Senho"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Minyon</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Son Aşama: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: rgb(153, 255, 255)\">Buz Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/db13288db6b90ec33f8adc2656d2019f_2319324171589661137.png",
                "id": "talent63568",
                "key": "Buzdan Seki no To",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/1447ebe24c4e7bd955c4b795be517cd3_6517803659355851260.png",
                "title": "Buzdan Seki no To"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Buz Etkisi uygular ve şu Element Tepkimelerini tetikleyebilir: <br>[</span><span style=\"color: #99FFFF\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #FF9999\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">]</span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Erime</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">: Bu seferki Hasar 2 artar.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: #99FFFF\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #FFACFF\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">]</span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Süper İletim</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">: Bu seferki Hasar 1 artar ve hedef dışındaki tüm rakip karakterlere 1 Delme Hasarı verir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: #99FFFF\">Buz </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #80C0FF\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">]</span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Donma</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">: Bu seferki Hasar 1 artar ve hedef bu turda hamle yapamaz. (Hedef, Fiziksel Hasar ve Ateş Hasarı alınca kaldırılır, fazladan 2 Hasar alır.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/4bcc4b82a9d7ee22770f60afa54e9919_418777729660990377.png",
                "id": "talent57808",
                "key": "Buz Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Buz Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleşmez. </span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı </span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır. </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> 0 olduktan sonra bu kart hemen atılır.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_935853443867976578.png",
