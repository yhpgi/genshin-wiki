      "name": "Beceri",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">2 </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Fiziksel Hasar </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/145542732/10316b5178d5109d597f415d6e7903dc_4477973078054031475.png",
                "id": "talent91481",
                "key": "Dövüş Kulübü Efsanesi",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Dövüş Kulübü Efsanesi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Element Becerisi</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">3 </span><span style=\"color: rgb(255, 230, 153)\">Toprak Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir. </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Ushi </span><span style=\"color: rgba(255, 255, 255, 0.45)\">çağırır. Bu karakter </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Doğaüstü Güç </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kazanır.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Doğaüstü Güç</span></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bunu kuşanmış karakter Yüklü Saldırı kullandığında fazladan 1 Hasar verir. Eğer Kullanım Hakkı 2'den az değilse harcanan Nötr Element kullanımı 1 azalır.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı: 1 (En fazla 3 kademe birikebilir.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/145542732/c75ed9237fb342dae8cd65729ddc0bba_7991404756657444476.png",
                "id": "talent15984",
                "key": "Masatsu Zetsugi: Akaushi Patlaması!",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Masatsu Zetsugi: Akaushi Patlaması!"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Element Patlaması</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">5 </span><span style=\"color: rgb(255, 230, 153)\">Toprak Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verir ve bu karakter </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Kızgın Oni Kralı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kazanır.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Kızgın Oni Kralı</span></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartı kuşanmış karakterin Normal Saldırıları fazladan 2 Hasar verir ve verdiği </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar, </span><span style=\"color: rgb(255, 230, 153)\">Toprak Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">olarak değişir.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Tur Süresi: 2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartı kuşanmış karakter bir Normal Saldırı yaptıktan sonra </span><span style=\"color: rgb(236, 229, 216)\">Doğaüstü Güç </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kazanır. (Her turda bir defa.)</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Doğaüstü Güç</span></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bunu kuşanmış karakter Yüklü Saldırı kullandığında fazladan 1 Hasar verir. Eğer Kullanım Hakkı 2'den az değilse harcanan Nötr Element kullanımı 1 azalır.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı: 1 (En fazla 3 kademe birikebilir.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/145542732/d5b0f60e30da0341b4165d1a76b3c73b_5291509503546002516.png",
                "id": "talent20375",
                "key": "Belalı Oni Kral: Itto, Dünyaya Karşı!",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Belalı Oni Kral: Itto, Dünyaya Karşı!"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Minyon</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Aktif karakterin Hasar aldığında alınan Hasar 1 azalır.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı: 1. Bu kart Kullanım Hakkı sınırına ulaştığında atılmaz.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Aşağıdaki etki, bu Minyon varken tetiklenebilir. Aktif karakterin Hasar aldığında Arataki Itto </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Doğaüstü Güç </span><span style=\"color: rgba(255, 255, 255, 0.45)\">kazanır. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Son Aşama: Bu kartı atarak 1 </span><span style=\"color: #FFE699\">Toprak Hasarı </span><span style=\"color: rgba(255, 255, 255, 0.45)\">verebilirsin.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Doğaüstü Güç</span></p><p><span style=\"color: rgb(255, 215, 128)\">Durum</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bunu kuşanmış karakter Yüklü Saldırı kullandığında fazladan 1 Hasar verir. Eğer Kullanım Hakkı 2'den az değilse harcanan Nötr Element kullanımı 1 azalır.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı: 1 (En fazla 3 kademe birikebilir.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/145542732/db13288db6b90ec33f8adc2656d2019f_6991763298464344627.png",
                "id": "talent76648",
                "key": "Minyon - Ushi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/145542732/ea059a3f7bee2dea6bcee851752339c3_5407748595033747014.png",
                "title": "Minyon - Ushi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Zaten uygulanmış olan Elementlerle tepkimeye girer:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 230, 153)\">Toprak </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Buz</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Buz Kristalleşmesi</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> Bu seferki Hasar 1 artar ve aktif karakterin 1 Kalkan puanı kazanır. (üst üste birikebilir ve maksimum 2 puan).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 230, 153)\">Toprak </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Su</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Su Kristalleşmesi</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve aktif karakterin 1 Kalkan puanı kazanır. (üst üste birikebilir ve maksimum 2 puan).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 230, 153)\">Toprak </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Ateş</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Ateş Kristalleşmesi</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve aktif karakterin 1 Kalkan puanı kazanır. (üst üste birikebilir ve maksimum 2 puan).</span></p><ol><li><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[</span><span style=\"color: rgb(255, 230, 153)\">Toprak </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Elektrik</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Elektrik Kristalleşmesi</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu seferki Hasar 1 artar ve aktif karakterin 1 Kalkan puanı kazanır. (üst üste birikebilir ve maksimum 2 puan).</span></p></li></ol>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/145542732/fd37cbfdd3b1b2c16e6e83fb0aa96889_7973777733760784980.png",
                "id": "talent96908",
                "key": "Toprak Hasarı",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Toprak Hasarı"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Fiziksel Hasar</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Fiziksel Hasar, herhangi bir Element uygulamaz veya Element Tepkimesi gerçekleşmez. <br></span></p><ol><li><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Yüklü Hasar</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Toplam Element Zarı miktarı çift sayı olduğunda kullanılacak Normal Saldırı, Yüklü Saldırı olarak sayılır.</span></p></li><li><p></p></li></ol><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Nötr Element</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu tür bir maliyeti ödemek için herhangi bir elementin Element Zarını kullanabilirsin.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bu kartın etkisi tetiklendikten sonra 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> harcanır. </span><strong><span style=\"color: rgba(255, 255, 255, 0.45)\">Kullanım Hakkı</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> 0 olduktan sonra bu kart hemen atılır.</span></p><p></p><ol><li><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Tur Süresi</span></strong></p></li><li><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Her turun Son Aşamasında Tur Süresi 1 azalır; Tur Süresi tükendikten sonra bu kart hemen atılır.</span></p></li></ol>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/145542732/245c229cf6f7364c7c9a7aea3db1a1ad_5592764810098321133.png",
