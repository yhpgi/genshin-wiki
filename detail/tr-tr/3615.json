    {
      "id": "39",
      "name": "Silah Hakkında",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "Önerilen Karakterler",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Kızıl Çölün İradesi, kuşanan karaktere yüksek",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Kritik Oranı",
                      "type": "text"
                    },
                    {
                      "text": "sağlayan ve pasifi sayesinde",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Element Becerisi Hasar",
                      "type": "text"
                    },
                    {
                      "text": "verdiğinde ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "aldığında",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Saldırı",
                      "type": "text"
                    },
                    {
                      "text": "sağlayan bir",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Çift Elli Kılıçtır",
                      "type": "text"
                    },
                    {
                      "text": ". Aşağıda bazı önerilen karakterler verilmiştir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3463,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/02/25073864/65b22311e1e38ffa45a4928d4005ecee_97571996295361468.png",
                      "name": "Dehya",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Dehya, savaş alanında olmadan takım arkadaşlarının aldığı",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "kendine yansıtabildiği ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Element Becerisi",
                      "type": "text"
                    },
                    {
                      "text": "sürekli olarak",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasar",
                      "type": "text"
                    },
                    {
                      "text": "verdiği için silahın pasifinin iki kısmını da verimli olarak kullanabilir. Ayrıca Dehya takımlarında kalkana ihtiyacınız olmadığı için kendi",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Maks. Canını",
                      "type": "text"
                    },
                    {
                      "text": "da artırabilir ve",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Maks. Can",
                      "type": "text"
                    },
                    {
                      "text": "arttığı için",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Hasarı",
                      "type": "text"
                    },
                    {
                      "text": "da artar. Bu silah, Dehya'nın imza silahıdır.",
                      "type": "text"
