          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Saldırı</span></p><p>2 Fiziksel Hasar verir.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/15/25073864/c369b96fc6417e8fc2bb607e37297ad4_6993361422333558747.png",
                "id": "talent23241",
                "key": "Khanda Bariyer Kırıcı",
                "materials": [],
                "points": [
                  {
