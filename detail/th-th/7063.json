      "name": "ความสามารถ",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: #FFD780\">โจมตีปกติ</span></p><p>สร้าง<span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span> 2 หน่วย</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/08/53372413/3e35605b5b8ba7b28cc8f4394de0d690_4776339125155870527.png",
                "id": "talent1343",
                "key": "Floral-Ring Caress",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Floral-Ring Caress"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>สร้าง<span style=\"color: rgb(153, 255, 136)\">ความเสียหายไม้</span> 3 หน่วย และสร้าง <span style=\"color: rgb(255, 255, 255)\">Spirit-Serpent's Blessing</span> 1 ชั้น</p><p></p><p><strong><span style=\"color: #ECE5D8\">Spirit-Serpent's Blessing</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">เมื่อฝ่ายเราใช้เทคนิคของ Spirit of Omen: Dendro Spirit-Serpent:</span> <span style=\"color: rgb(255, 255, 255)\">เทคนิค</span>นี้จะสร้างความเสียหาย +1 และไม่หักใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>ของ <span style=\"color: rgb(255, 255, 255)\">Spirit of Omen: Dendro Spirit-Serpent</span></p><p><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้:</span> 1 (ซ้อนทับได้โดยไม่มีขีดจำกัด)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/08/53372413/c26c17cce52ff41d5b978fd4d248efea_4838265687426503274.png",
                "id": "talent38041",
                "key": "Spiraling Whirl",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Spiraling Whirl"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: rgb(153, 255, 136)\">ความเสียหายไม้</span> 4 หน่วย โดยจะจำกัดดูเอลละ 1 ครั้ง และเพิ่ม<span style=\"color: rgb(255, 255, 255)\"> Spirit of Omen: Dendro Spirit-Serpent</span> 1 ใบ เข้ามาในมือของเรา</p><p>(ตัวละครที่ติดตั้งการ์ด <span style=\"color: rgb(255, 255, 255)\">Spirit of Omen: Dendro Spirit-Serpent </span>สามารถใช้เทคนิคได้:<span style=\"color: rgba(255, 255, 255, 0.85)\"> Viny Razorscale</span>)</p><p></p><p><strong><span style=\"color: #ECE5D8\">Spirit of Omen: Dendro Spirit-Serpent</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">เทคนิค</span></p><p><span style=\"color: rgb(255, 255, 255)\">เทคนิค:</span> Viny Razorscale</p><p><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้:</span> 2</p><p>(ตัวละครจะสามารถสวมใส่ \"เทคนิค\" ได้มากสุด 1 อัน)</p><p></p><p><strong><span style=\"color: #ECE5D8\">Viny Razorscale</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">เทคนิค</span></p><p>สร้าง<span style=\"color: rgb(153, 255, 136)\">ความเสียหายไม้</span> 1 หน่วย</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/08/53372413/86b01f7358a08b03bb712ccefea15285_4949314220317045124.png",
                "id": "talent78034",
                "key": "Spirit of Omen's Awakening: Dendro Spirit-Serpent",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Spirit of Omen's Awakening: Dendro Spirit-Serpent"
              },
              {
                "attributes": [],
                "desc": "<p>[ติดตัว] <span style=\"color: #FFFFFF\">หลังจากที่ตัวละครนี้ได้รับความเสียหาย:</span> หากค่าพลังชีวิตของตัวละครนี้ต่ำกว่า 7 จะได้รับ<span style=\"color: #FFFFFF\">พลังงาน </span>1 หน่วย (เทิร์นละ 1 ครั้ง)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/08/53372413/eb96a0e1f4fd6ddf6d0975dfcf1fed10_8009095366979687838.png",
                "id": "talent28710",
                "key": "Spirit of Omen's Power",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Spirit of Omen's Power"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">เทคนิค</span></p><p><span style=\"color: #FFFFFF\">เทคนิค:</span> Viny Razorscale</p><p><span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้:</span> 2</p><p>(ตัวละครจะสามารถสวมใส่ \"เทคนิค\" ได้มากสุด 1 อัน)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/09/53372413/db13288db6b90ec33f8adc2656d2019f_5358917170568593845.png",
                "id": "talent98718",
                "key": " Spirit of Omen: Dendro Spirit-Serpent",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [
                  {
                    "description": "",
                    "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/09/53372413/caeb5aaf82eb3f105c6b3e9f4b29d917_1628739728129759722.png"
                  }
                ],
                "title": " Spirit of Omen: Dendro Spirit-Serpent"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะธาตุไม้จะสามารถทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro </span>] <span style=\"color: rgb(255, 255, 255)\">งอกเงย:</span> ความเสียหายนี้ +1 และทำให้เกิด <span style=\"color: rgb(255, 255, 255)\">[Dendro Core]</span> ที่ทำให้ความเสียหายไฟ/ไฟฟ้า ครั้งต่อไป +2</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">ติดไฟ:</span> ความเสียหายนี้ +1 และจะทำให้เกิด <span style=\"color: rgb(255, 255, 255)\">[Burning Flame] </span>ที่สร้างความเสียหายไฟ 1 หน่วย ในตอนสั้นสุดเทิร์น (ใช้ได้ 1ครั้ง ซ้อนทับได้มากสุดถึง 2)</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>]<span style=\"color: rgb(255, 255, 255)\"> ปลุกเร้า: </span>ความเสียหายนี้ +1 และทำให้เกิด<span style=\"color: rgb(255, 255, 255)\"> [Catalyzing Field] </span>ที่จะทำให้ ความเสียหายไม้/ไฟฟ้า 3 ครั้ง ถัดไป +1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/08/53372413/e8cff941b5a0ff248efde360ec9e91fe_1075688232373162931.png",
                "id": "talent42104",
                "key": "ความเสียหายไม้",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "ความเสียหายไม้"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #ECE5D8\">ความเสียหายกายภาพ</span></p><p>ความเสียหายกายภาพ จะไม่ทำให้ติดสถานะธาตุ และก็ไม่ทำให้เกิดปฏิกิริยาธาตุด้วย</p><p></p><p><strong><span style=\"color: #ECE5D8\">จำนวนครั้งที่ใช้ได้</span></strong></p><p>หลังการ์ดใบนี้เกิดเอฟเฟกต์ จะใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span> 1 ครั้ง;</p><p>และหลังจากที่<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>หมด การ์ดใบนี้จะถูกทิ้งไป</p><p></p><p><strong><span style=\"color: #ECE5D8\">พลังงาน</span></strong></p><p>เมื่อตัวละครใช้ <span style=\"color: rgb(255, 255, 255)\">\"ท่าไม้ตาย\"</span> จะต้องใช้พลังงาน</p><p>หลังจากที่ตัวละครใช้ <span style=\"color: rgb(255, 255, 255)\">\"สกิลธาตุ\"</span> หรือ <span style=\"color: rgb(255, 255, 255)\">\"การโจมตีปกติ\"</span> จะได้รับพลังงาน 1 หน่วย</p><p></p><p><strong><span style=\"color: #ECE5D8\">เทคนิค</span></strong></p><p>เมื่อตัวละครที่เข้าต่อสู้ติดตั้งการ์ด \"เทคนิค\" จะสามารถใช้ \"เทคนิค\" ที่เกี่ยวข้องได้</p><p>การใช้ \"เทคนิค\" เป็นการ \"ดำเนินการต่อสู้\" อย่างหนึ่ง เมื่อตัวละครไม่สามารถใช้สกิลได้เนื่องจากสถานะแช่แข็ง, กลายเป็นหิน, มึนงง ฯลฯ จะไม่สามารถใช้ \"เทคนิค\" ได้เช่นกัน</p><p>เมื่อตัวละครใช้ \"เทคนิค\" จะไม่นับเป็นการใช้สกิล และไม่สามารถทำให้เกิดเอฟเฟกต์ \"หลังจากใช้สกิล\" หรือ \"หลังจากที่ตัวละครทำให้เกิดปฏิกิริยาธาตุ\" ได้; นอกจากนี้ ความเสียหายที่เกิดจากการใช้ \"เทคนิค\" ของตัวละคร จะไม่ถูกนับว่าเป็นความเสียหายที่ตัวละครสร้าง</p><p></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/08/53372413/07bae546ac7c69ef6402170b283840c5_6501235817662179702.png",
