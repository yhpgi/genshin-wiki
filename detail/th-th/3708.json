                      "name": "เหรียญนําโชค",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "แขกที่มาท้าทาย: Kamisato Ayato",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"อยากลองดูเอลกันสักตาเหรอ? หึ ฉันก็ปฏิเสธคำขอแบบนี้ไม่ลงซะด้วยสิ\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "[ข้อแนะนำ] เด็คของ Kamisato Ayato จะอาศัย \"ดาบ\" และ \"การโจมตีปกติ\" เป็นหลัก ซึ่งเขาถนัดด้านการติดตั้งการ์ดอาวุธแล้วทำการโจมตีต่อเนื่องอย่างชาญฉลาดเพื่อพิชิตศัตรู",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "ทีมของคู่ต่อสู้",
