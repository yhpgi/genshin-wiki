                      "menu_id": 17,
                      "name": "Kamisato Ayaka",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3184,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/144837601/9d7ad9d3cf203bf7ff1f53966709c4f1_995364308030355184.png",
                      "menu_id": 17,
                      "name": "Bennett",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ปลดล็อกหลัง:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "มีเลเวลผู้เล่นถึง 7",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "สำเร็จเป้าหมายการท้าทาย",
                      "type": "text"
                    },
                    {
                      "text": "Kamisato Ayato",
                      "type": "text"
                    },
                    {
                      "text": "- เป็นมิตร 3 อัน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "เป้าหมายการท้าทาย",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
