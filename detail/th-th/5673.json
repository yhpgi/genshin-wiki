            "list": [
              {
                "item_values": [],
                "key": "ชื่อ",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Silvershower Heartstrings</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "หาได้จาก",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">กิจกรรมอธิษฐานอาวุธ</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "ประเภท",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">ธนู</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "ค่าสถานะรอง",
                "string_values": [
                  "<p><span style=\"color: rgb(255, 255, 255)\">เปอร์เซ็นต์พลังชีวิต</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Dryas's Nocturne",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">ผู้สวมใส่จะได้รับเอฟเฟกต์ \"กู้ชีพ\" เมื่อมีเอฟเฟกต์กู้ชีพ 1/2/3 ชั้น พลังชีวิตสูงสุดจะเพิ่มขึ้น </span><span style=\"color: #37FFFF\">12%/24%/40%</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> ผู้สวมใส่จะได้รับกู้ชีพเพิ่มเติม 1 ชั้น ภายใต้สถานการณ์ต่อไปนี้: เมื่อปลดปล่อยสกิลธาตุ จะมีผล 25 วินาที; เมื่อค่าบ่วงพันธะชีวันเพิ่มขึ้น จะมีผล 25 วินาที; เมื่อทำการรักษา จะมีผล 20 วินาที จะยังคงใช้งานได้แม้ผู้ที่สวมใส่อยู่ในทีม แต่ไม่ได้เข้าร่วมการต่อสู้ ช่วงเวลาต่อเนื่องของเอฟเฟกต์กู้ชีพแต่ละชั้นจะคำนวณแยกกัน นอกจากนี้ เมื่ออยู่ในสถานะกู้ชีพ 3 ชั้น อัตราคริของท่าไม้ตายจะเพิ่มขึ้น </span><span style=\"color: #37FFFF\">28%</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> เอฟเฟกต์นี้จะหายไปเมื่อกู้ชีพไม่ถึง 3 ชั้น ภายใน 4 วินาที</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
