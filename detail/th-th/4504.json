                  "content": [
                    {
                      "text": "Vigneire",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "อดีตคนรักของ",
                      "type": "text"
                    },
                    {
                      "text": "Vacher",
                      "type": "text"
                    },
                    {
                      "text": "ภายหลังเธอสูญหายไปอันเนื่องมาจาก",
