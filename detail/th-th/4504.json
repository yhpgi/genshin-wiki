                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "หรืออาจไม่ใช่เมื่อวาน สับสนเรื่องวันและเวลามาสักพักแล้ว",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
