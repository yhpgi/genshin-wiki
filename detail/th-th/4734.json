      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #37FFFF\">La Signora</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span></p><p>สร้าง<span style=\"color: #99FFFF\">ความเสียหายน้ำแข็ง</span> 1 หน่วย</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/115795437/1ce09211f025bf5470682189e0837732_7933882382419149254.png",
                "id": "talent88040",
                "key": "Frostblade Hailstorm",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Frostblade Hailstorm"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(55, 255, 255)\">La Signora</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>สร้าง<span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span> 2 หน่วย และทำให้ตัวละครเป้าหมายได้รับ <span style=\"color: rgb(255, 255, 255)\">Sheer Cold</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Sheer Cold</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">จบเฟส</span>: สร้าง<span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span>ให้กับตัวละครที่มีสถานะนี้ 1 หน่วย</p><p><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>: 1</p><p>เมื่อตัวละครที่มีสถานะนี้ติดสถานะ <span style=\"color: rgb(255, 255, 255)\">Blazing Heat</span> จะลบล้างเอฟเฟกต์นี้</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/115795437/289913e1d0feaab0fa03891032b086c0_9192640638393276205.png",
                "id": "talent77175",
                "key": "Biting Shards",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Biting Shards"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(55, 255, 255)\">La Signora</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span> 4 หน่วย และรักษาตัวละครนี้ 2 หน่วย ลบล้าง <span style=\"color: rgb(255, 255, 255)\">Ice-Sealed Crimson Witch of Embers</span> และตัวละครนี้จะเปลี่ยนเป็น <span style=\"color: rgb(255, 255, 255)\">\"Crimson Witch of Embers\"</span> อย่างถาวร</p><p></p><p><strong><span style=\"color: #FFFFFF\">Ice-Sealed Crimson Witch of Embers</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">เมื่อแอ็กชันเฟสเริ่มต้น</span>: หากตัวละครที่มีการ์ดใบนี้ มีค่าพลังชีวิตไม่เกิน 4 จะลบล้างเอฟเฟกต์นี้</p><p><span style=\"color: rgb(255, 255, 255)\">เมื่อตัวละครที่มีการ์ดใบนี้ถูกเอาชนะ</span>: จะลบล้างเอฟเฟกต์นี้ ทำให้ตัวละคร<span style=\"color: rgb(255, 255, 255)\">หลีกเลี่ยงการพ่ายแพ้</span> และรักษาค่าพลังชีวิตของตัวละครดังกล่าว 1 หน่วย</p><p><span style=\"color: rgb(255, 255, 255)\">เมื่อเอฟเฟกต์นี้ถูกลบล้าง</span>: ตัวละครที่มีการ์ดใบนี้จะเปลี่ยนสถานะเป็น <span style=\"color: rgb(255, 255, 255)\">\"Crimson Witch of Embers\"</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Crimson Witch of Embers</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">\"Signora\"</span> สามารถเปลี่ยนร่างเป็น <span style=\"color: rgb(255, 255, 255)\">\"Crimson Witch of Embers\" </span>ได้ถาวร หลังจากเปลี่ยนร่าง ประเภทธาตุของธาตุ <span style=\"color: rgb(255, 255, 255)\">\"Signora\" </span>จะเปลี่ยนจาก<span style=\"color: rgb(153, 255, 255)\">ธาตุน้ำแข็ง</span>เป็น<span style=\"color: rgb(255, 153, 153)\">ธาตุไฟ</span></p><p>หลังจากเปลี่ยนร่างแล้ว ตัวละครนี้จะสามารถใช้สกิลของ <span style=\"color: rgb(255, 255, 255)\">\"Crimson Witch of Embers\"</span> ได้ แต่จะไม่สามารถใช้สกิลเดิมของ <span style=\"color: rgb(255, 255, 255)\">\"Signora\"</span> ได้อีก</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/115795437/f819c287507962ff41ad86e68661a707_8074421910412038274.png",
                "id": "talent70236",
