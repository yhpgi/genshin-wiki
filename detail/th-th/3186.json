                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/08/77454259/c85bfab46d8c95659ab6dfb2e1629a87_2572904672223728374.png",
                      "name": "Lucky Coin",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "1",
