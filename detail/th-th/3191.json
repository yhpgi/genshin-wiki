              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span></p><p>จะสร้าง<span style=\"color: #FFD780\">ความเสียหายหิน</span> 1 หน่วย</p>",
