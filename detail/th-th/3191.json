                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Jade Screen"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: rgb(255, 215, 128)\">ความเสียหายหิน</span> 6 หน่วย; หากมี <span style=\"color: rgb(255, 255, 255)\">Jade Screen</span> อยู่ในสนาม จะทำให้ความเสียหายนี้ +2</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Jade Jade Screen</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">สถานะการต่อสู้</span></p><p><span style=\"color: rgb(255, 255, 255)\">เมื่อตัวละครที่เข้าต่อสู้ของฝ่ายเราได้รับความเสียหายอย่างน้อย 2 หน่วย:</span> ลบล้างความเสียหาย 1 หน่วย</p><p><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้: 2</span><strong><span style=\"color: rgb(236, 229, 216)\">Screen</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">สถานะการต่อสู้</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/55dfd3944aa4091c2684c17412739558_2443324431648707050.png",
                "id": "talent33327",
                "key": "Starshatter",
                "materials": [],
