    {
      "id": "36",
      "name": "เกมกลเจ็ดอัจฉริยะ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอล: จงอย่ารบกวนความสง่างาม",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "หลังจากเดินทางข้ามเขาลูกแล้วลูกเล่า กวีได้บังเอิญเจอสถานที่ที่ทำให้เกิดแรงบันดาลใจในป่า และต้องการหยิบปากกาขึ้นมาเพื่อเขียนกวีบทใหม่ แต่แล้วก็ถูกขัดขวางโดยอันธพาลทั้งสาม...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "[กฏพิเศษ] ในแต่ละเทิร์น เมื่อฝ่ายเราใช้การ์ดแอ็กชันใบแรก จะใช้ Elemental Dice น้อยลง 2 ลูก เมื่อแอ็กชันเฟสเริ่มต้น: หากตัวละครที่เข้าต่อสู้ของฝ่ายเราได้รับการปกป้องจากโล่ จะก่อให้เกิดธาตุสารพัดประโยชน์ 2 ลูก และจั่วการ์ด 2 ใบ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3919,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/07/144837601/8a1c0a295d2c80022672cca2b2ac301d_8856142619391997602.png",
