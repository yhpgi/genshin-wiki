      "name": "ความสามารถ",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">โจมตีปกติ</span></p><p><span style=\"color: rgb(236, 228, 217)\">สร้าง</span><strong><span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span></strong><span style=\"color: rgb(236, 228, 217)\">&nbsp;2 หน่วย</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/fac25ea0c7b14ad3af8c35f1e7230768_1871257065862339496.png",
                "key": "Whirling Scythe ",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Whirling Scythe "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>สร้าง<span style=\"color: rgb(128, 192, 255)\">ความเสียหายน้ำ</span> 3 หน่วย<br>หากมีตัวละครฝ่ายศัตรูที่มี <span style=\"color: rgb(255, 255, 255)\">แช่แข็ง</span> หรือ <span style=\"color: rgb(255, 255, 255)\">Mist Bubble Prison</span> ตัวละครนี้จะได้รับ<span style=\"color: rgb(255, 255, 255)\">พลังงาน</span> 1 หน่วย (เทิร์นละ 1 ครั้ง)</p><p></p><p><strong><span style=\"color: #ECE5D8\">แช่แข็ง</span></strong><br><span style=\"color: #FFD780\">ไม่สามารถดำเนินการได้</span><br><span style=\"color: rgb(255, 255, 255)\">ตัวละครไม่สามารถใช้สกิลได้</span> (จนกว่าจะจบเทิร์น)<br>เมื่อตัวละครได้รับ <span style=\"color: rgb(255, 153, 153)\">ความเสียหายไฟ</span> หรือ <span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span> จะลบล้างเอฟเฟกต์นี้ และทำให้ความเสียหายดังกล่าว +2<br></p><p><strong><span style=\"color: #ECE5D8\">Mist Bubble Prison</span></strong><br><span style=\"color: #FFD780\">ไม่สามารถดำเนินการได้</span><br><span style=\"color: rgb(255, 255, 255)\">ตัวละครไม่สามารถใช้สกิลได้</span> (จนกว่าจะจบเทิร์น)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/a0d727e22385bc9dbaf22efe44cd53fd_6537152090055876222.png",
                "key": "Slash of Surging Tides ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Slash of Surging Tides "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: rgb(128, 192, 255)\">ความเสียหายน้ำ</span> 3 หน่วย และทำให้เกิดการ์ด <span style=\"color: rgb(255, 255, 255)\">Mist Bubble Slime</span><br>(ตัวละครที่ติดตั้งการ์ด <span style=\"color: rgb(255, 255, 255)\">Mist Bubble Slime</span> สามารถใช้เทคนิค: <span style=\"color: rgb(255, 255, 255)\">Bubble Battle Tactics</span>)</p><p></p><p><strong><span style=\"color: #ECE5D8\">Mist Bubble Slime</span></strong><br><span style=\"color: #FFD780\">เทคนิค</span><br><span style=\"color: rgb(255, 255, 255)\">เทคนิค</span>: Bubble Battle Tactics<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้: 2</span><br>(ตัวละครจะสามารถสวมใส่ \"เทคนิค\" ได้มากสุด 1 อัน)<br></p><p><strong><span style=\"color: #ECE5D8\">Bubble Battle Tactics</span></strong><br><span style=\"color: #FFD780\">เทคนิค</span><br>(ต้องใช้เวลาเตรียม 1 เทิร์น) สร้าง<span style=\"color: rgb(128, 192, 255)\">ความเสียหายน้ำ</span> 1 หน่วย และตัวละครที่เข้าต่อสู้ของฝ่ายศัตรู จะได้รับ <span style=\"color: rgb(255, 255, 255)\">Mist Bubble Prison</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/70991d794303f5f0b58d175ff23cff00_7147730678647927770.png",
                "key": "Bubblefloat Blitz ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Bubblefloat Blitz "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">เทคนิค</span><br><span style=\"color: rgb(255, 255, 255)\">เทคนิค</span>: Bubble Battle Tactics<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้: 2</span><br>(ตัวละครจะสามารถสวมใส่ \"เทคนิค\" ได้มากสุด 1 อัน)<br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/db13288db6b90ec33f8adc2656d2019f_3233203408866389951.png",
                "key": "Mist Bubble Slime",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/47f0e77e4279d21ba6bb0062db34d677_1213446592686484466.png",
                "title": "Mist Bubble Slime"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะธาตุน้ำ จะทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] ระเหย</span>: ความเสียหายนี้ +2</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">] ชาร์จไฟฟ้า</span>: ความเสียหายนี้ +1 และสร้างความเสียหายทะลวง 1 หน่วย ให้แก่ตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] แช่แข็ง</span>: ความเสียหายนี้ +1 และก็ทำให้เป้าหมายไม่สามารถดำเนินการต่าง ๆ ได้ในเทิร์นนี้ (จะหายไปหลังจากที่ได้รับความเสียหายกายภาพ หรือความเสียหายไฟ แต่ความเสียหายที่ได้รับ จะ +2)</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] งอกเงย</span>: ความเสียหายนี้ +1 และทำให้เกิด [<span style=\"color: rgb(255, 255, 255)\">Dendro Core</span>] ที่ทำให้ ความเสียหายไฟ หรือความเสียหายไฟฟ้า ครั้งต่อไป +2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/a126c6a302d81c07e19cf9a9f1260f90_4220459197074280804.png",
                "key": "ความเสียหายน้ำ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายน้ำ"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะธาตุไฟ จะทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p>[<span style=\"color: rgb(255, 153, 153)\">ไฟ</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">น้ำแข็ง</span>] <span style=\"color: rgb(255, 255, 255)\">ละลาย: </span>ความเสียหายนี้ +2</p><p>[<span style=\"color: rgb(255, 153, 153)\">ไฟ</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">น้ำ</span>] <span style=\"color: rgb(255, 255, 255)\">ระเหย:</span> ความเสียหายนี้ +2</p><p>[<span style=\"color: rgb(255, 153, 153)\">ไฟ</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">ไฟฟ้า</span>] <span style=\"color: rgb(255, 255, 255)\">โอเวอร์โหลด:</span> ความเสียหายนี้ +2 และตัวเป้าหมายจะถูกบังคับให้เปลี่ยนไปใช้ตัวละครถัดไป</p><p>[<span style=\"color: rgb(255, 153, 153)\">ไฟ</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">ไม้</span>] <span style=\"color: rgb(255, 255, 255)\">ติดไฟ:</span> ความเสียหายนี้ +1 และจะทำให้เกิด [Burning Flame] ที่สร้างความเสียหายไฟ 1 หน่วย ในตอนสิ้นสุดเทิร์น (ใช้ได้ 1 ครั้ง ซ้อนทับได้มากสุดถึง 2)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/d714b3b669cc08d1d8e34464fd7a3630_5376264627617148914.png",
                "key": "ความเสียหายไฟ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายไฟ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">ความเสียหายกายภาพ</span></strong><br>ความเสียหายกายภาพ จะไม่ทำให้ติดสถานะธาตุ และก็ไม่ทำให้เกิดปฏิกิริยาธาตุด้วย</p><p></p><p><strong><span style=\"color: #ECE5D8\">พลังงาน</span></strong><br>เมื่อตัวละครใช้ \"ท่าไม้ตาย\" จะต้องใช้พลังงาน<br>หลังจากที่ตัวละครใช้ \"สกิลธาตุ\" หรือ \"การโจมตีปกติ\" จะได้รับพลังงาน 1 หน่วย<br></p><p><strong><span style=\"color: #ECE5D8\">เทคนิค</span></strong><br>เมื่อตัวละครที่เข้าต่อสู้ติดตั้งการ์ด \"เทคนิค\" จะสามารถใช้ \"เทคนิค\" ที่เกี่ยวข้องได้<br>การใช้ \"เทคนิค\" เป็นการ \"ดำเนินการต่อสู้\" อย่างหนึ่ง เมื่อตัวละครไม่สามารถใช้สกิลได้เนื่องจากสถานะแช่แข็ง, กลายเป็นหิน, มึนงง ฯลฯ จะไม่สามารถใช้ \"เทคนิค\" ได้เช่นกัน<br>เมื่อตัวละครใช้ \"เทคนิค\" จะไม่นับเป็นการใช้สกิล และไม่สามารถทำให้เกิดเอฟเฟกต์ \"หลังจากใช้สกิล\" หรือ \"หลังจากที่ตัวละครทำให้เกิดปฏิกิริยาธาตุ\" ได้; นอกจากนี้ ความเสียหายที่เกิดจากการใช้ \"เทคนิค\" ของตัวละคร จะไม่ถูกนับว่าเป็นความเสียหายที่ตัวละครสร้าง<br></p><p><strong><span style=\"color: #ECE5D8\">จำนวนครั้งที่ใช้ได้</span></strong><br>หลังการ์ดใบนี้เกิดเอฟเฟกต์ จะใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span> 1 ครั้ง;<br>และหลังจากที่<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>หมด การ์ดใบนี้จะถูกทิ้งไป</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/07bae546ac7c69ef6402170b283840c5_5426333498253670673.png",
