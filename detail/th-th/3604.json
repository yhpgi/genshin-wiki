                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "สำเร็จเป้าหมายการท้าทาย",
                      "type": "text"
                    },
                    {
                      "text": "Eula",
                      "type": "text"
