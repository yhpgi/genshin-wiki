                      ],
                      "text": "หมายเหตุ",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2812,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/10/09/144837601/586d726f9ebda3506c78beaaa41f13b6_5545751724024546149.png",
                      "menu_id": 2,
                      "name": "Nilou",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เป็นอาวุธที่เหมาะกับ Nilou เนื่องจากค่าสถานะรองเป็น",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ค่าพลังชีวิต",
                      "type": "text"
                    },
                    {
                      "text": "ซึ่งสามารถประสานกับการทำปฏิกิริยาธาตุและพรสวรรค์ของ Nilou นอกจากนี้ เอฟเฟกต์เฉพาะของอาวุธชิ้นนี้ยังช่วย",
                      "type": "text"
