    {
      "id": "8",
      "name": "ค่าสถานะ",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "ชื่อ",
                "string_values": [
                  "<p>The Dockhand's Assistant</p>"
                ]
              },
              {
                "item_values": [],
                "key": "หาได้จาก",
                "string_values": [
                  "<p>กิจกรรมอธิษฐานอาวุธ</p>"
                ]
              },
              {
                "item_values": [],
                "key": "ประเภท",
                "string_values": [
                  "<p>ดาบ</p>"
                ]
              },
              {
                "item_values": [],
                "key": "ค่าสถานะรอง",
                "string_values": [
                  "<p>เปอร์เซ็นต์พลังชีวิต</p>"
                ]
              },
              {
                "item_values": [],
                "key": "Sea Shanty",
                "string_values": [
                  "<p>เมื่อได้รับการรักษาหรือทำการรักษา จะได้รับสัญลักษณ์ Stoic หนึ่งอัน เป็นเวลา 30 วินาที โดยสามารถมีสัญลักษณ์ Stoic ได้สูงสุด 3 อัน เมื่อปล่อยสกิลธาตุหรือท่าไม้ตาย จะใช้สัญลักษณ์ Stoic ทั้งหมด เพื่อสร้างเอฟเฟกต์ \"Roused\" เป็นเวลา 10 วินาที: สัญลักษณ์ Stoic แต่ละอันที่ใช้ไปจะเพิ่มความชำนาญธาตุขึ้น<span style=\"color: #37FFFF\"> 40</span> หน่วย และหลังจากที่เกิดเอฟเฟกต์ 2 วินาที สัญลักษณ์ Stoic แต่ละอันที่ใช้ไปจะฟื้นฟูพลังงานธาตุ <span style=\"color: #37FFFF\">2 </span>หน่วย ให้กับผู้สวมใส่ เอฟเฟกต์ Roused สามารถเกิดขึ้นได้มากสุดหนึ่งครั้ง ในทุก 15 วินาที เมื่อตัวละครอยู่ในทีมแต่ไม่ได้เข้าร่วมการต่อสู้ จะยังสามารถรับสัญลักษณ์ Stoic ได้</p>"
                ]
              }
            ]
          }
        }
      ]
    },
