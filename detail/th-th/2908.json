{
  "id": 2908,
  "name": "Key of Khaj-Nisut",
  "desc": "<p><span style=\"color: #FFFFFF\">หนึ่งในคู่คทาที่ทำจากออบซิเดียน ตามตำนานเล่าว่า ประตูสู่สรวงสวรรค์ที่ซ่อนอยู่ ณ จุดสิ้นสุดของทะเลทรายถูกเปิดออกโดยกุญแจดอกนี้</span></p>",
  "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/10/13/176148810/3973f7304395ef6e4f95739356af934d_5445750456263677785.png",
  "modules": [
    {
      "id": "8",
      "name": "ค่าสถานะ",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "ชื่อ",
                "string_values": [
                  "<p><span style=\"color: #FFFFFF\">Key of Khaj-Nisut</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "หาได้จาก",
                "string_values": [
                  "<p><span style=\"color: #FFFFFF\">กิจกรรมอธิษฐานอาวุธ</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "ประเภท",
                "string_values": [
                  "<p><span style=\"color: #FFFFFF\">ดาบ</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "ค่าสถานะรอง",
                "string_values": [
                  "<p><span style=\"color: #FFFFFF\">เปอร์เซ็นต์พลังชีวิต</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Sunken Song of the Sands",
                "string_values": [
                  "<p><span style=\"color: #FFFFFF\">ค่าพลังชีวิตเพิ่มขึ้น </span><span style=\"color: #80C0FF\">20%</span><span style=\"color: #FFFFFF\"> และเมื่อสกิลธาตุถูกศัตรู จะทำให้เกิดเอฟเฟกต์ Grand Hymn เป็นเวลา 20 วินาที: จะได้รับความชำนาญธาตุเพิ่ม </span><span style=\"color: #80C0FF\">0.12%</span><span style=\"color: #FFFFFF\"> ของพลังชีวิตสูงสุดของผู้ใช้ โดยที่ทุก 0.3 วินาที เอฟเฟกต์นี้จะเกิดขึ้นได้มากสุดหนึ่งครั้ง และจะซ้อนทับได้มากสุด 3 ชั้น ซึ่งเมื่อเอฟเฟกต์นี้ ซ้อนทับกันถึง 3 ชั้น หรือเมื่อช่วงเวลาต่อเนื่องของทั้ง 3 ชั้น ถูกรีเฟรช จะเพิ่มความชำนาญธาตุให้แก่ตัวละครทั้งหมดในทีม ที่อยู่ในบริเวณใกล้เคียง </span><span style=\"color: #80C0FF\">0.2%</span><span style=\"color: #FFFFFF\"> ของพลังชีวิตสูงสุดของผู้ใช้ เป็นเวลา 20 วินาที</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
