              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">โจมตีปกติ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">สร้าง</span><span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2 หน่วย และสร้าง</span><span style=\"color: rgb(255, 255, 255)\">ความเสียหายทะลวง</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2 หน่วย ให้แก่ตัวละครนอกสนามทั้งหมดของฝ่ายศัตรู</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/144837601/c369b96fc6417e8fc2bb607e37297ad4_8331871292639513887.png",
                "id": "talent5925",
