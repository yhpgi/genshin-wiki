          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "ชื่อ",
                "string_values": [
                  "<p>Grounded Geoshroom</p>"
                ]
              },
              {
                "item_values": [],
                "key": "ประเภท",
                "string_values": [
                  "<p>สัตว์อสูรลึกลับ</p>"
                ]
              },
              {
                "item_values": [],
                "key": "แนะนำการเล่น",
                "string_values": [
                  "<p>มอนสเตอร์ที่มีวิวัฒนาการมาจากสปอร์ และมีสติปัญญาอยู่ในระดับพื้นฐาน หลังจากได้รับการโจมตีด้วย<span style=\"color: #FFD780\">ธาตุไฟฟ้าหรือธาตุไฟ</span>เป็นครั้งแรก จะเข้าสู่สถานะตื่นตัวหรือไหม้เกรียม โดยขึ้นกับประเภทของธาตุที่ใช้ในการโจมตี ซึ่งเมื่อเอาชนะ Fungus ที่เปลี่ยนแปลงสถานะแล้ว บางทีอาจจะได้รับรางวัลที่แตกต่างกันออกไป...</p>"
                ]
              }
            ]
          }
        }
      ]
