                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Niwabi Fire-Dance"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: #FF9999\">ความเสียหายไฟ</span> 3 หน่วย และสร้าง Aurous Blaze</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/144837601/26b28348d7d58e4a29a39d14cf4a81a8_2366184396331773155.png",
                "id": "talent69811",
                "key": "Ryuukin Saxifrage",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ryuukin Saxifrage"
              },
              {
                "attributes": [],
                "desc": "<p>ความเสียหายไฟ</p><p>การติดสถานะ <span style=\"color: rgb(255, 153, 153)\">ธาตุไฟ</span> จะทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">ละลาย:</span> ความเสียหายนี้ +2</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">ระเหย:</span> ความเสียหายนี้ +2</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">โอเวอร์โหลด:</span> ความเสียหายนี้ +2 และตัวเป้าหมายจะถูกบังคับให้เปลี่ยนไปใช้ตัวละครถัดไป</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">ติดไฟ:</span> ความเสียหายนี้ +1 และจะทำให้เกิด [Burning Flame] ที่สร้างความเสียหายไฟ 1 หน่วย ในตอนสั้นสุดเทิร์น (ใช้ได้ 1 ครั้ง ซ้อนทับได้มากสุดถึง 2)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/144837601/d714b3b669cc08d1d8e34464fd7a3630_4447398505985338314.png",
                "id": "talent85673",
                "key": "ความเสียหายไฟ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายไฟ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">ความเสียหายกายภาพ</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span><span style=\"color: rgba(255, 255, 255, 0.65)\">จะไม่ทำให้ติดสถานะธาตุและก็ไม่ทำให้เกิดปฏิกิริยาธาตุด้วย</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Niwabi Enshou</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">สถานะ</span></p><p><span style=\"color: #FFFFFF\">การโจมตีปกติ</span>ของตัวละครที่มีการ์ดใบนี้จะสร้างความเสียหาย +1</p><p>และ<span style=\"color: #FFFFFF\">ความเสียหายกายภาพ</span>ที่สร้าง จะเปลี่ยนเป็น<span style=\"color: #FF9999\">ความเสียหายไฟ</span></p><p><span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้: 2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Aurous Blaze</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">สถานะการต่อสู้</span></p><p>หลังจากตัวละครฝ่ายเราที่ไม่ใช่ Yoimiya ใช้สกิล: สร้าง<span style=\"color: #FF9999\">ความเสียหายไฟ</span> 1 หน่วย</p><p><span style=\"color: #FFFFFF\">จำนวนเทิร์นต่อเนื่อง: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/144837601/07bae546ac7c69ef6402170b283840c5_3986401817003137920.png",
