              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>ตัวละครนี้เข้าสู่สภาวะ Niwabi Enshou (สกิลนี้ไม่ก่อให้เกิดพลังงาน)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/144837601/9fb70e06b7a56894f130c6394d8c6915_2886956777758427465.png",
                "id": "talent95520",
