    {
      "id": "48",
      "name": "ความสามารถ",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span></p><p><span style=\"color: rgb(236, 228, 217)\">สร้าง</span><strong><span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span></strong><span style=\"color: rgb(236, 228, 217)\"> 1 หน่วย</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/53372413/464df75643b85d808ea7457d333c2520_3942251294243404226.png",
                "id": "talent85717",
                "key": "Hurtling Bolts",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Hurtling Bolts"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>เรียก Electro Cicin</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Electro Cicin</span></strong><br><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง <strong><span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span></strong><span style=\"color: rgb(236, 228, 217)\"> 1 หน่วย</span></p><p><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>: 2 (ซ้อนทับได้ มากสุด 3 ครั้ง)<br><br><span style=\"color: #FFFFFF\">หลังจากฝ่ายศัตรูใช้การ์ดแอ็กชันสะสมครบ 3 ใบ</span>: การ์ดใบนี้มี<span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้</span> +1 (ซ้อนทับได้มากสุดถึง 3)</p><p>หลังจาก <span style=\"color: #FFFFFF\">Fatui - Electro Cicin Mage ได้รับความเสียหายจากปฏิกิริยาธาตุ:</span> การ์ดใบนี้จะมี<span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้ -1</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/53372413/ba8a520b631a5349ea54ca1fad2ec264_1782321203506411836.png",
                "id": "talent11417",
                "key": "Misty Call",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Misty Call"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p><span style=\"color: rgb(236, 228, 217)\">สร้าง</span><strong><span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span></strong><span style=\"color: rgb(236, 228, 217)\"> 1 หน่วย ทำให้ตัวละครนี้ติด</span><strong><span style=\"color: rgb(255, 172, 255)\">ติดสถานะธาตุไฟฟ้า</span></strong><span style=\"color: rgb(236, 228, 217)\"> สร้าง </span><span style=\"color: rgb(255, 255, 255)\">Electro Cicin Shield</span><span style=\"color: rgb(236, 228, 217)\"> และเตรียมสกิล </span><span style=\"color: rgb(255, 255, 255)\">Surging Thunder</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Electro Cicin Shield</span></strong><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">โล่ป้องกัน</span><br>มอบ<span style=\"color: rgb(255, 255, 255)\">โล่ป้องกัน</span> 1 หน่วย ให้แก่ตัวละครที่เข้าต่อสู้ของฝ่ายเรา<br><span style=\"color: rgb(255, 255, 255)\">ในขณะที่สร้าง</span>: หากในสนามของฝ่ายเรามี <span style=\"color: rgb(255, 255, 255)\">Electro Cicin</span> อยู่ด้วย จะมอบ<span style=\"color: rgb(255, 255, 255)\">โล่ป้องกัน</span>เพิ่มเติมให้ โดยมีจำนวนเท่ากับ<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>ของ Electro Cicin (มอบ<span style=\"color: rgb(255, 255, 255)\">โล่ป้องกัน</span>เพิ่มเติมสูงสุด 3 หน่วย)</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Surging Thunder</span></strong><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">ท่าไม้ตาย</span><br><span style=\"color: rgb(236, 228, 217)\">(ต้องใช้เวลาเตรียม 1 เทิร์น)</span><br><span style=\"color: rgb(236, 228, 217)\">สร้าง</span><strong><span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span></strong><span style=\"color: rgb(236, 228, 217)\"> 2 หน่วย</span><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/53372413/58e7aa03ca09a144cdac07649148383f_6798122171571499555.png",
                "id": "talent79186",
                "key": "Thundering Shield",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Thundering Shield"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สิ่งอัญเชิญ</span></p><p><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง <strong><span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span></strong><span style=\"color: rgb(236, 228, 217)\"> 1 หน่วย</span></p><p><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>: 2 (ซ้อนทับได้ มากสุด 3 ครั้ง)<br><br><span style=\"color: rgb(255, 255, 255)\">หลังจากฝ่ายศัตรูใช้การ์ดแอ็กชันสะสมครบ 3 ใบ</span>: การ์ดใบนี้มี<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span> +1 (ซ้อนทับได้มากสุดถึง 3)</p><p>หลังจาก <span style=\"color: rgb(255, 255, 255)\">Fatui - Electro Cicin Mage ได้รับความเสียหายจากปฏิกิริยาธาตุ:</span> การ์ดใบนี้จะมี<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้ -1</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/53372413/db13288db6b90ec33f8adc2656d2019f_2496471564169692555.png",
                "id": "talent99523",
                "key": "Electro Cicin",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/53372413/c32e8d1f898b13385973738aba9d5c6a_3731223121396055172.png",
                "title": "Electro Cicin"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะธาตุไฟฟ้าจะทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">โอเวอร์โหลด: </span>ความเสียหายนี้ +2 และตัวเป้าหมายจะถูกบังคับให้เปลี่ยนไปใช้ตัวละครถัดไป</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">นำไฟฟ้า:</span> ความเสียหายนี้ +1 และสร้างความเสียหายทะลวง 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">ชาร์จไฟฟ้า:</span> ความเสียหายนี้ +1 และสร้างความเสียหายทะลวง 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span>] <span style=\"color: rgb(255, 255, 255)\">ปลุกเร้า: </span>ความเสียหายนี้ +1 และทำให้เกิด [Catalyzing Field] ที่จะทำให้ความเสียหายไม้/ไฟฟ้า 3 ครั้ง ถัดไป +1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/53372413/11ea6117480145a30b7893f1e8bd7115_8724827317734864248.png",
                "id": "talent96174",
                "key": "ความเสียหายไฟฟ้า",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายไฟฟ้า"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">จำนวนครั้งที่ใช้ได้</span></strong><br>หลังการ์ดใบนี้เกิดเอฟเฟกต์ จะใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span> 1 ครั้ง;<br>และหลังจากที่<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>หมด การ์ดใบนี้จะถูกทิ้งไป</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">โล่ป้องกัน</span></strong><br>เมื่อตัวละครที่ได้รับการป้องกันจากโล่นี้ถูกโจมตี โล่ป้องกันจะถูกใช้เพื่อลบล้างความเสียหาย</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/53372413/07bae546ac7c69ef6402170b283840c5_8669055076491192410.png",
