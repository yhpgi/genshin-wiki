    {
      "id": "36",
      "name": "เกมกลเจ็ดอัจฉริยะ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การท้าทายผจญภัย : ทำให้ชินแล้วมันจะดีเอง",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "นั้นเป็นเรื่องราวการลอยขึ้นของ Jade Chamber เหล่ามอนสเตอร์นอกเมืองนั้นไม่เคยพบเห็นเรื่องประหลาดเช่นนี้มาก่อน หนึ่งในนั้นก็คือ Abyss Mage ตนหนึ่ง กับพวก Hilichurl อีกกลุ่มที่ทยอยตามกันมา",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "[กฏพิเศษ] ในตอนเริ่ม พื้นที่สนับสนุนของฝ่ายเราจะมีการ์ด \"๋Jade Chamber\" อยู่ 1 ใบ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ffe699"
                      ],
                      "text": "[ข้อแนะนำ] สร้างความเสียหายอื่นนอกเหนือจากธาตุน้ำแข็ง เพื่อทำลายโล่ของ \"Cryo Abyss Mage\" ซะ!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3365,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/35428890/ef7b92766258ced0868c745e1ff1cd6a_369121003223345553.png",
                      "menu_id": 19,
                      "name": "Anemo Samachurl",
                      "type": "custom_entry"
                    },
