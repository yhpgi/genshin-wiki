          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">การโจมตีปกติ</span></p><p>จะสร้าง<span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span> 2 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/144837601/241eba6e4c00020975cf91170050f435_1039433211315727075.png",
                "id": "talent92868",
