                      ],
                      "text": "ตัวอย่างตัวละคร - \"Abyss Lector - Fathomless Flames: สมบัติในหน้ากระดาษ\"",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
