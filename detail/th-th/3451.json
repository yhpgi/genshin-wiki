      "name": "รายละเอียด",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "ความสัมพันธ์ตัวละคร",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Yanagibashi Takuto",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "ซามูไรมนุษย์คนหนึ่ง เป็นเพื่อนกับโยไก Kamai และ Chizuru ได้พบเมื่อตอนที่เธอยังไม่ได้รับพลังของโยไก",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Kamai Kenji",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "โยไกและเพื่อนของซามูไรมนุษย์ พลังของเขาปลุกจิตสำนึกจากฮาโกอิตะที่ Kamai และซามูไรใช้เล่น Akitsu Hazura",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Yae Miko_icon.png",
                      "name": "Яэ Мико",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "จิ้งจอก ผู้ได้เห็นการเกิดจิตสำนึกของ Chizuru ภายในฮาโกอิตะคู่หนึ่ง เธอทำให้ Chizuru ได้รับรู้ถึงคุณค่าของมิตรภาพระหว่างมนุษย์กับโยไก",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2263,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Shikanoin Heizou_icon.png",
                      "name": "Shikanoin Heizou",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "นักสืบผู้คาดเดาตัวจริงของ Hanyuuda Chizuru ได้อย่างถูกต้อง",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3450,
                      "icon_url": "",
                      "name": "Каппа",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3449,
                      "icon_url": "",
                      "name": "Ёко",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3448,
