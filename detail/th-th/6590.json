                      "display_style": "card",
                      "ep_id": 6590,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/144837601/27ae9488713507608da8d4325ead1777_2346841116814247960.png",
