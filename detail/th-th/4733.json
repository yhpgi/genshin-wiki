                ],
                "talent_img": "",
                "title": "Abductive Reasoning"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">สร้าง</span><span style=\"color: rgb(153, 255, 136)\">ความเสียหายไม้</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">2 หน่วย และตัวละครนี้จะได้รับ</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">Chisel-Light Mirror</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Chisel-Light Mirror</span></strong><br><span style=\"color: rgb(236, 229, 216)\">ความเสียหายกายภาพ</span><span style=\"color: rgba(255, 255, 255, 0.65)\">ที่ตัวละครสร้างขึ้นจะเปลี่ยนเป็น</span><span style=\"color: rgb(153, 255, 136)\">ความเสียหายไม้</span><br><span style=\"color: rgb(255, 255, 255)\">หลังจากที่ฝ่ายเราใช้การโจมตีปกติ:</span><strong><span style=\"color: rgb(255, 255, 255)\"> </span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">จะสร้าง</span><span style=\"color: rgb(153, 255, 136)\">ความเสียหายไม้</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">1 หน่วย หากสกิลนี้เป็น</span><span style=\"color: rgb(255, 255, 255)\">ชาร์จโจมตี</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">จะทำให้สถานะนี้มี</span><span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+1</span><br><span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: 2 (สามารถซ้อนทับได้มากสุด 3 เทิร์น)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/115795437/8491b6dd997a8a4878767f1191a2b6aa_6651188867807984333.png",
                "id": "talent62271",
