              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">สร้าง</span><span style=\"color: #ECE5D8\">ความเสียหายกายภาพ</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2 หน่วย</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/115795437/94aa30ae75b8c7c6a9c64ab05bd5dda7_8063726608540662761.png",
