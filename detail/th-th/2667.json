                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 26,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Bennett_icon.png",
                      "menu_id": 2,
                      "name": "Bennett",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "อาวุธนี้มีสถานะพื้นฐานสูงในฐานะอาวุธ 4 ดาว ทำให้เหมาะสำหรับท่าไม้ตายของ Bennett ซึ่งเพิ่มค่า",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "พลังโจมตี",
                      "type": "text"
                    },
                    {
                      "text": "จาก",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ece5d8"
                      ],
                      "text": "ค่าพลังโจมตีพื้นฐาน",
                      "type": "text"
                    },
                    {
                      "text": "ของตัว Bennett และอาวุธ นอกจากนี้ ค่า",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "ฟื้นฟูพลังงาน",
                      "type": "text"
                    },
                    {
                      "text": "จากค่าสถานะรองของอาวุธยังช่วยแบ่งเบาภาระในการหาค่าสถานะ",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "การฟื้นฟูพลังงาน",
                      "type": "text"
                    },
                    {
                      "text": "จากจากอาร์ติแฟกต์อีกด้วย",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2674,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/23/169177528/04f769b0b1671b5ffbbafefd7286b4b2_5011166561144979392.png",
                      "menu_id": 2,
                      "name": "นักเดินทาง (ไม้)",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เนื่องจากนักเดินทางธาตุไม้สามารถใช้เอฟเฟกต์เฉพาะของอาวุธชิ้นนี้ซึ่งเน้นไปที่การทำ",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ff88"
                      ],
                      "text": "ปฏิกิริยาธาตุไม้",
                      "type": "text"
                    },
                    {
                      "text": "ได้ง่าย และค่าสถานะรองจากอาวุธนี้ช่วยลดภาระในการหาค่า",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "การฟื้นฟูพลังงาน",
                      "type": "text"
                    },
                    {
                      "text": "จากอาร์ติแฟกต์ Sapwood Blade จึงเป็นหนึ่งในตัวเลือกที่ดีสำหรับนักเดินทางธาตุไม้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
