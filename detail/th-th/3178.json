      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span></p><p>จะสร้าง<span style=\"color: #80C0FF\">ความเสียหายน้ำ</span> 1 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/144837601/1ce09211f025bf5470682189e0837732_1160738134655679239.png",
                "id": "talent9193",
