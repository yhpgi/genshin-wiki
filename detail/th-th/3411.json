      "name": "เกมกลเจ็ดอัจฉริยะ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอล : การโจรกรรมกลางผืนทราย",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "บางครั้งในตอนที่พวกเราขนส่งเสบียง ก็เคยเจอการขัดขวางโดยพวก Fatui บ้างเหมือนกัน แต่ฉันไมคิดว่าพวกเราจะขาดแคลนเสบียงหรอกนะ มันน่าจะเพื่อจุดประสงค์อื่นมากกว่า...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "[กฏพิเศษ] ในแต่ละครั้งที่เริ่มแอ็กชันเฟส: ตัวละครทั้งหมดของฝ่ายเราจะได้รับพลังงาน 1 หน่วย",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมเริ่มต้น :",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3356,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/144837601/af1f601c2a484de17df8d520264e640f_6058844202372511698.png",
                      "menu_id": 19,
