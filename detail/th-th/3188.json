                      ],
                      "text": "รางวัล",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "ได้รับชัยชนะ",
                      "type": "text"
