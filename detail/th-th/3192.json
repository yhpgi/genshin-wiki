                ],
                "talent_img": "",
                "title": "Favonius Bladework"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>สร้าง<span style=\"color: #80FFD7\">ความเสียหายลม</span> 3 หน่วย และบังคับฝ่ายตรงข้าม ให้สลับไปใช้ตัวละครถัดไป</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/f21a21302c39df14caac1bbc0a6bef40_3645697665550728782.png",
                "id": "talent72025",
