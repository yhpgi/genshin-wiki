                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Gale Blade"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>รักษาตัวละครทั้งหมดของฝ่ายเรา 2 หน่วย และเรียก <span style=\"color: #FFFFFF\">Dandelion Field</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/06d120531fd7d61a928bac235bbaeed2_5385064795630752974.png",
                "id": "talent83279",
                "key": "Dandelion Breeze",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Dandelion Breeze"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">Dandelion Field</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">สิ่งอัญเชิญ</span></p><p><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(128, 255, 215)\">ความเสียหายลม</span> 2 หน่วย และรักษาตัวละครที่เข้าต่อสู้ของฝ่ายเรา 1 หน่วย</p><p><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/db13288db6b90ec33f8adc2656d2019f_8918809608210666766.png",
                "id": "talent64641",
                "key": "Dandelion Field",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/9138f4f0e38e85d3c4e035bdf2025636_4268447652120204140.png",
                "title": "Dandelion Field"
              },
              {
                "attributes": [],
                "desc": "<p>จะเกิดปฏิกิริยาธาตุกับสถานะธาตุที่ติดอยู่ก่อน:<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">กระจาย (น้ำแข็ง): </span>สร้างความเสียหายน้ำแข็ง 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">กระจาย (น้ำ): </span>สร้างความเสียหายน้ำ 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">กระจาย (น้ำไฟ): </span>สร้างความเสียหายน้ำไฟ 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">กระจาย (น้ำไฟฟ้า): </span>สร้างความเสียหายไฟฟ้า 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/c97292d96456bfe4abeca16bfce801e4_5146530588932252067.png",
                "id": "talent30129",
                "key": "ความเสียหายลม",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายลม"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">ความเสียหายกายภาพ</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span><span style=\"color: rgba(255, 255, 255, 0.65)\">จะไม่ทำให้ติดสถานะธาตุและก็ไม่ทำให้เกิดปฏิกิริยาธาตุด้วย</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">จำนวนเทิร์นต่อเนื่อง</span></strong></p><p>ในตอนจบเฟสของแต่ละเทิร์น<span style=\"color: rgb(255, 255, 255)\"> จำนวนเทิร์นต่อเนื่อง</span>จะ -1; หลังจากที่ใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span>จนหมดการ์ดใบนี้จะถูกทิ้งไป</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/07bae546ac7c69ef6402170b283840c5_4027406276488162930.png",
