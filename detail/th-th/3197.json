    {
      "id": "50",
      "name": "การดูเอลในร้านเหล้า ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอลฉันมิตร",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"เมี๊ยว...\" \"เมื่อนานมาแล้ว มันเป็นเรื่องเล่าจากแมวตัวหนึ่งที่หลบอยู่ในเรือของ Inazuma... เห็นบอกว่าที่ Inazuma มีจักรกลปีศาจที่ใช้ดาบอยู่...\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ece5d8"
                      ],
                      "text": "[กฎพิเศษ] \"Maguu Kenki\" จะต้านทานต่อการแช่แข็ง, การมึนงง และการกลายเป็นหิน โดยในตอนเริ่มจะติดตั้งการ์ดพรสวรรค์ \"Transcendent Automaton\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมของคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3353,
                      "icon_url": "",
                      "menu_id": 19,
                      "name": "Nobushi: Hitsukeban",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3197,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/144837601/2947e673f7bd07277456232818fd5a6d_4752260377715648164.png",
                      "menu_id": 17,
                      "name": "Maguu Kenki",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3353,
                      "icon_url": "",
                      "menu_id": 19,
                      "name": "Nobushi: Hitsukeban",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ปลดล็อกหลัง:",
                      "type": "text"
                    }
