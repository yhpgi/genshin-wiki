              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span><br>สร้าง<span style=\"color: rgba(255, 255, 255, 0.85)\">ความเสียหายกายภาพ</span> 2 หน่วย</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/31/115795437/241eba6e4c00020975cf91170050f435_8771611736086988036.png",
