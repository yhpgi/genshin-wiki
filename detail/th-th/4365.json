          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">โจมตีปกติ </span></p><p>จะสร้าง<span style=\"color: rgb(128, 255, 215)\">ความเสียหายลม</span> 1 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/26/144837601/1ce09211f025bf5470682189e0837732_8711239072370244039.png",
                "id": "talent67177",
                "key": "Yuuban Meigen ",
