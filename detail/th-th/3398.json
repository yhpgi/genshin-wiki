    {
      "id": "36",
      "name": "เกมกลเจ็ดอัจฉริยะ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การท้าทายผจญภัย : บันทึกการเดินทางรอบนครหิน",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "พวกคุณหยุดพักที่ Wangshu Inn เพราะฝนตกแต่ในตอนดึก กลับได้ยินเสียงใครบางคนมาทำ ลับๆ ล่อๆ หลังจากมองดูดีๆ ปรากฏว่ามี Fatui จำนวนหนึ่งกำลังซุ่มดูอยู่...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "[กฏพิเศษ] ในตอนเริ่ม พื้นที่สนับสนุนของฝ่ายเราจะมีการ์ด \"๋Liu Su\" อยู่ 1 ใบ; เมื่อแอ็กชันเฟสเริ่มต้น จะทำให้ตัวละครที่เข้าต่อสู้ของทั้งสองฝ่ายติดสถานะธาตุน้ำ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3196,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/348541b315d22c004cf91a87f4f5523e_7376820683137585254.png",
                      "menu_id": 17,
                      "name": "Fatui Pyro Agent",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3356,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/35428890/af1f601c2a484de17df8d520264e640f_1756025593903565099.png",
                      "menu_id": 19,
                      "name": "Fatui Skirmisher - Anemoboxer Vanguard",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
