    {
      "id": "36",
      "name": "เกมกลเจ็ดอัจฉริยะ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอล : ฟันเฟืองแห่งโชคชะตา",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "มันแย่เหมือนกับผลการทำนายที่ได้จากการแปรธาตุพยากรณ์เลย แม้ว่าสิ่งที่คุณทำ จะเป็นเพียงแค่การเก็บสิ่งต่างๆ ในป่าทั่วไป แต่กลับต้องไปเจอกับ Abyss Mage กลุ่มหนึ่งเข้า...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "[กฏพิเศษ] การต่อสู้กับ \"Abyss Mage\" หลายชนิดในคราวเดียว บางทีปฏิกิริยา \"กระจาย\" อาจทำให้เกิดเอฟเฟกต์ที่คาดไม่ถึงก็ได้นะ...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "ทีมคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3360,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/144837601/43d362bc5860c73bc0a10fc6e6f8f46d_8792592415688428673.png",
