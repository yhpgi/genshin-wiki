    {
      "id": "48",
      "name": "ความสามารถ",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">โจมตีปกติ</span></p><p><span style=\"color: rgb(236, 228, 217)\">สร้าง</span><strong><span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span></strong><span style=\"color: rgb(236, 228, 217)\">&nbsp;2 หน่วย</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/04/144837601/241eba6e4c00020975cf91170050f435_7418438912840999021.png",
                "id": "talent95630",
                "key": "Gleaming Spear - Guardian Stance",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Gleaming Spear - Guardian Stance"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p><span style=\"color: rgb(236, 228, 217)\">ตัวละครนี้จะได้รับ&nbsp;</span><strong><span style=\"color: rgb(255, 255, 255)\">Heron Shield</span></strong><span style=\"color: rgb(236, 228, 217)\">&nbsp;และการ</span><strong><span style=\"color: rgb(255, 255, 255)\">เตรียมสกิล</span></strong><span style=\"color: rgb(236, 228, 217)\">:&nbsp;</span><strong><span style=\"color: rgb(255, 255, 255)\">Heron Strike</span></strong></p><p></p><p><strong><span style=\"color: #ECE5D8\">Heron Shield</span></strong><br><span style=\"color: rgb(255, 215, 128)\">โล่ป้องกัน</span><br>แอ็กชันต่อไปของตัวละครนี้ จะใช้สกิลนี้โดยทันที:&nbsp;<strong><span style=\"color: rgb(255, 255, 255)\">Heron Strike</span></strong><br>ระหว่างเตรียมสกิล: มอบ<strong><span style=\"color: rgb(255, 255, 255)\">โล่ป้องกัน</span></strong>&nbsp;2 หน่วย เพื่อปกป้องตัวละครที่มีการ์ดใบนี้<br></p><p><strong><span style=\"color: #ECE5D8\">Heron Strike</span></strong><br><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span><br>(ต้องใช้เวลาเตรียม 1 เทิร์น)<br>สร้าง<strong><span style=\"color: rgb(128, 192, 255)\">ความเสียหายน้ำ</span></strong>&nbsp;3 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/04/144837601/a5b6de0eb1a96b975ff0680617f6b78c_3826028340665929745.png",
                "id": "talent65869",
                "key": "Sacred Rite: Heron's Sanctum",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sacred Rite: Heron's Sanctum"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p><span style=\"color: rgb(236, 228, 217)\">สร้าง</span><strong><span style=\"color: rgb(128, 192, 255)\">ความเสียหายน้ำ</span></strong><span style=\"color: rgb(236, 228, 217)\">&nbsp;2 หน่วย และสร้าง&nbsp;</span><strong><span style=\"color: rgb(255, 255, 255)\">Prayer of the Crimson Crown</span></strong></p><p></p><p><strong><span style=\"color: #ECE5D8\">Prayer of the Crimson Crown</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">การโจมตีปกติ</span></strong><span style=\"color: rgb(236, 228, 217)\">ของตัวละครฝ่ายเรา สร้างความเสียหาย +1</span><br><strong><span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span></strong><span style=\"color: rgb(236, 228, 217)\">ที่เกิดจากตัวละครที่ใช้อาวุธดาบ ดาบใหญ่ หรือหอกของฝ่ายเรา จะเปลี่ยนเป็น</span><strong><span style=\"color: rgb(128, 192, 255)\">ความเสียหายน้ำ</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">หลังจากที่ฝ่ายเราเปลี่ยนตัวละคร:</span></strong><span style=\"color: rgb(236, 228, 217)\">&nbsp;สร้าง</span><strong><span style=\"color: rgb(128, 192, 255)\">ความเสียหายน้ำ</span></strong><span style=\"color: rgb(236, 228, 217)\">&nbsp;1 หน่วย (เทิร์นละ 1 ครั้ง)</span><br><br><strong><span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span></strong>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/04/144837601/167888d3c5143ad97a97db7dda53ce5d_4206762769720088245.png",
                "id": "talent56116",
                "key": "Sacred Rite: Wagtail's Tide",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Sacred Rite: Wagtail's Tide"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะ ธาตุน้ำ จะทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] ระเหย:</span> ความเสียหายนี้ +2</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">] ชาร์จไฟฟ้า:</span> ความเสียหายนี้ +1 และสร้างความเสียหายทะลวง 1 หน่วย ให้แก่ตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] แช่แข็ง: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">ความเสียหายนี้ +1 และก็ทำให้เป้าหมายไม่สามารถดำเนินการต่าง ๆ ได้ในเทิร์นนี้ (จะหายไปหลังจากที่ได้รับความเสียหายกายภาพหรือความเสียหายไฟ แต่ความเสียหายที่ได้รับ จะ +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] งอกเงย: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">ความเสียหายนี้ +1 และทำให้เกิด </span><span style=\"color: rgb(255, 255, 255)\">[Dendro Core]</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> ที่ทำให้ ความเสียหายไฟ/ไฟฟ้า ครั้งต่อไป +2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/04/144837601/a126c6a302d81c07e19cf9a9f1260f90_7758157821673543244.png",
                "id": "talent98051",
                "key": "ความเสียหายน้ำ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายน้ำ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span></strong><br>ความเสียหายกายภาพ จะไม่ทำให้ติดสถานะธาตุ และก็ไม่ทำให้เกิดปฏิกิริยาธาตุด้วย<br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">โล่ป้องกัน</span></strong><br>เมื่อตัวละครที่ได้รับการป้องกันจากโล่นี้ถูกโจมตี โล่ป้องกันจะถูกใช้เพื่อลบล้างความเสียหาย<br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">เตรียมสกิล</span></strong><br>สกิลบางส่วนไม่สามารถใช้งานโดยตรงได้ ต้องใช้รอบดำเนินการจำนวนหนึ่ง เพื่อทำการ<strong><span style=\"color: rgb(255, 255, 255)\">เตรียมสกิล</span></strong><br>เมื่อมาถึงตาดำเนินการของผู้เล่นฝ่ายใดฝ่ายหนึ่ง หาก \"ตัวละครที่เข้าต่อสู้\" ของผู้เล่นคนนั้น ๆ กำลัง<strong><span style=\"color: rgb(255, 255, 255)\">เตรียม</span></strong>สกิล จะเป็นการข้ามการดำเนินการของผู้เล่นคนนั้น; หากสกิล<strong><span style=\"color: rgb(255, 255, 255)\">เตรียม</span></strong>เสร็จแล้ว ตัวละครจะทำการใช้งานสกิลในทันที (สกิลประเภทที่ต้อง<strong><span style=\"color: rgb(255, 255, 255)\">เตรียม</span></strong>ก่อน จะไม่ทำให้เกิดเอฟเฟกต์ \"หลังจากใช้งานสกิล\")<br>มีแค่ \"ตัวละครที่เข้าต่อสู้\" เท่านั้นที่จะ<strong><span style=\"color: rgb(255, 255, 255)\">เตรียม</span></strong>สกิลได้; หาก \"ตัวละครที่เข้าต่อสู้\" ที่กำลัง<strong><span style=\"color: rgb(255, 255, 255)\">เตรียม</span></strong>สกิล ถูกสลับไปเป็นตัวละครนอกสนาม การ<strong><span style=\"color: rgb(255, 255, 255)\">เตรียม</span></strong>สกิลจะถูกขัดจังหวะ<br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span></strong><br>ในตอนจบเฟสของแต่ละเทิร์น&nbsp;<strong><span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span></strong>จะ -1;<br>หลังจากที่ใช้<strong><span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span></strong>จนหมด การ์ดใบนี้จะถูกทิ้งไป</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/04/144837601/07bae546ac7c69ef6402170b283840c5_6626914821087281000.png",
                "id": "talent76910",
                "key": "รายละเอียดกติกา",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "รายละเอียดกติกา"
              }
            ]
          }
        }
      ]
    },
