                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ปลดล็อกหลัง:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "สำเร็จเป้าหมายการท้าทาย Yaoyao - เป็นมิตร 3 อัน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "เป้าหมายการท้าทาย",
                      "type": "text"
                    }
