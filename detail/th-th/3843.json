                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ominous Star "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">สกิลติดตัว</span></p><p>[ติดตัว] เมื่อเริ่มการต่อสู้ ในตอนแรกเริ่มจะได้รับสถานะ <span style=\"color: rgb(255, 255, 255)\">Fiery Rebirth</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Fiery Rebirth</span></strong><br><span style=\"color: rgb(255, 255, 255)\">เมื่อตัวละครที่มีการ์ดใบนี้ถูกเอาชนะ:</span> ลบล้างเอฟเฟกต์นี้ ทำให้ตัวละคร<span style=\"color: rgb(255, 255, 255)\">หลีกเลี่ยงการพ่ายแพ้</span> และรักษาค่าพลังชีวิตของตัวละครดังกล่าวถึง 3 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/144837601/241466b9ccdefb6219ef6bf74cd493e2_6227390770474457853.png",
                "id": "talent98100",
                "key": "Fiery Rebirth ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Fiery Rebirth "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">สิ่งอัญเชิญ</span></p><p><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(255, 153, 153)\">ความเสียหายไฟ</span> 1 หน่วย และสร้าง<span style=\"color: rgb(255, 255, 255)\">ความเสียหายทะลวง</span> 1 หน่วย แก่ตัวละครนอกสนามทั้งหมดของฝ่ายศัตรู<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/144837601/db13288db6b90ec33f8adc2656d2019f_8963220660451104610.png",
                "id": "talent3782",
                "key": "Darkfire Furnace",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/144837601/2cce1877020bad6ed9476a8bb8db436c_2603626149943533646.png",
                "title": "Darkfire Furnace"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะ <span style=\"color: rgb(255, 153, 153)\">ธาตุไฟ</span> จะทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">ละลาย:</span> ความเสียหายนี้ +2</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">ระเหย:</span> ความเสียหายนี้ +2</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">โอเวอร์โหลด:</span> ความเสียหายนี้ +2 และตัวเป้าหมายจะถูกบังคับให้เปลี่ยนไปใช้ตัวละครถัดไป</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">ติดไฟ:</span> ความเสียหายนี้ +1 และจะทำให้เกิด [Burning Flame] ที่สร้างความเสียหายไฟ 1 หน่วย ในตอนสั้นสุดเทิร์น (ใช้ได้ 1 ครั้ง ซ้อนทับได้มากสุดถึง 2)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/144837601/d714b3b669cc08d1d8e34464fd7a3630_5355888770437336937.png",
                "id": "talent65822",
                "key": "ความเสียหายไฟ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายไฟ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">ความเสียหายทะลวง</span></strong><br>ความเสียหายทะลวงไม่สามารถรับโบนัสความเสียหายได้ แต่ก็จะไม่สามารถลบล้างด้วยเอฟเฟกต์อื่น ๆ อย่างเช่น โล่ป้องกัน, การต้านทานความเสียหาย ฯลฯ<br></p><p><strong><span style=\"color: #ECE5D8\">จำนวนครั้งที่ใช้ได้</span></strong><br>หลังการ์ดใบนี้เกิดเอฟเฟกต์ จะใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span> 1 ครั้ง;<br>และหลังจากที่<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>หมด การ์ดใบนี้จะถูกทิ้งไป<br></p><p><strong><span style=\"color: #ECE5D8\">หลีกเลี่ยงการพ่ายแพ้</span></strong><br>เมื่อค่าพลังชีวิตของตัวละครลดลงเหลือ 0 เอฟเฟกต์บางอย่างจะทำให้ตัวละคร<span style=\"color: rgb(255, 255, 255)\">หลีกเลี่ยงการพ่ายแพ้</span> และรักษาค่าพลังชีวิตของตัวละครดังกล่าวถึงจำนวนหนึ่ง<br>ซึ่งในช่วงเวลานี้ ตัวละครจะไม่ถือว่า<span style=\"color: rgb(255, 255, 255)\">พ่ายแพ้</span> (ดังนั้น อุปกรณ์และสถานะที่ติดตั้งอยู่กับตัวละครจะไม่ถูกถอดออก และจะไม่ล้างพลังงาน)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/144837601/07bae546ac7c69ef6402170b283840c5_6763666631410412094.png",
