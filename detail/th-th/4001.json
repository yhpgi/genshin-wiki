      "name": "ตัวละครที่แนะนำ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "ตัวละคร",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "หมายเหตุ",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2813,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/21/176148810/e09e2bda5e022611fad0dea1bb6518bb_4530553851238597882.png",
                      "menu_id": 2,
                      "name": "Cyno",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เนื่องจาก Cyno เป็นตัวละครที่สามารถเล่นในทีมเน้นการทำปฏิกิริยาธาตุได้ดี และความเสียหายโดยรวมของ Cyno ยังคำนวณร่วมกับ",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "ค่าความชำนาญธาตุ",
                      "type": "text"
                    },
                    {
                      "text": "จึงทำให้สามารถใช้เอฟเฟต์เฉพาะของอาวุธชิ้นนี้ได้เป็นอย่างดี แต่อย่างไรก็ตาม จำเป็นต้องใช้ตัวละครธาตุอื่นให้ครบสามธาตุตามเงื่อนไขของอาวุธชิ้นนี้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 49,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Raiden Shogun_icon.png",
                      "menu_id": 2,
                      "name": "Raiden Shogun",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
