{
  "id": 3692,
  "name": "Jadefall's Splendor",
  "desc": "<p>ภาชนะสำหรับประกอบพิธีกรรมซึ่งแกะสลักขึ้นจากหยกชิ้นงาม ส่งประกายแสงระยิบระยับของท้องฟ้า และผื้นน้ำอันใสสะอาด</p>",
  "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/20/53372413/52a0070af901b0305bd2182d2e77377c_8544435025887864013.png",
  "modules": [
    {
      "id": "8",
      "name": "ค่าสถานะ",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "ชื่อ",
                "string_values": [
                  "<p><br>Jadefall's Splendor</p>"
                ]
              },
              {
                "item_values": [],
                "key": "หาได้จาก",
                "string_values": [
                  "<p>กิจกรรมอธิษฐานอาวุธ</p>"
                ]
              },
              {
                "item_values": [],
                "key": "ประเภท",
                "string_values": [
                  "<p>สื่อเวทย์</p>"
                ]
              },
              {
                "item_values": [],
                "key": "ค่าสถานะรอง",
                "string_values": [
                  "<p>เปอร์เซ็นต์พลังชีวิต</p>"
                ]
              },
              {
                "item_values": [],
                "key": "Primordial Jade Regalia",
                "string_values": [
                  "<p><span>ภายใน 3 วินาที หลังจากปล่อยท่าไม้ตาย หรือสร้างโล่ขึ้นมา จะเกิดเอฟเฟกต์ \"Primordial Jade Regalia\": ในทุก 2.5 วินาที จะฟื้นฟูพลังงานธาตุ 4.5 หน่วย และทุก 1,000 หน่วย ของค่าพลังชีวิตสูงสุดของผู้ใช้อาวุธนี้ จะทำให้โบนัสความเสียหายธาตุ ตามประเภทธาตุที่เกี่ยวข้องเพิ่มขึ้น 0.3% โดยจะเพิ่มขึ้นได้มากสุดถึง 12% และเมื่อตัวละครที่ใช้อาวุธนี้อยู่ในทีม แต่ไม่ได้เข้าร่วมการต่อสู้ เอฟเฟกต์ \"Primordial Jade Regalia\" จะยังคงเกิดขึ้นได้</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
