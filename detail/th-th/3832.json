                      ],
                      "text": "เป้าหมายการท้าทาย",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "รางวัล",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ได้รับชัยชนะ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3832,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/9d4755dfcf7b10e16ef5cd965065bd8f_606019191448656509.png",
                      "menu_id": 17,
                      "name": "Shenhe",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ได้รับชัยชนะภายใน 6 เทิร์น",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3845,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/ad04ba6a225a192690bc641f3bfa7f9a_4224542954594453187.png",
                      "menu_id": 18,
                      "name": "Mystical Abandon",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ชนะโดยจำนวนตัวละครที่ถูกกำจัดต่ำกว่า 2 ตัว",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3845,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/ad04ba6a225a192690bc641f3bfa7f9a_4224542954594453187.png",
                      "menu_id": 18,
                      "name": "Mystical Abandon",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การต่อสู้อย่างจริงจัง",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"อืม เป็นการละเล่นที่ไม่เลวเลย ช่วยให้จิตใจผ่อนคลายลงได้จริง ๆ จากนี้ฉันจะแสดงทักษะที่เรียนมาก่อนหน้าทั้งหมดล่ะนะ โปรดชี้แนะด้วย\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "[กฎพิเศษ] ในตอนเริ่ม \"Shenhe\" จะติดตั้งการ์ดพรสวรรค์ \"Mystical Abandon\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมของคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3832,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/9d4755dfcf7b10e16ef5cd965065bd8f_606019191448656509.png",
