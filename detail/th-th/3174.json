              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span></p><p>จะสร้าง<span style=\"color: #FFFFFF\">ความเสียหายกายภาพ</span> 2 หน่วย</p>",
