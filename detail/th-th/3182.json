              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: #FF9999\">ความเสียหายไฟ</span> 2 หน่วย และสร้าง Pyronado</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/144837601/f10ee07430ab7e5e55a9263695844987_6761262568265883804.png",
                "id": "talent69345",
