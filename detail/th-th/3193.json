                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Wind Spirit Creation"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>สร้าง<span style=\"color: #80FFD7\">ความเสียหายลม</span> 3 หน่วย และบังคับฝ่ายตรงข้าม ให้สลับไปใช้ตัวละครก่อนหน้า</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/dceff798de3e5575ac1c3dad5718d18e_2543536872876952836.png",
                "id": "talent6968",
                "key": "Astable Anemohypostasis Creation - 6308",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Astable Anemohypostasis Creation - 6308"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: #80FFD7\">ความเสียหายลม</span> 1 หน่วย และเรียก Large Wind Spirit</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/28de70f699de4ba7cf0f77f2fcfb1483_6902957933117456033.png",
                "id": "talent29253",
                "key": "Forbidden Creation - Isomer 75 / Type II",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Forbidden Creation - Isomer 75 / Type II"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Large Wind Spirit</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">สิ่งอัญเชิญ</span></p><p><span style=\"color: #FFFFFF\">จบเฟส: </span>สร้าง<span style=\"color: #80FFD7\">ความเสียหายลม</span> 2 หน่วย</p><p><span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้: 3</span></p><p></p><p>หลังจากที่ตัวละครฝ่ายเรา หรือสิ่งอัญเชิญ ทำให้เกิดปฏิกิริยากระจาย: จะเกิดการเปลี่ยนประเภทธาตุของการ์ดใบนี้ และจะสร้างความเสียหายของประเภทธาตุที่กระจายแทน (จำกัดหนึ่งครั้งก่อนออกสนาม)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/db13288db6b90ec33f8adc2656d2019f_5128620339245937043.png",
                "id": "talent2359",
                "key": "Large Wind Spirit\n",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/b91de96bc6f45b8b9a5b10ab4a127a88_5928728849114292423.png",
                "title": "Large Wind Spirit\n"
              },
              {
                "attributes": [],
                "desc": "<p>จะเกิดปฏิกิริยาธาตุกับสถานะธาตุที่ติดอยู่ก่อน:<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: #FFFFFF\">กระจาย (น้ำแข็ง): </span>สร้างความเสียหายน้ำแข็ง 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">กระจาย (น้ำ): </span>สร้างความเสียหายน้ำ 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">กระจาย (น้ำไฟ): </span>สร้างความเสียหายน้ำไฟ 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">กระจาย (น้ำไฟฟ้า): </span>สร้างความเสียหายไฟฟ้า 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/c97292d96456bfe4abeca16bfce801e4_8766286271473106243.png",
                "id": "talent60493",
                "key": "ความเสียหายลม",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายลม"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">จำนวนเทิร์นต่อเนื่อง</span></strong></p><p>ในตอนจบเฟสของแต่ละเทิร์น<span style=\"color: rgb(255, 255, 255)\"> จำนวนเทิร์นต่อเนื่อง</span>จะ -1; หลังจากที่ใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span>จนหมดการ์ดใบนี้จะถูกทิ้งไป</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/07bae546ac7c69ef6402170b283840c5_6372254044738407314.png",
