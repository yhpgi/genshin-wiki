                      "text": "ชนะโดยจำนวนตัวละครที่ถูกกำจัดต่ำกว่า 2 ตัว",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3458,
                      "icon_url": "",
                      "menu_id": 18,
                      "name": "Pounding Surprise",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การต่อสู้อย่างจริงจัง",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Klee น่ะเก่งมากเลยนะ!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "[กฎพิเศษ] ในตอนเริ่ม \"Klee\" จะติดตั้งการ์ดพรสวรรค์ \"Pounding Surprise\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมของคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
