                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span></p><p>สร้าง<span style=\"color: #FF9999\">ความเสียหายไฟ</span> 1 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/144837601/1ce09211f025bf5470682189e0837732_2308115836003693335.png",
