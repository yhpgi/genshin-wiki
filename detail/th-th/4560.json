                      "icon_url": "",
                      "menu_id": 18,
                      "name": "Discretionary Supplement",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การต่อสู้อย่างจริงจัง",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"ฮิฮิ โชคและความเฉียบแหลมทางธุรกิจของคุณนี่ไม่เลวเลยนะ! เห็นทีนายท่าน Sangemah Bay อย่างฉันคงต้องหยิบสมบัติที่ซ่อนอยู่ใต้ก้นกล่องออกมาแล้วล่ะ!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "[กฎพิเศษ] ในตอนเริ่ม \"Dori\" จะติดตั้งการ์ดพรสวรรค์ \"Discretionary Supplement\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมของคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4560,
                      "icon_url": "",
                      "menu_id": 17,
