                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Alcazarzaray's Exactitude"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFFFFF\">จบเฟส</span>: สร้าง<span style=\"color: #FFACFF\">ความเสียหายไฟฟ้า</span> 1 หน่วย </p><p><span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้</span>: 1</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/10257458/db13288db6b90ec33f8adc2656d2019f_4776294933335313015.png",
                "id": "talent12540",
                "key": "After-Sales Service",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/10257458/4dc11b7dc5d87f85d5124e37b423a947_3652336300060329282.png",
                "title": "After-Sales Service"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFFFFF\">จบเฟส</span>: ทำการรักษาตัวละครที่เข้าต่อสู้ของฝ่ายเรา 2 หน่วย และได้รับพลังงาน 1 หน่วย </p><p><span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้</span>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/10257458/db13288db6b90ec33f8adc2656d2019f_1549729020896790761.png",
                "id": "talent45539",
                "key": "Jinni",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/10257458/67b7fdfa996e64de9630aa9be8af9b7b_1539047940990759570.png",
                "title": "Jinni"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะธาตุไฟฟ้า จะทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">โอเวอร์โหลด</span>: ความเสียหายนี้ +2 และตัวเป้าหมายจะถูกบังคับให้เปลี่ยนไปใช้ตัวละครถัดไป</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">นำไฟฟ้า</span>: ความเสียหายนี้ +1 และสร้างความเสียหายทะลวง 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">ชาร์จไฟฟ้า</span>: ความเสียหายนี้ +1 และสร้างความเสียหายทะลวง 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span>] <span style=\"color: rgb(255, 255, 255)\">ปลุกเร้า</span>: ความเสียหายนี้ +1 และทำให้เกิด [Catalyzing Field] ที่จะทำให้ ความเสียหายไม้ หรือความเสียหายไฟฟ้า 2 ครั้ง ถัดไป +1</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/10257458/11ea6117480145a30b7893f1e8bd7115_7498747329270117243.png",
                "id": "talent11048",
                "key": "ความเสียหายไฟฟ้า",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายไฟฟ้า"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">ความเสียหายกายภาพ </span></strong></p><p>ความเสียหายกายภาพ จะไม่ทำให้ติดสถานะธาตุ และก็ไม่ทำให้เกิดปฏิกิริยาธาตุด้วย</p><p></p><p><strong><span style=\"color: #ECE5D8\">จำนวนครั้งที่ใช้ได้ </span></strong></p><p>หลังการ์ดใบนี้เกิดเอฟเฟกต์ จะใช้<span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้</span> 1 ครั้ง</p><p>และหลังจากที่<span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้</span>หมด การ์ดใบนี้จะถูกทิ้งไป</p><p></p><p><strong><span style=\"color: #ECE5D8\">พลังงาน </span></strong></p><p>เมื่อตัวละครใช้ \"ท่าไม้ตาย\" จะต้องใช้พลังงาน </p><p>หลังจากที่ตัวละครใช้ \"สกิลธาตุ\" หรือ \"การโจมตีปกติ\" จะได้รับพลังงาน 1 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/10257458/245c229cf6f7364c7c9a7aea3db1a1ad_2461225881644295233.png",
                "id": "talent17155",
                "key": "รายละเอียดกติกา",
