              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 1 หน่วย และเรียก Jinni</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/10257458/9858bca5debb2537f7499d5999cf8424_6397892652278500069.png",
                "id": "talent14317",
