                      "ep_id": 4568,
                      "icon_url": "",
                      "menu_id": 18,
                      "name": "Discretionary Supplement",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ชนะโดยจำนวนตัวละครที่ถูกกำจัดต่ำกว่า 2 ตัว",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
