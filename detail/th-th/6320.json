                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "เชิญตัวละคร",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอลฉันมิตร",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"การเล่นการ์ดกับคู่ต่อสู้ที่มีฝีมือ ไม่ต่างอะไรกับการฝึกฝนความคิดแบบพิเศษเลย สำหรับสมาชิกทีมลาดตระเวนพิเศษแล้ว ถือเป็นสิ่งที่ไม่เลวเลยทีเดียว... แต่แน่นอนว่า ต้องไม่ส่งผลกระทบต่องานประจำวันนะ\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "[ข้อแนะนำ] เด็คของ Chevreuse จะใช้ \"ปฏิกิริยาโอเวอร์โหลด\" เป็นหลัก ซึ่งทำให้สามารถทำให้เกิด \"ปฏิกิริยาโอเวอร์โหลด\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "ได้ง่ายขึ้น และเมื่อทำให้เกิด \"ปฏิกิริยาโอเวอร์โหลด\" จะได้รับการเสริมพลังจำนวนมาก",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมของคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
