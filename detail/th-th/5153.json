                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "เชิญตัวละคร",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอลฉันมิตร",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"การประลองที่ดุเดือดบนโต๊ะดูเอล ดูเหมือนจะสามารถเขียนเป็นรายงานที่มีเอกลักษณ์ได้...ขอบคุณที่ให้ข้อมูลข่าวกับฉันนะ!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "[ข้อแนะนำ] เด็คของ Charlotte เด่นในเรื่องการใช้การ์ดตัวละครและการ์ดแอ็กชันมอบ \"การรักษา\" จำนวนมาก และทำการโจมตีสวนกลับหลังจากสถานการณ์คงที่แล้ว",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมของคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5153,
                      "icon_url": "",
