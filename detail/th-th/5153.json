                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Framing: Freezing Point Composition"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span> 1 หน่วย รักษาตัวละครทั้งหมดของฝ่ายเรา 1 หน่วย และเรียก <span style=\"color: rgba(255, 255, 255, 0.85)\">Newsflash Field</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Newsflash Field</span></strong></p><p><span style=\"color: #FFFFFF\">จบเฟส:</span> สร้าง<span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span> 1 หน่วย และรักษาตัวละครที่เข้าต่อสู้ของฝ่ายเรา 1 หน่วย</p><p><span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้:</span> 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/14/10257458/d1cf9afd3481f21b5ec894c5c65557fe_1673046657639117144.png",
