              {
                "item_values": [],
                "key": "แนะนำการเล่น",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">จักรกลที่สร้างขึ้นจากเทคโนโลยีกลไกซับซ้อน และแหล่งพลังงานพิเศษของ Fontaine พวกมันจะมีการเคลื่อนไหวต่อสู้ที่แตกต่างกันออกไป ตามคุณสมบัติ</span><strong><span style=\"color: rgb(255, 225, 75)\">พลังสสารหรือพลังวิญญาณ</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">ที่แสดงออก; เมื่อพลังงานคุณสมบัติพิเศษเหล่านี้ถูกทำลายล้าง โดย</span><strong><span style=\"color: rgb(255, 225, 75)\">การโจมตีคุณสมบัติขั้วตรงข้าม</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">จะทำให้แหล่งพลังงานโอเวอร์โหลดและใช้การไม่ได้ พร้อมทั้งสูญเสียกำลังในการต่อสู้อีกด้วย</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
