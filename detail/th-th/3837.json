    {
      "id": "48",
      "name": "ความสามารถ",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">โจมตีปกติ </span></p><p>สร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 1 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/1ce09211f025bf5470682189e0837732_8784966863593667533.png",
                "id": "talent75513",
                "key": "Spiritfox Sin-Eater ",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Spiritfox Sin-Eater "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">สกิลธาตุ </span></p><p>เรียก <span style=\"color: rgb(255, 255, 255)\">Sesshou Sakura</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Sesshou Sakura</span></strong><br><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 1 หน่วย;<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>: 3 (ซ้อนทับได้ มากสุด 6 ครั้ง)<br><span style=\"color: rgb(255, 255, 255)\">เมื่อฝ่ายเราแจ้งจบเทิร์น:</span> หาก<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>ของการ์ดใบนี้มีอย่างน้อย 4 ครั้ง จะสร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 1 หน่วย (ต้องใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/7e9f291d99b3519d86302e803782b2f7_7840863575007850839.png",
                "id": "talent26295",
                "key": "Yakan Evocation: Sesshou Sakura",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Yakan Evocation: Sesshou Sakura"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">ท่าไม้ตาย </span></p><p>สร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 4 หน่วย; หากในสนามของฝ่ายเรามี <span style=\"color: rgb(255, 255, 255)\">Sesshou Sakura</span> จะสลายมัน และสร้าง <span style=\"color: rgb(255, 255, 255)\">Tenko Thunderbolt</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Sesshou Sakura</span></strong><br><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 1 หน่วย;<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้: 3</span> (ซ้อนทับได้ มากสุด 6 ครั้ง)<br><span style=\"color: rgb(255, 255, 255)\">เมื่อฝ่ายเราแจ้งจบเทิร์น:</span> หาก<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>ของการ์ดใบนี้มีอย่างน้อย 4 ครั้ง จะสร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 1 หน่วย (ต้องใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>)<br></p><p><strong><span style=\"color: #ECE5D8\">Tenko Thunderbolt</span></strong><br><span style=\"color: rgb(255, 255, 255)\">ก่อนที่ฝ่ายเราจะเลือกการดำเนินการ:</span> สร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 3 หน่วย<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้: 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/56f64a44b1ccee62527e2a18a46de27f_3772112023565022648.png",
                "id": "talent57178",
                "key": "Great Secret Art: Tenko Kenshin ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Great Secret Art: Tenko Kenshin "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สิ่งอัญเชิญ</span></p><p><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 1 หน่วย;<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>: 3 (ซ้อนทับได้ มากสุด 6 ครั้ง)<br><span style=\"color: rgb(255, 255, 255)\">เมื่อฝ่ายเราแจ้งจบเทิร์น:</span> หาก<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>ของการ์ดใบนี้มีอย่างน้อย 4 ครั้ง จะสร้าง<span style=\"color: rgb(255, 172, 255)\">ความเสียหายไฟฟ้า</span> 1 หน่วย (ต้องใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/db13288db6b90ec33f8adc2656d2019f_3977285058282728952.png",
                "id": "talent56853",
                "key": "Sesshou Sakura",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/9935fc2ef27a255d96756090578adee7_5212308555308144507.png",
                "title": "Sesshou Sakura"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะธาตุไฟฟ้าจะทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">โอเวอร์โหลด: </span>ความเสียหายนี้ +2 และตัวเป้าหมายจะถูกบังคับให้เปลี่ยนไปใช้ตัวละครถัดไป</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">นำไฟฟ้า:</span> ความเสียหายนี้ +1 และสร้างความเสียหายทะลวง 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">ชาร์จไฟฟ้า:</span> ความเสียหายนี้ +1 และสร้างความเสียหายทะลวง 1 หน่วย ให้กับตัวละครทั้งหมดของฝ่ายศัตรู (ยกเว้นเป้าหมาย)</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span>] <span style=\"color: rgb(255, 255, 255)\">ปลุกเร้า: </span>ความเสียหายนี้ +1 และทำให้เกิด [Catalyzing Field] ที่จะทำให้ความเสียหายไม้/ไฟฟ้า 3 ครั้ง ถัดไป +1</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/11ea6117480145a30b7893f1e8bd7115_5817173018235150028.png",
                "id": "talent82037",
                "key": "ความเสียหายไฟฟ้า",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายไฟฟ้า"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">จำนวนครั้งที่ใช้ได้</span></strong><br>หลังการ์ดใบนี้เกิดเอฟเฟกต์ จะใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span> 1 ครั้ง;<br>และหลังจากที่<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>หมด การ์ดใบนี้จะถูกทิ้งไป</p>",
