                      "amount": 1,
                      "display_style": "text",
                      "ep_id": 3333,
                      "icon_url": "",
                      "name": "เหรียญนําโชค",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "แขกที่มาท้าทาย: Hu Tao",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"โอ๊ะโอ? คู่ต่อสู้คราวนี้เป็นเธอเองเหรอ? งั้นหัวหน้าโถงฯ คนนี้ไม่เกรงใจล่ะนะ!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "[ข้อแนะนำ] เด็คของ Hu Tao ประกอบด้วยการ์ด \"อาหาร\" ที่มีประโยชน์หลากหลาย และการ์ดที่เข้ากับ \"การโจมตีปกติ\" อยู่เป็นจำนวนมาก ซึ่งทำให้สามารถจู่โจมด้วย \"การโจมตีปกติ\" ที่ได้รับการเสริมพลัง ในขณะที่รักษาความเสียหายไปด้วยได้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมของคู่ต่อสู้",
                      "type": "text"
