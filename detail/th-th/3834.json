                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3848,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/ebb568fbec05a9d31ccf1843c0d1ea49_4983239305098470655.png",
