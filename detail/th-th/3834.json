                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "เป้าหมายการท้าทาย",
                      "type": "text"
                    }
