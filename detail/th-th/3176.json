                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>จะสร้าง<span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span> 7 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/144837601/d98d17703b86282b89569cb7c5dde12c_4884242811970060644.png",
