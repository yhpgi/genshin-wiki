{
  "id": 4571,
  "name": "Hydro Tulpa",
  "desc": "<p>มอนสเตอร์รูปร่างคล้ายมนุษย์ที่เกิดจากการรวมตัวกันของน้ำ</p>",
  "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/09/53372413/685c8e4b6a58dbed2c74cbbf1cbb977c_8188280064399098895.png",
  "modules": [
    {
      "id": "11",
      "name": "ค่าสถานะ",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "ชื่อ",
                "string_values": [
                  "<p>Hydro Tulpa</p>"
                ]
              },
              {
                "item_values": [],
                "key": "ประเภท",
                "string_values": [
                  "<p>สิ่งมีชีวิตธาตุ</p>"
                ]
              },
              {
                "item_values": [],
                "key": "แนะนำการเล่น",
                "string_values": [
                  "<p>สิ่งมีชีวิตขนาดใหญ่ที่เกิดจากการรวมตัวของหยดน้ำจำนวนมาก ในระหว่างการท้าทาย \"Half-Tulpa\" ขนาดเล็ก จะปรากฏขึ้นอย่างต่อเนื่องเพื่อโจมตีศัตรู Hydro Tulpa จะดูดซับ Half-Tulpa ระหว่างการต่อสู้ เพื่อเพิ่มพลังและทำให้แข็งแกร่งยิ่งขึ้น กระบวนการดูดซับสามารถถูกขัดจังหวะได้ด้วยการโจมตีหรือใช้ปฏิกิริยาธาตุ เพื่อทำลาย Half-Tulpa ในระหว่างกระบวนการดูดซับ</p>"
                ]
              }
            ]
          }
        }
      ]
    },
