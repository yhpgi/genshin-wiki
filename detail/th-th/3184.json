                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การต่อสู้อย่างจริงจัง",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"...ถึงดวงเกี่ยวกับการ์ดและลูกเต๋าของฉันจะไม่ดี แต่ผู้เล่นที่แท้จริงจะไม่ยอมท้อใจอย่างเด็ดขาด จะต้องใช้ทักษะในการเล่น เพื่อเอาชนะความยากลำบากและคว้าชัยชนะมาให้ได้!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "[กฎพิเศษ] ในตอนเริ่ม \"Bennett\" จะติดตั้งการ์ดพรสวรรค์ \"Grand Expectation\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมของคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3184,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/144837601/9d7ad9d3cf203bf7ff1f53966709c4f1_995364308030355184.png",
                      "menu_id": 17,
                      "name": "Bennett",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3187,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/144837601/31f1af14b97e8b36a6617bfa7f094abb_1112094279963317465.png",
                      "menu_id": 17,
                      "name": "Razor",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3180,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/144837601/c6ac0dbf3ded0fa17b5dcf1f46f20930_1783619318891100110.png",
                      "menu_id": 17,
                      "name": "Barbara",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ปลดล็อกหลัง:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "มีเลเวลผู้เล่นถึง 7",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "สำเร็จเป้าหมายการท้าทาย Bennett - เป็นมิตร 3 อัน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "เป้าหมายการท้าทาย",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "รางวัล",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "ได้รับชัยชนะ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "1000x",
                      "type": "text"
                    },
                    {
                      "amount": 1,
                      "display_style": "text",
                      "ep_id": 3333,
                      "icon_url": "",
