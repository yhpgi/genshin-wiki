                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "แขกที่มาท้าทาย: Bennett",
                      "type": "text"
                    }
