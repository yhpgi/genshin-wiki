                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>จะสร้าง<span style=\"color: #FF9999\">ความเสียหายไฟ</span> 3 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/144837601/7fae27e2ff070ba5aedf9d5c45e28d2e_6979861901899234868.png",
