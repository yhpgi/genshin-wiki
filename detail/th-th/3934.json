      "name": "เกมกลเจ็ดอัจฉริยะ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอล : Railah",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"ผู้มาเยือนจากต่างแดน ภูมิปัญญาจากต่างแดน ประกายแห่งต่างแดน จุดประกายความรู้จากต่างแดนที่เชื่อมโยงกันเป็นลูกโซ่\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Railah เปิดกล่องศักดิ์สิทธิ์ของเธอ มันคือเด็คที่ประกอบไปด้วย \"Yae Miko\", \"Sangonomiya Kokomi\" และ \"Arataki Itto\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3837,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/343ab804c901e9d3c328c09a77c76b6f_1958745510122960908.png",
                      "menu_id": 17,
                      "name": "Yae Miko",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
