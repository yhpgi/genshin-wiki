                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 49,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Raiden Shogun_icon.png",
                      "menu_id": 2,
                      "name": "Raiden Shogun",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ในขณะที่ Raiden Shogun ใช้",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ท่าไม้ตาย",
                      "type": "text"
                    },
                    {
                      "text": "จะสามารถใช้สกิลติดตัวของอาวุธชิ้นนี้เพื่อเพิ่มความเสียหายโดยรวมได้เป็นอย่างมาก นอกจากนี้ Raiden Shogun ยังได้ค่า",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 172, 255)"
                      ],
                      "text": "โบนัสความเสียหายไฟฟ้า",
                      "type": "text"
                    },
                    {
                      "text": "เพิ่มเติมจากค่า",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "การฟื้นฟูพลังงาน",
                      "type": "text"
                    },
                    {
                      "text": "จากพรสวรรค์ของเธอ จึงทำให้สามารถใช้ค่าสถานะรองของอาวุธชิ้นนี้และสกิลติดตัวของอาวุธได้เป็นอย่างดี",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 29,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Shenhe_icon.png",
                      "menu_id": 2,
                      "name": "Shenhe",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เนื่องจาก Shenhe เป็นตัวละครที่ต้องพึ่งพาการใช้",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ท่าไม้ตาย",
                      "type": "text"
                    },
                    {
                      "text": "เพื่อสนับสนุนเพื่อนร่วมทีม ทำให้สามารถใช้งานค่าสถานะรองของอาวุธชิ้นนี้ได้ดี นอกจากนี้ ด้วย",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ค่าพลังโจมตีพื้นฐาน",
                      "type": "text"
                    },
                    {
                      "text": "ของอาวุธชิ้นนี้ซึ่งค่อนข้างสูง สามารถช่วยเพิ่มประสิทธิภาพในการสนับสนุนเพื่อนร่วมทีมให้แก่ Shenhe ได้เป็นอย่างดี",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 46,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Zhongli_icon.png",
                      "menu_id": 2,
                      "name": "Zhongli",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เนื่องจาก Zhongli เป็นตัวละครที่สามารถกดใช้",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ท่าไม้ตาย",
                      "type": "text"
                    },
                    {
                      "text": "เพื่อเพิ่มความเสียหายโดยรวมให้แก่ทีมได้ จึงทำให้สามารถใช้ค่าสถานะรองของอาวุธชิ้นนี้ได้เป็นอย่างดี",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2813,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/21/176148810/e09e2bda5e022611fad0dea1bb6518bb_4530553851238597882.png",
                      "menu_id": 2,
                      "name": "Cyno",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
