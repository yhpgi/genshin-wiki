      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">โจมตีปกติ </span></p><p>สร้าง<span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span> 2 หน่วย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/241eba6e4c00020975cf91170050f435_7436198957189840421.png",
                "id": "talent68094",
                "key": "Rain of Stone ",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Rain of Stone "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลธาตุ</span></p><p>สร้าง<span style=\"color: rgb(255, 230, 153)\">ความเสียหายหิน</span> 1 หน่วย และเรียก <span style=\"color: rgb(255, 255, 255)\">Stone Stele</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Stone Stele</span></strong><br><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(255, 230, 153)\">ความเสียหายหิน</span> 1 หน่วย<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/bd88dd4e84f0956abd3d34b19442d2c6_3845865432900023132.png",
                "id": "talent27964",
                "key": "Dominus Lapidis ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Dominus Lapidis "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">สกิลธาตุ </span></p><p>สร้าง<span style=\"color: rgb(255, 230, 153)\">ความเสียหายหิน</span> 3 หน่วย เรียก <span style=\"color: rgb(255, 255, 255)\">Stone Stele</span> และทำให้เกิด <span style=\"color: rgb(255, 255, 255)\">Jade Shield</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Stone Stele</span></strong><br><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(255, 230, 153)\">ความเสียหายหิน</span> 1 หน่วย<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้: 2</span><br></p><p><strong><span style=\"color: #ECE5D8\">Jade Shield</span></strong><br>โล่ป้องกัน<br>มอบ<span style=\"color: rgb(255, 255, 255)\">โล่ป้องกัน 2 หน่วย</span> ให้แก่ตัวละครที่เข้าต่อสู้ของฝ่ายเรา</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/857631feb4f9832ee5644c9f6faf3a44_8978817400562707539.png",
                "id": "talent38235",
                "key": "Dominus Lapidis: Striking Stone ",
                "materials": [],
                "points": [
                  {
                    "point_count": 5,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Dominus Lapidis: Striking Stone "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">ท่าไม้ตาย </span></p><p>สร้าง<span style=\"color: rgb(255, 230, 153)\">ความเสียหายหิน</span> 4 หน่วย และทำให้ตัวละครเป้าหมายได้รับ <span style=\"color: rgb(255, 255, 255)\">Petrification</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Petrification</span></strong><br>ไม่สามารถดำเนินการได้<br><span style=\"color: rgb(255, 255, 255)\">ตัวละครไม่สามารถใช้สกิลได้</span> (จนกว่าจะจบเทิร์น)<br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/c701cbbd15b971aaee458b19e71b4ced_1202245553256759516.png",
                "id": "talent7348",
                "key": "Planet Befall ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Planet Befall "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สิ่งอัญเชิญ</span></p><p><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(255, 230, 153)\">ความเสียหายหิน</span> 1 หน่วย<br><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/db13288db6b90ec33f8adc2656d2019f_3094167597013488625.png",
                "id": "talent54814",
                "key": "Stone Stele",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/905fb3dd007f1806491f7e9df8812d45_2582901306374390920.png",
                "title": "Stone Stele"
              },
              {
                "attributes": [],
                "desc": "<p>จะเกิดปฏิกิริยาธาตุกับสถานะธาตุที่ติดอยู่ก่อน:<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">ตกผลึก (น้ำแข็ง):</span> ความเสียหายนี้ +1 และตัวละครที่เข้าต่อสู้ของฝ่ายเราจะได้รับโล่ป้องกัน 1 หน่วย (สามารถซ้อนทับได้มากสุด 2 หน่วย)<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">ตกผลึก (น้ำ):</span> ความเสียหายนี้ +1 และตัวละครที่เข้าต่อสู้ของฝ่ายเราจะได้รับโล่ป้องกัน 1 หน่วย (สามารถซ้อนทับได้มากสุด 2 หน่วย)<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">ตกผลึก (ไฟ): </span>ความเสียหายนี้ +1 และตัวละครที่เข้าต่อสู้ของฝ่ายเราจะได้รับโล่ป้องกัน 1 หน่วย (สามารถซ้อนทับได้มากสุด 2 หน่วย)<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">ตกผลึก (ไฟฟ้า):</span> ความเสียหายนี้ +1 และตัวละครที่เข้าต่อสู้ของฝ่ายเราจะได้รับโล่ป้องกัน 1 หน่วย (สามารถซ้อนทับได้มากสุด 2 หน่วย)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/fd37cbfdd3b1b2c16e6e83fb0aa96889_7152149779315517194.png",
                "id": "talent11403",
                "key": "ความเสียหายหิน",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายหิน"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">ความเสียหายกายภาพ</span></strong><br>ความเสียหายกายภาพ จะไม่ทำให้ติดสถานะธาตุ และก็ไม่ทำให้เกิดปฏิกิริยาธาตุด้วย<br></p><p><strong><span style=\"color: #ECE5D8\">จำนวนครั้งที่ใช้ได้</span></strong><br>หลังการ์ดใบนี้เกิดเอฟเฟกต์ จะใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span> 1 ครั้ง;<br>และหลังจากที่<span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้</span>หมด การ์ดใบนี้จะถูกทิ้งไป<br></p><p><strong><span style=\"color: #ECE5D8\">โล่ป้องกัน</span></strong><br>เมื่อตัวละครที่ได้รับการป้องกันจากโล่นี้ถูกโจมตี โล่ป้องกันจะถูกใช้เพื่อลบล้างความเสียหาย</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/144837601/07bae546ac7c69ef6402170b283840c5_5820944415376066979.png",
                "id": "talent33788",
                "key": "รายละเอียดกติกา",
