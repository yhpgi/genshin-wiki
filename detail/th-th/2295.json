          "component_id": "body",
          "data": {
            "list": [
              {
                "content": "<p>Olah! Olah!<br>Yoyo mosi mita!<br>Nye, nye mosi mita,<br>Yeye mosi gusha!<br>Mosi gusha, mosi tiga,<br>Yeye kucha kucha!</p>",
                "id": "body80449",
                "title": "แบบร่างบทอาขยาน"
              },
              {
                "content": "<p>Biadam! Ye dada nesina,<br>Ye dada nesina nunu,<br>Nunu shato!<br>Shato celi, shato lata,<br>Ye dada nesina,<br>Nini zido!<br>Nini zido!</p>",
                "id": "body68828",
                "title": "แบบร่างบทบรรยาย"
              },
              {
                "content": "<p>Gusha, gusha,<br>Gusha muhe kucha<br>Kucha mita pupu,<br>Pupu si kucha mita<br>Mi mosi mita,<br>Ye mosi gusha,<br>Kucha</p>",
                "id": "body31000",
                "title": "แบบร่างบทกวี"
              }
            ]
          }
