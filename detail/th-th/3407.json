    {
      "id": "36",
      "name": "เกมกลเจ็ดอัจฉริยะ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอล : ก็แค่อีกวันของเจ้าหน้าที่พิทักษ์ป่า",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ภายในป่า บางครั้งจะได้เห็นฉากที่ Mitachurl ชนิดต่างๆ หรือแม้กระทั่ง Lawachurl กำลังประชันหน้ากัน... อย่างไรก็ตาม มันจะดีที่สุดถ้าไม่เข้าใกล้มันจนเกินไป...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 230, 153)"
                      ],
                      "text": "[กฏพิเศษ] เมื่อแอ็กชันเฟสเริ่มต้น จะทำให้ตัวละครที่เข้าต่อสู้ของทั้งสองฝ่ายติดสถานะธาตุไม้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3364,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/144837601/5cee49592fa1288d62fc93934c66396b_4583566008923709384.png",
                      "menu_id": 19,
                      "name": "Blazing Axe Mitachurl",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3198,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/144837601/6c1a40b971633c08f8f376ce5bc61f7c_5112367191574226827.png",
                      "menu_id": 17,
                      "name": "Stonehide Lawachurl",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3361,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/144837601/1f1d0fd1b7cb02082d432baf1433c3a9_3748266325849389290.png",
                      "menu_id": 19,
                      "name": "Crackling Axe Mitachurl",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "ข้อกำหนดเบื้องต้น",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "มีเลเวลผู้เล่นถึง 7",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "เป้าหมายการท้าทาย",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "รางวัล",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ได้รับชัยชนะ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "270x ค่าประสบการณ์ผู้เล่น",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "300x",
