                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ค่าการฟื้นฟูพลังงาน",
                      "type": "text"
                    },
                    {
                      "text": "ทำให้ Xiangling สามารถใช้",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ท่าไม้ตาย",
                      "type": "text"
                    },
