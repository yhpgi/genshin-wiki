                      "ep_id": 15,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Yoimiya_icon.png",
                      "menu_id": 2,
                      "name": "Yoimiya",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เนื่องจาก Yoimiya เป็นตัวละครที่เน้นสร้างความเสียหายจาก",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "การโจมตีปกติ",
                      "type": "text"
                    },
                    {
                      "text": "และไม่ได้ใช้ประโยชน์จาก",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ท่าไม้ตาย",
                      "type": "text"
                    },
                    {
                      "text": "มากนัก จึงทำให้สามารถใช้สกิลติดตัวของอาวุธชิ้นนี้ได้เป็นอย่างดี นอกจากนี้ค่า",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "พลังโจมตี",
                      "type": "text"
                    },
                    {
                      "text": "จากค่าสถานะรองของอาวุธชิ้นนี้ยังช่วยเพิ่มความเสียหายโดยรวมให้แก่ Yoimiya ได้อีกด้วย",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 28,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Ganyu_icon.png",
                      "menu_id": 2,
                      "name": "Ganyu",
