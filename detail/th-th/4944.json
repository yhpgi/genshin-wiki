                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Plunging Ice Shards"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สกิลติดตัว</span></p><p>[ติดตัว] เมื่อเริ่มการต่อสู้ ในตอนแรกเริ่มจะได้รับ <span style=\"color: #FFFFFF\">Cryocrystal Core</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Cryocrystal Core</span></strong></p><p><span style=\"color: #FFFFFF\">เมื่อตัวละครที่มีสถานะนี้ถูกกำจัด:</span> ลบล้างเอฟเฟกต์นี้ ทำให้ตัวละคร<span style=\"color: #FFFFFF\">หลีกเลี่ยงการพ่ายแพ้</span> และรักษาค่าพลังชีวิตของตัวละครดังกล่าวถึง 1 หน่วย</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/31/115795437/c9fb58d0c17579d0eca97a167035bc53_7411106911442321085.png",
                "id": "talent98048",
