                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Ice Ring Waltz"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">ท่าไม้ตาย</span></p><p>สร้าง<span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span> 2 หน่วย สร้าง<span style=\"color: #FFFFFF\">ความเสียหายทะลวง</span> 1 หน่วย ให้แก่ตัวละครนอกสนามทั้งหมดของฝ่ายศัตรู และเรียก <span style=\"color: rgb(255, 255, 255)\">Piercing Iceridge</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Piercing Iceridge</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">จบเฟส:</span> สร้าง<span style=\"color: rgb(153, 255, 255)\">ความเสียหายน้ำแข็ง</span> 1 หน่วย ให้กับ<span style=\"color: #FFFFFF\">ตัวละครที่อยู่ใกล้กับตัวละครที่เข้าต่อสู้ของฝ่ายเรา</span>มากที่สุดของฝ่ายศัตรู</p><p><span style=\"color: rgb(255, 255, 255)\">จำนวนครั้งที่ใช้ได้:</span> 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/31/115795437/77df8fb6101bdb6c35d501967b98f941_8351307927201536190.png",
                "id": "talent52345",
                "key": "Plunging Ice Shards",
                "materials": [],
