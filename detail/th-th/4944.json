              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">โจมตีปกติ</span><br>สร้าง<span style=\"color: #99FFFF\">ความเสียหายน้ำแข็ง</span> 1 หน่วย</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/31/115795437/1ce09211f025bf5470682189e0837732_5831503943397442965.png",
