              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">สิ่งอัญเชิญ</span></p><p><span style=\"color: #FFFFFF\">จบเฟส:</span> สร้าง<span style=\"color: #99FF88\">ความเสียหายไม้</span> 2 หน่วย</p><p><span style=\"color: #FFFFFF\">จำนวนครั้งที่ใช้ได้: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/db13288db6b90ec33f8adc2656d2019f_5542917124517284313.png",
