                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/e4c575a9b78928d6dd760a34a0bd9681_6295340662938637732.png",
                "title": "Cuilein-Anbar"
              },
              {
                "attributes": [],
                "desc": "<p>การติดสถานะธาตุไม้จะสามารถทำให้เกิดปฏิกิริยาธาตุดังนี้:</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro </span>] <span style=\"color: #FFFFFF\">งอกเงย:</span> ความเสียหายนี้ +1 และทำให้เกิด <span style=\"color: #FFFFFF\">[Dendro Core]</span> ที่ทำให้ความเสียหายไฟ/ไฟฟ้า ครั้งต่อไป +2</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: #FFFFFF\">ติดไฟ:</span> ความเสียหายนี้ +1 และจะทำให้เกิด <span style=\"color: #FFFFFF\">[Burning Flame] </span>ที่สร้างความเสียหายไฟ 1 หน่วย ในตอนสั้นสุดเทิร์น (ใช้ได้ 1ครั้ง ซ้อนทับได้มากสุดถึง 2)</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>]<span style=\"color: #FFFFFF\"> ปลุกเร้า: </span>ความเสียหายนี้ +1 และทำให้เกิด<span style=\"color: #FFFFFF\"> [Catalyzing Field] </span>ที่จะทำให้ ความเสียหายไม้/ไฟฟ้า 3 ครั้ง ถัดไป +1</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/17/144837601/e8cff941b5a0ff248efde360ec9e91fe_2691037951482375671.png",
                "id": "talent90203",
                "key": "ความเสียหายไม้",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "ความเสียหายไม้"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">ความเสียหายกายภาพ</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">ความเสียหายกายภาพ</span><span style=\"color: rgba(255, 255, 255, 0.65)\">จะไม่ทำให้ติดสถานะธาตุและก็ไม่ทำให้เกิดปฏิกิริยาธาตุด้วย</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">จำนวนเทิร์นต่อเนื่อง</span></strong></p><p>ในตอนจบเฟสของแต่ละเทิร์น<span style=\"color: rgb(255, 255, 255)\"> จำนวนเทิร์นต่อเนื่อง</span>จะ -1; หลังจากที่ใช้<span style=\"color: rgb(255, 255, 255)\">จำนวนเทิร์นต่อเนื่อง</span>จนหมดการ์ดใบนี้จะถูกทิ้งไป</p>",
