                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 29,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Shenhe_icon.png",
                      "name": "Shenhe",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "อาวุธชิ้นนี้เป็นอาวุธประจำตัว Shenhe ที่ให้ทั้งความสวยงามและให้ค่าสถานะที่สามารถเพิ่มการสร้าง",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "ความเสียหายน้ำแข็ง",
                      "type": "text"
                    },
                    {
                      "text": "ของ Shenhe",
                      "type": "text"
                    },
                    {
                      "text": "ได้ โดยสกิลติดตัวของอาวุธจะเพิ่มโบนัสความเสียหายธาตุ และเมื่อกดสกิลธาตุ จะสามารถเพิ่ม",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "พลังโจมตี",
                      "type": "text"
                    },
                    {
                      "text": "ได้ ซึ่งสอดคล้องกับพรสวรรค์ของเธอที่จะเพิ่ม",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "ความเสียหายน้ำแข็ง",
                      "type": "text"
                    },
                    {
                      "text": "โดยขึ้นอยู่กับ",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ค่าพลังโจมตี",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5714,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/06/10257458/e4a7b8f7d28f5a7256bad31de65371d4_4221067243999071026.png",
                      "menu_id": 2,
                      "name": "Emilie",
                      "type": "custom_entry"
