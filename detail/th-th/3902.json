            "list": [
              {
                "item_values": [],
                "key": "ชื่อ",
                "string_values": [
                  "<p>Ibis Piercer</p>"
                ]
              },
              {
                "item_values": [],
                "key": "หาได้จาก",
                "string_values": [
                  "<p>กิจกรรม 'ดูเอล! สุดยอดนักอัญเชิญ!' (เวอร์ชัน 3.7)</p>"
                ]
              },
              {
                "item_values": [],
                "key": "ประเภท",
                "string_values": [
                  "<p>ธนู</p>"
                ]
              },
              {
                "item_values": [],
                "key": "ค่าสถานะรอง",
                "string_values": [
                  "<p>เปอร์เซ็นต์พลังโจมตี</p>"
                ]
              },
              {
                "item_values": [],
                "key": "Secret Wisdom's Favor",
                "string_values": [
                  "<p>ภายใน 6 วินาที หลังจากที่การชาร์จโจมตีถูกศัตรู ความชำนาญธาตุของตัวละครจะเพิ่มขึ้น 40 หน่วย โดยเอฟเฟกต์นี้จะซ้อนทับมากสุด 2 ชั้น และในทุก 0.5 วินาที จะเกิดขึ้นได้มากสุดหนึ่งครั้ง</p>"
                ]
              }
            ]
          }
        }
      ]
