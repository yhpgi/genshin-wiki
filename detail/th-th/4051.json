                  "<p><span style=\"color: rgb(219, 222, 225)\">จักรกลอัตโนมัติ</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "แนะนำการเล่น",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">จักรกลที่สร้างขึ้นจากเทคโนโลยีกลไกซับซ้อน และแหล่งพลังงานพิเศษของ Fontaine พวกมันจะมีการเคลื่อนไหวต่อสู้ ที่แตกต่างกันออกไปตามคุณสมบัติ</span><strong><span style=\"color: rgb(255, 225, 75)\">พลังสสารหรือพลังวิญญาณ</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">ที่แสดงออก; เมื่อพลังงานคุณสมบัติพิเศษเหล่านี้ถูกทำลายล้าง โดย</span><strong><span style=\"color: rgb(255, 225, 75)\">การโจมตีคุณสมบัติขั้วตรงข้าม</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> จะทำให้แหล่งพลังงานโอเวอร์โหลดและใช้การไม่ได้ หลังจากนั้นจะเปิดใช้พลังงานฉุกเฉินมาดำเนินการต่อสู้ในบริเวณที่จำกัด</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
