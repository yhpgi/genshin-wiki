      "name": "ตัวละครที่แนะนำ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "ตัวละคร",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "หมายเหตุ",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 10,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Keqing_icon.png",
                      "menu_id": 2,
                      "name": "Keqing",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เนื่องจาก Keqing เป็นตัวละครที่สามารถเล่นในทีมสำหรับสร้าง",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "ความเสียหายกายภาพ",
                      "type": "text"
                    },
                    {
                      "text": "ได้ จึงทำให้ Keqing ได้รับประโยชน์จากค่า",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "โบนัสความเสียหายกายภาพ",
                      "type": "text"
                    },
                    {
                      "text": "จากค่าสถานะรองของอาวุธชิ้นนี้ และใช้ประโยชน์จากเอฟเฟกต์เฉพาะของอาวุธชิ้นนี้ได้อย่างมีประสิทธิภาพ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 27,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Jean_icon.png",
                      "menu_id": 2,
                      "name": "Jean",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เนื่องจาก",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "ค่าพลังโจมตีพื้นฐาน",
                      "type": "text"
                    },
                    {
                      "text": "ของอาวุธชิ้นนี้ค่อนข้างสูง และสกิลติดตัวยังสามารถเพิ่มพลังโจมตีให้แก่ผู้ใส่ได้ จึงทำให้ Jean สามารถ",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "ฟื้นฟูพลังชีวิต",
                      "type": "text"
                    },
                    {
                      "text": "ให้แก่เพื่อนร่วมทีมได้มากขึ้น แม้จะไม่จำเป็นต้องใช้ค่า",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "โบนัสความเสียหายกายภาพ",
                      "type": "text"
                    },
                    {
                      "text": "มากนัก ทำให้สามารถใช้อาวุธชิ้นนี้ได้ หากไม่สามารถหาอาวุธชิ้นอื่นมาทดแทนได้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 26,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Bennett_icon.png",
                      "menu_id": 2,
                      "name": "Bennett",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "เนื่องจาก",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ค่าพลังโจมตีพื้นฐาน",
                      "type": "text"
                    },
                    {
                      "text": "ของอาวุธชิ้นนี้ค่อนข้างสูง ทำให้ Bennett สามารถมอบบัฟเพิ่ม",
                      "type": "text"
                    },
                    {
