    {
      "id": "68",
      "name": "เกมกลเจ็ดอัจฉริยะ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "การดูเอล : ความลับของเครื่องเทศ",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "แนะนำด่าน",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "มีอยู่วันหนึ่ง เพื่อที่จะตามหาความลับที่จะทำให้อาหารมีรสชาติอร่อยยิ่งขึ้น Abyss Mage จึงได้...เอ๋? ไม่เคยเห็นพวกมันกินอะไรมาก่อนเลยงั้นเหรอ แหม ยังไงซะมันก็เป็นแค่เรื่องเล่าล่ะน่าา...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "[กฎพิเศษ] หลังจากที่ Abyss Maage ใช้สกิล จำทำให้การซ่อมแซม \"โล่ธาตุ\" ที่ถูกทำลายไป",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทีมคู่ต่อสู้",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "ข้อกำหนดเบื้องต้น",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "มีเลเวลผู้เล่นถึง 9",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "เป้าหมายการท้าทาย",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "รางวัล",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ได้รับชัยชนะ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "330x ค่าประสบการณ์ผู้เล่น",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "350x",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(211, 188, 142)"
                      ],
                      "text": "เหรียญนําโชค",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ได้รัยชัยชนะภายใน 5 เทิร์น",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "700x",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(211, 188, 142)"
                      ],
                      "text": "เหรียญนําโชค",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ทำให้เกิด \"ปฏิกิริยาธาตุ\" 2 ครั้ง",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "700x",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(211, 188, 142)"
                      ],
                      "text": "เหรียญนําโชค",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
