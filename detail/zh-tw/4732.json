            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成2點<span style=\"color: rgb(255, 255, 255)\">物理傷害</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/125391187/ad8a357fa8480f61f3fe665b69d9c263_1538591564145018185.png",
                "key": "呲牙裂扇箭",
                "materials": [],
