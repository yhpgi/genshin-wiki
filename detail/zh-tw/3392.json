                      "menu_id": 17,
                      "name": "柯萊",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3186,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/181140897/9135fdcb8dc1dca18a13b4f4818cb2d2_597416977738463379.png",
                      "menu_id": 17,
                      "name": "刻晴",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "解鎖要求",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "「牌手等級」到達1級",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
