                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/12/51635400/c32bab10651059ad3c0c8a0e5bbd2e03_5004906481475328879.png",
                      "menu_id": 5,
                      "name": "Золотая труппа",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4302,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/10/124137736/5297fd201cef47a3124d0d2c95f8d6db_5456087551234690903.png",
                      "menu_id": 9,
                      "name": "Загадочная страница I",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
