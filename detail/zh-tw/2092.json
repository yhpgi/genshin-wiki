            },
            "flower_of_life": {
              "desc": "湛藍而堅硬，永不凋敗、永不褪色的人造花朵。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Pale Flame/flower_of_life_icon.png",
              "position": "生之花",
