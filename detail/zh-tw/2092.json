            },
            "plume_of_death": {
              "desc": "邊緣無比銳利的不祥翎羽，或許象徵著異類的不羈。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Pale Flame/plume_of_death_icon.png",
