      "components": [
        {
          "component_id": "artifact_list",
          "data": {
            "circlet_of_logos": {
              "desc": "儘管飽經風霜，但依舊光彩照人的禮帽。其中似乎迴盪著古老悠揚的樂聲。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Wanderer's Troupe/circlet_of_logos_icon.png",
              "position": "理之冠",
              "title": "指揮的禮帽"
            },
            "flower_of_life": {
              "desc": "小小的花形徽章。側耳細聽的話，仿佛能聽到悠揚的笛聲和清新的歌唱聲。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Wanderer's Troupe/flower_of_life_icon.png",
              "position": "生之花",
              "title": "樂團的晨光"
            },
            "goblet_of_eonothem": {
              "desc": "外型奇妙的古代水壺，內側安裝著琴弦，隨流水而奏出無旋律的奇妙樂聲。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Wanderer's Troupe/goblet_of_eonothem_icon.png",
              "position": "空之杯",
              "title": "吟遊者之壺"
            },
            "plume_of_death": {
              "desc": "青藍色的箭羽，並未在漫長歲月中褪色破碎。似乎帶來了落珠流水的琴聲。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Wanderer's Troupe/plume_of_death_icon.png",
              "position": "死之羽",
              "title": "琴師的箭羽"
            },
            "sands_of_eon": {
              "desc": "為樂團的演奏計時的沙漏，曾發出俐落的聲響。如今他們的表演已經落幕。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Wanderer's Troupe/sands_of_eon_icon.png",
