                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ffffff"
                      ],
                      "text": "該武器的高",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:#ffe14b"
                      ],
                      "text": "攻擊力",
