                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "狐靈食罪式"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素戰技</span></p><p>召喚<span style=\"color: #FFFFFF\">殺生櫻</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/7998136/7e9f291d99b3519d86302e803782b2f7_5137762215741241132.png",
                "id": "talent32836",
                "key": "野干役咒·殺生櫻",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "野干役咒·殺生櫻"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆發</span></p><p>造成4點<span style=\"color: rgb(255, 172, 255)\">雷元素傷害</span>；如果我方場上存在<span style=\"color: #FFFFFF\">殺生櫻</span>，則將其消滅，然後生成<span style=\"color: #FFFFFF\">天狐霆雷</span>。</p><p></p><p><strong><span style=\"color: #FFFFFF\">天狐霆雷</span></strong></p><p><span style=\"color: #FFD780\">出戰狀態</span></p><p><span style=\"color: #FFFFFF\">我方選擇行動前：</span>造成3點<span style=\"color: #FFACFF\">雷元素傷害</span>。</p><p><span style=\"color: #FFFFFF\">可用次數：1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/7998136/56f64a44b1ccee62527e2a18a46de27f_3493580745541173022.png",
                "id": "talent96850",
                "key": "大密法·天狐顯真",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "大密法·天狐顯真"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">召喚物</span></p><p><span style=\"color: #FFFFFF\">結束階段：</span>造成1點<span style=\"color: #FFACFF\">雷元素傷害</span>；</p><p><span style=\"color: #FFFFFF\">可用次數：3</span>（可疊加，至多疊加6層）</p><p><span style=\"color: #FFFFFF\">我方宣布結束時：</span>如果此牌的<span style=\"color: #FFFFFF\">可用次數</span>至少為4，則造成1點<span style=\"color: #FFACFF\">雷元素傷害</span>。（需消耗<span style=\"color: #FFFFFF\">可用次數</span>）</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/26/7998136/db13288db6b90ec33f8adc2656d2019f_4776843375792945246.png",
                "key": "殺生櫻",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/26/7998136/9935fc2ef27a255d96756090578adee7_6151583701727737707.png",
                "title": "殺生櫻"
              },
              {
                "attributes": [],
                "desc": "<p>附著雷元素，可發生元素反應：</p><p>【<span style=\"color: rgb(255, 172, 255)\">雷元素</span>+<span style=\"color: rgb(255, 153, 153)\">火元素</span>】<span style=\"color: rgb(255, 255, 255)\">超載</span>：本傷害+2，目標強制切換到下一個角色</p><p>【<span style=\"color: rgb(255, 172, 255)\">雷元素</span>+<span style=\"color: rgb(153, 255, 255)\">冰元素</span>】<span style=\"color: rgb(255, 255, 255)\">超導</span>：本傷害+1，對目標以外的所有敵方角色造成1點穿透傷害</p><p>【<span style=\"color: rgb(255, 172, 255)\">雷元素</span>+<span style=\"color: rgb(128, 192, 255)\">水元素</span>】<span style=\"color: rgb(255, 255, 255)\">感電</span>：本傷害+1，對目標以外的所有敵方角色造成1點穿透傷害</p><p>【<span style=\"color: rgb(255, 172, 255)\">雷元素</span>+<span style=\"color: rgb(153, 255, 136)\">草元素</span>】<span style=\"color: rgb(255, 255, 255)\">原激化</span>：本傷害+1，生成使下2次草元素或雷元素傷害+1的<span style=\"color: rgb(255, 255, 255)\">[激化領域]</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/26/7998136/11ea6117480145a30b7893f1e8bd7115_4988462393329727306.png",
