                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 29,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Shenhe_icon.png",
                      "name": "申鶴",
                      "type": "custom_entry"
