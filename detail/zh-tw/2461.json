    {
      "id": "93",
      "name": "媒體",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "預告和過場動畫",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "劇情預告-「人間至味」",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/30/157749474/7caca68a51e7ac54570df4a2b11efd75_7234490854212547311.jpg"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "2021年10月2日",
                      "type": "text"
                    },
                    {
                      "text": "年歲一箸，山海一壺。閱古話今，幾度春秋。",
                      "type": "text"
                    },
                    {
                      "text": "炊煙喜樂，柴米朝暮。纖雲逐月，塵世繫舟。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "劇情預告-「神女劈觀」",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/30/157749474/c7c89b91a563baec537660234250afd6_6825275876191438500.jpg"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "2022年1月6日",
                      "type": "text"
                    },
                    {
                      "text": "道仙緣奇談，物是人非，疏卻千絲怨愁。",
                      "type": "text"
                    },
                    {
                      "text": "歌巾幗英姿，再添新話，重入萬家燈火。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "飛彩鐫流年活動過場動畫「歲華流彩」",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/30/157749474/21da0584c68f1fc3b166df576240cd2c_1641874575977619212.jpg"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "2022年1月31日",
                      "type": "text"
                    },
                    {
                      "text": "火樹銀花，散漫天飛星，迎萬象似錦。",
                      "type": "text"
                    },
                    {
                      "text": "榮輝彩華，凝萬千心願，祝山月常新。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "磬弦奏華夜活動過場動畫-「虹歌燈宴」",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/30/157749474/302104f08566c84d9702f4868938fffe_6070247187472958099.jpg"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "2023年1月21日",
                      "type": "text"
                    },
                    {
                      "text": "新歲新象，摯友摯願。",
                      "type": "text"
                    },
                    {
                      "text": "在這華彩映照的夜晚，璃月港內不止有霄燈，還有融匯萬籟的仙樂。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "劇情預告-「餘音縈心」",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/30/157749474/7cca2be08e92fd6268d1fe9478f14c74_5430484790489824034.jpg"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "2023年1月21日",
                      "type": "text"
                    },
                    {
                      "text": "過眼雲煙，浮萍無根。",
                      "type": "text"
                    },
                    {
                      "text": "涓涓行水，渺渺滌塵。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "風物集短片-璃月篇",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/24/237301566/50e9716fc5f9012a00e38edd53ac83e2_3420861946456836153.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "2023年6月21日",
                      "type": "text"
                    },
                    {
                      "text": "山石奇景，巍巍難撼。",
                      "type": "text"
                    },
                    {
                      "text": "商港熙榮，閱盡千帆。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
