                      "menu_id": 17,
                      "name": "魔偶劍鬼",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3178,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/169177528/2c2d8a83c9a5a9a97531fee1491efa85_5772037314151874646.png",
                      "menu_id": 17,
                      "name": "莫娜",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "解鎖要求",
