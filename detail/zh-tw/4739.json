              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">被動技能</span></p><p>【被動】戰鬥開始時，初始附屬<span style=\"color: rgb(255, 255, 255)\">磐岩百相·元素汲取</span><span style=\"color: rgb(236, 228, 217)\">。</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/23/142229365/f422e67b045b43006341d9b296f52662_5043658459778244264.png",
