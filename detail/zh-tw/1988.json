      "name": "故事",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "傳說，著名的英雄在斬殺毒龍之後，</br>以獵獲的龍血沐浴，以期刀槍不入。</br>龍血確有此奇效：受其洗刷的軀體，</br>捲了無數刀劍的刃，折了無數槍矛的尖，</br>漫天飛來的箭，在他的笑聲中紛紛彈開。</br>最終，他的敵人們發現：</br>他是背著鍾愛的大劍沐浴龍血的，</br>背上有一整塊大劍尺寸的弱點哩。</br>",
                "id": "story45369",
                "title": ""
              }
            ]
          }
        }
      ]
