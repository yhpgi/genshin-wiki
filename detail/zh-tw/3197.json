              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">召喚物</span></p><p><span style=\"color: rgb(255, 255, 255)\">結束階段：</span>造成1點<span style=\"color: #99FFFF\">冰元素傷害</span>。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次數：2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/22/84496276/db13288db6b90ec33f8adc2656d2019f_4744025368156133997.png",
