      "name": "技能",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成1點<span style=\"color: rgb(153, 255, 136)\">草元素傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/125391187/95142c2955e1896817dc3d6ff9639ac5_1448151702845829492.png",
                "id": "talent64233",
                "key": "金匱針解",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "金匱針解"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素戰技</span></p><p>造成1點<span style=\"color: rgb(153, 255, 136)\">草元素傷害</span>，召喚<span style=\"color: #FFFFFF\">遊絲徵靈</span>。</p><p></p><p><strong><span style=\"color: #FFFFFF\">遊絲徵靈</span></strong></p><p><span style=\"color: #FFFFFF\">結束階段：</span>造成1點<span style=\"color: #99FF88\">草元素傷害</span>，治療我方出戰角色1點。</p><p><span style=\"color: #FFFFFF\">可用次數：1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/125391187/02943d17a2ad29f325fdac70651d2bae_4547641736716947655.png",
                "id": "talent23404",
                "key": "太素診要",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "太素診要"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆發</span></p><p>生成<span style=\"color: rgb(255, 255, 255)\">脈攝宣明</span>和<span style=\"color: rgb(255, 255, 255)\">無郤氣護盾</span>。</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">脈攝宣明</span></strong></p><p><span style=\"color: #FFD780\">出戰狀態</span></p><p><span style=\"color: rgb(255, 255, 255)\">行動階段開始時：</span>生成<span style=\"color: rgb(255, 255, 255)\">無郤氣護盾</span>。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次數：2</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">無郤氣護盾</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">護盾</span></p><p>提供<span style=\"color: #FFFFFF\">1點護盾</span>，保護我方出戰角色。</p><p><span style=\"color: rgb(255, 255, 255)\">此效果被移除，或被重複生成時：</span>造成1點<span style=\"color: rgb(153, 255, 136)\">草元素傷害</span>，治療我方出戰角色1點。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/10/125391187/ed10b8e3def17c518055b3421bfcb94a_2199292448953165064.png",
                "id": "talent57215",
                "key": "癒氣全形論",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "癒氣全形論"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">召喚物</span></p><p><span style=\"color: rgb(255, 255, 255)\">結束階段：</span>造成1點<span style=\"color: rgb(153, 255, 136)\">草元素傷害</span>，治療我方出戰角色1點。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次數：1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/18/125391187/db13288db6b90ec33f8adc2656d2019f_1351936200002883657.png",
                "id": "talent93495",
                "key": "游絲徵靈",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/18/125391187/a3d29e698acee488ea48e7cd36af0835_3677794619081844136.png",
                "title": "游絲徵靈"
              },
              {
                "attributes": [],
                "desc": "<p>附著<span style=\"color: rgb(153, 255, 136)\">草元素</span>，可發生元素反應：</p><p>【<span style=\"color: rgb(153, 255, 136)\">草元素</span>+<span style=\"color: rgb(128, 192, 255)\">水元素</span>】<span style=\"color: rgb(255, 255, 255)\">綻放</span>：本傷害+1，生成使下次<span style=\"color: rgb(255, 153, 153)\">火元素</span>或<span style=\"color: rgb(255, 172, 255)\">雷元素</span>傷害+2的<span style=\"color: rgb(255, 255, 255)\">「草原核」</span></p><p>【<span style=\"color: rgb(153, 255, 136)\">草元素</span>+<span style=\"color: rgb(255, 172, 255)\">雷元素</span>】<span style=\"color: rgb(255, 255, 255)\">原激化</span>：本傷害+1，生成「<span style=\"color: rgb(255, 255, 255)\">激化領域</span>」</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">草原核</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">出戰狀態</span></p><p>我方對敵方出戰角色造成<span style=\"color: rgb(255, 153, 153)\">火元素傷害</span>或<span style=\"color: rgb(255, 172, 255)\">雷元素傷害</span>時，傷害值+2。</p><p><span style=\"color: rgb(153, 255, 255)\">可用次數：1</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">激化領域</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">出戰狀態</span></p><p>我方對敵方出戰角色造成<span style=\"color: rgb(255, 172, 255)\">雷元素傷害</span>或<span style=\"color: rgb(153, 255, 136)\">草元素傷害</span>時，傷害值+1。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次數：2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/18/125391187/e8cff941b5a0ff248efde360ec9e91fe_4066469219751928639.png",
                "key": "草元素傷害‧其一",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "草元素傷害‧其一"
              },
              {
                "attributes": [],
                "desc": "<p>附著<span style=\"color: rgb(153, 255, 136)\">草元素</span>，可發生元素反應：</p><p>【<span style=\"color: rgb(153, 255, 136)\">草元素</span>+<span style=\"color: rgb(255, 153, 153)\">火元素</span>】<span style=\"color: rgb(255, 255, 255)\">燃燒</span>：本傷害+1，召喚<span style=\"color: rgb(255, 255, 255)\">燃燒烈焰</span></p><p><span style=\"color: rgb(255, 215, 128)\"><br></span><strong><span style=\"color: rgb(255, 255, 255)\">燃燒烈焰</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">召喚物</span></p><p><span style=\"color: rgb(255, 255, 255)\">結束階段：</span>造成1點<span style=\"color: rgb(255, 153, 153)\">火元素傷害</span>。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次數：1，最多叠加到2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/18/125391187/e8cff941b5a0ff248efde360ec9e91fe_3942665106781084793.png",
                "key": "草元素傷害‧其二",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/18/125391187/3c3362a64ac984342133762388c9eb41_1156655956414497958.png",
                "title": "草元素傷害‧其二"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">可用次數</span></strong></p><p>此牌效果觸發後，會消耗1次<span style=\"color: rgb(255, 255, 255)\">可用次數</span>；</p><p><span style=\"color: rgb(255, 255, 255)\">可用次數</span>耗盡後，立刻棄置此牌。</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">護盾</span></strong></p><p>此護盾所保護的角色受到傷害時，將會消耗護盾來抵消傷害。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/18/125391187/07bae546ac7c69ef6402170b283840c5_8034877803604854612.png",
