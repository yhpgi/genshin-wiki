                      ],
                      "text": "紀念預告-「熒熒微光」",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/07/142453215/d4f10a7505c69f58ba884ce5359152a6_8043419971379624829.png"
