      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成1點<span style=\"color: #80FFD7\">風元素傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/292125737/1ce09211f025bf5470682189e0837732_5062154785994423017.png",
                "id": "talent87596",
                "key": "簡式風靈作成",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "簡式風靈作成"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素戰技</span></p><p>造成3點<span style=\"color: #80FFD7\">風元素傷害</span>，使對方強制切換到前一個角色。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/292125737/dceff798de3e5575ac1c3dad5718d18e_1447322353061241356.png",
                "id": "talent20305",
                "key": "風靈作成·陸參零捌",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "風靈作成·陸參零捌"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆發</span></p><p>造成1點<span style=\"color: rgb(128, 255, 215)\">風元素傷害</span>，召喚<span style=\"color: #FFFFFF\">大型風靈</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/292125737/28de70f699de4ba7cf0f77f2fcfb1483_5226985305570388714.png",
                "id": "talent85252",
                "key": "禁·風靈作成·柒伍同構貳型",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "禁·風靈作成·柒伍同構貳型"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">召喚物</span></p><p><span style=\"color: #FFFFFF\">結束階段</span>：造成2點風<span style=\"color: rgb(128, 255, 215)\">元素傷害</span>。</p><p><span style=\"color: #FFFFFF\">可用次數：3</span></p><p></p><p><span style=\"color: #FFFFFF\">我方角色或召喚物引發擴散反應後：</span>轉換此牌的元素類型，改爲造成被擴散的元素類型的傷害。（離場前僅限一次）</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/23/84496276/db13288db6b90ec33f8adc2656d2019f_2607461124199714316.png",
                "id": "talent14586",
                "key": "大型風靈",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/23/84496276/b91de96bc6f45b8b9a5b10ab4a127a88_5862197226815983186.png",
                "title": "大型風靈"
              },
              {
                "attributes": [],
                "desc": "<p>和已附著的元素發生元素反應：</p><p>【<span style=\"color: rgb(128, 255, 215)\">風元素</span>+<span style=\"color: rgb(153, 255, 255)\">冰元素</span>】<span style=\"color: rgb(255, 255, 255)\">擴散（冰）</span>：對目標以外的所有敵方角色造成1點<span style=\"color: rgb(153, 255, 255)\">冰元素傷害</span></p><p>【<span style=\"color: rgb(128, 255, 215)\">風元素</span>+<span style=\"color: rgb(128, 192, 255)\">水元素</span>】<span style=\"color: rgb(255, 255, 255)\">擴散（水）</span>：對目標以外的所有敵方角色造成1點<span style=\"color: rgb(128, 192, 255)\">水元素傷害</span></p><p>【<span style=\"color: rgb(128, 255, 215)\">風元素</span>+<span style=\"color: rgb(255, 153, 153)\">火元素</span>】<span style=\"color: rgb(255, 255, 255)\">擴散（火）</span>：對目標以外的所有敵方角色造成1點<span style=\"color: rgb(255, 153, 153)\">火元素傷害</span></p><p>【<span style=\"color: #80FFD7\">風元素</span>+<span style=\"color: rgb(255, 172, 255)\">雷元素</span>】<span style=\"color: rgb(255, 255, 255)\">擴散（雷）</span>：對目標以外的所有敵方角色造成1點<span style=\"color: rgb(255, 172, 255)\">雷元素傷害</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/23/84496276/c97292d96456bfe4abeca16bfce801e4_4732141244504198048.png",
                "id": "talent2689",
                "key": "風元素傷害",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "風元素傷害"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">可用次數</span></strong></p><p>此牌效果觸發後，會消耗一層可用次數；</p><p>可用次數耗盡後，立刻棄置此牌。</p>",
