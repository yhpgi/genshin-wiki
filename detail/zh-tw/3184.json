          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成2點<span style=\"color: #FFFFFF\">物理傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/292125737/26b9736a2d14fc4162b2448963f45695_5210099029278746764.png",
                "id": "talent92684",
                "key": "好運劍",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
