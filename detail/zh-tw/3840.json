          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻擊</span></p><p>造成2點<span style=\"color: #FFFFFF\">物理傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/7998136/241eba6e4c00020975cf91170050f435_7520033987096553807.png",
