            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成2點<span style=\"color: #FFFFFF\">物理傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/292125737/26b9736a2d14fc4162b2448963f45695_4853424795644055813.png",
                "id": "talent47511",
                "key": "西風劍術",
                "materials": [],
