              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">召喚物</span></p><p><span style=\"color: #FFFFFF\">結束階段：</span>造成2點<span style=\"color: rgb(153, 255, 136)\">草元素傷害</span>。</p><p><span style=\"color: #FFFFFF\">可用次數：2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/23/84496276/db13288db6b90ec33f8adc2656d2019f_9141451268977091864.png",
