            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成1點<span style=\"color: #FF9999\">火元素傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/22/84496276/1ce09211f025bf5470682189e0837732_8428216260273986254.png",
                "id": "talent8352",
