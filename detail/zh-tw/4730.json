        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成2點<span style=\"color: rgb(255, 255, 255)\">物理傷害</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/125391187/f0d674be287c96be7066ab5e4e75b0fb_6939903839241665610.png",
                "id": "talent54423",
                "key": "迫牌易位式",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "迫牌易位式"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成3點<span style=\"color: rgb(255, 153, 153)\">火元素傷害</span>。召喚<span style=\"color: rgb(255, 255, 255)\">怪笑貓貓帽</span>，累積1層<span style=\"color: rgb(255, 255, 255)\">隱具餘數</span>。</p><p>如果本角色生命值至少為6，則對自身造成1點<span style=\"color: rgb(255, 255, 255)\">穿透傷害</span>。</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">隱具餘數</span></strong></p><p><span style=\"color: #FFD780\">狀態</span></p><p><span style=\"color: rgb(255, 255, 255)\">隱具餘數</span>最多可以疊加到3層。</p><p><span style=\"color: rgb(255, 255, 255)\">角色使用眩惑光戲法時：</span>每層<span style=\"color: rgb(255, 255, 255)\">隱具餘數</span>使傷害+1。技能結算後，耗盡<span style=\"color: rgb(255, 255, 255)\">隱具餘數</span>，每層治療角色1點。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/125391187/67d6f9d70e695a791caa42953d11e1e3_7883463432074043954.png",
                "id": "talent80922",
                "key": "隱具魔術箭",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "隱具魔術箭"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素戰技</span></p><p>造成3點<span style=\"color: #FF9999\">火元素傷害</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/125391187/053697dd2072f984e7e9b4e118b3dec9_6061252020844861767.png",
                "id": "talent40813",
