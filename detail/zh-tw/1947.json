    {
      "id": "10",
      "name": "故事",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "傳說，璃月過去盛產螭虎魚，是平民最愛吃的魚。</br>但街頭巷尾談論久了，便訛成了「吃虎魚」。</br>如今，真正的螭虎魚已不多見，</br>吃虎魚一詞卻成了璃月人大啖魚肉的代名詞。</br>",
                "id": "story29697",
                "title": ""
              }
            ]
          }
        }
      ]
    },
