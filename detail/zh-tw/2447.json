    {
      "id": "36",
      "name": "對話",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "日常對話⁣⁣⁣⁣",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "妳/你來了。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "是來比試的嗎？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "對話1（遊戲時間02:00-23:59）：",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "準備接招吧。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "很好，來吧。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "對話1（遊戲時間00:00-01:59）：",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "準備接招吧。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "很好，來吧。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "此刻海風正好，「貴月胴切」也在興奮地躁動。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "呵呵，我的興致來了，會拿出不同於以往的力量應戰，妳/你做好準備吧。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "對話1-1：",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)",
                        "italic"
                      ],
                      "text": "挑戰成功",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "呵呵，竟然還是贏不過妳/你。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "也罷，妳/你的武藝仍在精進，我卻因為心性所限再也悟不出更高深的奧義了。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "不過，若妳/你習得了新的技藝，我依然樂於見識。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "那麽，下次再會吧。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "對話1-2：",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)",
                        "italic"
                      ],
                      "text": "挑戰失敗",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "看來妳/你近日來疏於練習。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "武者稍有一日怠惰便浪費了十日的勤勉，這個道理，妳/你應該知道。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "回去磨練自己吧，妳/你不該只有這點本事。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "對話2：",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "想和你說說話。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "我放棄了自己的過去，今後也不想再對這個世界訴說些什麽了。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "只想找人聊天的話，妳/你不該找我。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "「公義」：",
                      "type": "text"
                    },
                    {
                      "text": "妳/你走吧。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
