    {
      "id": "25",
      "name": "更多訊息",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "audios": [],
                "desc": "<p>協會認證牌手田鐵嘴。璃月的說書人，因為經常看來聽評書的客人玩牌，而對「七聖召喚」的牌局有相當高段的理解。</p>",
                "id": "更多訊息10415",
                "img": "",
                "name": "地圖文本",
                "order": 2,
                "sortId": "更多訊息10415",
                "title": "地圖文本"
              },
              {
                "artifactPos": "",
                "audios": [],
                "desc": "<p>說書人田鐵嘴所贈的摺扇掛飾，扇面繪有田鐵嘴說書名段《創龍點睛》中的傳奇畫面。傳說中，岩王帝君以靈石雕出若陀龍王後，為其點上雙目以汲天地靈魄，剎那間真龍出世。</p>",
                "id": "更多訊息24218",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/28/84496276/2e209907078c80555240efc048c0368d_3666102826662310657.png",
                "name": "「創龍點睛奇象」",
                "order": 1,
                "sortId": "更多訊息24218",
                "title": "「創龍點睛奇象」"
              }
            ]
          }
        }
      ]
    },
