                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/05/157749474/7f04e9d0b83ab550cc91ddf708008a7d_3962428389587493975.png",
                      "name": "瑪麗安·吉約丹",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
