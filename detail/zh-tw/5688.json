              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素戰技</span></p><p>造成3點<span style=\"color: rgb(128, 255, 215)\">風元素傷害</span>，抽1張牌。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/25/125391187/c810824214ed1ed7d4c4519a109c0ba5_6530786908738716528.png",
