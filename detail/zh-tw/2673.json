              "key": "circlet_of_logos",
              "posKey": "circlet_of_logos",
              "posName": "理之冠",
              "position": "理之冠",
              "title": "沙王的投影"
            },
            "flower_of_life": {
              "desc": "<p>暗金打造的蓓蕾，再無機會開放的花瓣包裹著赤紅的花芯。</p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/26/7998136/ae8a2c6f24df66e1bd7cc2dbd83d330d_4462363939857277268.png",
