      "components": [
        {
          "component_id": "artifact_list",
          "data": {
            "circlet_of_logos": {
              "desc": "<p>舊日沙漠祭司的鑲金頭巾，其形制乃是為了效仿傳說中的沙民之王。</p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/26/7998136/892e17a4a5d0b9438bf3581d88bf209e_9149444117290903536.png",
