              "posKey": "flower_of_life",
              "posName": "生之花",
              "position": "生之花",
              "title": "夢中的鐵花"
            },
            "goblet_of_eonothem": {
              "desc": "<p>曾在古老盛大的宴會上使用的酒杯，褪去了往日華麗的顏色。</p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/26/7998136/3668bbfcc8d7242aa295b7e073e71d9f_6801647359094414328.png",
