            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成2點<span style=\"color: #FFFFFF\">物理傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/181140897/47817b4476bcd8b44c86c87debf042f2_8339069469532019112.png",
