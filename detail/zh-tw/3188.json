            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻擊</span></p><p>造成2點<span style=\"color: #FFFFFF\">物理傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/285626729/c369b96fc6417e8fc2bb607e37297ad4_3078433402262366241.png",
                "id": "talent90606",
                "key": "罪滅之矢",
                "materials": [],
                "points": [
