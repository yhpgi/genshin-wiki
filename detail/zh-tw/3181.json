                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "逆焰之刃"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆發</span></p><p>造成8點<span style=\"color: rgb(255, 153, 153)\">火元素傷害</span>，本角色附屬<span style=\"color: rgb(255, 153, 153)\">火元素附魔</span>。</p><p></p><p><strong><span style=\"color: #FFFFFF\">火元素附魔</span></strong></p><p><span style=\"color: #FFD780\">狀態</span></p><p>所附屬角色造成的<span style=\"color: #FFFFFF\">物理傷害</span>，變爲<span style=\"color: #FF9999\">火元素傷害</span>。</p><p><span style=\"color: #FFFFFF\">持續回合：2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/292125737/7f35364dc83b6694a3200aae53f6670f_7818726193858846184.png",
                "id": "talent60904",
                "key": "黎明",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "黎明"
              },
              {
                "attributes": [],
                "desc": "<p>附著<span style=\"color: rgb(255, 153, 153)\">火元素</span>，可發生元素反應：</p><p>【<span style=\"color: rgb(255, 153, 153)\">火元素+</span><span style=\"color: rgb(153, 255, 255)\">冰元素</span>】<span style=\"color: rgb(255, 255, 255)\">融化</span>：本傷害+2</p><p>【<span style=\"color: rgb(255, 153, 153)\">火元素</span>+<span style=\"color: rgb(128, 192, 255)\">水元素</span>】<span style=\"color: rgb(255, 255, 255)\">蒸發</span>：本傷害+2</p><p>【<span style=\"color: rgb(255, 153, 153)\">火元素</span>+<span style=\"color: rgb(255, 172, 255)\">雷元素</span>】<span style=\"color: rgb(255, 255, 255)\">超載</span>：本傷害+2，目標強制切換到下一個角色</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/23/84496276/d714b3b669cc08d1d8e34464fd7a3630_294743599819144172.png",
                "id": "talent3541",
                "key": "火元素傷害·其一",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "火元素傷害·其一"
              },
              {
                "attributes": [],
                "desc": "<p>附著<span style=\"color: rgb(255, 153, 153)\">火元素</span>，可發生元素反應：</p><p>【<span style=\"color: rgb(255, 153, 153)\">火元素</span>+<span style=\"color: rgb(153, 255, 136)\">草元素</span>】<span style=\"color: rgb(255, 255, 255)\">燃燒</span>：本傷害+1，召喚<span style=\"color: rgb(255, 255, 255)\">燃燒烈焰</span></p><p><span style=\"color: rgb(255, 215, 128)\"><br></span><strong><span style=\"color: rgb(255, 255, 255)\">燃燒烈焰</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">召喚物</span></p><p><span style=\"color: rgb(255, 255, 255)\">結束階段：</span>造成1點<span style=\"color: rgb(255, 153, 153)\">火元素傷害</span>。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次數：1，最多叠加到2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/23/84496276/d714b3b669cc08d1d8e34464fd7a3630_6561662928639372763.png",
                "id": "talent33198",
                "key": "火元素傷害·其二",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/23/84496276/3c3362a64ac984342133762388c9eb41_2081888945642630150.png",
                "title": "火元素傷害·其二"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">物理傷害</span></strong></p><p>物理傷害不會附著元素，也不會發生元素反應。</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">持續回合</span></strong></p><p>每回合結束階段，持續回合-1；</p><p>持續回合耗盡後，立刻棄置此牌。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/23/84496276/07bae546ac7c69ef6402170b283840c5_6474324292056903802.png",
