              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素戰技</span></p><p>造成3點<span style=\"color: #FFACFF\">雷元素傷害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/292125737/c5f5c789f46baf1c0c0ff52d5feabe9a_996448997042161501.png",
