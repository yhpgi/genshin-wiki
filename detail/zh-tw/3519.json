                      "ep_id": 3521,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/7998136/61275d8b97a9c5e4055ed07a4d34c4fa_4971785901129253440.png",
                      "name": "浮舍",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3518,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/7998136/2a70abcd41f1c25b94da6c18901fc863_7894191907524225366.png",
                      "name": "彌怒",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3520,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/7998136/7280f8fc2afecab369f640ed8370390d_6200798172196515158.png",
                      "name": "應達",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2314,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/book/Yakshas: The Guardian Adepti_icon.png",
                      "name": "護法仙眾夜叉錄",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
