    {
      "id": "25",
      "name": "更多訊息",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "audios": [],
                "desc": "<p>協會認證的牌手艾琳。渴望成為騎士的少女，經常在蒙德城內進行建樹的練習。不管是為了成為西風騎士，還是獲得牌局的勝利，好好思考都是很重要的。</p>",
                "id": "更多訊息85667",
                "img": "",
                "title": "地圖文本"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "32",
