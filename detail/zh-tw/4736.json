              },
              {
                "attributes": [],
                "desc": "<p>【被動】<span style=\"color: #FFFFFF\">此角色受到傷害後：</span>如果此角色生命值不多於7，則獲得1點<span style=\"color: #FFFFFF\">充能</span>。（整場牌局限制1次）</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/27/125391187/eb96a0e1f4fd6ddf6d0975dfcf1fed10_1818852856616204091.png",
