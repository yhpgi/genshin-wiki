                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/05/157749474/be516a2c9005727dcfd1fe45662a826d_3682068746055334164.png",
                      "name": "卡特皮拉",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
