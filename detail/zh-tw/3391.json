                      "ep_id": 3195,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/285626729/fabb347ed25053eb8fa6947980cf514a_5682299898784811088.png",
                      "menu_id": 17,
                      "name": "藏镜仕女",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3182,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/285626729/6219bf1fb0b7c46b8ecf960443f737d5_2536850083560578410.png",
                      "menu_id": 17,
                      "name": "香菱",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "解鎖要求",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "「牌手等級」到達1級",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "獲勝獎勵",
