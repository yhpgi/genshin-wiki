              "title": "流放者頭冠"
            },
            "flower_of_life": {
              "desc": "帶在身上的黯淡的花。是流放之身也要帶著，一定有重要的意義吧。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/The Exile/flower_of_life_icon.png",
              "position": "生之花",
              "title": "流放者之花"
            },
            "goblet_of_eonothem": {
              "desc": "黯淡的重金屬製成的杯形器皿，可以看出外壁上原本鑲有寶石，又被挖掉了。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/The Exile/goblet_of_eonothem_icon.png",
