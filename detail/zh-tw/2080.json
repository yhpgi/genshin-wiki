              "title": "流放者之杯"
            },
            "plume_of_death": {
              "desc": "並不是刻意的裝飾物，只是在荒野流浪中偶然沾上的不知名的鳥羽。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/The Exile/plume_of_death_icon.png",
              "position": "死之羽",
              "title": "流放者之羽"
            },
            "sands_of_eon": {
              "desc": "水晶製成的錶鏡已經破碎，連錶針也全數脫落，但仍然不願丟棄。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/The Exile/sands_of_eon_icon.png",
