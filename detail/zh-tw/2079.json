              "position": "理之冠",
              "title": "酒漬船帽"
            },
            "flower_of_life": {
              "desc": "色澤暗淡的斗篷別針。原本鍍上的金色已經被海風磨去。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Heart of Depth/flower_of_life_icon.png",
              "position": "生之花",
              "title": "飾金胸花"
            },
            "goblet_of_eonothem": {
              "desc": "無心打撈上來的褪色酒盞，暗淡的外觀呢喃著海波之底的往日。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Heart of Depth/goblet_of_eonothem_icon.png",
