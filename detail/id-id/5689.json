                    {
                      "amount": 1,
                      "display_style": "text",
                      "ep_id": 3331,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/26/25750596/03b60aec345461dae970832766ebacf8_2042005238006202277.png",
