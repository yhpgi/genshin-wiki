                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Genius Invokation TCG Stage",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Tantangan Tavern: Persahabatan - Kontemplasi Penjaga Oasis",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Pengenalan Stage",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Meong...\" \"Ada beberapa kucing yang bisa merasakan keagungan, jadi mereka akan menjaga jarak dan menghormati tempat sakral. Bahkan saking takutnya membuat gaduh, mereka bahkan tidak berani membuat suara langkah kaki ....\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Aturan Khusus: Lawanmu kali ini akan \"berduel\" denganmu, dan ini bukanlah \"Tantangan Petualangan\". Guardian of Apep's Oasis kebal terhadap Frozen, Stun, serta Petrification, dan akan memulai duel dengan mengenakan Kartu Talenta \"A Thousand Young\". Setiap kali Ronde dimulai, akan memulihkan 1 HP diri sendiri dan membuang 1 kartu \"Awaken, My Kindred\" dari Tangan.",
                      "type": "text"
                    }
