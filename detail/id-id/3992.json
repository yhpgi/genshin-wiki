    {
      "id": "30",
      "name": "Informasi lainnya",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Armored Crablord yang telah bertahan hidup selama berabad-abad dan berhasil melampaui seluruh Fontemer Aberrant lainnya. </span><strong><span style=\"color: rgb(255, 225, 75)\">Sepasang tanduk berapi meleleh</span></strong><span style=\"color: rgb(236, 228, 217)\"> di kepalanya mengandung </span><strong><span style=\"color: rgb(255, 225, 75)\">Pyro</span></strong><span style=\"color: rgb(236, 228, 217)\">, dapat melancarkan serangan elemen lebih ganas serta memberikan kemampuan bertahan yang lebih kuat. Saat Armored Crablord melancarkan serangan tertentu, sepasang tanduk berapi meleleh itu </span><strong><span style=\"color: rgb(255, 225, 75)\">akan mendekat ke permukaan tanah</span></strong><span style=\"color: rgb(236, 228, 217)\">. Manfaatkan kesempatan ini dan gunakan </span><strong><span style=\"color: rgb(255, 225, 75)\">Reaksi Elemental</span></strong><span style=\"color: rgb(236, 228, 217)\"> untuk menghilangkan elemen Pyro-nya.</span></p>",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/01/1023623/a3fc2e7f905b3b3bc14a72236ffa171a_914378218298274910.png",
                "title": "Tutorial"
              }
            ]
          }
        }
      ]
