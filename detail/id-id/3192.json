          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Attack</span></p><p>Mengakibatkan 2 poin <span style=\"color: #FFFFFF\">Physical DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/1023623/26b9736a2d14fc4162b2448963f45695_5734320474742285899.png",
