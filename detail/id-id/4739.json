                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "*Memiliki 25 HP",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
