                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Aturan Khusus: \"Hydro Hilichurl Rogue\" akan memulai duel dengan memiliki 2 poin Energy.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
