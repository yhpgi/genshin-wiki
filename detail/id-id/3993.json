    {
      "id": "30",
      "name": "Informasi lainnya",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Pertunjukan mewah yang disajikan oleh Maillardet dari Institut Penelitian Fontaine dengan menggunakan Clockwork Meka Coppelia dan Coppelius. Sebelum memulai tantangan, kamu harus </span><strong><span style=\"color: rgb(255, 225, 75)\">berbicara dengan Maillardet</span></strong><span style=\"color: rgb(236, 228, 217)\"> dulu dan memilih pertunjukan yang ingin ditantang. Setelah menyelesaikan tantangan, sumber daya yang dihasilkan oleh </span><strong><span style=\"color: rgb(255, 225, 75)\">Ley Line Blossom</span></strong><span style=\"color: rgb(236, 228, 217)\"> akan berkaitan dengan pertunjukan yang ditantang.</span></p>",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/01/1023623/c2d634770bef2f62aae8a5f671d92879_6609661026216920963.png",
                "title": "Tutorial 1"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Dirge of Coppelia: Karakter utama merupakan gadis robot dengan mekanisme roda gigi bernama Coppelia. Saat mencapai fase puncak pada pertunjukan, Coppelia akan berhenti di tengah lantai dansa dan memperlihatkan komponen roda gigi buatan yang terisi oleh energi </span><strong><span style=\"color: rgb(255, 225, 75)\">Ousia</span></strong><span style=\"color: rgb(236, 228, 217)\"> untuk meningkatkan efisiensi pertempurannya, dan memanggil angin topan yang tak terhitung jumlahnya untuk mengantar kematian.</span></p>",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/01/1023623/f4234c328129c61312779036ff1c7f04_4606273620486180529.png",
                "title": "Tutorial 2"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Nemesis of Coppelius: Karakter utama merupakan aristokrat robot dengan mekanisme roda gigi bernama Coppelius. Saat mencapai fase puncak pada pertunjukan, Coppelius akan berhenti di tengah lantai dansa dan memperlihatkan komponen roda gigi buatan yang terisi oleh energi </span><strong><span style=\"color: rgb(255, 225, 75)\">Pneuma</span></strong><span style=\"color: rgb(236, 228, 217)\"> untuk meningkatkan efisiensi pertempurannya, memanggil tiga buah Frostheart, dan membentuk perisai untuk diri sendiri.</span></p>",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/01/1023623/baefdc25f8798e6b6bd9f5e5d313460e_5916678014738755023.png",
                "title": "Tutorial 3"
              }
            ]
          }
        }
      ]
    },
