                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Genius Invokation TCG Stage",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Tantangan Tavern: Persahabatan - Pelayaran",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "All-Devouring Narwhal",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Pengenalan Stage",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Miau.\" \"Sebagian besar kucing takut tercebur ke air, apalagi ke danau dan lautan. Makhluk raksasa yang bersembunyi di kedalaman air, pasti akan membuat kucing yang sadar akan keberadaannya menjadi panik dan kabur.\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ff9999"
                      ],
                      "text": "Aturan Khusus: Lawanmu kali ini akan \"berduel\" denganmu, dan ini bukanlah \"Tantangan Petualangan\". All-Devouring Narwhal kebal terhadap Frozen, Stun, serta Petrification, dan akan memulai duel dengan mengenakan Kartu Talenta \"Lightless Feeding\". Setiap kali Ronde dimulai, akan membuang 1 kartu dari Tangan.",
                      "type": "text"
