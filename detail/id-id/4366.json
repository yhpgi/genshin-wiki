          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Attack</span><br>Mengakibatkan 2 poin <span style=\"color: rgb(255, 255, 255)\">Physical DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/25/25750596/241eba6e4c00020975cf91170050f435_3718385389421337731.png",
