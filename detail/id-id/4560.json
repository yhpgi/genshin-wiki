              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Burst</span></p><p>Mengakibatkan 1 poin <span style=\"color: rgb(255, 172, 255)\">Electro DMG</span> dan memanggil <span style=\"color: rgb(255, 255, 255)\">Jinni</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/09/15595270/9858bca5debb2537f7499d5999cf8424_3284906754426685827.png",
