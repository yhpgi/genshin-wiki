                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Pengenalan Stage",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Aku sudah siap kali ini. Akan kutunjukkan padamu kemajuanku!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
