                "title": "Pyronado"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Panggilan</span><br><span style=\"color: rgb(255, 255, 255)\">Tahap Selesai</span>: Mengakibatkan 2 <span style=\"color: rgb(255, 153, 153)\">Pyro DMG</span>.<br><span style=\"color: rgb(255, 255, 255)\">Penggunaan: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/15/25750596/db13288db6b90ec33f8adc2656d2019f_6827735983076426957.png",
