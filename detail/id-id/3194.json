          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Attack</span></p><p>Mengakibatkan 1 poin <span style=\"color: rgb(128, 192, 255)\">Hydro DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/1023623/1ce09211f025bf5470682189e0837732_6752908406890202406.png",
