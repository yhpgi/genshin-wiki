                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Oceanid Mimic Summoning"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p>Memanggil 2 <span style=\"color: rgb(255, 255, 255)\">Oceanid Mimic</span> secara acak.</p><p>(Mengutamakan pemanggilan tipe yang berbeda, hanya 2 jenis Oceanid Mimic yang dapat muncul di Zona Panggilan dalam waktu bersamaan)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/25750596/b94e2c26e1f09a4ad1c7ffc224f6f0ad_4305829883188239042.png",
