              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Panggilan</span></p><p><span style=\"color: rgb(255, 255, 255)\">Tahap Selesai:</span> Mengakibatkan 1 <span style=\"color: rgb(128, 192, 255)\">Hydro DMG</span></p><p><span style=\"color: rgb(255, 255, 255)\">Penggunaan: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/15/25750596/db13288db6b90ec33f8adc2656d2019f_8472302640550550362.png",
                "id": "talent56874",
                "key": "Hydro Mimic Raptor",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
