                ],
                "talent_img": "",
                "title": "The Myriad Wilds"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Burst</span></p><p>Mengakibatkan 4 poin <span style=\"color: rgb(128, 192, 255)\">Hydro DMG</span>. Untuk setiap Panggilan yang ada di Zona Panggilanmu, mengakibatkan DMG +1 tambahan.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/1023623/691eab78e5923e0f25d72843ef295e1d_5143831477612879616.png",
