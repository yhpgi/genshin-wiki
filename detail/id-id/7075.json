                      ],
                      "text": "Hubungan",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Karakter",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ringkasan",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4912,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/03/237301566/513d51e0ebfd54f5da34a9f85dfaf61f_4293187669096717509.png",
                      "menu_id": 10,
                      "name": "Набу Маликата",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Para Jinni adalah familiar Nabu Malikata.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4911,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/03/237301566/513d51e0ebfd54f5da34a9f85dfaf61f_2834910047270303942.png",
                      "menu_id": 10,
                      "name": "Аль-Ахмар",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Setelah kematian Nabu Malikata, Al-Ahmar berjanji kepada para Jinni bahwa majikan mereka ditakdirkan untuk terbangun suatu hari nanti, sehingga mereka mulai mengabdi kepadanya.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ay-Khanoum",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Kota Gadis Rembulan\", yang dibangun oleh Nabu Malikata dan Al-Ahmar untuk para Jinni.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Gurabad",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Sebuah kota yang bangkit dan runtuh di bawah pengaruh Ibu para Jinni, Liloupar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ormazd",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Seorang gembala yang menjadi penguasa Gurabad di bawah pengaruh Liloupar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Shirin",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kisra Parvezravan",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Anak Liloupar.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Shiruyeh",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Cucu Liloupar, putra Shirin dan Kisra, penyebab terjadinya bencana wabah yang disebut “Penyakit Shiruyeh.”",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Hubungan Jinni Terkenal",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Karakter",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ringkasan",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3530,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/06/237301566/919fe68dc22d6d80b3a8118ce6c80491_7611509035816815714.png",
                      "menu_id": 10,
                      "name": "Лилупар",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ibu dari para Jinni memberikan kekuatan kepada Ormazd untuk memerintah Gurabad dan menyebabkan kejatuhannya.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ferigees",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Penjaga Kota Gadis Rembulan dan Ibu para Jinni yang menjadi segel di Oasis Abadi.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Item/Buku Terkait",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
