    {
      "id": "25",
      "name": "Informasi lainnya",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Langit malam itu bermekaran dengan bunga-bunga,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bintang-bintang malam itu bersenandung seperti lebah,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Mencari nektar dan mimpi.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Dan kami, malam itu, masih baru seperti embun,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Di bawah sinar bulan yang mengalir seperti madu sutra,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Kata-kata kita manis saat kita duduk di dekat mata air.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Tapi aku berbalik dan meninggalkanmu sendirian,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Puisi dalam hatiku tak terucapkan.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Dan sejak saat itu,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Bintang-bintang tidak berkelap-kelip, bulan sedingin es.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Aku menyembunyikan mereka di dalam air,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Tapi air matamu jatuh dan menemukan mereka.</span></p>",
                "title": "Puisi tentang di Atas Daun yang Jatuh"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Keinginan itu tetap ada, tetapi waktunya sudah lewat.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Anak laki-laki di musim semi tumbuh terlalu cepat.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Tapi ketika mimpi mengalir menjadi kenyataan, di mana aliran sungai bergabung dengan laut,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Kami akan melakukan perjalanan dalam lamunan tak berujung.</span></p>",
                "title": "Puisi tentang di Atas Daun yang Jatuh"
              }
            ]
          }
        }
      ]
    },
