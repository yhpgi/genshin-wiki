    {
      "id": "30",
      "name": "Informasi lainnya",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Monster kegelapan yang berasal dari kegelapan Abyss, yang menggerogoti ingatan daratan. Dia bisa membengkokkan dirinya dan berubah menjadi musuh yang kuat. Sebagian serangannya akan bisa memberikan status Attrition, setelah satu kurun waktu, akan membuat Karakter aktif diri sendiri kehilangan HP. Di dalam pertempuran, Tenebrous Papilla akan menggunakan Beseech the Dark untuk memberikan Pelindung Void kepada dirinya sendiri. Pada saat ini, manfaatkanlah </span><strong><span style=\"color: rgb(255, 225, 75)\">serangan elemen selama beberapa kali</span></strong><span style=\"color: rgb(236, 228, 217)\"> untuk menghancurkan Pelindungnya, dan membuatnya menjadi bingung. Gunakan </span><strong><span style=\"color: rgb(255, 225, 75)\">serangan Nightsoul-aligned</span></strong><span style=\"color: rgb(236, 228, 217)\"> untuk menghancurkan Pelindung-nya dengan lebih efektif.</span></p>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/10/1023623/cd1607ba79168be8221c18f858c3b143_5545344365809874188.png",
                "title": "Tutorial"
              }
            ]
          }
        }
      ]
