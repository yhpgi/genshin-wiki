              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Burst</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Mengakibatkan 2 poin </span><span style=\"color: rgb(153, 255, 136)\">Dendro DMG</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> dan memanggil </span><span style=\"color: rgb(255, 255, 255)\">Cuilein-Anbar</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/1023623/b1519a139b4737aaa5e6844da801d167_5792677638383272266.png",
