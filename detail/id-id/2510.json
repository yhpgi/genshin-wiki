    {
      "id": "68",
      "name": "Percakapan",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/13/1023623/cf06082c02d01632b14b6c179b129f9c_340622289051174345.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Khedive",
                      "type": "text"
                    },
                    {
                      "text": ": Oh, aku pikir kamu sudah pergi. Halo (Nama Pengembara).",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Khedive",
                      "type": "text"
                    },
                    {
                      "text": ": Data energi yang terbaca sudah mulai stabil. Terima kasih atas kerja kerasmu. Aku pasti akan tulis namamu di dalam tesis.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Khedive",
                      "type": "text"
                    },
                    {
                      "text": ": Tapi sebagai penyandang gelar ketua regu penjelajahan, aku masih harus tinggal di sini untuk jangka panjang dan mengawasi perubahan yang mungkin terjadi.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "➥ Jadi, gimana penelitianmu?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Khedive",
                      "type": "text"
                    },
                    {
                      "text": ": Karena kamu sudah membantuku begitu banyak, mungkin tidak apa-apa kalau aku memberitahumu sedikit tentangnya.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Khedive",
                      "type": "text"
                    },
                    {
                      "text": ": Kami datang ke sini untuk memantau anomali energi yang terus merembes keluar dari dalam jurang dan mempelajari efek yang mereka punya terhadap Chasm.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Khedive",
                      "type": "text"
                    },
                    {
                      "text": ": Tapi, sepertinya sekarang sudah jelas kalau situasi yang kita hadapi lebih rumit dari yanng kita bayangkan.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Khedive",
                      "type": "text"
                    },
                    {
                      "text": ": Kalau bukan karena keberanian kalian, aku ragu kami akan mendapatkan data sebanyak ini.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "➥ Aku pergi dulu.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Khedive",
                      "type": "text"
                    },
                    {
                      "text": ": Aku tidak akan memaksamu untuk tinggal. Tapi regu penjelajahan akan selalu menyambutmu.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
