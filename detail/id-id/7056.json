    {
      "id": "30",
      "name": "Informasi lainnya",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Mesin dengan daya hancur yang sangat kuat. Saat Karakter memasuki dan mempertahankan status Nightsoul&#39;s Blessing, Secret Source Automaton: Configuration Device akan mengakumulasi kemajuan efek Adaptive Countermeasures miliknya. Setelah penuh, dia akan mulai mempersiapkan Boltsphere Cannon. Dalam fase ini, Configuration Device akan mengaktifkan Accretion Mechanism untuk menggali Phlogiston padat dan mengumpulkan Phlogiston. Accretion Mechanism sendiri akan menghasilkan sebuah medan energi. Jika kamu ingin menghancurkan Accretion Mechanism untuk menghentikan pengumpulan energi Boltsphere Cannon, maka </span><strong><span style=\"color: rgb(255, 225, 75)\">kamu harus memanjat Phlogiston padat dan masuk ke medan energinya dulu</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/07/1023623/732f10fa3208822128adc0745000d5a1_4380032614674933804.png",
                "title": "Tutorial"
              }
            ]
          }
        }
      ]
