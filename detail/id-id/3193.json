                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Pengenalan Stage",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Aku telah menjalankan aturan dengan hati, dan aku juga telah mengumpulkan banyak data eksperimental dari pertandinganku. Aku tidak boleh kalah kali ini ....\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
