    {
      "id": "68",
      "name": "Percakapan",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/13/1023623/d871a1095e53374d6e29eb804f73f59d_8006600957403985654.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Taliesin",
                      "type": "text"
                    },
                    {
                      "text": ": Maaf ... aku sedikit pusing, tapi aku masih kuat kok. Duh ....",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "➥ Kamu ngapain disini?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Taliesin",
                      "type": "text"
                    },
                    {
                      "text": ": Aku kan penyair aliran lama, tentu saja datang untuk mencari inspirasi dong.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Taliesin",
                      "type": "text"
                    },
                    {
                      "text": ": Yah, tapi aku memang belum pernah turun ke tambang. Lalu aku juga agak rusuh waktu menuju ke sini, dan akhirnya aku ... keseleo.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Taliesin",
                      "type": "text"
                    },
                    {
                      "text": ": Aduh-duh-duh-duh ....",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "➥ Aku tidak ganggu deh.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Taliesin",
                      "type": "text"
                    },
                    {
                      "text": ": Ah, hati-hati dijalan. Kalau ada cerita baru, tolong beri tahu ya!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
