            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Attack</span><br>Mengakibatkan 2 poin <span style=\"color: rgb(255, 255, 255)\">Physical DMG</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/25750596/ad8a357fa8480f61f3fe665b69d9c263_2531736447284949209.png",
                "id": "talent95806",
                "key": "Ripping Fang Fletchling",
                "materials": [],
                "points": [
                  {
