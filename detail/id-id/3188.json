              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Mengakibatkan 1 poin </span><span style=\"color: rgb(255, 172, 255)\">Electro DMG</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> dan memanggil </span><span style=\"color: rgb(255, 255, 255)\">Oz</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/1023623/7521cde834fa3119ec5a1a10ea5bce58_5011140413575939518.png",
