                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Nightrider"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Burst</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Mengakibatkan 4 poin </span><span style=\"color: rgb(255, 172, 255)\">Electro DMG</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, mengakibatkan 2 poin </span><span style=\"color: rgb(255, 255, 255)\">Piercing DMG</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> ke seluruh Karakter standby lawan.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/1023623/aa84d77a03ee4e755a8df65d62146b13_4911218925745544770.png",
                "id": "talent7499",
                "key": "Midnight Phantasmagoria",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Midnight Phantasmagoria"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Panggilan</span><br><span style=\"color: rgb(255, 255, 255)\">Tahap Selesai</span>: Mengakibatkan 1 <span style=\"color: rgb(255, 172, 255)\">Electro DMG</span>.<br><span style=\"color: rgb(255, 255, 255)\">Penggunaan: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/15/25750596/db13288db6b90ec33f8adc2656d2019f_2313847616091823473.png",
                "id": "talent66146",
                "key": "Oz",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/15/25750596/6a5ec549833ce08e3439c207909b0bdb_4478965163203163937.png",
                "title": "Oz"
              },
              {
                "attributes": [],
                "desc": "<p>Memberikan Electro dan dapat memicu Reaksi Elemental berikut:</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Overloaded</span>: DMG +2 poin untuk kasus ini, target berganti ke Karakter selanjutnya secara paksa</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">Superconduct</span>: DMG +1 poin untuk kasus ini, mengakibatkan 1 Piercing DMG kepada seluruh Karakter lawan selain daripada target</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Electro-Charged</span>: DMG +1 poin untuk kasus ini, mengakibatkan 1 Piercing DMG kepada seluruh Karakter lawan selain daripada target</p><p>[<span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span>] <span style=\"color: rgb(255, 255, 255)\">Quicken</span>: DMG +1 poin untuk kasus ini, menciptakan [<span style=\"color: rgb(255, 255, 255)\">Catalyzing Field</span>] yang memberikan +1 poin DMG ke 2 kasus Dendro DMG atau Electro DMG berikutnya</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/15/25750596/11ea6117480145a30b7893f1e8bd7115_6419046122862455431.png",
                "id": "talent2689",
                "key": "Electro DMG",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Electro DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Physical DMG</span></strong></p><p>Physical DMG tidak dapat memberikan elemen apa pun dan memicu Reaksi Elemental.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Piercing DMG</span></strong></p><p>Piercing DMG tidak dapat dipengaruhi oleh Bonus DMG apa pun, namun tidak dapat ditahan oleh efek seperti Perisai atau kekebalan DMG.<br><br><strong><span style=\"color: rgb(236, 229, 216)\">Penggunaan</span></strong></p><p>Setelah efek kartu ini dipicu, 1 <span style=\"color: rgb(255, 255, 255)\">Penggunaan</span>-nya akan dikonsumsi.</p><p>Kartu ini akan langsung dibuang setelah semua <span style=\"color: rgb(255, 255, 255)\">Penggunaan</span> telah dikonsumsi.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/04/25750596/245c229cf6f7364c7c9a7aea3db1a1ad_3462197112441573791.png",
