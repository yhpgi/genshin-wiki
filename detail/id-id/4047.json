    {
      "id": "30",
      "name": "Informasi lainnya",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Mesin yang dibuat untuk menambal kekurangan energi mekanisme roda gigi dan meningkatkan efisiensi kerja. Berdasarkan ciri khas energi </span><strong><span style=\"color: rgb(255, 225, 75)\">Ousia atau Pneuma</span></strong><span style=\"color: rgb(236, 228, 217)\">-nya yang terlihat dari luar, bisa memberikan buff yang berbeda dan menghasilkan energi secara berkala, sehingga bisa </span><strong><span style=\"color: rgb(255, 225, 75)\">memulihkan energi</span></strong><span style=\"color: rgb(236, 228, 217)\"> mekanisme roda gigi yang hampir rusak di sekitar yang memiliki ciri khas sama. Setelah dihancurkan oleh </span><strong><span style=\"color: rgb(255, 225, 75)\">serangan yang berlawanan</span></strong><span style=\"color: rgb(236, 228, 217)\">, akan kehilangan energi karena kelebihan daya, dan akan membutuhkan waktu untuk memperbaiki dirinya sendiri sebelum akhirnya bisa memulihkan fungsi pembangkit energinya lagi.</span></p>",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/02/1023623/c24684238d3e898f5f41751d14f84a30_2461936742005744889.png",
