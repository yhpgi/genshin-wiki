                "talent_img": "",
                "title": "Prowl"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Burst</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Mengakibatkan 5 poin </span><span style=\"color: rgb(255, 153, 153)\">Pyro DMG</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/1023623/9d7849a60fd861aa8dd811f90ab22d02_8316549904926537098.png",
                "id": "talent79684",
