            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Hewan air yang menapaki jalur evolusi yang unik karena faktor lingkungan di Fontaine. Dengan bantuan </span><strong><span style=\"color: rgb(255, 225, 75)\">Electro</span></strong><span style=\"color: rgb(236, 228, 217)\">, dia akan bisa melancarkan serangan elemen yang lebih kuat dan memiliki kemampuan bertahan yang lebih kuat. Jika bisa menggunakan </span><strong><span style=\"color: rgb(255, 225, 75)\">reaksi elemental</span></strong><span style=\"color: rgb(236, 228, 217)\"> untuk menghancurkan perisainya, mungkin akan bisa dikalahkan lebih mudah.</span></p>",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/02/1023623/7a600e5de85bb5cbf3d17be859d55ca8_411251988409081451.png",
