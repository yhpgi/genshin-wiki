          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Wayward Hermetic Spiritspeaker dapat memanggil Radiant Reflection yang sama persis dengan dirinya dan bersembunyi di antaranya. Pada saat ini, </span><strong><span style=\"color: rgb(255, 225, 75)\">seranglah seluruh Pelindung Elemental Radiant Reflection</span></strong><span style=\"color: rgb(236, 228, 217)\"> untuk membuatnya menampakkan jati dirinya dan kelemahannya. Selain itu, Iktomisaurus dan Karakter Penguasa Angin Malam bisa </span><strong><span style=\"color: rgb(255, 225, 75)\">menggunakan Mode Tahan dan membidik Radiant Reflection</span></strong><span style=\"color: rgb(236, 228, 217)\"> untuk membuat gerakannya berhenti sesaat ....</span></p>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/01/13/1023623/193d92e11eae035d8554dee33ce6cbc8_2749974011865677337.png",
