                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Estrellas del crepúsculo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFE699\">Carta de equipamiento</span></p><p><span style=\"color: #FFFFFF\">Técnica especial</span>: Potenciación adépttica.</p><p><span style=\"color: #FFFFFF\">Número de usos: 2.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.25)\">Cada personaje solo puede llevar equipada 1 técnica especial.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/12/73555894/db13288db6b90ec33f8adc2656d2019f_6224668078292657538.png",
