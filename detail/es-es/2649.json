              {
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/07/10742394/88ee4f61d5e227b415f519100bebbcfa_8574548643483177736.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Estos misteriosos espíritus se llaman “electrógranos”. Salen de las ramas de los Cerezos del Trueno y simbolizan la protección del elemento Electro.</span></p>",
                "key": "Tip #1"
              },
              {
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/07/10742394/e223c115fbe468127b48c9d86638d985_3073696623204611153.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Los electrógranos tienen todo tipo de poderes. Al llevarlos contigo, puedes </span><span style=\"color: #FFE14B\">usar rayos globulares para moverte rápidamente</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, entrar en las </span><span style=\"color: #FFE14B\">barreras electrificadas</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e incluso resistir </span><span style=\"color: #FFE14B\">zonas eléctricas</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "key": "Tip #2"
              },
              {
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/07/10742394/39a26a01487b34d77d2445ae64e59405_1236198075259587216.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Puedes ofrecerle Insignias Electro al Cerezo Sagrado del Gran Santuario Narukami y fortalecer así los electrógranos.<br>Los electrógranos fortalecidos también pueden ayudar a los viajeros con los que se conectan a luchar contra sus enemigos.</span></p>",
                "key": "Tip #3"
              }
            ],
