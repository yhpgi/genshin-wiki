              {
                "item_values": [],
                "key": "Tutorial",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una bestia salvaje y muy agresiva que habita en el Valle Chenyu. Congélala usando </span><span style=\"color: #FFE699\">Reacciones Elementales</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> y luego haz uso de las reacciones de </span><span style=\"color: #FFE699\">Rompehielo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> o </span><span style=\"color: #FFE699\">Derretido</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> para destruir el hielo y paralizarla temporalmente.</span></p>"
                ]
              }
