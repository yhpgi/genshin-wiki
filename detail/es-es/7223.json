              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Elemental</span></p><p><span style=\"color: rgb(209, 213, 219)\">Crea 1 carta de </span><span style=\"color: rgb(255, 255, 255)\">Acuaglóbulo revitalizante grande</span><span style=\"color: rgb(209, 213, 219)\"> y la coloca en la tercera posición de tu pila de cartas. Este personaje obtiene 3 cargas de </span><span style=\"color: rgb(255, 255, 255)\">pacto vital</span><span style=\"color: rgb(209, 213, 219)\">. Tras activar el efecto de </span><span style=\"color: rgb(255, 255, 255)\">Acuaglóbulo revitalizante grande</span><span style=\"color: rgb(209, 213, 219)\">, se crea un </span><span style=\"color: rgb(255, 255, 255)\">Acuaglóbulo revitalizante mediano</span><span style=\"color: rgb(209, 213, 219)\"> y se coloca en la pila de cartas del rival. Tras activar el efecto de </span><span style=\"color: rgb(255, 255, 255)\">Acuaglóbulo revitalizante mediano</span><span style=\"color: rgb(209, 213, 219)\">, se crea un </span><span style=\"color: rgb(255, 255, 255)\">Acuaglóbulo revitalizante pequeño</span><span style=\"color: rgb(209, 213, 219)\"> y se coloca en tu pila de cartas.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/13/73555894/4c63b534981dea6d803658390b92f1c4_2842502221882039753.png",
                "key": "Hidroterapia de rebote",
