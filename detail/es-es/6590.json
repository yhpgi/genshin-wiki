              {
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Ataque Normal</span></p><p>Inflige 2 pts. de <span style=\"color: rgb(255, 255, 255)\">Daño Físico</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/12/73555894/10316b5178d5109d597f415d6e7903dc_5803742799678119777.png",
                "key": "Espada vortiginosa",
                "points": [
