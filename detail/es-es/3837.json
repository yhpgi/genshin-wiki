              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Elemental</span></p><p>Invoca un <span style=\"color: rgb(255, 255, 255)\">cerezo kitsune</span>. Si en el campo ya hay uno, este inflige daño +1 adicional como máximo.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/73555894/7e9f291d99b3519d86302e803782b2f7_2788759194872581112.png",
