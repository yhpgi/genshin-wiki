    {
      "id": "31",
      "name": "Información adicional",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Según las leyendas de los habitantes del mar de arena, las anguilas del desierto y los gusanos de arena son descendientes de la antigua gran serpiente que devoró el sol. Aunque esta afirmación carece de fundamento, es cierto que, tal y como ha demostrado la investigación de crisálidas arenosas, la composición de la grasa corporal de las anguilas del desierto comparte bastantes similitudes con la de los gusanos de arena. Precisamente por esto, algunos astutos comerciantes a veces muelen las crisálidas arenosas que recolectan para hacerlas pasar por especias gourmet que obtienen al refinar la grasa de los gusanos de arena.</span></p>",
                "title": "Archivo"
              }
            ]
          }
        }
      ]
