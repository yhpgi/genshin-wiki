              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Elemental</span></p><p><span style=\"color: rgb(156, 163, 175)\">Inflige 1 pt. de </span><span style=\"color: rgb(255, 153, 153)\">Daño Pyro</span><span style=\"color: rgb(156, 163, 175)\">. Si este personaje tiene un </span><span style=\"color: rgb(255, 255, 255)\">caparazón de Cangrejo Acorazado</span><span style=\"color: rgb(156, 163, 175)\"> con al menos 7 cargas, infligirá daño +1.</span><br><span style=\"color: rgb(156, 163, 175)\">Después, este personaje obtiene un </span><span style=\"color: rgb(255, 255, 255)\">caparazón de Cangrejo Acorazado</span><span style=\"color: rgb(156, 163, 175)\"> de 2 cargas.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/28/73555894/a9c20ff9f809e176b5b49857c4ad1153_523686093120973913.png",
