                "title": "Explosión flagrante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Definitiva</span></p><p><span style=\"color: rgb(156, 163, 175)\">Este personaje </span><span style=\"color: rgb(255, 255, 255)\">prepara la habilidad</span><span style=\"color: rgb(156, 163, 175)\"> </span><span style=\"color: rgb(255, 255, 255)\">Explosión ardiente</span><span style=\"color: rgb(156, 163, 175)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/28/73555894/0ae22e52af3cd0693c58a452cef1d284_8010275798681749436.png",
