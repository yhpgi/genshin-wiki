      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "id": "gallery_character38870",
                "img": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2023/12/11/342d79e871b35c81b07308b65c3fd444_8197298106034674714.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Cuando una burbuja de rocío es </span><span style=\"color: #FFE14B\">atacada</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, </span><span style=\"color: #FFE14B\">se romperá</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> y liberará una ondulación. La burbuja se puede </span><span style=\"color: #FFE14B\">impulsar</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> con la habilidad de un Esferoctópodo cromático, la cual puedes usar para dos cosas: cambiar su ubicación y, a través de los aros que crea al ser impulsada, predecir la zona en la que la burbuja creará una ondulación al romperse. Cuando dos burbujas de rocío entran en contacto, se </span><span style=\"color: #FFE14B\">fusionarán </span><span style=\"color: rgba(255, 255, 255, 0.65)\">en una burbuja</span><span style=\"color: #FFE14B\"> más grande</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> que libera una ondulación de una mayor AdE al romperse.</span></p>",
                "key": "Tip #1"
              },
              {
                "id": "gallery_character46254",
                "img": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2023/12/11/1f57b66a5413200dfc4d991c8928a87c_8275855079759152856.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Unas ramas de rocío poco comunes y capaces de crear burbujas de rocío. Igual que muchas otras cosas, perderán sus funciones vitales al estar en una zona de contaminación bacteriana.</span></p>",
                "key": "Tip #2"
              },
              {
                "id": "gallery_character93106",
                "img": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2023/12/11/e74a4807c17e377a9241ac64fe0fb8f4_8198875849329830288.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Estas ondulaciones son indispensables para completar los desafíos de los tubos armónicos, y pueden interactuar con monumentos elementales Hydro y demás mecanismos y objetos sensibles a dicho elemento.</span></p>",
                "key": "Tip #3"
              }
            ],
            "pic": ""
          }
        }
      ]
