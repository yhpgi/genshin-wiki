                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Convite de la solista"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Elemental</span></p><p><span style=\"color: rgb(209, 213, 219)\">El tipo de arjé actual de </span><span style=\"color: rgb(255, 255, 255)\">Furina</span><span style=\"color: rgb(209, 213, 219)\"> es ousía: invoca a los </span><span style=\"color: rgb(255, 255, 255)\">miembros del salón</span><span style=\"color: rgb(209, 213, 219)\">.</span><br><span style=\"color: rgb(209, 213, 219)\">Cuando el tipo de arjé de Furina sea pneuma, invoca al </span><span style=\"color: rgb(255, 255, 255)\">juglar de las aguas</span><span style=\"color: rgb(209, 213, 219)\"> en su lugar.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/73555894/47e3b8a03c0e9406c19655e1aa7c3b30_2486514313048043348.png",
                "id": "talent70046",
                "key": "Salón Solitaire",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Salón Solitaire"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Definitiva</span></p><p><span style=\"color: rgb(209, 213, 219)\">Inflige 2 pts. de </span><span style=\"color: rgb(128, 192, 255)\">Daño Hydro</span><span style=\"color: rgb(209, 213, 219)\"> y crea el estado de </span><span style=\"color: rgb(255, 255, 255)\">jolgorio ecuménico</span><span style=\"color: rgb(209, 213, 219)\">.</span></p><p></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Jolgorio ecuménico</span></p><p><span style=\"color: rgb(255, 230, 153)\">Estado de combate</span></p><p><span style=\"color: rgb(255, 255, 255)\">Cuando tu personaje recibe daño o curación</span>, acumula 1 pt. de<span style=\"color: #FFFFFF\"> jolgorio</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Duración de rondas: 2.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/73555894/e5d9f5e8170236ccfb246be6a8bee57f_4541003214272242043.png",
                "id": "talent36674",
                "key": "¡Que el mundo entero festeje!",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "¡Que el mundo entero festeje!"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Invocación</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase final: </span>inflige 1 pt. de<span style=\"color: rgb(128, 255, 215)\"> </span><span style=\"color: #80C0FF\">Daño Hydro</span>. Si tienes un personaje con al menos 6 pts. de Vida, inflige 1 pt. de <span style=\"color: #FFFFFF\">Daño Penetrante</span> al personaje  que menos daño haya recibido y luego inflige 1 pt. más de<span style=\"color: #80C0FF\"> Daño Hydro</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Número de usos: 2</span></p><p>(acumulable hasta 4 veces).</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/73555894/47e3b8a03c0e9406c19655e1aa7c3b30_6602650328399491718.png",
