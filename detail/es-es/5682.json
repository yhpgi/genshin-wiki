          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Ataque Normal</span></p><p><span style=\"color: rgb(209, 213, 219)\">Inflige 2 pts. de </span><span style=\"color: rgb(255, 255, 255)\">Daño Físico</span><span style=\"color: rgb(209, 213, 219)\">.</span><br><span style=\"color: rgb(255, 255, 255)\">Una vez por ronda:</span><span style=\"color: rgb(209, 213, 219)\"> si no tienes la carta </span><span style=\"color: rgb(255, 255, 255)\">Sacralidad y secularidad</span><span style=\"color: rgb(209, 213, 219)\"> en la mano, crea una.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/73555894/26b9736a2d14fc4162b2448963f45695_3391264748391735801.png",
                "id": "talent35160",
                "key": "Convite de la solista",
                "materials": [],
