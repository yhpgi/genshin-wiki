                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Aullido acechador"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Definitiva</span></p><p>Inflige 3 pts. de <span style=\"color: rgb(255, 230, 153)\">Daño Geo</span>, así como 1 pt. de <span style=\"color: rgb(255, 255, 255)\">Daño Penetrante</span> contra todos los personajes enemigos en reserva y les aplica el efecto de <span style=\"color: rgb(255, 255, 255)\">corrosión dorada</span>.</p><p><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/13/73555894/54fafafd3720e95ffa305f16d15dbfca_4780278078548509755.png",
