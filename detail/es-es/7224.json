          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Ataque Normal</span></p><p><span style=\"color: rgb(156, 163, 175)\">Inflige 2 pts. de </span><span style=\"color: rgb(255, 255, 255)\">Daño Físico</span><span style=\"color: rgb(156, 163, 175)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/13/73555894/47817b4476bcd8b44c86c87debf042f2_4821343935105856051.png",
                "key": "Zarpazo del Rey Acechador",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Zarpazo del Rey Acechador"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Elemental</span></p><p><span style=\"color: rgb(209, 213, 219)\">Inflige 1 pt. de </span><span style=\"color: rgb(255, 230, 153)\">Daño Geo</span><span style=\"color: rgb(209, 213, 219)\">. Al personaje objetivo se le aplican 2 cargas de </span><span style=\"color: rgb(255, 255, 255)\">corrosión dorada</span><span style=\"color: rgb(209, 213, 219)\"> e invoca unas </span><span style=\"color: rgb(255, 255, 255)\">calaveras de Acechador</span><span style=\"color: rgb(209, 213, 219)\">.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Corrosión dorada</span></p><p><span style=\"color: rgb(255, 230, 153)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">fase final:</span><span style=\"color: rgb(209, 213, 219)\"> si el personaje que obtiene este efecto está en reserva. inflige 1 pt. de </span><span style=\"color: #FFFFFF\">Daño Penetrante </span><span style=\"color: rgb(209, 213, 219)\">por cada </span><span style=\"color: #FFFFFF\">uso </span><span style=\"color: rgb(209, 213, 219)\">que haya.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Número de usos: 1</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(acumulable hasta 3 veces).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/13/73555894/88bee9c24128a7b8fae306dd5feecea3_7745227706947312333.png",
