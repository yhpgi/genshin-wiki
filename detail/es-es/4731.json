                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Definitiva</span></p><p><span style=\"color: rgb(156, 163, 175)\">Inflige 2 pts. de </span><span style=\"color: rgb(128, 255, 215)\">Daño Anemo</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgb(156, 163, 175)\">y crea una </span><span style=\"color: rgb(255, 255, 255)\">michicaja sorpresa</span><span style=\"color: rgb(156, 163, 175)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/21/73555894/b718fd9ceee2d78fdf5d76f345458f71_6552716405101154681.png",
