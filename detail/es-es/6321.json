                ],
                "talent_img": "",
                "title": "Etiqueta vidriopírica"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidad Definitiva</span></p><p><span style=\"color: rgb(209, 213, 219)\">Inflige 1 pt. de </span><span style=\"color: rgb(255, 230, 153)\">Daño Geo</span><span style=\"color: rgb(209, 213, 219)\">, así como 1 pt. de </span><span style=\"color: rgb(255, 255, 255)\">Daño Penetrante</span><span style=\"color: rgb(209, 213, 219)\"> contra todos los personajes enemigos en reserva. Invoca una </span><span style=\"color: rgb(255, 255, 255)\">salva de cañones</span><span style=\"color: rgb(209, 213, 219)\"> y crea 1 carta de </span><span style=\"color: rgb(255, 255, 255)\">Fragmento de metralla</span><span style=\"color: rgb(209, 213, 219)\"> para añadirla a tu mano.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/07/73555894/25547c6b405dc204653b701c121b1096_9101192643945453068.png",
