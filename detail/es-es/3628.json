    {
      "id": "41",
      "name": "Contenido legible",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Hace mucho que no nos vemos, ¿cómo les ha ido durante este tiempo?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Un pajarito me contó que están viajando por Sumeru.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Qué casualidad, yo también me encuentro en Puerto Ormos por motivos de trabajo.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Estos días, voy todas las tardes a la",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Taberna Yafar a tomarme unas copas.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Si tuviese la buena fortuna de que esta carta llegase a sus manos, vengan a",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "verme para hablar sobre los viejos tiempos.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Considérenlo cosa del destino.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "right",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Saludos de su viejo y leal amigo, Kaeya.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
