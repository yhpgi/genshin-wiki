                "desc": "<p><span style=\"color: #FFE699\">Ataque Normal</span></p><p><span style=\"color: rgb(156, 163, 175)\">Inflige 1 pt. de </span><span style=\"color: rgb(128, 192, 255)\">Daño Hydro</span><span style=\"color: rgb(156, 163, 175)\">.</span></p>",
