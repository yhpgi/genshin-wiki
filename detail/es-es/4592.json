    {
      "id": "10",
      "name": "Historia",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgb(255, 255, 255)\">El camino siempre está repleto de encuentros y despedidas.</span><br><span style=\"color: rgb(255, 255, 255)\">Pero hay dos compañeros que nunca abandonan a la persona con la que viajan.</span><br><span style=\"color: rgb(255, 255, 255)\">Y esos son sus sueños y su espada.</span><br><br><span style=\"color: rgb(255, 255, 255)\">Antes de envejecer, ese viajero eterno cruzará muchos mundos.</span><br><span style=\"color: rgb(255, 255, 255)\">Y de él solo quedará un sinfín de historias y un futuro con un tenue brillo.</span></p>",
                "title": ""
              }
            ]
          }
        }
      ]
