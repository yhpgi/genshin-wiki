                "desc": "<p><span style=\"color: rgb(255, 225, 75)\">Habilidad Definitiva</span></p><p>Inflige 5 pts. de <span style=\"color: #FFFFFF\">Daño Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396192/36768cf2c0fc7aafe7c6c956fee29fba_4605603799266522105.png",
                "id": "talent97960",
