          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/29/10742394/de5f2e13750f95bf1630d19244232b3e_8482895576731946554.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">En Inazuma, esta barrera que obstaculiza el paso se llama “barrera electrificada”.<br>Por razones desconocidas, si obtienes el reconocimiento de los </span><span style=\"color: #FFE14B\">electrógranos </span><span style=\"color: rgba(255, 255, 255, 0.65)\">y los llevas contigo, podrás atravesar las barreras sin ningún impedimento.</span></p>",
                "key": "Tip #1"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/29/10742394/cb7dcd379d28561c8d213698bf9c5dad_3038614480048155074.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Sin embargo, para atravesar barreras más grandes, necesitarás electrógranos más poderosos. Ofrécele </span><span style=\"color: #FFE14B\">Insignias Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> al Cerezo Sagrado del Gran Santuario Narukami y tal vez algún día podrás acceder a todas las zonas bloqueadas por barreras electrificadas.</span></p>",
                "key": "Tip #2"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/29/10742394/7855ce0a5a9adc6542d82c050d69a4b9_7736605967828980752.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">En estas barreras hay encerradas unas rocas del trueno con un poder frenético y descomunal que puede ser reprimido mediante electrógranos.<br>Al hacerlo, la barrera desaparecerá.</span></p>",
                "key": "Tip #3"
              }
            ],
            "pic": ""
          }
        }
