              {
                "item_values": [],
                "key": "Tutorial",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una criatura de la Orden del Abismo. Es capaz de manipular distintos elementos para atacar y usar escudos resistentes al daño del elemento correspondiente. Durante el combate, crea aros elementales para canalizar un poderoso ataque. Si rompes todos los aros con Reacciones Elementales, podrás evitar el desastre inminente.</span></p>"
                ]
