                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Ataque Normal</span></p><p>Inflige 2 pts. de <span style=\"color: rgb(255, 255, 255)\">Daño Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/73555894/c369b96fc6417e8fc2bb607e37297ad4_518701222104176326.png",
