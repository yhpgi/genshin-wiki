    {
      "id": "31",
      "name": "Información adicional",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">La flor de una planta enredadera que crece en los peñascos más escarpados. La gente lo llama “loto” por su apariencia, ya que en realidad no tienen nada en común con ellos.<br>En Sumeru, las vides crecen por todas partes a lo largo de los acantilados como si del tiempo se tratara, sin principio ni fin. La leyenda dice que estas vides son las creaciones originales de Rukkhadevata y los ancestros de todas las plantas de Sumeru. Las raíces de todos los grandes árboles de Sumeru, e incluso del inmortal Árbol Sagrado, están unidas por estas lianas. Esta afirmación fue desmentida hace tiempo por los eruditos de la Escuela de Biología, pero sigue siendo muy extendida entre la gente.</span></p>",
                "title": "Archivo"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">La flor de una planta enredadera que crece en los peñascos más escarpados. La gente la llama “loto” por su apariencia, ya que en realidad no tienen nada en común.<br>En Sumeru, las enredaderas crecen por todas partes a lo largo de los acantilados como si del tiempo se tratara, sin principio ni fin. La leyenda dice que estas enredaderas fueron las primeras creaciones del bosque y los ancestros de todas las plantas de Sumeru. Las raíces de todos los grandes árboles de Sumeru, e incluso del inmortal Árbol Sagrado, están unidas por ellas. Esta afirmación fue desmentida hace tiempo por los eruditos de la Escuela de Biología, pero sigue siendo muy extendida entre la gente.</span></p><p><strong><span style=\"color: #FF9999\">Luego de completar la misión «¿Dónde estará el Barco de la Consciencia?»</span></strong></p>",
                "title": "Archivo - Alternativo"
              }
            ]
          }
        }
      ]
    },
