                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "items": [
                    [
                      {
                        "content": [
                          {
                            "text": "Geh zum Ufer des hängenden Nebels.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Folge Mao.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Beseitige das Miasma in der Umgebung.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Betritt die Höhle.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Untersuche die Höhle.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Mao.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Folge dem goldenen Karpfen.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Bereite den Regenjade-Ritus vor.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Begib dich zu „Des Adepten Ruhe“.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Beseitige das Miasma in der Umgebung.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Untersuche die Spuren in der Umgebung.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Untersuche die Wandgemälde.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Geh zum Berg Xuanlian.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Erkunde den Berg Xuanlian.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Mao.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sammle die Seelenperlen.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Nutze die Adeptenkraft, um die Seelenperlen zu aktivieren.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Geh zum Pavillon auf dem Berg.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Geh zurück zu Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Besteige den adeptischen Berg.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Begleite Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Beseitige das Miasma in der Umgebung.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Begleite Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Lingyuan.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Besiege die Xuanwen-Bestien.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Begleite Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Beseitige das Miasma in der Umgebung.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Betritt die Chiwang-Terrasse.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Lass Lingyuan sich beruhigen.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Mao.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Bringe Mao zurück ins Dorf Qiaoying.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ]
