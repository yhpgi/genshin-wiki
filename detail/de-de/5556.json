                      ],
                      "text": "Besondere Gegner",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Eine adeptische Bestie, die tief in den Bergen nistet und sowohl",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Hydro",
                      "type": "text"
                    },
                    {
                      "text": "- als auch",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Anemo",
                      "type": "text"
                    },
                    {
                      "text": "-Kraft nutzen kann. Friere sie ein, wenn sie die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Hydro",
                      "type": "text"
                    },
                    {
                      "text": "-Adeptenkraft sammelt. Zerschlage dann das Eis mit",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Elementarreaktionen wie Eisbrecher oder Schmelzen",
                      "type": "text"
                    },
                    {
                      "text": ", um sie kurzzeitig zu lähmen. Zerstöre die von ihr beschworenen Geistwind-Perlen mithilfe von",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Angriffen eines Elements, das mit der Anemo-Kraft reagieren kann",
                      "type": "text"
                    },
                    {
                      "text": ", wenn sie die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
