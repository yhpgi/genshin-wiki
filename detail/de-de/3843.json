      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Standardangriff</span></p><p>Verursacht 1 Pkt. <span style=\"color: #FF9999\">Pyro-SCH</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/61142474/1ce09211f025bf5470682189e0837732_6563579468093882257.png",
                "id": "talent69288",
                "key": "Erlösende Flamme",
                "materials": [],
