    {
      "id": "41",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Sieh den Brief als Botschaft:",
                      "type": "text"
                    },
                    {
                      "text": "Es tut mir leid, dass ich den Brief so abrupt abgebe.",
                      "type": "text"
                    },
                    {
                      "text": "Ich hoffe, ich habe dich damit nicht belästigt.",
                      "type": "text"
                    },
                    {
                      "text": "Einen Brief zu schreiben, der einen Fremden aus einem anderen Land einlädt, ist auch für mich neu.",
                      "type": "text"
                    },
                    {
                      "text": "Aber ich glaube, dass die Begegnung mit dir kein Zufall war.",
                      "type": "text"
                    },
                    {
                      "text": "Nun denn,",
                      "type": "text"
                    },
                    {
                      "text": "zufälligerweise scheint der Mond heute Nacht noch, also hoffe ich, dass es dir nichts ausmacht, mich zu treffen.",
                      "type": "text"
                    },
                    {
                      "text": "Bitte mach dir keine Sorgen, dass die Vasallen und Wachen auf Patroullie sind, ich habe meine eigene Art, sie wegzulocken.",
                      "type": "text"
                    },
                    {
                      "text": "Ich freue mich auf deinen Besuch.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
