                "item_values": [],
                "key": "Widerhall",
                "string_values": [
                  "<p>Schießt bei Treffern mit Standardangriffen und heftigen Schlägen mit einer Wahrscheinlichkeit von 50% eine Kugel des Herzensblicks ab und verursacht Schaden in Höhe von <span style=\"color: rgb(55, 255, 255)\">240% ~ 270% ~ 300% ~ 330% ~ 360%</span> ANG. Geht bis zu 4-mal auf Gegner in der Nähe über. <span style=\"color: rgb(55, 255, 255)\">12s ~ 11s ~ 10s ~ 9s ~ 8s</span> Abklingzeit.</p>"
                ]
              }
