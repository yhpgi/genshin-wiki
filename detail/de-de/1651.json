    {
      "id": "41",
      "name": "Inhalt",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "„Eric kann nicht länger durchhalten ... Wir hatten keine andere Wahl, als aufzugeben.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Ich werde dieses Notizbuch hier lassen. Vielleicht ist dieser Schatz für jemand anderen bestimmt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Wie du vielleicht bemerkt hast, muss die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffe14b"
                      ],
                      "text": "an der Tür angebrachte Vorrichtung ständig von jemanden bedient werden",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": ". Andernfalls können die anderen Vorrichtungen nicht bedient werden. Aber die Sache hat einen Haken ...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Die Person, welche die Vorrichtung an der Tür bedient, geht ein enormes Risiko ein. Wenn die anderen Vorrichtungen in der falschen Reihenfolge betätigt werden, wird diese Person ...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Ein weiterer Ratschlag:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffe14b"
                      ],
                      "text": "Die Anzahl der Fackeln sagt nichts über die Reihenfolge der Bedienung aus",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "... Wir haben diesen Fehler gemacht und einen schmerzhaften Preis dafür bezahlt.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Vielleicht ...",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffe14b"
                      ],
                      "text": "hat die Reihenfolge etwas mit der Position der Fackeln auf dem Boden zu tun",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Wie lautet die Antwort?",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Oh, wie gern würde ich es wissen ...",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Aber Eric hält körperlich nicht mehr durch ...“",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
