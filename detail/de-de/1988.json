      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "Nach der Legende badete der berühmte Held, nachdem er den Drachen geköpft hatte,</br>im Blut des Drachen, um Unsterblichkeit zu erlangen.</br>Das Blut wirkte in der Tat:</br>Egal ob Schwerter, Speere oder Pfeilhagel, </br>alles prallte von ihm ab, während er nur lachte.</br>Zum Schluss bemerkten seine Feinde,</br>er hatte mit seinem preisgekrönten Großschwert zusammen im Blut gebadet.</br>Seine größte Stärke wurde zu seiner größten Schwäche.</br>",
                "title": ""
              }
            ]
          }
        }
      ]
