                "talent_img": "",
                "title": "Steinhagel"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elementarfähigkeit</span></p><p>Verursacht 1 Pkt. <span style=\"color: #FFE699\">Geo-SCH</span>, erschafft 1 <span style=\"color: #FFFFFF\">Hügelkamm</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/61142474/bd88dd4e84f0956abd3d34b19442d2c6_6001162343583674255.png",
