                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Standardangriff</span></p><p>Verursacht 2 Pkt. <span style=\"color: #FFFFFF\">phys. SCH</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/61142474/241eba6e4c00020975cf91170050f435_5943481632242777617.png",
