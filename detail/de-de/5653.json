                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/20/36893887/7557f4558ab243d82e8b6b9994fc97ee_8069464724970248372.png",
                      "menu_id": 5,
                      "name": "Fragment harmonischer Launen",
