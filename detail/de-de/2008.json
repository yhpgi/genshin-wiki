          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Letzter Seufzer",
                      "type": "text"
                    },
                    {
                      "text": "erhöht nicht nur die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Elementarkunde",
                      "type": "text"
                    },
                    {
                      "text": "des Trägers, sondern auch die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Elementarkunde",
                      "type": "text"
                    },
                    {
                      "text": "und den",
