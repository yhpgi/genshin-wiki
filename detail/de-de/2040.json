    {
      "id": "39",
      "name": "Empfohlene Figuren",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Amos' Bogen",
                      "type": "text"
                    },
                    {
                      "text": "bietet seinem Träger einen Bonus für dessen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Standardangriffe",
                      "type": "text"
                    },
                    {
                      "text": "und",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "heftigen Schläge",
                      "type": "text"
                    },
                    {
                      "text": ". Außerdem wird dieser Bonus verstärkt, je länger ein Pfeil in der Luft ist. Dies geht oft mit der Distanz zum Gegner einher. Verschiedene",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "heftige Schläge",
                      "type": "text"
                    },
                    {
                      "text": "fliegen etwas langsamer oder sind länger in der Luft, wodurch diese mehrere Stapelungen von diesem Effekt erhalten.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Figur",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 28,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Ganyu_icon.png",
                      "name": "Ganyu",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ganyu ist eine Figur mit einem spezialisierten heftigen Schlag, der den passiven Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Willensstarker Pfeil",
                      "type": "text"
                    },
                    {
                      "text": "dieser Waffe perfekt ausnutzt. Außerdem erhöht Ganyus Talent",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Eintracht",
                      "type": "text"
                    },
                    {
                      "text": "in Kombination mit dem",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Kryo Einklang",
                      "type": "text"
                    },
                    {
                      "text": "der Truppe und dem 4-teiligen Artefaktset",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2062,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Blizzard Strayer/flower_of_life_icon.png",
                      "name": "Im Schnee irrender Recke",
                      "type": "custom_entry"
                    },
                    {
                      "text": "die KT-Rate, was ideal für das Nebenattribut dieser Waffe ist. Außerdem harmoniert die Waffe auch gut mit dem 4-teiligen Artefaktset",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2081,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Wanderer's Troupe/flower_of_life_icon.png",
                      "name": "Wanderorchester",
                      "type": "custom_entry"
                    },
                    {
                      "text": ", da so Ganyus heftiger Schlag noch weiter verstärkt wird.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 15,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Yoimiya_icon.png",
                      "name": "Yoimiya",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Yoimiya ist spezialisiert auf Standardangriffe. Da diese Waffe durch ihren passiven Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Willensstarker Pfeil",
                      "type": "text"
                    },
                    {
                      "text": "ebenfalls auf Standardangriffe spezialisiert ist und alle Angriffe von Yoimiya mit ANG skalieren, ist sie eine gute Wahl für Yoimiya.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 38,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Fischl_icon.png",
                      "name": "Fischl",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Fischl ist eine vielseitige Figur, die auch mit Standardangriffen viel Schaden austeilen kann. Als 5-Sterne-Waffe erhöht der Amos' Bogen ihre ANG-Werte erheblich, was ihren",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "physischen SCH",
                      "type": "text"
                    },
                    {
                      "text": "erhöhen kann. Aber auch ihr Begleiter",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 172, 255)"
                      ],
                      "text": "Oz",
                      "type": "text"
                    },
                    {
                      "text": "profitiert vom hohen ANG-Wert wodurch Fischls Elementarfähigkeitsschaden ebenfalls steigt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 14,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Amber_icon.png",
                      "name": "Amber",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Auch für Amber kann der Amos' Bogen eine gute Wahl sein. Mit ihrem Sternenbild",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Manuelle Explosion",
                      "type": "text"
                    },
                    {
                      "text": "kann Amber ihre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Sprengpuppe",
                      "type": "text"
                    },
                    {
                      "text": "durch einen aufgeladenen Schuss früher explodieren lassen, wodurch sie zusätzlich mehr",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Pyro-SCH",
                      "type": "text"
                    },
                    {
                      "text": "verursachen kann. Auch das Nebenattribut ANG ist bei Amber von Vorteil, da ihre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Sprengpuppe",
                      "type": "text"
                    },
                    {
                      "text": "und ihr",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Pfeilregen",
                      "type": "text"
                    },
                    {
                      "text": "mit ANG skalieren.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
