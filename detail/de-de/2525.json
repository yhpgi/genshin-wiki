    {
      "id": "24",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p><strong>Baishi:</strong> Seidene Roben mit Phönixstickerei, leichte Röcke mit feinen Mustern ... hehe ...</p>",
                "id": "Weitere Informationen84130",
                "img": "",
                "title": "Dialog: Begrüßung"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Hallo?</p><p><strong>Baishi:</strong> Du, wo kommst du denn her! Du hast mich erschreckt! Bist du der/die Reisende/r?</p><p><strong>Baishi:</strong> Hast du nicht sehen können, dass ich ... mir überlegt habe, was Ningguang am besten stehen würde?</p><p></p><p><strong>Reisende/r:</strong> Doch, doch. Dein Sabbern war nicht zu übersehen.</p><p><strong>Baishi:</strong> Du ... Ich glaub, du verstehst da was falsch! Ich sorge mich nur um Ningguangs Ruf unter den Menschen.</p><p><strong>Baishi:</strong> Jemand wie sie, der die Last einer ganzen Region schultert, sollte seine Zeit nicht mit so alltäglichen Kleinigkeiten vertrödeln.</p><p><strong>Baishi:</strong> Außerdem ist das meine Pflicht als Sekretärin!</p><p><strong>Baishi:</strong> Wenn ich nur daran denke, mit welcher Eleganz Nigguang sich vor den Menschen präsentiert, oder ihre Silhouette, wenn sie sich umzieht oder gerade vom Baden kommt ...</p><p><strong>Baishi:</strong> Ah, oder vielleicht ist Ningguangs Festtagskleid auch sehr schön, schlicht und edel, mit dem Orchideenschleier, der darüber streicht, ätherisch duftend ...</p><p><strong>Baishi:</strong> Das macht mich ganz ... ah ... ähem ...</p><p></p><p><strong>Reisende/r:</strong> Ich verehre Ningguang.</p><p><strong>Baishi:</strong> Verehren? Was ... Was für eine Art der Verehrung ist das? Geistig? Spirituell? Oder ...</p><p><strong>Baishi:</strong> Hmpf! Was auch immer es ist, trau dich nicht, etwas Verbotenes zu tun, und behalte deine Hände bei dir!</p><p><strong>Baishi:</strong> Ningguang ist eine äußerst beschäftigte Person. Sie hat keine Zeit für deinen Fanatismus.</p><p><strong>Baishi:</strong> Ich möchte dich auf dem Pfad des „Fleißes“ unterweisen. Danach kannst du gehen und über deine Taten nachdenken.</p><p><em><span style=\"color: #ECE5D8\">(Dialogbelohnung: 1x Anleitung zum „Fleiß“)</span></em></p>",
                "id": "Weitere Informationen88930",
                "img": "",
                "title": "Dialog: Unterhaltung 1"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Mach ruhig weiter, ich will nicht stören.</p><p><strong>Baishi:</strong> Ach, welchen Duft sollte sie wohl nehmen ... hihi ...</p>",
                "id": "Weitere Informationen70807",
                "img": "",
                "title": "Dialog: Abschied"
              }
            ]
          }
        }
      ]
