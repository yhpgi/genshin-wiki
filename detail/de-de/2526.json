    {
      "id": "24",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p><strong>Baiwen:</strong> Willkommen! Bist du hier, um Ningguang zu sehen?</p>",
                "id": "Weitere Informationen57742",
                "img": "",
                "title": "Dialog: Begrüßung"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Hallo.</p><p><strong>Baiwen:</strong> Nun, hallo, du bist gekommen, also ist es so, dass deine Reise mit den Informationen übereinstimmt, die uns vorliegen.</p><p><strong>Baiwen:</strong> Wenn du Ningguang sehen möchtest, bist du hier richtig. Denn dies ist das Jadegemach, das Zentrum der Planung und Strategie von Liyue.</p><p><strong>Baiwen:</strong> Gemäß den Daten, die wir über dich gesammelt haben, hättest du unseren Schätzungen nach aber schon vor zwei Stunden hier sein sollen.</p><p><strong>Baiwen:</strong> Darüber muss ich nachdenken. Hatten wir falsche Informationen oder waren unsere Berechnungen falsch?</p><p></p><p><strong>Reisende/r:</strong> Ich habe wirklich Respekt vor Ningguang.</p><p><strong>Baiwen:</strong> Das ist nicht selten. Ich habe das auch.</p><p><strong>Baiwen:</strong> Die Worte des Tianquans können Berge versetzen, das weiß jeder. Es ist meine Aufgabe, Ningguang dabei zu helfen, ihr Geheimdienstnetzwerk zu organisieren.</p><p><strong>Baiwen:</strong> Sobald sie das Chaos und die Asche ausgesiebt hat, wird sie uns aus dem Jadegemach zum „Wohlstand“ führen.</p><p><strong>Baiwen:</strong> Möchtest du von solchen Dingen erfahren?</p><p><em><span style=\"color: #ECE5D8\">(Dialogbelohnung: 1x Anleitung zum „Wohlstand“)</span></em></p>",
                "id": "Weitere Informationen27713",
                "img": "",
                "title": "Dialog: Unterhaltung 1"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r: </strong>Ich bin nur auf der Durchreise.</p><p><strong>Baiwen:</strong> Ach wirklich? Seltsam ...</p><p><strong>Baiwen:</strong> Du bist ja sicher nicht nur zum Spaß hergekommen.</p><p><strong>Baiwen:</strong> Es ist bisher noch nie vorgekommen, dass jemand das Jadegemach ohne Grund betreten wollte.</p><p><strong>Baiwen:</strong> Als Sekretärin, die Informationen für Ningguang sammelt und zusammenstellt, muss ich über jeden Informationen haben, auch über dich als hohen Gast.</p>",
                "id": "Weitere Informationen78658",
                "img": "",
                "title": "Dialog: Unterhaltung 2"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r: </strong>Tschüs.</p><p><strong>Baiwen:</strong> Bis bald! Möge dich Reichtum erwarten.</p>",
                "id": "Weitere Informationen24525",
                "img": "",
                "title": "Dialog: Abschied"
              }
            ]
          }
        }
      ]
    },
