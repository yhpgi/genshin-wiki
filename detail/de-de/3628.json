      "id": "41",
      "name": "Inhalt",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Es ist schon eine Weile her. Wie geht es dir?",
                      "type": "text"
                    },
                    {
                      "text": "Ich habe gehört, dass ihr beide in Sumeru unterwegs seid,",
                      "type": "text"
                    },
                    {
                      "text": "und ich bin zufällig aus dienstlichen Gründen in Ormos.",
                      "type": "text"
                    },
                    {
                      "text": "In letzter Zeit gehe ich jeden Nachmittag auf ein oder zwei Drinks in die Djafar-Taverne.",
                      "type": "text"
                    },
                    {
                      "text": "Wenn das Glück auf meiner Seite ist und dieser Brief dich erfolgreich erreicht,",
                      "type": "text"
                    },
                    {
                      "text": "dann komm zu mir und wir können über alte Zeiten plaudern.",
                      "type": "text"
                    },
                    {
                      "text": "Wir sollten es als eine schicksalhafte Begegnung sehen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "— Dein treuer Kumpel, Kaeya",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
