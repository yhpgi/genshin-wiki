                  "type": "paragraph"
                },
                {
                  "items": [
                    [
                      {
                        "content": [
                          {
                            "text": "Warum im Wasser treiben?",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "„Jade, o Jade, alles, was mein Herz begehrt ...“",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ]
