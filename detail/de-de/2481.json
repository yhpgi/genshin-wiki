    {
      "id": "68",
      "name": "Geniale Beschwörung",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Abenteuer-Herausforderung: Die Legende von Eis und Feuer",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Einführung der Herausforderung",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Vom Drachengrat kam ein Mitachurl mit Eisschild herunter. Aus dem Wald kamen zwei Mitachurle mit Feueraxt. Mitachurle vom Drachengrat wollten ihre Eisschilde gegen Feueräxte tauschen ...",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Sonderregel:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Verleiht zu Beginn des Kampfes all deinen Figuren 2 Pkt. Aufladung.",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Hinweis:",
                      "type": "text"
                    },
                    {
                      "text": "Es strotzt nun vor Aufladungspunkten, nutz sie aus und wende möglichst häufig Spezialfähigkeiten an!",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Gegnerische Aufstellung",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3364,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/21/61142474/5cee49592fa1288d62fc93934c66396b_2949863382082185756.png",
                      "menu_id": 19,
                      "name": "Mitachurl mit Feueraxt",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3362,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/21/61142474/1918424a4792d788847c2ffaccd310eb_1520461000994701372.png",
                      "menu_id": 19,
                      "name": "Mitachurl mit Eisschild",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3364,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/21/61142474/5cee49592fa1288d62fc93934c66396b_2949863382082185756.png",
                      "menu_id": 19,
                      "name": "Mitachurl mit Feueraxt",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Voraussetzung",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Erreiche Kartenbeschwörerstufe 1",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Ziele der Herausforderung",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Belohnungen",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Erringe den Sieg",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "amount": 100,
                      "display_style": "card",
                      "ep_id": 3333,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/26/61142474/c053b3827ca93a7a2c51136e29ffa043_4008801292869690158.png",
                      "menu_id": 9,
                      "name": "Glücksmünze",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 120,
                      "display_style": "card",
                      "ep_id": 3816,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/23/47685001/a3dfc591cecc908ea00f31c9a3de083f_16688270701636672.png",
                      "name": "Kartenbeschwörer-EP",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
