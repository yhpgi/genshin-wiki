    {
      "id": "39",
      "name": "Empfohlene Figuren",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Gesang der Stille",
                      "type": "text"
                    },
                    {
                      "text": "ist eine schmiedbare Waffe aus Fontaine und bietet vor allem sehr viel ANG%-Boni. Der Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Benthischer Puls",
                      "type": "text"
                    },
                    {
                      "text": "aktiviert sich, wenn der Träger",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "geheilt",
                      "type": "text"
                    },
                    {
                      "text": "wird und bietet diesem kurzzeitig einen SCH-Bonus. Dieser Effekt wird auch dann aktiviert, wenn die aktive Figur dabei nicht aktiv auf dem Feld ist oder bereits volle LP hat – sie muss nur",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "geheilt",
                      "type": "text"
                    },
                    {
                      "text": "werden. Für das optimale Nutzen dieser Waffe ist es zu empfehlen, einen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Heiler",
                      "type": "text"
                    },
                    {
                      "text": "in der Truppe zu haben.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Figur",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 38,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Fischl_icon.png",
                      "name": "Fischl",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Fischl verursacht ihren kompletten Schaden fast ausschließlich mit ihrer",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Elementarfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "und ist nie lange aktiv auf dem Feld. Da der Effekt der Waffe sich auch aktiviert, wenn sie nicht aktiv auf dem Feld ist wenn sie",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "geheilt",
                      "type": "text"
                    },
                    {
                      "text": "wird, kann sie den Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Benthischer Puls",
                      "type": "text"
                    },
                    {
                      "text": "hervorragend nutzen. Der SCH-Bonus ist besonders in",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ff88"
                      ],
                      "text": "Dendro",
                      "type": "text"
                    },
                    {
                      "text": "-Kompositionen für ihren",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ff88"
                      ],
                      "text": "Urwuchs",
                      "type": "text"
                    },
                    {
                      "text": "-Schaden gu",
                      "type": "text"
                    },
                    {
                      "text": "t.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 42,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Tartaglia_icon.png",
                      "name": "Tartaglia",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tartaglia's Schadensprofil umfasst alle seine Fähigkeiten und Angriffe. Dadurch ist der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Gesang der Stille",
                      "type": "text"
                    },
                    {
                      "text": "für ihn insofern interessant, da der passive Effekt alle seine Fähigkeiten gleichermaßen stärkt. Da er seine",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Elementarfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "nur selten für längere Zeit am Stück nutzen will, muss er nur einmal",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "geheilt",
                      "type": "text"
                    },
                    {
                      "text": "werden, um den Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Benthischer Puls",
                      "type": "text"
                    },
                    {
                      "text": "für seine aktive Zeit auf dem Feld zu nutzen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 28,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Ganyu_icon.png",
                      "name": "Ganyu",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Mit dem",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 1999,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/weapon/破魔之弓.png",
                      "name": "Hamayumi",
                      "type": "custom_entry"
                    },
                    {
                      "text": "und",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2028,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/weapon/试作澹月.png",
                      "name": "Mondschein-Prototyp",
                      "type": "custom_entry"
                    },
                    {
                      "text": "besitzt Ganyu bereits einige schmiedbare Bögen, die sie gut nutzen kann. Der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Gesang der Stille",
                      "type": "text"
                    },
                    {
