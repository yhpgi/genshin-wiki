{
  "id": 4334,
  "name": "Werftklinge",
  "desc": "<p>Ein praktisches Schneidewerkzeug, das heutzutage fast nirgends mehr zu finden ist. Stumpfe Klingen können bei Gebrauch ersetzt werden.</p>",
  "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/20/36893887/eac5d6d4056f7b28c876e64866825e46_1406291676391823008.png",
