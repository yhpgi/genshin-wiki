    {
      "id": "24",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p><strong>Baixiao:</strong> Hallo, Reisende/r, willkommen. Darf ich fragen, was ich für dich tun kann?</p>",
                "id": "Weitere Informationen76278",
                "img": "",
                "title": "Dialog: Begrüßung"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Wegen des Jadegemachs ...</p><p><strong>Baixiao:</strong> Im Jadegemach schmiedet Ningguang politische und gesellschaftliche Pläne.</p><p><strong>Baixiao:</strong> Von hier aus kann sie ganz Liyue überwachen und weiß über alles Bescheid, was in der Umgebung vor sich geht. Nichts entgeht unseren Augen und Ohren.</p><p><strong>Baixiao:</strong> Obwohl wir Sekretäre in den Tagen vor der Restaurierung und dem Bau des Jadegemach noch für Ningguang arbeiten, ist es stimmungsvoller, wieder hier zu sein ...</p><p><strong>Baixiao:</strong> Obwohl du ein Ehrengast von Ningguang bist, bitte ich dich, mir zu verzeihen, dass ich dir die im Jadegemach gesammelten Informationen nicht mitteilen kann.</p><p></p><p><strong>Reisende/r:</strong> Kannst du mir etwas über Ningguang sagen?</p><p><strong>Baixiao:</strong> Ningguang ist eine der Qixing, sie hat die Aufsicht über Liyue und die Händler.</p><p><strong>Baixiao:</strong> Bedauerlicherweise bin ich nicht befugt, dir mehr über sie zu sagen.</p><p><strong>Baixiao:</strong> Aber in Anbetracht deiner Freundschaft mit Ningguang ... Wenn du Fragen hast, kannst du sie selbst fragen.</p><p></p><p><strong>Reisende/r:</strong> Ich habe den höchsten Respekt vor Ningguang.</p><p><strong>Baixiao:</strong> Hmm ... Du bist wahrlich ein seltener und ehrlicher Mensch, der aus einem anderen Holz geschnitzt ist als diese schmierigen Händler, die nach dem kleinsten Fitzelchen Information gieren.</p><p><strong>Baixiao:</strong> Der Weg zum Wohlstand ist im Grunde ganz simpel. Ich habe viel Zeit an der Seite Ningguangs verbracht und einige ... Geheimnisse gelernt, hier und dort.</p><p><strong>Baixiao:</strong> Wie wäre es hiermit. Ich zeige dir die wahre Bedeutung von „Gold“. Nicht auf ihren Namen, sondern auf meinen. Mögen Glück und Wohlstand dir hold sein.</p><p><em><span style=\"color: rgb(236, 229, 216)\">(Dialogbelohnung: 1x Anleitung zum „Gold“)</span></em></p>",
                "id": "Weitere Informationen82007",
                "img": "",
                "title": "Dialog: Unterhaltung 1"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Tschüs.</p><p><strong>Baixiao:</strong> Auf Wiedersehen und gute Reise!</p>",
                "id": "Weitere Informationen52911",
                "img": "",
                "title": "Dialog: Abschied"
              }
            ]
          }
        }
      ]
