    {
      "id": "41",
      "name": "Inhalt",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Freunde von Mondstadt, lasst uns feiern, hoch die Tassen!",
                      "type": "text"
                    },
                    {
                      "text": "Es kam der Tag, an dem Barbatos ihre Gebete erhörte.",
                      "type": "text"
                    },
                    {
                      "text": "Ihrem roten Haar folgend kam der Gott des Windes zu ihrer Gefängniszelle.",
                      "type": "text"
                    },
                    {
                      "text": "„Jedes Lebewesen sollte einen Namen haben“, grinste er.",
                      "type": "text"
                    },
                    {
                      "text": "„Lass mich deinen Namen in ein Lied verweben,",
                      "type": "text"
                    },
                    {
                      "text": "ich erhoffe mir nichts als deine Freundschaft.“",
                      "type": "text"
                    },
                    {
                      "text": "Das Mädchen stimmte sofort zu, sie fühlte sich, als ob ein Stein von ihrem Herzen fiel.",
                      "type": "text"
                    },
                    {
                      "text": "Und so, mit der Macht in Barbatos’ Lied,",
                      "type": "text"
                    },
                    {
                      "text": "besiegte sie einen Drachen, der in den Feldern wütete.",
                      "type": "text"
                    },
                    {
                      "text": "Selbst die Aristokraten mit ihren Wohlstandsbäuchen kriegten es mit der Angst zu tun.",
                      "type": "text"
                    },
                    {
                      "text": "„Mondstadt soll frei sein“, sangen die Winde für das Volk.",
                      "type": "text"
                    },
                    {
                      "text": "Der einsame Wind aus dem Wald sammelte sich und pustete den hohen Turm des Tyrannen um.",
                      "type": "text"
                    },
                    {
                      "text": "Und so stand die junge Löwin, endlich frei von ihren Ketten, den Kopf hoch gerichtet im Wind des Sieges.",
                      "type": "text"
                    },
                    {
                      "text": "Dies brachte ihr viel Ruhm und Ehre.",
                      "type": "text"
                    },
                    {
                      "text": "Ihr Herz war so voller Stolz und Anerkennung, dass sie an der Seite des Gottes des Windes singen durfte.",
                      "type": "text"
                    },
                    {
                      "text": "Worte des Dankes lehnte Barbatos jedoch ab:",
                      "type": "text"
                    },
                    {
                      "text": "„In deinem Lied bist du die Heldin.",
                      "type": "text"
                    },
                    {
                      "text": "Du gabst mir deine Freundschaft und deinen Namen,",
                      "type": "text"
                    },
                    {
                      "text": "um deine Freiheit zu feiern, kam mein Lied zu dir.“",
                      "type": "text"
                    },
                    {
                      "text": "Freunde, lasst uns noch einen heben!",
                      "type": "text"
                    },
                    {
                      "text": "Trinken wir auf das, was Mondstadt den Frieden gebracht hat.",
                      "type": "text"
                    },
                    {
                      "text": "Wenn die Nacht hereinbricht und die Hoffnung schwindet,",
                      "type": "text"
                    },
                    {
                      "text": "Vergesst niemals die Heldengeschichten von Vennessa mit dem flammenden Haar.",
                      "type": "text"
                    },
                    {
                      "text": "Gebt niemals die Hoffnung auf Frieden und Freiheit auf!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
