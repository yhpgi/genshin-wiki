          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Standardangriff</span></p><p>Verursacht 2 Pkt.<span style=\"color: rgb(255, 255, 255)\"> phys. SCH.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/26/61142474/241eba6e4c00020975cf91170050f435_6905324806216423454.png",
                "id": "talent89618",
                "key": "Wackel aber wacker!",
                "materials": [],
