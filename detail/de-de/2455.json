    {
      "id": "24",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><strong>Eury:</strong> Hallo, möchtest du etwas kaufen?</p>",
                "title": "Dialog: Begrüßung"
              },
              {
                "desc": "<p><strong>Reisende/r:</strong> Ich möchte mich nur umsehen.</p><p><strong>Eury: </strong>Ich beneide euch Leute, die ihre Kauflust unter Kontrolle haben ...</p><p><strong>Eury:</strong> Ich brauche nur ein Schild mit „Rabatt“ zu sehen und schon hole ich meinen Geldbeutel heraus.</p><p><strong>Eury:</strong> Sag mal, hast du einen Trunkenbold, auch „mein Mann“ genannt, gesehen? Er wird doch nicht schon wieder Wein kaufen gehen.</p>",
                "title": "Dialog: Unterhaltung 1"
              },
              {
                "desc": "<p><strong>Reisende/r:</strong> Hast du etwas Schönes eingekauft?</p><p><strong>Eury:</strong> Eben habe ich einen hübschen Edelsteinring gesehen.</p><p><strong>Eury:</strong> Ich musste ihn einfach nehmen. Aber natürlich war das ein großer Fehler.</p><p><strong>Eury:</strong> Ich hätte gleich wissen müssen, dass meine zarten Äuglein den Anblick dieses Preises nicht ertragen würden.</p>",
                "title": "Dialog: Unterhaltung 2"
              },
              {
                "desc": "<p><strong><em><span style=\"color: rgb(236, 229, 216)\">Verfügbar nach dem Kampf gegen Sturmschrecken während des Archontenauftrags Prolog: 3. Akt - „Das Lied von dem Drachen und der Freiheit“</span></em></strong></p><p></p><p><strong>Reisende/r: </strong>Was weißt du über Sturmschrecken?</p><p><strong>Eury:</strong> *seufz* Mir wurde erst bewusst, wie friedlich diese Tage des Schaufensterbummelns und des Verhandeln mit den Ladenbesitzern war, als ich Sturmschreckens Angriff erlebte.</p><p><strong>Eury:</strong> Ich wollte ursprünglich meinen Mann dazu bringen, mit dem Trinken aufzuhören ...</p><p><strong>Eury:</strong> Aber zur Feier dieses schwer verdienten Friedens schätze ich, dass das fürs Erste noch warten kann.</p>",
                "title": "Dialog: Sturmschrecken"
              },
              {
                "desc": "<p><strong>Reisende/r:</strong> Tschüs.</p><p><strong>Eury:</strong> Tschüssili! Viel Spaß in Mondstadt!</p>",
                "title": "Dialog: Abschied"
              }
            ]
          }
        }
      ]
    },
