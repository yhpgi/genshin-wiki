    {
      "id": "10",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p>Reisen sind voll von Begegnungen und Abschieden. Wahrscheinlich sind immer noch die treusten Begleiter eines Reisenden das Schwert in der Hand und der Traum im Herzen. Bevor er in die Jahre kommt, wird der Reisende viele Welten durchwandern. Übrig bleibt nur eine wachsende Zahl von Geschichten und eine hoffnungsvollere Zukunft.</p>",
                "title": "Weitere Informationen"
              }
            ]
          }
        }
      ]
