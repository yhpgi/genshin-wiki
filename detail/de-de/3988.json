      "name": "Empfohlene Figuren",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Fließende Reinheit",
                      "type": "text"
                    },
                    {
                      "text": "ist eine schmiedbare Waffe aus Fontaine und bietet vor allem Elementar-SCH Bonus, sowie ein ANG%-Nebenattribut. Der Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Eid des Lebens",
                      "type": "text"
                    },
                    {
                      "text": "wird beim Nutzen der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Elementarfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "aktiviert und bietet weitere Boni, wenn die Figur um den Wert des Eides",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "geheilt",
                      "type": "text"
                    },
                    {
                      "text": "wurde. Dabei berechnet sich der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Eid des Lebens",
                      "type": "text"
                    },
                    {
                      "text": "auf die maximalen LP der Figur. Das optimale Nutzen dieser Waffe setzt einen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Heiler",
                      "type": "text"
                    },
                    {
                      "text": "in der Truppe voraus.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
