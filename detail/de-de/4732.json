                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Juuga – Vorwärts zum Sieg"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Beschwörung</span></p><p><span style=\"color: rgb(255, 255, 255)\">Endphase</span>: Verursacht 1 Pkt. <span style=\"color: #FFE699\">Geo-SCH</span>. Befinden sich in deiner Truppe 2 <span style=\"color: #FFE699\">Geo</span>-Figuren: Erschafft 1 <span style=\"color: #FFFFFF\">Kristallisation</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Einsatzmöglichkeit: 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/24/61142474/db13288db6b90ec33f8adc2656d2019f_4970546052555301559.png",
                "id": "talent7338",
                "key": "Würde des Generals",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/24/61142474/e473fedde5cae543bffc4ffb4faeef30_8238361258574863513.png",
                "title": "Würde des Generals"
              },
              {
                "attributes": [],
                "desc": "<p>Löst Reaktionen mit dem bestehenden Elementarattribut aus:<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(153, 255, 255)\">Kryo</span>] <span style=\"color: rgb(255, 255, 255)\">Kristallisation (Kryo)</span>: Diesmaliger SCH +1, verleiht deiner aktiven Figur 1 Pkt. Schild (2-fach stapelbar).<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Kristallisation (Hydro):</span> Diesmaliger SCH +1, verleiht deiner aktiven Figur 1 Pkt. Schild (2-fach stapelbar).<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Kristallisation (Pyro)</span>: Diesmaliger SCH +1, verleiht deiner aktiven Figur 1 Pkt. Schild (2-fach stapelbar).<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(255, 172, 255)\">Elektro</span>] <span style=\"color: rgb(255, 255, 255)\">Kristallisation (Elektro)</span>: Diesmaliger SCH +1, verleiht deiner aktiven Figur 1 Pkt. Schild (2-fach stapelbar).</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/24/61142474/fd37cbfdd3b1b2c16e6e83fb0aa96889_3515244905239738963.png",
                "id": "talent86665",
                "key": "Geo-Schaden",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Geo-Schaden"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Physischer Schaden</span></strong></p><p>Physischer Schaden verleiht kein Elementarattribut und löst keine Elementarreaktionen aus.</p><p></p><p><strong><span style=\"color: #FFFFFF\">Dauer (Runden)</span></strong></p><p>In jeder Endphase wird die <span style=\"color: #FFFFFF\">Dauer (Runden)</span> um 1 Runde reduziert.</p><p>Diese Karte wird sofort abgeworfen, sobald ihre <span style=\"color: #FFFFFF\">Dauer (Runden)</span> abgelaufen ist.</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Einsatzmöglichkeit</span></strong></p><p>Nach Auslösen des Effekts dieser Karte wird 1 <span style=\"color: rgb(255, 255, 255)\">Einsatzmöglichkeit </span>verbraucht. </p><p>Diese Karte wird sofort abgeworfen, sobald ihre <span style=\"color: rgb(255, 255, 255)\">Einsatzmöglichkeiten </span>aufgebraucht sind.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/24/61142474/245c229cf6f7364c7c9a7aea3db1a1ad_3648733923803439936.png",
