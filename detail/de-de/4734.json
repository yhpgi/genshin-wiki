              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Standardangriff</span></p><p>Verursacht 1 Pkt. <span style=\"color: #FF9999\">Pyro-SCH</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/24/61142474/1ce09211f025bf5470682189e0837732_3426761179260392200.png",
                "id": "talent1321",
