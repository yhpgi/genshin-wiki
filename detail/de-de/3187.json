            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Standardangriff</span></p><p>Verursacht 2 Pkt. <span style=\"color: #FFFFFF\">phys. SCH</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/47685001/10316b5178d5109d597f415d6e7903dc_4535717177783370127.png",
