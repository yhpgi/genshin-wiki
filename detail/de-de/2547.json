                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Albedo_icon.png",
                      "name": "Albedo",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Timaeus' Lehrer. Er hilft Timaeus dabei, seine Alchemie-Fertigkeiten zu verbessern.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 30,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Sucrose_icon.png",
                      "name": "Saccharose",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Eine gute Bekannte. Timaeus beneidet sie für die Anerkennung, die sie von Albedo bekommt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 2544,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/npc/Ying'er_icon.png",
                      "name": "Ying’er",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Eine Bekannte, die er während seiner Studien zum „Qualmgraupelelixir“ kennenlernte.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
