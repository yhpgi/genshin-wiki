    {
      "id": "24",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p><strong>Huffman:</strong> Oh, du bist es. Sei gegrüßt, Ehrenritter!</p><p><strong>Huffman:</strong> Kann ich dir irgendwie behilflich sein?</p>",
                "id": "Weitere Informationen15849",
                "img": "",
                "title": "Dialog: Begrüßung"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong><em><span style=\"color: #ECE5D8\">Verfügbar nach dem Kampf gegen Sturmschrecken während des Archontenauftrags Prolog: 3. Akt - „Das Lied von dem Drachen und der Freiheit“</span></em></strong></p><p></p><p><strong>Reisende/r:</strong> Was weißt du über Sturmschrecken?</p><p><strong>Huffman:</strong> Auch wenn das Ende der Krise eine gute Sache ist, so kommt es mit ganz eigenen Problemen.</p><p><strong>Huffman:</strong> Die Toten und Verletzten zählen, beschädigten Besitz reparieren und unsere Verteidigungen ausbauen, falls jemand Schwierigkeiten macht, vor uns liegt noch viel.</p><p><strong>Huffman:</strong> In dieser schwierigen Zeit müssen wir alle unser Bestes tun, um dem stellvertretenden Großmeister einen Teil seiner Last abzunehmen.</p>",
                "id": "Weitere Informationen21552",
                "img": "",
                "title": "Dialog: Sturmschrecken"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Erzähl mir vom Ordo Favonius.</p><p><strong>Huffman:</strong> Möchtest du wissen, wie es uns in der letzten Zeit ergangen ist?</p><p><strong>Huffman:</strong> Vielen Dank für die Anteilnahme! Dank euch konnten wir viele Probleme lösen.</p><p><strong>Huffman:</strong> Es war wundervoll den Erwartungen der Bewohner Mondstadts gerecht zu werden.</p><p><strong>Huffman:</strong> Ich und meine werten Kollegen werden weiterhin unser Bestes tun, die Bürger zu beschützen.</p>",
                "id": "Weitere Informationen95769",
                "img": "",
                "title": "Dialog: Unterhaltung 1"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Erzähl mir von Mondstadt.</p><p><strong>Huffman:</strong> Diese Stadt wird von seinem Gott und seinen Bewohnern geliebt. Sie ist der Grund für die Existenz des Ritterordens.</p><p><strong>Huffman:</strong> Tja, das war's auch mehr oder weniger. Unser Glaube ist gut auf den Punkt zu bringen. Deswegen ist er auch so stark. Was denkst du?</p>",
                "id": "Weitere Informationen47075",
                "img": "",
                "title": "Dialog: Unterhaltung 2"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Auf Wiedersehen.</p><p><strong>Huffman:</strong> Bis bald! Genieße den Wind in Mondstadt.</p>",
                "id": "Weitere Informationen81768",
                "img": "",
                "title": "Dialog: Abschied"
              }
            ]
          }
        }
      ]
    },
