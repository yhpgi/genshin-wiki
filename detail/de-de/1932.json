      "name": "Empfohlene Figuren",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "ewige Mondschein",
                      "type": "text"
                    },
                    {
                      "text": "bietet seinem Träger LP% und verstärkt dessen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Heileffekte",
                      "type": "text"
                    },
                    {
                      "text": ". Zusätzlich werden auch die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Standardangriffe",
                      "type": "text"
                    },
                    {
                      "text": "des Trägers, basierend auf seinen maximalen LP verstärkt und stellen nach dem Einsatz der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Spezialfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "sogar etwas",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Elementarenergie",
                      "type": "text"
                    },
                    {
                      "text": "wieder her.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Figur",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 25,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Sangonomiya Kokomi_icon.png",
                      "name": "Sangonomiya Kokomi",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Sangonomiya Kokomi's eigene Signaturwaffe ist ihre beste Wahl für bessere",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Heilung",
                      "type": "text"
                    },
                    {
                      "text": "und mehr persönlichen Schaden. Das Nebenattribut bietet eine Menge LP% und der passive Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Byakuya Kougetsu",
                      "type": "text"
                    },
                    {
                      "text": "verstärkt alle Heilungseffekte weiter. Zudem verstärkt diese Waffe die eigenen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Standardangriffe",
                      "type": "text"
                    },
                    {
                      "text": "und einen Teil der eigenen maximalen LP - wovon Kokomi normalerweise recht viel hat - und das Einsetzen der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Spezialfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "lässt Kokomi für sich selber geringfügig",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Elementarenergie",
                      "type": "text"
                    },
                    {
                      "text": "wiederherstellen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3609,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/28/61142474/05599650d7f42e1c4adde373de6b297d_722432638078852054.png",
                      "name": "Baizhu",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Baizhu profitiert vor allem vom LP%-Nebenattribut sowie von der Verstärkung der Heileffekte. Baizhu ist oftmals nicht lange auf dem Feld, allerdings bietet diese Waffe ihm etwas mehr persönlichen Schaden mit seinen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Standardangriffen",
                      "type": "text"
                    },
                    {
                      "text": ", da auch er in der Regel recht hohe LP-Werte anstrebt. Sollte man mit ihm",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Standardangriffe",
                      "type": "text"
                    },
                    {
                      "text": "nutzen, um beispielsweise von deren",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Dendro",
                      "type": "text"
                    },
                    {
                      "text": "-Applikation zu profitieren, so kann man auch den passiven Effekt nutzen und etwas von Baizhu's",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Elementarenergie",
                      "type": "text"
                    },
                    {
                      "text": "wiederherstellen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 35,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Barbara_icon.png",
                      "name": "Barbara",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Barbara, ähnlich wie",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 25,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Sangonomiya Kokomi_icon.png",
                      "name": "Sangonomiya Kokomi",
                      "type": "custom_entry"
                    },
                    {
                      "text": "und",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 3609,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/28/61142474/05599650d7f42e1c4adde373de6b297d_722432638078852054.png",
                      "name": "Baizhu",
                      "type": "custom_entry"
                    },
                    {
                      "text": ", nutzt diese Waffe vor allem, da ihre Attribute Barbara's",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Heilung",
                      "type": "text"
                    },
                    {
                      "text": "verbessert. Auch Barbara kann den Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Byakuya Kougetsu",
                      "type": "text"
                    },
                    {
                      "text": "nutzen, um ihre Standardangriffe zu verstärken und mit ihnen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Elementarenergie",
                      "type": "text"
                    },
                    {
                      "text": "wiederherzustellen. Da Barbara selbstständig ohne Sternbilder (1. oder 4.) keine Elementarpartikel generieren kann, kann dieser Effekt ihr dabei etwas helfen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
