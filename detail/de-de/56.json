          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "5. Akt, 3. Szene",
                      "type": "text"
                    },
                    {
                      "text": "„... Juusaburou führte den Rest der Samurai an und kämpfte erbittert mit den Banditen ...",
                      "type": "text"
                    },
                    {
                      "text": "... Die Banditen zerstreuten sich allmählich und flohen unter dem Angriff von Juusaburou und den anderen.",
                      "type": "text"
                    },
                    {
                      "text": "Text:",
                      "type": "text"
                    },
                    {
                      "text": "„Kyuuzou: Juusaburou! Die Banditen sind fast weg!“",
                      "type": "text"
                    },
                    {
                      "text": "„Juusaburou: Sie werden nie Taniko so einfach aufgeben! Mach die Augen auf!“",
                      "type": "text"
                    },
                    {
                      "text": "... Nachdem er die Banditen besiegt hatte, schaute sich Juusaburou verwirrt um und rief:",
                      "type": "text"
                    },
                    {
                      "text": "Text:",
                      "type": "text"
                    },
                    {
                      "text": "„Juusaburou: Wo sind die Banditen?“",
                      "type": "text"
                    },
                    {
                      "text": "„Kyuuzou: Ich habe mich gut um sie gekümmert.“",
                      "type": "text"
                    },
                    {
                      "text": "Juusaburou stand wie erstarrt da, schaute sich um und heulte plötzlich auf.“",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
