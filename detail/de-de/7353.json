                      "text": "Geniale Beschwörung Herausforderungen",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Figuren-Einladungsduell: Duell - Nett",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Einführung der Herausforderung",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "„Komm, lass mich dich in die wunderbare Welt der Karten entführen. Als Kartenbeschwörerin hab ich außerdem auch ziemlich was auf dem Kasten!“",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(204, 191, 173)"
                      ],
                      "text": "Hinweis:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ccbfad"
                      ],
                      "text": "Herzstück von Mualanis Deck sind „Beschwörungen“. Außerdem versteht sie sich darauf, zwischen verschiedenen Figuren hin- und herzuwechseln, wodurch sie flexibel Schaden auszuteilen vermag.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Gegnerische Aufstellung",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7353,
                      "icon_url": "",
                      "name": "Mualani",
                      "type": "custom_entry"
                    },
