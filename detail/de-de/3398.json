    {
      "id": "68",
      "name": "Geniale Beschwörung",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Abenteuer-Herausforderung: Reise durch das Reich des Gesteins",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Einführung der Herausforderung",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Wegen des strömenden Regens habt ihr im Gasthaus Wangshu Halt gemacht. Doch da hörtet ihr Geflüster von irgendwelchen Plänen. Du schaust genau dahin, und ach - wer könnte das noch sein, wenn nicht die Spione der Fatui?",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Sonderregel:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Dein Unterstützungsplatz hat anfangs eine „Lui Su“-Karte; verleiht den aktiven Figuren beider Seiten zu Beginn der Zugphase das Hydro-Attribut.",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
