                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elementarfähigkeit</span><br>Erschafft 1 <span style=\"color: rgb(255, 255, 255)\">Schwertschatten – Einsamer Sturm</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/61142474/2277b4223c3dad658f81a6111c9afa1a_6081236865920829076.png",
