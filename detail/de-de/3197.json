                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Einsamer Sturm"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elementarfähigkeit</span></p><p>Erschafft 1 <span style=\"color: rgb(255, 255, 255)\">Schwertschatten – Galoppierender Frost</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/61142474/c3c234c2ef7f4886cf9e3f66a9d7c7af_1102845362845010296.png",
                "id": "talent50768",
                "key": "Frostiger Schatten",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Frostiger Schatten"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Spezialfähigkeit</span></p><p>Verursacht 4 Pkt. <span style=\"color: rgb(128, 255, 215)\">Anemo-SCH</span>, löst den Effekt aller eigenen Beschwörungen von <span style=\"color: rgb(255, 255, 255)\">Schwertschatten </span>aus (Kein Verbrauch ihrer Einsatzmöglichkeiten).</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/61142474/0d7c96d3e920a99c58744d15b1b20d0b_4174765752302536090.png",
                "id": "talent85148",
                "key": "Maschineller Tengu-Feger",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Maschineller Tengu-Feger"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Beschwörung</span></p><p><span style=\"color: rgb(255, 255, 255)\">Endphase</span>: Verursacht 1 Pkt. <span style=\"color: rgb(128, 255, 215)\">Anemo-SCH</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Einsatzmöglich</span><span style=\"color: #FFFFFF\">keit: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/61142474/db13288db6b90ec33f8adc2656d2019f_1671258168763503032.png",
                "id": "talent9105",
                "key": "Schwertschatten - Einsamer Sturm",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/61142474/01ccafbe27188aef259b0286fd0b4545_1315546141993496453.png",
                "title": "Schwertschatten - Einsamer Sturm"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Beschwörung</span></p><p><span style=\"color: rgb(255, 255, 255)\">Endphase</span>: Verursacht 1 Pkt. <span style=\"color: rgb(153, 255, 255)\">Kryo-SCH</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Einsat</span><span style=\"color: #FFFFFF\">zmöglichkeit: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/61142474/db13288db6b90ec33f8adc2656d2019f_3401824486944029779.png",
                "id": "talent35704",
                "key": "Schwertschatten - Galoppierender Frost",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/61142474/e7a414623d5d709d441b0ca6779155bf_28785652850791591.png",
                "title": "Schwertschatten - Galoppierender Frost"
              },
              {
                "attributes": [],
                "desc": "<p>Löst Reaktionen mit dem bestehenden Elementarattribut aus:<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(153, 255, 255)\">Kryo</span>] <span style=\"color: rgb(255, 255, 255)\">Verwirbelung (Kryo)</span>: Fügt allen Figuren des Gegners außer deinem Ziel 1 Pkt. Kryo-SCH zu.<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Verwirbelung (Hydro):</span> Fügt allen Figuren des Gegners außer deinem Ziel 1 Pkt. Hydro-SCH zu.<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Verwirbelung (Pyro)</span>: Fügt allen Figuren des Gegners außer deinem Ziel 1 Pkt. Pyro-SCH zu.<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 172, 255)\">Elektro</span>] <span style=\"color: rgb(255, 255, 255)\">Verwirbelung (Elektro)</span>: Fügt allen Figuren des Gegners außer deinem Ziel 1 Pkt. Elektro-SCH zu.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/61142474/c97292d96456bfe4abeca16bfce801e4_2378120717459460785.png",
                "id": "talent5952",
                "key": "Anemo-Schaden",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Anemo-Schaden"
              },
              {
                "attributes": [],
                "desc": "<p>Verleiht Kryo-Attribut und kann folgende Elementarreaktionen auslösen:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Kryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Schmelzen</span>: Diesmaliger SCH +2.</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Kryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Elektro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Supraleiter</span>: Diesmaliger SCH +1, fügt allen Figuren des Gegners außer deinem Ziel 1 Pkt. durchdringenden SCH zu.</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Kryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Gefroren</span>: Diesmaliger SCH +1, Aktionen des Ziels in dieser Runde unmöglich (Phys. SCH und Pyro-SCH an dem Ziel +2, bricht zugleich seinen Gefrorenen-Zustand).</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/61142474/4bcc4b82a9d7ee22770f60afa54e9919_4416878486652139617.png",
                "id": "talent28564",
                "key": "Kryo-Schaden",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Kryo-Schaden"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Physischer Schaden</span></strong></p><p>Physischer Schaden verleiht kein Elementarattribut und löst keine Elementarreaktionen aus.</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Einsatzmöglichkeit</span></strong></p><p>Nach Auslösen des Effekts dieser Karte wird 1 <span style=\"color: rgb(255, 255, 255)\">Einsatzmöglichkeit </span>verbraucht.</p><p>Diese Karte wird sofort abgeworfen, sobald ihre <span style=\"color: rgb(255, 255, 255)\">Einsatzmöglichkeiten </span>aufgebraucht werden.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/12/61142474/245c229cf6f7364c7c9a7aea3db1a1ad_4763746044443793292.png",
                "id": "talent44584",
                "key": "Detaillierte Regeln",
