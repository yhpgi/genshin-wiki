    {
      "id": "41",
      "name": "Inhalt",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Freunde von Mondstadt, lasst uns feiern, hoch die Tassen!",
                      "type": "text"
                    },
                    {
                      "text": "Für die Freiheit, auf den Gott des Windes!",
                      "type": "text"
                    },
                    {
                      "text": "Auf Vennessa, den allerbesten Ritter!",
                      "type": "text"
                    },
                    {
                      "text": "Kinder von Mondstadt, vergesst niemals das Geschenk des Windes in euren Herzen!",
                      "type": "text"
                    },
                    {
                      "text": "Nein, Freiheit ist kein Geschenk, Widerstand schon!",
                      "type": "text"
                    },
                    {
                      "text": "Die Geschichte beginnt vor langer Zeit.",
                      "type": "text"
                    },
                    {
                      "text": "Freunde des Weins, bitte verzeiht meine Abschweifungen.",
                      "type": "text"
                    },
                    {
                      "text": "Aber eines sollt ihr verstehen, dass die Freiheit Mondstadts",
                      "type": "text"
                    },
                    {
                      "text": "begann, als Barbatos die Saiten erstmalig zum Beben brachte.",
                      "type": "text"
                    },
                    {
                      "text": "Gedichte sprechen von seiner Heldengestalt,",
                      "type": "text"
                    },
                    {
                      "text": "namenlose Freiheit ist jedoch das, was wir in Erinnerung behalten sollten.",
                      "type": "text"
                    },
                    {
                      "text": "Zu jener Zeit ächzte Mondstadt unter den Fesseln der Aristokratie",
                      "type": "text"
                    },
                    {
                      "text": "und Festlichkeiten waren nur für die Reichen vorbestimmt,",
                      "type": "text"
                    },
                    {
                      "text": "nicht zu erreichen für das normale Volk.",
                      "type": "text"
                    },
                    {
                      "text": "Mondstadt war nichts mehr als ein Gefängnis im Wind.",
                      "type": "text"
                    },
                    {
                      "text": "Sklavenspiele waren ein Vergnügen für die Adligen.",
                      "type": "text"
                    },
                    {
                      "text": "Doch niemand war sich bewusst, in einem Gefängnis zu sein.",
                      "type": "text"
                    },
                    {
                      "text": "Ein jüngeres Mädchen war ebenfalls im Gefängnis.",
                      "type": "text"
                    },
                    {
                      "text": "Sie kam aus südlicheren Gefilden.",
                      "type": "text"
                    },
                    {
                      "text": "Frei geboren und dennoch in Ketten.",
                      "type": "text"
                    },
                    {
                      "text": "In den Händen eines Tyrannen",
                      "type": "text"
                    },
                    {
                      "text": "gab sie niemals das Beten um Besserung auf.",
                      "type": "text"
                    },
                    {
                      "text": "Beten für ihre Leute, für das Volk von Mondstadt, für die Freiheit aller.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
