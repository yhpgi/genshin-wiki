                {
                  "content": [
                    {
                      "text": "Voraussetzung",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Erreiche Kartenbeschwörerstufe 8",
