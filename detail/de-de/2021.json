                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 29,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Shenhe_icon.png",
                      "name": "Shenhe",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Die Favonius-Lanze bietet Shenhe einen hohen Basis-ANG, den sie mit mehreren ANG%-Artefakten verstärken kann, um mithilfe ihren",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Eisfedern",
                      "type": "text"
                    },
                    {
                      "text": "ihre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Kryo-Truppenmitglieder",
                      "type": "text"
                    },
                    {
                      "text": "zu unterstützen. Neben dem Aufladerate-Nebenattribut bietet die Favonius-Lanze mit dem passiven Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Folge dem Wind",
                      "type": "text"
                    },
                    {
                      "text": "Shenhe die Möglichkeit, für ihre Truppenmitglieder",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Energiepartikel",
                      "type": "text"
                    },
                    {
                      "text": "zu generieren und damit ihre Rolle als",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Unterstützer",
                      "type": "text"
                    },
                    {
                      "text": "noch weiter zu festigen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 46,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Zhongli_icon.png",
                      "name": "Zhongli",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Besitzt Zhongli ausreichend LP% damit sein",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Schild",
                      "type": "text"
                    },
                    {
                      "text": "für die aktive Figur genug Schaden absorbieren kann, gewinnt die Favonius-Lanze für Zhongli an Wert. Nicht nur erlaubt ihm mehr Aufladerate, dass er mit seiner",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Spezialfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "Gegner öfters",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Versteinern",
                      "type": "text"
                    },
                    {
                      "text": "kann, der Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Folge dem Wind",
                      "type": "text"
                    },
                    {
                      "text": "kann auch eine weitere Möglichkeit der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Unterstützerrolle",
                      "type": "text"
                    },
                    {
                      "text": "öffnen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 49,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Raiden Shogun_icon.png",
                      "name": "Shougun Raiden",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Shougun Raiden profitiert über mehrere Wege von einer hohen Aufladerate, nicht zuletzt mit dem Artefaktset",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2090,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Emblem of Severed Fate/flower_of_life_icon.png",
                      "name": "Wappen des getrennten Schicksals",
                      "type": "custom_entry"
                    },
                    {
                      "text": ". Darüberhinaus bietet ihr die Favonius-Lanze einen hohen Basis-ANG und die Möglichkeit, neben der Elementarenergie-Wiederherstellung von",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Musou Isshin",
                      "type": "text"
                    },
                    {
                      "text": ", auch mit dem passiven Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Folge dem Wind",
                      "type": "text"
                    },
                    {
                      "text": "allen Truppenmitgliedern",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Energiepartikel",
                      "type": "text"
                    },
                    {
                      "text": "zur Verfügung zu stellen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2815,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/27/61142474/2f43da4ece9eabfbde6ec2fcc81b3bff_330495388711675042.png",
                      "name": "Candace",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Neben etwas",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "Hydro-Schaden",
                      "type": "text"
                    },
                    {
                      "text": ", der mit Candaces LP skaliert, ist ihre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Spezialfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "in erster Linie utilitärer Natur. Es ist die einzige Fähigkeit die es erlaubt, anderen Figuren die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "Hydro-Kraft",
                      "type": "text"
                    },
                    {
                      "text": "zu verleihen. Aus diesem Grund ist die Favonius-Lanze für Candace besonders interessant, da es ihr nicht nur mit dem Aufladerate-Nebenattribut hilft, ihre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Spezialfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "öfter einsetzen zu können, sondern auch der ganzen Truppe zusätzliche",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Energiepartikel",
                      "type": "text"
                    },
                    {
                      "text": "zur Verfügung stellen kann und damit ihre Rolle als",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Unterstützer",
                      "type": "text"
                    },
                    {
                      "text": "noch weiter zu festigt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 33,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Rosaria_icon.png",
                      "name": "Rosaria",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ein Großteil von Rosarias Stärke liegt in ihrere",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Spezialfähigkeit Letze Salbung",
                      "type": "text"
                    },
                    {
                      "text": ". Besonders in Truppen, in denen sie eine",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "unterstützende",
                      "type": "text"
                    },
                    {
                      "text": "Rolle einnimmt, und vor allem für ihre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Kryo-Applikation",
                      "type": "text"
                    },
                    {
                      "text": "genutzt wird, kann Rosaria gut von der Favonius-Lanze Gebrauch machen. Ein Aufladerate-Nebenattribut, welches ihr beim Einsetzen ihrer",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
