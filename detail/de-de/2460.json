    {
      "id": "36",
      "name": "Dialoge",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Standarddialoge",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Ad astra abyssosque! Willkommen in der Abenteurergilde!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "[Belohnung für tägliche Missionen abholen (nicht vollständig erledigt)]",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Oh, das tut mir leid, aber du hast noch nicht genügend Missionen abgeschlossen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "[Belohnung für tägliche Missionen abholen (vollständig erledigt)]",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Wir danken dir, dass du die Missionen heute abgeschlossen hast. Hier ist deine Belohnung dafür.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "[Belohnung für tägliche Missionen abholen (Belohnung bereits erhalten)]",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Du hast deine Belohnung für heute schon abgeholt. Wir hoffen, dass du morgen weiter so fleißig bist und unsere Missionen annimmst.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Tschüs.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Tschüs. Vielen Dank für deinen Beitrag an die Abenteurergilde!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Regionsspezifische Dialoge",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Mondstadt",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Wer bist du?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Ich? Na, ich bin Katheryne, also die, die für die Mitglieder in der Gilde verantwortlich ist.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Ich kümmere mich um die Herausgabe von Aufträgen für Abenteurer in Mondstadt und übernehme einige assistierende Tätigkeiten.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Übrigens macht die Abenteurergilde keinen Urlaub!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Was macht die Abenteurergilde denn so?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Die Abenteurergilde ist eine Organisation, die die Abenteurer in den sieben Städten unterstützt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Auf diese Weise erhalten die neuen Abenteurer angemessene Hilfestellung, während die alten Hasen unbehelligt ihrem Tagwerk nachgehen können.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Die Gilde sammelt und ordnet all die Dinge, die die Abenteurer allerorts aufgeschnappt haben, um dann die passenden Aufträge an die Abenteurer zu vergeben.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Liyue",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Katheryne?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Ganz recht, ich bin Katheryne, die für die Mitglieder in der Gilde verantwortlich ist.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Ich kümmere mich um die Herausgabe von Aufträgen für Abenteurer und übernehme einige assistierende Tätigkeiten - das ganze Jahr über ohne Pause, möchte ich hinzufügen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Ist alles klar bei dir? Du scheinst irritiert zu sein.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Wie bist du denn hierhergekommen?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Tut mir leid, ich verstehe nicht ganz.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Jeder in der Gilde weiß, dass Katheryne die Empfangsdame ist. Auch die Niederlassung in Liyue kommt nicht ohne Empfangsdame aus.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Aus diesem Grund ist Katheryne hier.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Hast du damit irgendein Problem?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Inazuma",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Hallo?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Hallo, ich bin Katheryne, die Empfangsdame der Abenteurergilde. Meine Aufgabe ist es, die Abenteurer mit Missionen und nachrichtendienstlicher Unterstützung zu versorgen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Dieser Dienst ist rund um die Uhr verfügbar, sodass es keinen Grund zur Sorge gibt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Eine weitere Katheryne ...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Noch eine? Hehehe, hast du jemals mehr als eine Katheryne auf einmal gesehen?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Wenn nicht, hast du wahrscheinlich jedes Mal mich gesehen. Um den Anforderungen der Abenteurer aus aller Welt gerecht zu werden, benutze ich ein spezielles Werkzeug, um mich zu teleportieren und an mehreren Orten gleichzeitig zu arbeiten.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Ich würde mich auch gern teleportieren!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Oje, das hast du tatsächlich geglaubt?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Tut mir leid, das war ein Scherz. Bitte nimm es dir nicht zu Herzen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Auf jeden Fall weißt du wahrscheinlich, wie du die Teleportationspunkte benutzen kannst, richtig?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Sumeru",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Katheryne, du bist es wieder!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Hallo, ich bin es tatsächlich, Katheryne, die Empfangsdame der Abenteurergilde. Meine Aufgabe ist es, Abenteurer mit Missionen und nachrichtendienstlicher Unterstützung zu versorgen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Da du dich ja scheinbar schon mit der Arbeitsweise der Abenteurergilde auskennst, erspare ich mir eine Einführung.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Bist du mir etwa die ganze Zeit gefolgt, Katheryne?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Hehe, wenn ich auf öffentliche Kosten entsendet werden würde, würde ich das nicht ablehnen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Doch als Empfangsdame bin ich leider das ganze Jahr über beschäftigt, da bleibt mir keine Zeit für so etwas.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Zusätzlicher Dialog nach dem Beenden des Archontenauftrags Kapitel III – 3. Akt „Luftschlösser, Illusionen und Betrug“",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Reisende/r:",
                      "type": "text"
                    },
                    {
                      "text": "Wie fühlst du dich jetzt, Katheryne?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Wie ich mich fühle? ... Habe ich mich unwohl gefühlt?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Katheryne:",
                      "type": "text"
                    },
                    {
                      "text": "Es tut mir leid, aber ich fürchte, dass ich mich nicht genau erinnern kann, was vorher passiert ist ... aber da ich jetzt hier bin, war es wohl kein Problem.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
