    {
      "id": "41",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "An Etta",
                      "type": "text"
                    },
                    {
                      "text": "Wir beide haben von der Bitternis der Gefangenschaft gekostet.",
                      "type": "text"
                    },
                    {
                      "text": "Die Regeln des Königs der Könige sind wie der bevorstehende Sonnenuntergang.",
                      "type": "text"
                    },
                    {
                      "text": "Und dennoch will ich auch weiterhin die Freiheit für dich.",
                      "type": "text"
                    },
                    {
                      "text": "Freiheit, dieser ein Morgentau, der nirgendwo sonst herzubekommen ist,",
                      "type": "text"
                    },
                    {
                      "text": "ist eine Flussströmung, eine verborgene Oase und die Quelle aller Weisheit.",
                      "type": "text"
                    },
                    {
                      "text": "Ich bete, dass ein Tag kommen möge, an dem der Geist des Sieges nicht länger siegreich ist,",
                      "type": "text"
                    },
                    {
                      "text": "an dem sein Schwert durch seinen Stolz verrostet und an dem seine Krone auf dem Boden zurückbleibt.",
                      "type": "text"
                    },
                    {
                      "text": "An jenem Tag werden alle Ketten gesprengt werden",
                      "type": "text"
                    },
                    {
                      "text": "und in jedem Garten werden Lieder erklingen.",
                      "type": "text"
                    },
                    {
                      "text": "Der Morgentau wird unbemerkt mit dem Mondlicht kommen",
                      "type": "text"
                    },
                    {
                      "text": "und er wird uns zum Ende der gelben Sande führen,",
                      "type": "text"
                    },
                    {
                      "text": "zu einem Ort, der weiter entfernt ist als der Himmel selbst.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
