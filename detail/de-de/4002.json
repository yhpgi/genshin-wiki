      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Spross der flammenden Sonne",
                      "type": "text"
                    },
                    {
                      "text": "ist eine Waffe, die den Kauf des Gnostiker-Erlebnispasses voraussetzt. Neben dem KT-Nebenattribut bietet diese Waffe außerdem einen hohen Basis-ANG. Der passive Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Pfad der Sonnenflamme",
                      "type": "text"
                    },
                    {
                      "text": "verstärkt zusätzlich",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "heftige Schläge",
                      "type": "text"
                    },
                    {
                      "text": "gegen ein einzelnes Ziel.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
