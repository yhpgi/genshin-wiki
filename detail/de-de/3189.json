                "desc": "<p><span style=\"color: #FFD780\">Elementarfähigkeit</span></p><p>Verursacht 3 Pkt. <span style=\"color: #99FF88\">Dendro-SCH</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/36893887/65ecca0b0d5fbfffdb80965a99581b74_3967341373477443691.png",
