                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "13. August 2022",
                      "type": "text"
                    },
                    {
                      "text": "Überblick von den Gebirgen aus das üppige Grün,",
                      "type": "text"
                    },
                    {
                      "text": "riech den Duft von Rosen, die Felder und Hügel schmücken.",
                      "type": "text"
                    },
                    {
                      "text": "Lausch dem fröhlichen Vogelgezwitscher im Morgengrauen,",
                      "type": "text"
                    },
                    {
                      "text": "in dem die verstummte Weisheit mitschwingt, die aus dem hundertjährigen Schlummer erwacht ist.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
