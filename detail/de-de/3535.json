    {
      "id": "24",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p><strong>Nora:</strong> Ah, was? Willst du mit mir spielen?</p>",
                "id": "Weitere Informationen2392",
                "img": "",
                "title": "Dialog: Begrüßung"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Wo sind deine Eltern?</p><p><strong>Nora:</strong> Mein Papa ist Patton!</p><p><strong>Nora:</strong> Er ist dort, wo immer die ganzen betrunkenen Onkel hingehen.</p><p><strong>Nora:</strong> Papa hat viel zu tun. Deswegen muss ich allein spielen.</p>",
                "id": "Weitere Informationen94639",
                "img": "",
                "title": "Dialog: Unterhaltung 1"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Was spielst du denn?</p><p><strong>Nora:</strong> Ich spiele gern in der Nähe der Statue.</p><p><strong>Nora:</strong> Die Statue ist so groß und schön.</p><p><strong>Nora:</strong> Warst du schon mal oben? Ich wollte mal hoch, aber Tante Grace hat es mir verboten.</p><p><strong>Nora:</strong> Tante Grace ist lieb, ich will sie nicht verärgern.</p><p><strong>Nora:</strong> Wenn du mal oben bist, kannst du mir erzählen, wie die Aussicht ist.</p>",
                "id": "Weitere Informationen53889",
                "img": "",
                "title": "Dialog: Unterhaltung 2"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Tschüs.</p><p><strong>Nora:</strong> Ooh, du willst schon gehen?</p>",
                "id": "Weitere Informationen81248",
                "img": "",
                "title": "Dialog: Abschied"
              }
            ]
          }
        }
      ]
