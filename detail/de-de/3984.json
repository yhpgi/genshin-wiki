    {
      "id": "39",
      "name": "Empfohlene Figuren",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Das",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Finale in der Tiefe",
                      "type": "text"
                    },
                    {
                      "text": "ist eine schmiedbare Waffe aus Fontaine und bietet vor allem ANG und ANG%-Boni. Der Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Eid des Lebens",
                      "type": "text"
                    },
                    {
                      "text": "wird beim Nutzen der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Elementarfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "aktiviert und bietet weitere Boni, wenn die Figur um den Wert des Eides",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "geheilt",
                      "type": "text"
                    },
                    {
                      "text": "wurde. Dabei berechnet sich der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Eid des Lebens",
                      "type": "text"
                    },
                    {
                      "text": "auf die maximalen LP der Figur. Das optimale Nutzen dieser Waffe setzt einen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Heiler",
                      "type": "text"
                    },
                    {
                      "text": "in der Truppe voraus.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Figur",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3962,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/61142474/436e6f2b9b9006bfe511a98093259daf_834066188861128909.png",
                      "name": "Lynette",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Lynette's",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Elementarfähigkeit",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "heilt",
                      "type": "text"
                    },
                    {
                      "text": "sie selbst um genau 25%. Dies ist auch der Wert, den der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Eid des Lebens",
                      "type": "text"
                    },
                    {
                      "text": "immer annimmt. Damit hat sie keinerlei Probleme, diesen Effekt selbstständing zu nutzen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 32,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Kamisato Ayaka_icon.png",
                      "name": "Kamisato Ayaka",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ayaka profitiert sehr viel von ANG-Boni in ihren",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Gefrieren-Kompositionen",
                      "type": "text"
                    },
                    {
                      "text": ". Da sie in diesen Situationen oft einen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Heiler",
                      "type": "text"
                    },
                    {
                      "text": "in der Truppe hat, kann sie recht zuverlässig das volle Potential dieser Waffe ausnutzen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 27,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Jean_icon.png",
                      "name": "Jean",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Jean nutzt ANG-Boni sehr gut aus, kann aber zugleich auch die Rolle der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Heilerin",
                      "type": "text"
                    },
                    {
                      "text": "erfüllen. Dadruch kann sie diese Waffe ganz unabhängig vom Rest ihrer Truppe nutzen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 31,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Kamisato Ayato_icon.png",
                      "name": "Kamisato Ayato",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ayato profitiert selbst etwas von zusätzlichen LP (zB.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "Hydro-Resonanz",
                      "type": "text"
                    },
                    {
