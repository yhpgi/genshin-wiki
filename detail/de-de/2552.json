                      "name": "Fürst des untergehenden Mondes und der aufgehenden Sonne",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2519,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/21/19929963/24ed91484b6cba0d0f8c7dd916b9f774_8553136342884295936.png",
                      "name": "Fürst der fließenden Wasser und aufgetürmten Berge",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2523,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/21/19929963/46ee1323ddfe94fe1707c1d50912504e_1645445170765267682.png",
                      "name": "Fürstin der stehenden Wolken und des stillen Windes",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 28,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Ganyu_icon.png",
                      "name": "Ganyu",
