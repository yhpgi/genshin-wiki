                "desc": "<p><span style=\"color: #FFD780\">Elementarfähigkeit</span></p><p>Verursacht 3 Pkt. <span style=\"color: #FFFFFF\">phys. SCH</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/61142474/b81f8bd6ae1e5b5f53807a4cd0704469_8870021677662398502.png",
                "id": "talent46812",
