      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Lied unbekannter Herkunft",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "…",
                      "type": "text"
                    },
                    {
                      "text": "Wir sind Kinder ohne Blutsverwandte, demütige Diener an vorderster Front, wo uns der Segen der Zarin nicht erreichen kann.",
                      "type": "text"
                    },
                    {
                      "text": "In der linken Hand halten wir den Schild zur Verteidigung unseres Heimatlandes, in der rechten das Schwert, das den Willen des Wintersterns in Snezhnaya vertritt.",
                      "type": "text"
                    },
                    {
                      "text": "Wir tragen Masken und missachten somit die göttliche Vorsehung. Die falschen Götter und ihre Kettenhunde treten wir mit Füßen.",
                      "type": "text"
                    },
                    {
                      "text": "...",
                      "type": "text"
                    },
                    {
                      "text": "Ich bin das Böse im Guten, das Gift in der Medizin, der Wolf in der Schafherde und das Quecksilber im Goldkelch …",
                      "type": "text"
                    },
                    {
                      "text": "Ich muss mich oft von Brüdern, die enger als Blutsbrüder sind, verabschieden. Ich diene den Eltern, die besser sind, als eigene Eltern.",
                      "type": "text"
                    },
                    {
                      "text": "Lieber Snezhevich, liebe Snezhevna und liebste Geschwister,",
                      "type": "text"
                    },
                    {
                      "text": "wenn ich eines Tages unter einer großen Birke entschlafe, leuchte ich euch den Weg nach vorne …",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
