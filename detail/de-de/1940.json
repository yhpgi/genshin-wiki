      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Drachenschreck",
                      "type": "text"
                    },
                    {
                      "text": "bietet neben einem hohen Elementarkunde-Nebenattribut, auch einen Effekt, der den Schaden erhöht, wenn Gegner von",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "Hydro",
                      "type": "text"
                    },
                    {
                      "text": "- oder",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Pyro",
                      "type": "text"
                    },
                    {
                      "text": "-Effekten betroffenen sind. Dieser Effekt ist auch aktiv, wenn der Träger nicht aktiv auf dem Feld ist.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ist ein Gegner von der Reaktion „",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 172, 255)"
                      ],
                      "text": "Unter Strom",
                      "type": "text"
                    },
                    {
                      "text": "“ oder „",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "In Flammen",
                      "type": "text"
                    },
                    {
                      "text": "“ betroffen, gilt dies auch für den Effekt dieser Waffe.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Figur",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 50,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Xiangling_icon.png",
                      "name": "Xiangling",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Spielt man Xiangling in einer",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Verdampfen",
                      "type": "text"
                    },
                    {
                      "text": "-Komposition, so nutzt sie sowohl die Elementarkunde, als auch den Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Bewährtheit von Feuer und Wasser",
                      "type": "text"
                    },
                    {
                      "text": "perfekt aus. Trifft ihr",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Feuerrad",
                      "type": "text"
                    },
                    {
                      "text": "einen Gegner der unter der „",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 172, 255)"
                      ],
                      "text": "Unter Strom",
                      "type": "text"
                    },
                    {
                      "text": "“-Reaktion leidet, so löst sie außerdem noch eine",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Überladen-",
                      "type": "text"
                    },
                    {
                      "text": "Reaktion aus.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 34,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Hu Tao_icon.png",
                      "name": "Hu Tao",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Da Hu Tao einen Großteil ihres Schadens über die Umwandlung ihrer LP in ANG gewinnt, ist für sie eine Waffe mit geringerem Basis-ANG nicht so einschneidend. Hu Tao profitiert vor allem davon, ihre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "heftigen Schläge",
                      "type": "text"
                    },
                    {
                      "text": "mit der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Verdampfen",
                      "type": "text"
                    },
                    {
                      "text": "-Reaktion zu verstärken. Dadurch nutzt sie nicht nur das Elementarkunde-Nebenattribut, sondern profitiert auch vom Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Bewährtheit von Feuer und Wasser",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 49,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Raiden Shogun_icon.png",
                      "name": "Shougun Raiden",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Raiden hat genau eine Verwendung für den",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Drachenschreck",
                      "type": "text"
                    },
                    {
                      "text": ": als Auslöser der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Supraspross",
                      "type": "text"
                    },
                    {
                      "text": "-Reaktion. Zwar wird der Schaden dieser Reaktion nicht vom Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Bewährtheit von Feuer und Wasser",
                      "type": "text"
                    },
                    {
                      "text": "beeinflusst, aber es ist die Waffe, die Raiden die meiste Elementarkunde bietet.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
