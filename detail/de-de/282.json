    {
      "id": "41",
      "name": "Inhalt",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Auf jeder Straße in Mondstadt bin ich bereits gewandelt.",
                      "type": "text"
                    },
                    {
                      "text": "In der Luft lag eine Brise von Unbehagen und etwas undefinierbar Berauschendes.",
                      "type": "text"
                    },
                    {
                      "text": "Ich sah die Arrogantesten der Aristokraten,",
                      "type": "text"
                    },
                    {
                      "text": "aber auch die Ärmsten der Armen.",
                      "type": "text"
                    },
                    {
                      "text": "Die dunklen Straßen glichen einem Spinnennetz, fein säuberlich die Schichten der Gesellschaft trennend.",
                      "type": "text"
                    },
                    {
                      "text": "In der sonst stillen Nacht ist ein Rasseln zu vernehmen – das Rasseln der Ketten der Unterdrückten.",
                      "type": "text"
                    },
                    {
                      "text": "Als ich so durch die Straßen von Mondstadt wandelte,",
                      "type": "text"
                    },
                    {
                      "text": "auf denen meine Kollegen und Vorgesetzten einst verkündeten,",
                      "type": "text"
                    },
                    {
                      "text": "„Wir sind Ritter des Sternenlichts! Richtet auf euer stolzes Haupt!",
                      "type": "text"
                    },
                    {
                      "text": "Die Flagge funkelt in unserem Sternenglanz, wir sind die wahren Beschützer!“",
                      "type": "text"
                    },
                    {
                      "text": "Jedoch habe ich kein einziges Mal mein Haupt erhoben noch mir die Flagge angesehen.",
                      "type": "text"
                    },
                    {
                      "text": "Die Straßen hier sind dafür einfach zu dreckig.",
                      "type": "text"
                    },
                    {
                      "text": "Bankrotte Händler wimmern leise vor sich hin,",
                      "type": "text"
                    },
                    {
                      "text": "pensionierte Soldaten leiden immer noch an ihren Schmerzen.",
                      "type": "text"
                    },
                    {
                      "text": "In diesen tödlichen Straßen bei Nacht",
                      "type": "text"
                    },
                    {
                      "text": "höre ich, wie ein junges Mädchen, das von den Aristokraten abgelehnt wurde, um Barbatos Gnade fleht.",
                      "type": "text"
                    },
                    {
                      "text": "Seufzender Wind rüttelte am Tor der Kathedrale,",
                      "type": "text"
                    },
                    {
                      "text": "als der Schmerz und die Trauer der Unterdrückten an den opulenten Wänden kratzten.",
                      "type": "text"
                    },
                    {
                      "text": "Der Ruf einer jeden Mutter,",
                      "type": "text"
                    },
                    {
                      "text": "der Schrei eines jeden Kindes",
                      "type": "text"
                    },
                    {
                      "text": "sind genug, um jeden Schild zu brechen",
                      "type": "text"
                    },
                    {
                      "text": "und den schärfsten Speer zu biegen.",
                      "type": "text"
                    },
                    {
                      "text": "Laute von Seufzern lassen mir Schauer über den Rücken laufen.",
                      "type": "text"
                    },
                    {
                      "text": "Im Palast und in den hohen Türmen jedoch",
                      "type": "text"
                    },
                    {
                      "text": "und auf geheiligtem Boden",
                      "type": "text"
                    },
                    {
                      "text": "sind diese Seufzer nicht mehr als das Summen von Insekten in den Ohren der Mächtigen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
