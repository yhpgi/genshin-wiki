                    {
                      "amount": 1,
                      "display_style": "text",
                      "ep_id": 3332,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/05/236594615/e0aa5d2537230aec60f8a3969c532023_6159497285126806406.png",
