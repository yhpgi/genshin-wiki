    {
      "id": "43",
      "name": "Elementarer Einklang",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Wenn die Truppe mindestens 4 Figuren enthält, werden Effekte des elementaren Einklangs bereitgestellt, die den in der Truppe vorhandenen Elementartypen entsprechen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Elementarer Einklang kann in jeder Truppeneinstellung gefunden werden (Spielwelt, Abgrund, Domäne)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Wenn sich 2 Figuren desselben Elementartyps in der Truppe befinden, wird der Effekt des elementaren Einklangs des entsprechenden Elements aktiv. Es gibt auch einen einzigartigen Effekt, wenn sich 4 einzigartige Elemente in der Truppe befinden. Auf diese Weise beträgt die maximale Anzahl von Elementaren Einklängen für jede Truppe 2.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Voraussetzungen",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "items": [
                    [
                      {
                        "content": [
                          {
                            "text": "Die Truppe muss mindestens aus 4 Figuren bestehen",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Die maximale Anzahl von Effekten des elementaren Einklang in der Truppe ist 2.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Um den Effekt eines elementaren Einklang, außer",
                            "type": "text"
                          },
                          {
                            "styles": [
                              "color:rgb(236, 229, 216)"
                            ],
                            "text": "Verwobene Wehr",
                            "type": "text"
                          },
                          {
                            "text": ", auszulösen, werden 2+ Figuren des entsprechenden Elements in der Truppe benötigt.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Testfiguren können ebenfalls für Elementaren Einklang in Betracht gezogen werden. Wenn sich mehr als 4 Figuren in der Truppe befinden, werden nur die ersten 4 Figuren für Elementarer Einklang berücksichtigt.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Innerhalb von Domänen profitieren nur die in der Truppe anwesenden Figuren von den Effekten des elementaren Einklangs.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Elementarer Einklang wird im Mehrspieler-Modus aktiviert, sofern die Voraussetzungen erfüllt sind.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ]
                  ],
                  "ordered": true,
                  "type": "list"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Effektüberblick",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Elementarer Einklang",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Effekt des elementaren Einklangs",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Aufrichtiges Feuer",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
