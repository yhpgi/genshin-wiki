                      "menu_id": 10,
                      "name": "Remus",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Remus war Scyllas Freund und König Remurias. Remus vertraute Scylla die finale Harmonie, das Requiem, an.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
