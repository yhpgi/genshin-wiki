                {
                  "items": [
                    [
                      {
                        "content": [
                          {
                            "text": "Nutze die Adeptenkraft, um die Sphäre zu verlassen.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Geh zum Dorf Qiaoying.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Lu.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Geh zur Teewerkstatt.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Nimm an dem Gespräch zwischen Jin und Onkel Luo teil.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Verlasse Qiaoying.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Folge dem goldenen Karpfen.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Löse das Rätsel.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sprich mit Fujin.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Geh zum Yilong-Pier.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Suche nach der Technikerin aus Fontaine.",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
