                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5592,
                      "icon_url": "",
                      "menu_id": 17,
                      "name": "Abgrundbote - Reißender Strom",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
