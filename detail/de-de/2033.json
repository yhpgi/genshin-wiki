      "name": "Empfohlene Figuren",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Glocke",
                      "type": "text"
                    },
                    {
                      "text": "bietet dem Träger über das Nebenattribut LP%. Der Effekt wird aktiviert, wenn die Figur aktiv auf dem Feld ist und dabei Schaden erleidet. Der Schild bleibt beim Auswechseln bestehen, gilt aber nur für den Träger der Waffe.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Figur",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3463,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/27/61142474/65b22311e1e38ffa45a4928d4005ecee_7468297942613362106.png",
                      "name": "Dehya",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Dehya's Nutzen der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Glocke",
                      "type": "text"
                    },
                    {
                      "text": "beschränkt sich vorrangig auf das LP%-Nebenattribut. Der Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Beschützer der Rebellen",
                      "type": "text"
                    },
                    {
                      "text": "aktiviert sich auch durch den Schaden, den Dehya über ihre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Elementarfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "erhält, allerdings nur, wenn sie zu dem Moment aktiv auf dem Feld ist. Ist dieser Schild aktiviert, hält er weiteren Schaden ihrer",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Elementarfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "ab, auch wenn sie nicht mehr aktiv auf dem Feld ist.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2269,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/09/61142474/6539bea71efd0f839db897cfc4094362_4510784532064811526.png",
                      "name": "Dori",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für Dori ist vor allem das LP%-Nebenattribut wichtig. Der passive Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Beschützer der Rebellen",
                      "type": "text"
                    },
                    {
                      "text": "ist für sie wenig interessant.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
