                  "content": [
                    {
                      "text": "Die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Rechtmäßige Belohnung",
                      "type": "text"
                    },
                    {
                      "text": "ist eine schmiedbare Waffe aus Fontaine und bietet ein LP%-Nebenattribut. Der Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Speerspitze",
                      "type": "text"
                    },
                    {
                      "text": "aktiviert sich, wenn der Träger",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "geheilt",
                      "type": "text"
                    },
                    {
                      "text": "wird und stellt dabei",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Elementarenergie",
                      "type": "text"
                    },
                    {
                      "text": "wieder her. Dieser Effekt wird auch dann aktiviert, wenn die aktive Figur dabei nicht aktiv auf dem Feld ist oder bereits volle LP hat – sie muss nur",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "geheilt",
                      "type": "text"
                    },
                    {
                      "text": "werden. Für das optimale Nutzen dieser Waffe ist es zu empfehlen, einen",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "Heiler",
                      "type": "text"
                    },
                    {
                      "text": "in der Truppe zu haben.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
