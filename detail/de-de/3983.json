                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/04/61142474/56f8617276010e0e3c08713c3f4df80a_8575621167832524775.png",
                      "name": "Lyney (Bald verfügbar)",
