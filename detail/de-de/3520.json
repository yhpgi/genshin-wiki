                      "ep_id": 3487,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/15/141341446/623e8e3ab639fb91c6a55c58822308b3_7925910210052409481.png",
                      "name": "Guizhong",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3521,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/09/19929963/61275d8b97a9c5e4055ed07a4d34c4fa_6429051871871400732.png",
                      "name": "Bosacius",
