          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Standardangriff</span></p><p>Verursacht 2 Pkt. <span style=\"color: #FFFFFF\">phys. SCH</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/36893887/241eba6e4c00020975cf91170050f435_788305459344076861.png",
