    {
      "id": "41",
      "name": "Inhalt",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Nördlich des Wildschweinwaldes befindet sich ein Flecken Eiswüste.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Zu dieser Zeit war der verspielte Barbatos noch nicht zu diesem Teil des Landes vorgedrungen, sodass das Land noch mit Eis und Schnee bedeckt war.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Jegliche Kreatur, die auf diesem Grund und Boden wandelte, riskierte sich die Pfoten abzufrieren:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "„Zu kalt! Zu kalt! Meine Pfoten werden noch vom Frost zerspringen!“",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Selbst der Stärkste von allen, der König persönlich, fror sich dort seine Kronjuwelen ab:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "„Grunz, oh grunz! Mein Rüssel ist schon ganz lila gefroren!“",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Dort lebte jedoch als einziger Bewohner ein kleiner Wolf.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "(Am Seitenrand befinden sich weitere Kritzeleien: „Papa, warum haben die Pfoten von dem kleinen Wolf denn kein Aua?“)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
