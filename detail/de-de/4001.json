    {
      "id": "39",
      "name": "Empfohlene Figuren",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Ballade der Fjorde",
                      "type": "text"
                    },
                    {
                      "text": "ist eine Waffe, die den Kauf des Gnostiker-Erlebnispasses voraussetzt. Neben dem KT-Nebenattribut bietet diese Waffe außerdem den passiven Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "die vielen Geschichten der Eiswüste",
                      "type": "text"
                    },
                    {
                      "text": ". Dieser erhöht die Elementarkunde, wenn neben dem Träger noch 2 weitere Figuren mit jeweils verschiedenen Elementen in der Truppe sind.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Figur",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 50,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Xiangling_icon.png",
                      "name": "Xiangling",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Xiangling kann alle Werte der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Ballade der Fjorde",
                      "type": "text"
                    },
                    {
                      "text": "hervorrangend nutzen. Vorallem aber die hohe Elementarkunde in",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Verdampfen",
                      "type": "text"
                    },
                    {
                      "text": "-Kompositionen synergiert mit dem KT-Nebenattribut als offensive Grundlage.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2813,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/27/61142474/e09e2bda5e022611fad0dea1bb6518bb_7579417594109598988.png",
                      "name": "Cyno",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Spielt man Cyno in Teams, in welchen er neben der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Suprawuchs",
                      "type": "text"
                    },
                    {
                      "text": "-Reaktion auch noch",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Supraspross",
                      "type": "text"
                    },
                    {
                      "text": "auslösen kann, sind mit",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Dendro",
                      "type": "text"
                    },
                    {
                      "text": "- und",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 192, 255)"
                      ],
                      "text": "Hydro",
                      "type": "text"
                    },
                    {
                      "text": "-Truppenmitgliedern bereits alle Voraussetzungen dieser Waffe erfüllt. Besonders in solchen Truppen ist für ihn die Elementarkunde relevant.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 34,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Hu Tao_icon.png",
                      "name": "Hu Tao",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Hu Tao kann speziell in Kompositionen, in denen sie von der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Verdampfen",
                      "type": "text"
                    },
                    {
                      "text": "- oder gar",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Schmelzen",
                      "type": "text"
                    },
                    {
                      "text": "-Reaktion Gebrauch macht, die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Ballade der Fjorde",
                      "type": "text"
                    },
                    {
                      "text": "recht gut nutzen. Hu Tao erfreut sich über das KT-Nebenattribut und hat in den meisten Truppen kein Problem, die 3-Element-Voraussetzung zu erfüllen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 33,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Rosaria_icon.png",
                      "name": "Rosaria",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Rosaria kann die KT dieser Waffe nicht nur mit ihrer",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Spezialfähigkeit",
                      "type": "text"
                    },
                    {
                      "text": "an ihre Truppenmitglieder weitergeben, zudem kann sie die Elementarkunde in Kompositionen, die auf die",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Schmelzen",
                      "type": "text"
                    },
                    {
                      "text": "-Reaktion ausgelegt sind, auch selber sehr offensiv verwenden.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
