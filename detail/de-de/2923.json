    {
      "id": "41",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "O Nagarjuna,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "mit der Hilfe des Lichts der Geister segne ich das Land des ewigen Unheils.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Wenn der Schlick aus dem Abgrund das erste Königreich befällt,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Zerstreuen sich die glorreichen Geister, die dem Herrn der Weisheit geholfen haben, in Millionen Arten.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ich überquerte den Fluss der Trauer erneut in meinem Durst nach Tauwasser.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ich habe den Weg für die barmherzigen Geister erschlossen, damit das barmherzige Licht der Weisheit die Welt erleuchtet.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "O Nagarjuna,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "mit der Hilfe des Lichts der Geister nähre ich die barmherzigen Geister im Blumenmeer.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Sieh! Das Licht offenbart die Essenz der Geister, die letzten Nachkommen der Herrin der Pflanzen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Sieh! Der Recke, der Hunderte von Schlachten übersteht, ist der Feind der Dev.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Selbst die pechschwarze Finsternis draußen kann ihre Silhouetten nicht erodieren.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "O Nagarjuna,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "mit der Hilfe des Lichts der Geister habe ich die Toten der verdorbenen Erde übertroffen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ich befreie die Unschuldigen von ihren Sünden, damit sie in einer Welt ohne Leid wiedergeboren werden können.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Das Chakra der Welt enthält den Samen, der das Sein gebärt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Die Schandflecken und Herrlichkeiten der Welt sind nichts als flüchtige Illusionen der existierenden Samen.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "O Nagarjuna,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "mit der Hilfe des Lichts der Geister habe ich den Abgrund des Himmels geläutert.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Der Schlick aus dem Abgrund schwindet endlich,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Dahris Vermächtnis ist auch dem Gesetz ausgeliefert.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tausende von Lieder ertönen im Einklang und der erbitterte Regen klingt ab.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "O Nagarjuna,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "sollte die Welle des Bösen wiederkehren und der schwarze Abgrund erneut einkehren,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "stimme diese Hymne an und bete um das unbesiegbare Licht der Geister.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Das ewige Licht der Geister weist uns den Weg nach oben.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
