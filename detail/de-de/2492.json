            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Beziehungen",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Grace",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Grace ist Timmies Pflegemutter. Sie kümmert sich um Timmie seit sein Vater fortgegangen ist.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3717,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/21/141341446/d4cb7cd958802714c7b1375b1f0ed034_5593182806537714667.png",
                      "menu_id": 10,
                      "name": "Draff",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Draff gibt vor Timmies Vater zu sein. Er sendet Briefe an Timmie, seitdem Timmies Vater bei einem Jagdunfall ums Leben gekommen ist.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "68",
      "name": "Geniale Beschwörung",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Abenteuer-Herausforderung: Eine Geschichte über zwei Hilichurle",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Einführung der Herausforderung",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "So geht die Geschichte: Vor langer, langer Zeit standen auf der anderen Seite der Mondstadt-Brücke zwei Mitachurle, die Äxte schwangen ...",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Sonderregel:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Dein Unterstützungsplatz hat anfangs eine „Timmie“-Karte.",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Hinweis:",
                      "type": "text"
                    },
                    {
                      "text": "Nutz Elementarreaktionen, um den Gegnern verheerenden Schaden zuzufügen!",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Gegnerische Aufstellung",
                      "type": "text"
                    }
