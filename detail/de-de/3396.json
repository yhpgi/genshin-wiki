    {
      "id": "24",
      "name": "Hintergrund",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p><strong>Patton: </strong>Willst du nicht reinkommen und dich setzen? Bei der Engelsgabe haben wir gerade Sonderpreise!</p>",
                "id": "Weitere Informationen39405",
                "img": "",
                "title": "Dialog: Begrüßung"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Erzähl mir von der „Engelsgabe“.</p><p><strong>Patton:</strong> Ich kann mich noch daran erinnern, wie das Weingut Morgenröte gerade seine Pforten öffnete. Der Inhaber hat es selbst finanziert.</p><p><strong>Patton:</strong> Heute gehört die „Engelsgabe“ dem aktuellen Eigentümer des Weinguts Diluc. Die Geschäfte laufen immer besser.</p><p><strong>Patton:</strong> Er steht also nicht ohne Grund an der Spitze in ganz Mondstadt.</p><p><strong>Patton:</strong> Diluc springt auch gern selbst als Wirt ein, wenn er Lust hat, und lässt Charles eine Pause machen.</p><p><strong>Patton:</strong> Falls du das Glück hast, ihm persönlich zu begegnen, während er gerade arbeitet, solltest du dich von deiner besten Seite zeigen. Immerhin ist er der Reichste hier in Mondstadt.</p><p></p><p><strong>Reisende/r:</strong> Erzähl mir von der Getränkewirtschaft in Mondstadt.</p><p><strong>Patton:</strong> Das Klima in Mondstadt, das gute Wasser und die Vegetation sind einfach perfekt, um ein Weingut zu betreiben. Der Gott des Windes hat uns wahrlich gesegnet!</p><p><strong>Patton:</strong> Apfelwein und Kirschwasser sind wirklich einsame Spitze. Aber auch der Löwenzahnschnaps hat es in sich!</p><p><strong>Patton:</strong> Der Wein aus Mondstadt wird über eine Händlergilde nach Liyue exportiert, sodass der auch an den entferntesten Orten genossen werden kann.</p><p><strong>Patton:</strong> Dort kann man überall einen guten Preis dafür verlangen. Manche nennen den Wein sogar „Mora in Flaschen“.</p><p><strong>Patton:</strong> Das wird auch der Grund dafür sein, weshalb der Inhaber des Weinguts Morgenröte so reich ist.</p><p></p><p><strong>Reisende/r:</strong> Erzähl mir von dir.</p><p><strong>Patton:</strong> Ich gebe dir einen gut gemeinten Rat. Du solltest nicht mit den Flaschen im Laden herumspielen, auch wenn sie noch so einfach aussehen.</p><p><strong>Patton:</strong> Die Flasche, die ich zerbrochen habe, war aus der Sammlung besonderer Weine des alten Inhabers. Siehst du die Villa da hinten?</p><p><strong>Patton:</strong> Damit will ich sagen, dass diese Flasche Wein ungefähr so viel gekostet hat wie diese Villa.</p><p><strong>Patton:</strong> Ich habe das mal durchgerechnet. Ich habe noch 48 Jahre vor mir, um meine Schulden abzuarbeiten. Nahrungsaufnahme und Schlaf habe ich dabei noch nicht berücksichtigt ...</p><p><strong>Patton:</strong> Es besteht also noch gewisse Hoffnung ...</p><p><strong>Patton:</strong> Dann gehe ich mal lieber wieder an die Arbeit, damit ich mich freikaufen kann, solange ich noch lebe, hahaha ... *schnief*</p>",
                "id": "Weitere Informationen13109",
                "img": "",
                "title": "Dialog: Unterhaltung 1"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Hast du derzeit irgendwelche Spezialitäten.</p><p><strong>Patton:</strong> Im Moment geben wir jedem Kunden einen kostenfreien Spieß mit Champignons und Hühnchen. Passt toll zu jedem Getränk!</p><p><strong>Patton:</strong> Hier, nimm einen und setz dich. Ich verspreche dir, er wird dir gefallen!</p><p><em><span style=\"color: #ECE5D8\">(Dialogbelohnung: 4x Spieß mit Pilzen und Hühnchen)</span></em></p>",
                "id": "Weitere Informationen22870",
                "img": "",
                "title": "Dialog: Unterhaltung 2"
              },
              {
                "artifactPos": "",
                "desc": "<p><strong>Reisende/r:</strong> Nein, danke.</p><p><strong>Patton:</strong> Willst du schon gehen? Es gibt keinen Ort, der besser dafür geeignet wäre, den besten Wein in Mondstadt zu probieren.</p>",
                "id": "Weitere Informationen47411",
                "img": "",
                "title": "Dialog: Abschied"
              }
            ]
          }
        }
      ]
    },
