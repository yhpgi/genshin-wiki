    {
      "id": "39",
      "name": "Empfohlene Figuren",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "blasse Schwur der Freiheit",
                      "type": "text"
                    },
                    {
                      "text": "ist eine hervorragende Waffe für",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "Unterstützer",
                      "type": "text"
                    },
                    {
                      "text": ". Der passive Effekt kann auch ausgelöst werden, wenn der Träger nicht auf dem Feld ist und bietet dem Rest der Truppe einen ANG%-Bonus und verstärkt den Schaden aller Standardangriffe, heftigen Schlägen und Angriffen aus dem Fall.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Für folgende Figuren ist diese Waffe zu empfehlen:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Figur",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Begründung",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 22,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Kaedehara Kazuha_icon.png",
                      "name": "Kaedehara Kazuha",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Diese Waffe erhöht die Elementarkunde erheblich, was Kaedehara Kazuhas",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Reaktions-SCH",
                      "type": "text"
                    },
                    {
                      "text": "und",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 255, 215)"
                      ],
                      "text": "Verwirbelungs-SCH",
                      "type": "text"
                    },
                    {
                      "text": "erhöht. Am meisten profitiert sein Talent",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Poesie von Fuubutsu",
                      "type": "text"
                    },
                    {
                      "text": "von einer hohen Elementarkunde, da er so den",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Elementar-SCH",
                      "type": "text"
                    },
                    {
                      "text": "seiner Truppenmitglieder erhöht. Außerdem kann Kaedehara Kazuhas Elementarfähigkeit",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Chihayaburu",
                      "type": "text"
                    },
                    {
                      "text": "den passiven Effekt Gesang der Revolution dieser Waffe auslösen, der den Schaden von Verbündeten und ihren ANG erhöht.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 27,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Jean_icon.png",
                      "name": "Jean",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Eine hohe Elementarkunde ist bei Jean vor allem interessant, wenn sie mit dem Artefakt-Set",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2091,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Viridescent Venerer/flower_of_life_icon.png",
                      "name": "Grünlicher Schatten",
                      "type": "custom_entry"
                    },
                    {
                      "text": "gespielt wird, da so ihr",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(128, 255, 215)"
                      ],
                      "text": "Verwirbelungs-SCH",
                      "type": "text"
                    },
                    {
                      "text": "noch mehr verstärkt wird. Der passive Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Gesang der Revolution",
                      "type": "text"
                    },
                    {
                      "text": "verbessert zusätzlich Jeans Unterstützungsfähigkeit der Truppe gegenüber.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3336,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/17/61142474/25249dd20b86c775fb35bdbbd805d9ec_2198438037284230675.png",
                      "name": "Alhaitham",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Alhaitham profitiert durch sein",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Dendro-Element",
                      "type": "text"
                    },
                    {
                      "text": "sehr von Elementarkunde, da er hauptsächlich über",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Dendro-Reaktionen",
                      "type": "text"
                    },
                    {
                      "text": "Schaden austeilt. Ebenfalls wird bei ihm regelmäßig der passive Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Gesang der Revolution",
                      "type": "text"
                    },
                    {
                      "text": "der ausgelöst, wodurch er auch noch seine Truppenmitglieder unterstützt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2812,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/10/13/61142474/586d726f9ebda3506c78beaaa41f13b6_4521062174590153552.png",
                      "name": "Nilou",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Auch Nilou macht hauptsächlich über",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Elementarreaktionen",
                      "type": "text"
                    },
                    {
                      "text": "Schaden. Dadurch wird der passive Effekt",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Gesang der Revolution",
                      "type": "text"
                    },
                    {
                      "text": "regelmäßig ausgelöst, wodurch wiederum die gesamte Truppe unterstützt wird. Auch das Nebenattribut Elementarkunde ist für Nilou von Vorteil, da so der",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Sprießen-SCH",
                      "type": "text"
                    },
                    {
                      "text": "ihrer",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Kerne der Fülle",
                      "type": "text"
                    },
                    {
                      "text": "erhöht wird.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 10,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Keqing_icon.png",
                      "name": "Keqing",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Eine Keqing, die hauptsächlich auf",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Suprawuchs-SCH",
                      "type": "text"
                    },
                    {
                      "text": "gebaut wird, profitiert sehr vom Nebenattribut Elementarkunde dieser Waffe. Ebenfalls unterstützt sie, durch das regelmäßige Auslösen des passiven Effekts",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Gesang der Revolution",
                      "type": "text"
                    },
                    {
                      "text": ", ihre Truppenmitglieder mit einer Schadens- und ANG-Erhöhung.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 19,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Traveler_icon.png",
                      "name": "Reisender (Anemo)",
