              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Beschwörung</span><br><span style=\"color: rgb(255, 255, 255)\">Endphase</span>: Verursacht 1 Pkt. <span style=\"color: #FFACFF\">Elektro-SCH</span>. Verleiht der aktiven Figur<span style=\"color: #FFFFFF\"> Kraft der Krähenfeder</span>. <br><span style=\"color: rgb(255, 255, 255)\">Einsatzmöglichkeit: 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/26/61142474/db13288db6b90ec33f8adc2656d2019f_6286218165619157673.png",
