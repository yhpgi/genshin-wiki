                  }
                ],
                "talent_img": "",
                "title": "Quật Cánh Sấm Động"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật phe địch có áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Tiếng Sấm Thăm Dò</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Nếu phe địch không có nhân vật thỏa điều kiện, sẽ đổi thành gây sát thương cho nhân vật xuất chiến)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Tiếng Sấm Thăm Dò</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Trong thời gian trạng thái tồn tại có thể kích hoạt 1 lần: </span></strong><span style=\"color: rgb(236, 228, 217)\">Sát thương nhân vật áp dụng phải chịu từ Thực Thể Sấm Sét và tạo vật triệu hồi gây ra +1.</span><br><span style=\"color: rgb(236, 228, 217)\">(Một phe tối đa chỉ tồn tại 1 trạng thái này. Một số kỹ năng của Thực Thể Sấm Sét sẽ lấy nhân vật áp dụng làm mục tiêu.)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/ea30635ede9f19d574a7ed6254258b3f_8018226193401015072.png",
                "id": "talent96760",
                "key": "Tường Sét Xung Đột",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Tường Sét Xung Đột"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">, triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Sấm Sét Giam Cầm</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/4d189776bbafc230f0b2e1ee37ab7ece_1439404702977123520.png",
