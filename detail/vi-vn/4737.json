                ],
                "talent_img": "",
                "title": "Sấm Chớp Thăm Dò"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Vật Triệu Hồi</span></p><p><span style=\"color: rgb(236, 228, 217)\">Sấm Sét Giam Cầm</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai đoạn kết thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 3 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật phe địch có áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Tiếng Sấm Thăm Dò</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Nếu phe địch không có nhân vật thỏa điều kiện, sẽ đổi thành gây sát thương cho nhân vật xuất chiến)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/db13288db6b90ec33f8adc2656d2019f_1783965703163658478.png",
