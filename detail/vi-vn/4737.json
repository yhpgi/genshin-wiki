                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Sấm Sét Giam Cầm"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Bị động) Khi bắt đầu chiến đấu, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Đầu Dò Sét</span></strong><span style=\"color: rgb(236, 228, 217)\"> trong trận phe địch.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Đầu Dò Sét</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật phe sở tại dùng kỹ năng:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Tiếng Sấm Thăm Dò</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe sở tại. (Mỗi hiệp 1 lần)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/7fcdf904a4d1623ab0a882884eb4c2e2_8195569577394354470.png",
