                      ],
                      "text": "Khiêu Chiến Quán Rượu",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Đánh Giải Trí",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Giới Thiệu Ải",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "﻿﻿\"Meo\" \"Đôi khi khách ở quán rượu cũng kể cho chúng tôi nghe những câu chuyện. Tôi nhớ rất rõ một truyền thuyết về Inazuma... Trên một hòn đảo đầy mây đen và sấm sét, thỉnh thoảng sẽ có một âm thanh chói tai vang lên trong không trung.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ccbfad"
                      ],
                      "text": "Quy tắc đặc biệt: \"Thực Thể Sấm Sét\" miễn dịch Đóng Băng, Choáng, Hóa Thạch, ban đầu có áp dụng \"Sinh Mệnh Nguyên Tố - Lôi\", và +1 sát thương gây ra cho nhân vật có trạng thái \"Tiếng Sấm Thăm ﻿Dò\".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Đội Hình Đối Thủ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
