                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Khiêu Chiến Khám Phá: Lấy Hiệu Quả Tiết Mục Làm Chuẩn",
                      "type": "text"
