              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nộ</span></p><p>Gây 2 điểm <span style=\"color: rgb(153, 255, 136)\">Sát Thương Nguyên Tố Thảo</span>, triệu hồi <span style=\"color: rgb(255, 255, 255)\">Cuilein-Anbar</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/27215281/b1519a139b4737aaa5e6844da801d167_4261150773691927414.png",
                "id": "talent51695",
                "key": "Báu Vật Meo Meo",
                "materials": [],
                "points": [
