                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Gai Lạnh Thấu Xương"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 4 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, chữa trị cho nhân vật này 2 điểm. Xóa </span><strong><span style=\"color: rgb(255, 255, 255)\">Diệm Liệt Ma Nữ Băng Giá</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này vĩnh viễn đổi sang hình thái </span><strong><span style=\"color: rgb(255, 255, 255)\">Hỏa Ngục Ma Nữ</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Diệm Liệt Ma Nữ Băng Giá</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi bắt đầu giai đoạn hành động: </span></strong><span style=\"color: rgb(236, 228, 217)\">Nếu nhân vật áp dụng HP không hơn 4, sẽ xóa hiệu quả này.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng bị đánh bại:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Xóa hiệu quả này, khiến nhân vật </span><strong><span style=\"color: rgb(255, 255, 255)\">Không Bị Đánh Bại</span></strong><span style=\"color: rgb(236, 228, 217)\">, và chữa trị cho nhân vật này đến 1 điểm HP.</span><br><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi xóa hiệu quả này:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nhân vật áp dụng sẽ chuyển sang hình thái </span><strong><span style=\"color: rgb(255, 255, 255)\">Hỏa Ngục Ma Nữ</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/44749939/aef93c52b3cc6ec516d6db5f8810278d_4161389010405411298.png",
