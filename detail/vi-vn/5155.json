    {
      "id": "48",
      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/08/44749939/94aa30ae75b8c7c6a9c64ab05bd5dda7_8606390653032428308.png",
                "id": "talent38294",
                "key": "Cào Rách Hộp",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Cào Rách Hộp"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Bưu Kiện Mèo Khẩn Cấp</span></strong><span style=\"color: rgb(236, 228, 217)\"> và </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên Vận Chuyển An Toàn</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Bưu Kiện Mèo Khẩn Cấp</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi Kirara là nhân vật xuất chiến, sau khi phe ta Đổi Nhân Vật:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">, rút 1 lá bài.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng đồn, tối đa dồn đến 2 lần)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Khiên Vận Chuyển An Toàn</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Khiên</span><br><span style=\"color: rgb(236, 228, 217)\">Cung cấp </span><strong><span style=\"color: rgb(255, 255, 255)\">2 điểm Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe ta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/08/44749939/e1d9ab13ba19969303b42dbee09f59e7_4945858965355308181.png",
                "id": "talent71097",
                "key": "Mèo Tung Cước",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "Mèo Tung Cước"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 4 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Đậu Khấu Cỏ Mèo</span></strong><span style=\"color: rgb(236, 228, 217)\"> trong khu vực phe địch.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Đậu Khấu Cỏ Mèo</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi phe sở tại đánh ra 2 Thẻ Hành Động:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe sở tại.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/08/44749939/ec58f74c94bbd19ecbb0c33f972f5788_8543050088591034558.png",
                "id": "talent31064",
                "key": "Bí Pháp - Chuyển Phát Đặc Biệt",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Bí Pháp - Chuyển Phát Đặc Biệt"
              },
              {
                "attributes": [],
                "desc": "<p>Gán ấn Nguyên Tố Thảo, có thể tạo phản ứng nguyên tố:</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span>: Sát Thương +1, tạo thành [<span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span>] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Số lần dùng là 1, tối đa cộng dồn đến 2)</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Sinh Trưởng</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Khu Vực Xúc Tác</span>] khiến sát thương Thảo/Lôi 3 lần sau +1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/08/44749939/e8cff941b5a0ff248efde360ec9e91fe_7549877425635546078.png",
                "id": "talent91842",
                "key": "Sát Thương Nguyên Tố Thảo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Thảo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/08/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_8317669390600935071.png",
