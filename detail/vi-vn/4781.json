    {
      "id": "36",
      "name": "Đặc Tính",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Các Mối Quan Hệ",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4780,
                      "icon_url": "",
                      "name": "Эгерия",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Thuỷ Thần tiền nhiệm, đã tạo ra Focalors và cho cô cơ thể của một con người.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4376,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/70239714/263e5ea0784d182b393f67a7e24146a5_6841129024701614855.png",
                      "name": "Фурина",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Cơ thể và linh hồn được tạo ra bởi Focalors,với sứ mệnh diễn vai trò của \"Thuỷ Thần\" cai trị Fontaine trong suốt 500 năm..",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4924,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/08/94376896/5e33c09fbd3c6781bb822fd9c57b6abc_7075433854813111066.png",
                      "name": "Oceanids",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Những sinh mệnh nguyên tố Thuỷ, được tạo ra bởi vị Thần Thủy tiền nhiệm là Egeria. Focalors là 1 trong những Tinh Linh Nước Trong ấy.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4023,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/24/70239714/0513aa7f482dbb4778545d02f94956fe_5004007435087179259.png",
                      "name": "Нёвиллет",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Một trong Thất Long Vương và Thẩm Phán tối cao của Fontaine.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Cỗ Máy Phán Quyết",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Một cỗ máy đặc biệt được tạo ra bởi Focalors để tích trữ Indemnitium và phá huỷ ngai thần của vị thần chính nghĩa.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "68",
      "name": "Câu Truyện",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Focalors",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/09/237301566/b0fb20592e699cd5342b9c87d6fab121_6327654859344677399.png"
                    },
                    {
                      "text": "Trái tim của Biển Khởi Nguyên, Egeria, được biết đến với cái tên Chúa Tể Vùng Biển, đã tạo ra các dạng sống thông minh mang tên Tinh Linh Nước Trong. Các Tinh Linh Nước Trong vì ngưỡng mộ cuộc sống con người nên chúng luôn ao ước được trở thành con người. Chúa Tể Vùng Biển đã đáp lại mong muốn của họ và sử dụng thần lực của Biển Khởi Nguyên để biến một số Tinh Linh Nước Trong thành con người. Khi trở thành con người, những Tinh Linh Nước Trong vẫn có Nước Biển Khởi Nguyên chảy trong huyết quản. Tuy nhiên, Thuỷ Thần và người dân Fontaine đã bị Thiên Lí ban cho \"Nguyên Tội\". Đảo Thiên Không tức giận với Chúa Tể Vùng Biển vì đã \"cướp đoạt sức mạnh của Biển Khởi Nguyên\" và đã giam cầm cô. Một lời tiên tri sấm truyền ban xuống:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffffff",
                        "italic"
                      ],
                      "text": "\"Cuối cùng, tất cả mọi người đều bị hòa tan vào nước, và chỉ còn lại Thuỷ Thần ngồi khóc trên ngai thần. Như vậy, tội lỗi của người Fontaine mới được gột rửa\"",
                      "type": "text"
                    },
                    {
                      "text": ". Lời tiên tri đã được khắc vào phiến đá từ rất lâu trước đây và không thể tránh khỏi. Hàng thiên niên kỷ trước, Egeria sau khi trở về từ giam cầm đã lên nắm và thực thi quyền và nghĩa vụ của chức vụ Thủy Thần Fontaine.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "right",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/09/237301566/6ec960ac7a2160449e946df38d1b5da0_691909026731103960.png"
                    },
                    {
                      "text": "Focalors từng là gia quyến Tinh Linh Nước Trong của Egeria. Cô luôn muốn trở thành con người, vì sự tồn tại của một con người trong mắt cô chính là màn trình diễn đẹp nhất, vì vậy Egeria đã biến Focalors thành người. 500 năm trước, Chúa Tể Vùng Biển đã chết trong \"Đại Thảm Hoạ\" và chọn Focalors làm người kế nhiệm ngai vị Thuỷ Thần. Egeria biết rằng lời tiên tri sẽ trở thành sự thật và không thể chống lại Thiên Lý. Cô đặt trọng trách giải quyết vấn đề này lên vai Focalors. Nếu việc đánh cắp sức mạnh của Biển Khởi Nguyên là \"tội lỗi nguyên thủy\" của Fontaine, thì việc biến người Fontaine thành con người và gột rửa tội lỗi để trao quyền tồn tại cho họ sẽ là \"công lý nguyên thủy\" của Fontaine. \"Sự tồn tại\" là công lý của Egeria, và Focalors tiếp tục duy trì nguyên tắc này. Thách thức lời tiên tri và đảm bảo rằng người dân của Fontaine sẽ sống mãi — đó sẽ là nghĩa vụ được tôn lên trên tất cả những nghĩa vụ khác.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Các Mục Liên Quan:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3979,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/11/77454259/decfebf39c4d3b6e22cf9f28c98288f6_2534930988116773859.png",
                      "name": "Fontaine",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4924,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/08/94376896/5e33c09fbd3c6781bb822fd9c57b6abc_7075433854813111066.png",
                      "name": "Oceanids",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4780,
                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2023/12/20/a5b8d23dd3fbe0969cc3ebce78f9c29f_8021351765588020911.png",
                      "name": "Egeria",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Lời Tiên Tri",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/09/237301566/6b63ba3a7d5c46b0a07282251614a445_5914282810604832850.png"
                    },
                    {
                      "text": "Focalors đã suy nghĩ rất lâu về cách chống lại lời tiên tri và tìm ra câu trả lời khả thi duy nhất: cần phải đánh lừa Thiên Lý trong quá trình ứng nghiệm lời tiên tri. Sau khi trở thành Thần, Focalors đã tách \"thần cách\" của cô khỏi thể xác và tinh thần của cô. Phần \"nhân cách\" mà cô để lại, cô đặt tên là \"Furina\". Furina chỉ là một con người, nhưng cô có những cảm xúc hỷ nộ ái ố, khi ngông cuồng thì sẽ ngông cuồng, khi nhu nhược cũng sẽ nhu nhược. Ưu điểm của cô ấy là những ưu điểm mà chỉ loài người mới có, và khuyết điểm cũng vậy.",
                      "type": "text"
                    },
                    {
                      "text": "Trong mắt của Focalors,",
                      "type": "text"
                    },
                    {
                      "alignment": "right",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/09/237301566/7d385a6c1ba9e5d7ccb649d37c020ec0_8512935986327015719.png"
                    },
                    {
                      "text": "Furina chính là con người hoàn hảo, là người mà cô muốn trở thành. Sau khi tạo ra Furina, cô cũng nguyền rủa cô ấy, vì vậy chỉ cần \"thần cách\" của Focalors vẫn còn tồn tại, Furina sẽ không bao giờ chết, để ứng nghiệm tiên tri. Furina được giao nhiệm vụ trở thành nữ chính trên sân khấu của Viện Ca Kịch, vĩnh viễn đóng vai thần linh của vở kịch này, tất cả để làm lời tiên tri trở nên chân thật. Focalors",
                      "type": "text"
                    },
                    {
                      "text": "hứa rằng sự tra tấn của cô cuối cùng sẽ kết thúc bằng một phiên xét xử tựa như một vở kịch vĩ đại, sau đó tất cả mọi người sẽ được cứu",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    },
                    {
                      "text": "Furina không biết phiên xét xử cuối cùng sẽ diễn ra khi nào, vì vậy trong suốt 500 năm, Furina đã diễn vai Thuỷ Thần, cố gắng giải quyết lời tiên tri và cứu tất cả mọi người.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/10/237301566/f9637e460d788f9ba3c8144200245850_5440911958406479077.png"
                    },
                    {
                      "text": "Trong khi Furina cai trị Fontaine, Focalors tích lũy năng lượng để đánh lừa Thiên Lý. Cô đã tạo ra và đặt \"thần tính\" của mình cùng với Gnosis Thuỷ trong Cỗ Máy Chỉ Thị Phán Quyết — một thiết bị đặc biệt trong Viện Ca Kịch, nơi diễn ra mọi phiên tòa. Cỗ Máy Phán Quyết đã chuyển đổi niềm tin của mọi người vào công lý thành Indemnitium, một loại năng lượng có thể cung cấp cho đời sống ở Fontaine. Cùng với Thẩm Phán Tối Cao Neuvillette, thiết bị này đã tuyên án các vụ án và bản án của nó luôn mang tính quyết định",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    },
                    {
                      "text": "Mặc dù nó được sử dụng để xét xử, nhưng trên thực tế, mục đích chính của nó là giết Thuỷ Thần cùng với Ngai thần của vị thần chính nghĩa khi đến lúc. Focalors hiểu rằng chỉ có sức mạnh ở quy mô này mới có thể hy vọng phá hủy Ngai Thần của Thuỷ Thần, làm lung lay các quy tắc do Thiên Lý thiết lập và phá vỡ thể chế Thất Thần.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/09/237301566/e04b1145b19d9257af9cb3f66e5c8ffe_5112452436646273335.png"
                    },
                    {
                      "text": "500 năm sau, khi lời tiên tri bắt đầu trở thành sự thật và Focalors đã tích lũy đủ Indemnitium, Cỗ Máy Phán Quyết đã tuyên án tử hình \"Thuỷ Thần\". Focalors đã gặp Thuỷ Long Vương, Neuvillette, để giao phó quyết định về số phận người dân Fontaine cho anh ta. Neuvillette được mời đến Đại Sảnh Fontaine với tư cách là Thẩm Phán Tối Cao, như một phần trong kế hoạch của Focalors, vì cô biết rằng anh sẽ không thể phán quyết họ là \"có tội\" nữa.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "right",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/09/237301566/e00976a48b070bd08874a4b055a1eae9_2421534148313193330.png"
                    },
                    {
                      "text": "Lúc đầu, Neuvillette không hứng thú với sự tồn tại của con người, nhưng sau năm trăm năm tiếp xúc với họ, anh đã hiểu được loài người và cảm nhận những cảm xúc của họ. Khi Focalors nói lời tạm biệt với Thuỷ Long, Cỗ Máy Phán Quyết đã thực hiện bản án, phá hủy ngai thần của Thuỷ Thần, giết chết Focalors và trả lại toàn bộ quyền lực cho Thuỷ Long Vương. Sau khi có lại toàn bộ sức mạnh, Neuvillette đã đặc xá \"tội lỗi khởi nguyên\" của người dân Fontaine, và trao cho họ \"huyết mạch\" thực thụ, cứu họ khỏi cơn đại hồng thuỷ.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/09/237301566/610d1ce3d05a0bf14311b050c06efc04_2581014749507867284.png"
                    },
                    {
                      "text": "Một thời gian trước khi lời tiên tri bắt đầu trở thành sự thật, Cỗ Máy Phán Quyết đã phán Quan Chấp Hành Fatui thứ 11, Tartaglia, có tội trong vụ \"Thiếu Nữ Mất Tích\", một trong những vụ án bí ẩn đã xảy ra ở Fontaine trong vòng 20 năm qua. Mọi người coi sự hoà tan này là một trong những dấu hiệu cho thấy lời tiên tri đang dần dần ứng nghiệm. Một dấu hiệu khác là sự dâng lên hàng năm của nước Biển Khởi Nguyên. Mặc dù Childe không phải là nguyên nhân gốc rễ của thảm họa, nhưng Cỗ Máy Phán Quyết coi anh ta là một phần của toàn bộ bối cảnh: khi Tartaglia 14 tuổi, anh ta rơi vào vực sâu nào đó. Ở đó, tình cờ, anh ta đã đánh thức Thôn Tinh Kình Ngư — một sinh vật bí ẩn và khổng lồ đến từ thế giới khác, muốn hấp thụ Biển Khởi Nguyên và gây ra trận đại hồng thuỷ như lời tiên tri. Theo Neuvillette, phán quyết này có thể dựa trên trách nhiệm liên quan, hoặc Focalors có thể cố tình sử dụng Tartaglia để kéo dài thời gian với giả định rằng Thôn Tinh Kình Ngư có thể bị ngăn chặn. Sau cái chết của Focalors, Furina được giải thoát khỏi lời nguyền và trở thành một con người bình thường. Mặc dù mọi người đổ lỗi cho cô vì không giải quyết được lời tiên tri, thế nhưng cuối cùng cô cũng có thể là chính mình và không đóng vai Thuỷ Thần nữa.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Các Mục Liên Quan:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
