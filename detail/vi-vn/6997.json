                      "text": "18 Tháng 8, 2024",
                      "type": "text"
                    },
                    {
                      "text": "Nhà Lữ Hành thân mến!",
                      "type": "text"
                    },
                    {
                      "text": "Nhà Lữ Hành thích ngâm suối nước nóng không?",
                      "type": "text"
