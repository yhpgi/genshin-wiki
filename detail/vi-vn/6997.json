                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "28 Tháng 8, 2024",
                      "type": "text"
                    },
                    {
                      "text": "Trong hành trình thám hiểm Natlan, chắc chắn sẽ gặp gỡ nhiều loài Saurian khác nhau.",
                      "type": "text"
                    },
                    {
                      "text": "Hãy đồng hành cũng Saurian và thưởng thức thêm nhiều phong cảnh của Natlan nào.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
