              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span></p><p>Gây 2 điểm <span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/c369b96fc6417e8fc2bb607e37297ad4_6755775779717045377.png",
                "id": "talent54933",
