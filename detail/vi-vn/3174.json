                  }
                ],
                "talent_img": "",
                "title": "Xạ Thuật Thợ Săn"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span></p><p>Gây 2 điểm <span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span><span style=\"color: rgb(236, 229, 216)\">, tạo 1</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Khiên Vuốt Mèo</span><span style=\"color: rgb(236, 229, 216)\">.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Khiên Vuốt Mèo</span></p><p><span style=\"color: rgb(255, 215, 128)\">Hiệu Ứng Xuất Chiến</span></p><p>Cung cấp <span style=\"color: rgb(255, 255, 255)\">1 điểm </span><strong><span style=\"color: rgb(204, 191, 173)\">Khiên</span></strong> cho nhân vật xuất chiến phe ta.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/e0be64da66db784af5d4f957d93b6fad_3554986728452876259.png",
                "id": "talent86064",
                "key": "Móng Mèo Lạnh Giá",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Móng Mèo Lạnh Giá"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nộ</span></p><p>Gây 1 điểm <span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span><span style=\"color: rgb(236, 229, 216)\">, chữa trị cho nhân vật này 2 điểm, triệu hồi </span><span style=\"color: #FFFFFF\">Vùng Sương Rượu</span><span style=\"color: rgb(236, 229, 216)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/e4f93c5be05671f9b5a666361ad4812a_5807897957590183081.png",
                "id": "talent98147",
                "key": "Đặc Chế Mãnh Liệt",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Đặc Chế Mãnh Liệt"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Vật Triệu Hồi</span></p><p><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc: </span>Gây 1 điểm <span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span><span style=\"color: rgb(236, 229, 216)\">, chữa trị 2 điểm cho nhân vật xuất chiến phe ta.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/db13288db6b90ec33f8adc2656d2019f_1464906898273143313.png",
                "id": "talent86869",
                "key": "Vùng Sương Rượu",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/998d17590e24d8a0adee347db3a6940a_2665425117396745903.png",
                "title": "Vùng Sương Rượu"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(204, 191, 173)\">Sát Thương Vật Lý</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Sát Thương Vật Lý sẽ không đính kèm bất kì Nguyên tố nào, cũng như không thể tham gia vào Phản ứng Nguyên tố</span></p><p></p><p><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></p><p>Gán ấn Nguyên tố Băng, có thể tạo phản ứng nguyên tố:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Băng</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Băng</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">] Siêu Dẫn</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1 gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Băng</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span><span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p></p><p><strong><span style=\"color: rgb(204, 191, 173)\">Khiên</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/07bae546ac7c69ef6402170b283840c5_985258851854964205.png",
