                ]
              },
              {
                "item_values": [],
                "key": "Giáo Trình",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Cỗ máy được chế tạo dựa trên kỹ thuật lắp đặt tinh tế và kỹ thuật năng lượng độc đáo của Fontaine. Tùy theo đặc tính năng lượng </span><strong><span style=\"color: rgb(255, 225, 75)\">Ousia hoặc Pneuma</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> thể hiện ra bên ngoài của nó mà hành động khác nhau trong chiến đấu. Đặc tính năng lượng này sau khi bị </span><strong><span style=\"color: rgb(255, 225, 75)\">loại tấn công mang đặc tính đối lập</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> hủy diệt, sẽ dẫn đến quá tải và vô hiệu, đồng thời sau đó sẽ dùng năng lượng khẩn cấp để tiến hành chiến đấu ở mức độ hạn chế.</span></p>"
                ]
