              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật mục tiêu áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Sụp Đổ</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Sụp Đổ</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> hoặc </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\"> mà nhân vật áp dụng phải chịu +2.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/bb0d49f020ec5da8ac945ca46a5f763f_6248508690995718290.png",
                "key": "Cuồng Phong Tập Kích",
