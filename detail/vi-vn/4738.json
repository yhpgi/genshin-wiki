                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Phong Long Quét Sạch"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">(Cần chuẩn bị 1 lượt hành động)</span><br><span style=\"color: rgb(236, 228, 217)\">Gây cho nhân vật dự bị kế tiếp phe địch 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, sau đó </span><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><span style=\"color: rgb(236, 228, 217)\">: </span><strong><span style=\"color: rgb(255, 255, 255)\">Dọn Sạch Lần Cuối</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Khi phe địch không có nhân vật dự bị, đổi sang gây sát thương cho nhân vật xuất chiến)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/6d9f17ac20b8806cbca36313e77bdf23_7699967512129553666.png",
                "key": "Dọn Sạch Lâu Dài",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dọn Sạch Lâu Dài"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Cần chuẩn bị 1 lượt hành động)</span><br><span style=\"color: rgb(236, 228, 217)\">Gây cho nhân vật dự bị phía trước của phe địch 2 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Khi phe địch không có nhân vật dự bị, đổi sang gây sát thương cho nhân vật xuất chiến)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/6d9f17ac20b8806cbca36313e77bdf23_1560502914012661425.png",
                "key": "Dọn Sạch Lần Cuối",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dọn Sạch Lần Cuối"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 5 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, tất cả nhân vật dự bị phe địch áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Sụp Đổ</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Sụp Đổ</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> hoặc </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\"> mà nhân vật áp dụng phải chịu +2.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/fdffcf6a8e033feb0d73ad38a747e0e4_5682705621044245517.png",
                "key": "Khúc Bế Mạc",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Khúc Bế Mạc"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Sản sinh phản ứng nguyên tố với các ấn nguyên tố sau:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(153, 255, 255)\">Băng</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Băng</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(128, 192, 255)\">Thủy</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Thủy</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Hỏa</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Lôi</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/c97292d96456bfe4abeca16bfce801e4_8103769579062204594.png",
                "key": "Sát Thương Nguyên Tố Phong",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Phong"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Có một số kỹ năng không thể sử dụng trực tiếp, mà cần một số lượt hành động nhất định để tiến hành </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Khi đến lượt của một bài thủ hành động, nếu như \"nhân vật xuất chiến\" của bài thủ này đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng, thì sẽ bỏ qua lượt hành động của bài thủ; Nếu như đã </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> xong, nhân vật sẽ trực tiếp dùng kỹ năng đó vào lúc này. (Loại kỹ năng cần </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> này không thể kích hoạt hiệu quả \"sau khi sử dụng\".)</span><br><span style=\"color: rgb(236, 228, 217)\">Chỉ có \"nhân vật xuất chiến\" mới có thể </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng; Nếu như \"nhân vật xuất chiến\" đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng mà bị cho rời trận, thì quá trình </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> của kỹ năng sẽ bị gián đoạn.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_6170290044228072609.png",
