              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span><br>Gây 2 điểm <span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/15/44749939/240a7dfccb5e733342507e896ab68a90_1326206246184917794.png",
