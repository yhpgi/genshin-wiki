              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span></p><p>Gây 1 điểm <span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thuỷ</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/28/44749939/50e4a1f850c11d2b25d1d006760be5b8_4423851340653735211.png",
