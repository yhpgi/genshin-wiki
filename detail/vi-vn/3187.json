                      ],
                      "text": "Giới Thiệu Ải",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Bài, không hiểu, nhưng tôi... sẽ thắng!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
