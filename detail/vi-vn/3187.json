                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span></p><p>Gây 3 điểm <span style=\"color: #FFACFF\">Sát Thương Nguyên Tố Lôi</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/13/27215281/5a7f4821eca7816e8d923684ccee651c_9129983982147498827.png",
