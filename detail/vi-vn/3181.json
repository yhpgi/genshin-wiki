                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Kiếm Tôi Luyện"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gây 3 điểm</span><span style=\"color: rgb(255, 230, 153)\"> </span><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hoả</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Khi dùng kỹ năng này lần thứ 3 ở mỗi hiệp, sát thương +2.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/d0e27bc7054292e95c673e6f491ff677_6213502765370002984.png",
                "id": "talent80427",
                "key": "Lưỡi Đao Rực Lửa",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Lưỡi Đao Rực Lửa"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gây 8 điểm</span><span style=\"color: rgb(255, 230, 153)\"> </span><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hoả</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, nhân vật này nhận </span><span style=\"color: rgb(255, 255, 255)\">Đính Kèm Nguyên Tố Hoả</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/7f35364dc83b6694a3200aae53f6670f_7801072947543075616.png",
                "id": "talent19165",
                "key": "Bình Minh",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Bình Minh"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Trạng Thái</span></p><p><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý </span><span style=\"color: rgba(255, 255, 255, 0.65)\">do nhân vật áp dụng gây ra sẽ chuyển thành </span><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hoả</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/24/12108544/db13288db6b90ec33f8adc2656d2019f_5786629789100439647.png",
                "id": "talent45576",
                "key": "Đính Kèm Nguyên Tố Hoả",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Đính Kèm Nguyên Tố Hoả"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">Sát Thương Vật Lý</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Sát Thương Vật Lý sẽ không đính kèm bất kì Nguyên tố nào, cũng như không thể tham gia vào Phản ứng Nguyên tố</span></p><p></p><p><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hoả</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Hoả, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">] Quá Tải</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">Sát thương +2, mục tiêu bị buộc phải đổi thành nhân vật kế tiếp</span></p><p>[<span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span>: Sát Thương +1, tạo thành [<span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span>] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Có thể dùng 1 lần, tối đa cộng dồn 2 lần)</p><p></p><p><strong><span style=\"color: #ECE5D8\">Số Hiệp Duy Trì</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Mỗi Giai Đoạn Kết Thúc, </span><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> -1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> khi dùng hết sẽ tiêu huỷ thẻ bài này.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/16/27215281/07bae546ac7c69ef6402170b283840c5_49606440197497412.png",
