            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Tấn Công Thường</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gây 2 điểm</span> <span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/10316b5178d5109d597f415d6e7903dc_7566559828904312250.png",
