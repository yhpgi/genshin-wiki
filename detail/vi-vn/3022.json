            "list": [
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/09/44749939/82df2b94e8ef4556e4ff54aa5d1e3b4a_2496202292636974801.png",
                "imgDesc": "<p>﻿  Trên đảo Yashiori tồn tại một số cơ quan có sức mạnh trấn áp \"Họa Thần\" và được chia làm hai loại là \"Đá Dẫn Điện\" và \"Gương Lôi\".</p>",
                "key": "Trang 1/3"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/09/44749939/652cfb03a317d460d2713c44b23cdc1a_6375425870994398471.png",
                "imgDesc": "<p>﻿  \"Đá Dẫn Điện\" sau khi bị tấn công sẽ có thể phóng điện theo hướng đã định. Dòng điện này phá tan ý chí của Họa Thần trên Đảo Yashiori và hình thành kết giới.</p>",
                "key": "Trang 2/3"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/09/44749939/ec0e4a149f12df1a34089a23fb08118a_2212487660323231713.png",
                "imgDesc": "<p>﻿  \"Gương Lôi\" có thể tiếp nhận dòng diện mà \"Đá Dẫn Điện\" truyền tới, đồng thời phóng ra theo một hướng khác.</p>",
                "key": "Trang 3/3"
              }
