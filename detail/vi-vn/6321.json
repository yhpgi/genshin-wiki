      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/a360ce6a562e9559d28383ea05cbef26_614798819587526490.png",
                "id": "talent3648",
                "key": "Từ Chối Thẳng Thừng",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Từ Chối Thẳng Thừng"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Đính Kèm Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">; </span><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><span style=\"color: rgb(236, 228, 217)\"> tối đa 5 lá </span><strong><span style=\"color: rgb(255, 255, 255)\">Mảnh Đạn Pha Lê</span></strong><span style=\"color: rgb(236, 228, 217)\"> trên tay, với mỗi lá bị </span><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><span style=\"color: rgb(236, 228, 217)\"> sẽ +1 sát thương này và rút 1 lá bài.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Đính Kèm Nguyên Tố Nham</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> do nhân vật áp dụng gây ra sẽ chuyển thành </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/24ca85c0be3ccf3198472890b0c35ef6_9168673336998145612.png",
                "id": "talent97099",
                "key": "Đạn Pha Lê Thanh Lịch",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Đạn Pha Lê Thanh Lịch"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">, gây 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho tất cả nhân vật dự bị phe địch. Triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Pháo Hoa Hồng Vàng</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra 1 lá </span><strong><span style=\"color: rgb(255, 255, 255)\">Mảnh Đạn Pha Lê</span></strong><span style=\"color: rgb(236, 228, 217)\"> và thêm vào bộ bài trên tay.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/a0c7df34b00964186e625c89253dc08c_2086214970243607021.png",
                "id": "talent51862",
                "key": "Pháo Mừng Vang Trời",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Pháo Mừng Vang Trời"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Bị động) </span><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật phe địch nhận sát thương phản ứng Kết Tinh:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Sinh ra 3 lá </span><strong><span style=\"color: rgb(255, 255, 255)\">Mảnh Đạn Pha Lê</span></strong><span style=\"color: rgb(236, 228, 217)\">, đưa ngẫu nhiên vào kho bài phe ta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/46457886dbcd37d258d9cc229a02e574_1410394789629410821.png",
                "id": "talent40082",
                "key": "Mạng Lưới Hỗ Trợ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Mạng Lưới Hỗ Trợ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Thẻ Sự Kiện</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe địch, rút 1 lá bài.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/db13288db6b90ec33f8adc2656d2019f_3484215784958899531.png",
                "id": "talent54909",
                "key": " Mảnh Đạn Pha Lê",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "white"
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/ca5315848113a22db13d032f358ddbdb_789592482552588449.png",
                "title": " Mảnh Đạn Pha Lê"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Vật Triệu Hồi</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">, rút 1 lá </span><strong><span style=\"color: rgb(255, 255, 255)\">Mảnh Đạn Pha Lê</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/db13288db6b90ec33f8adc2656d2019f_3963922021793529314.png",
                "id": "talent13613",
                "key": "Pháo Hoa Hồng Vàng",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/1e170b966fa674e494fba2732677bcd8_3722882541550609175.png",
                "title": "Pháo Hoa Hồng Vàng"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sản sinh phản ứng nguyên tố với các ấn nguyên tố sau:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Kết Tinh (</span><span style=\"color: rgb(153, 255, 255)\">Băng</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Kết Tinh (</span><span style=\"color: rgb(128, 192, 255)\">Thủy</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Kết Tinh (</span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Kết Tinh (</span><span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/fd37cbfdd3b1b2c16e6e83fb0aa96889_1341075671327959865.png",
                "id": "talent3016",
                "key": "Sát Thương Nguyên Tố Nham",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Nham"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Mỗi Giai Đoạn Kết Thúc, </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> -1.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> khi dùng hết sẽ tiêu hủy thẻ bài này.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Thông qua hiệu quả của Thẻ Hành Động hoặc kỹ năng nhân vật, có thể loại bỏ Thẻ Hành Động trên tay hoặc trong kho bài</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát Thương Xuyên Thấu sẽ không được nhận sát thương tăng thêm, nhưng sẽ bỏ qua hiệu quả khiên và miễn dịch sát thương.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_2360369228429730817.png",
