              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span></p><p>Gây 1 điểm <span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thuỷ</span>, triệu hồi <span style=\"color: rgb(255, 255, 255)\">Vòng Âm Thanh</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/6ce6beac71091e13fe09094e6af6b210_1511374802020541064.png",
