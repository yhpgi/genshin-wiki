      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Mỗi hiệp 1 lần:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nếu không có thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Ngai Thánh Thần Và Thế Tục</span></strong><span style=\"color: rgb(236, 228, 217)\"> trên tay, sẽ sinh ra thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Ngai Thánh Thần Và Thế Tục</span></strong><span style=\"color: rgb(236, 228, 217)\"> trên tay.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/588c5bea39e55a2ff2e72cc3c4203111_2229478888622867012.png",
                "id": "talent41890",
                "key": "Lời Mời Độc Diễn",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Lời Mời Độc Diễn"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Furina</span></strong><span style=\"color: rgb(236, 228, 217)\"> hiện tại trong hình thái Sức Mạnh Nền Tảng: Ousia: Triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Thành Viên Salon</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">(Khi Furina trong hình thái Sức Mạnh Nền Tảng: Pneuma, sẽ chuyển sang triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Ca Sĩ Nước Nguồn</span></strong><span style=\"color: rgb(236, 228, 217)\">)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/2f0fe8e3f60c766f37ecfed80bf0eadc_5580338444435889690.png",
                "id": "talent33006",
                "key": "Salon Cô Độc",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Salon Cô Độc"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">. Nếu phe ta tồn tại nhân vật có tối thiểu 6 HP, thì sẽ gây 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật chịu ít sát thương nhất phe ta, sau đó gây ra thêm 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng dồn, tối đa dồn đến 4 lần)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/2f0fe8e3f60c766f37ecfed80bf0eadc_4004564640310032585.png",
                "id": "talent88202",
                "key": "Thành Viên Salon",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/12/44749939/742ece024b8fa2d5c64bdb5a98710fb7_3347899706063157049.png",
                "title": "Thành Viên Salon"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Chữa trị 1 điểm cho tất cả nhân vật phe ta. Nếu phe ta tồn tại nhân vật có HP không nhiều hơn 5, thì sẽ chữa trị thêm 1 điểm cho nhân vật chịu nhiều sát thương nhất.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng dồn, tối đa dồn đến 4 lần)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/12/44749939/51ae383a4cff7b823fc498cfdd070534_1164631604176222501.png",
                "id": "talent75095",
                "key": "Ca Sĩ Nước Nguồn",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/12/44749939/d87cb48ac9ce6214f901cfb7aa5cc542_5563461623475253148.png",
                "title": "Ca Sĩ Nước Nguồn"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Thỏa Sức Vui Đùa</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Thỏa Sức Vui Đùa</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật xuất chiến phe ta nhận sát thương hoặc chữa trị:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Cộng dồn 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Reo Hò</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/3f9b6381928c957398c658f17a2081f1_2068698512080988015.png",
                "id": "talent45512",
                "key": "Chúng Dân Reo Hò",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Chúng Dân Reo Hò"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Bị động) Khi bắt đầu chiến đấu, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Ngai Thánh Thần Và Thế Tục</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Ngai Thánh Thần Và Thế Tục</span><br><span style=\"color: rgb(236, 228, 217)\">Khi đang trong Sức Mạnh Nền Tảng: Ousia hoặc Sức Mạnh Nền Tảng: Pneuma, thay đổi hình thái Furina.</span><br><span style=\"color: rgb(236, 228, 217)\">Nếu trong trận phe ta tồn tại </span><strong><span style=\"color: rgb(255, 255, 255)\">Thành Viên Salon</span></strong><span style=\"color: rgb(236, 228, 217)\"> hoặc </span><strong><span style=\"color: rgb(255, 255, 255)\">Ca Sĩ Nước Nguồn</span></strong><span style=\"color: rgb(236, 228, 217)\">, cũng sẽ thay đổi hình thái của chúng.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/bb5cca1989b98706ff358e1f25f5efc8_1591826597253995695.png",
                "id": "talent87156",
                "key": "Sức Mạnh Nền Tảng: Ngai Thánh Thần Và Thế Tục",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sức Mạnh Nền Tảng: Ngai Thánh Thần Và Thế Tục"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/a126c6a302d81c07e19cf9a9f1260f90_4391376319927051753.png",
                "id": "talent38387",
                "key": "Sát Thương Nguyên Tố Thuỷ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Thuỷ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát Thương Xuyên Thấu sẽ không được nhận sát thương tăng thêm, nhưng sẽ bỏ qua hiệu quả khiên và miễn dịch sát thương.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Mỗi Giai Đoạn Kết Thúc, </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> -1.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_8244344749504526208.png",
