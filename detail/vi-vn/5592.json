      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tấn Công Thường</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/44749939/47817b4476bcd8b44c86c87debf042f2_7856826890644193026.png",
                "id": "talent12306",
                "key": "Nhát Chém Gợn Sóng",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Nhát Chém Gợn Sóng"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 1 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, sau đó </span><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><span style=\"color: rgb(236, 228, 217)\">: </span><strong><span style=\"color: rgb(255, 255, 255)\">Lưỡi Đao Gợn Sóng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Lưỡi Đao Gợn Sóng</span></strong><br><span style=\"color: #FFD780\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/44749939/09d978772c4b7b95a9b3896de9e32f9a_8412787306893033490.png",
                "id": "talent56226",
                "key": "Cạnh Sắc Xoáy Tròn",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Cạnh Sắc Xoáy Tròn"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 3 điểm</span> <strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong>. <span style=\"color: rgba(255, 255, 255, 0.45)\">Sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Lời Nguyền Dòng Nước Ngầm</span></strong> <span style=\"color: rgba(255, 255, 255, 0.45)\">trên sân đối phương.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Lời Nguyền Dòng Nước Ngầm</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật phe sở tại dùng Kỹ Năng Nguyên Tố hoặc Kỹ Năng Nộ:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Cần tiêu hao thêm 1 Xúc Xắc Nguyên Tố.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: <span style=\"color: rgba(255, 255, 255, 0.45)\">2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/44749939/d93cfa2833ead49715475616489de21c_2710215745698338176.png",
                "id": "talent42349",
                "key": "Chấn Động Nước Xiết",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Chấn Động Nước Xiết"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Kỹ Năng Bị Động</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Bị động) Khi bắt đầu chiến đấu, ban đầu áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Nguồn Nước Tái Sinh</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Nguồn Nước Tái Sinh</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng bị đánh bại:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Xóa hiệu quả này, khiến nhân vật </span><strong><span style=\"color: rgb(255, 255, 255)\">Không Bị Đánh Bại</span></strong><span style=\"color: rgb(236, 228, 217)\">, và chữa trị cho nhân vật này đến 4 điểm HP. Sau khi kích hoạt hiệu quả này, </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> nhân vật gây ra chuyển thành </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, và </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\"> +1.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/44749939/1bbe84955410406904930648b9a4dd36_8791794011667378305.png",
                "id": "talent82604",
                "key": "Nguồn Nước Tái Sinh",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Nguồn Nước Tái Sinh"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/44749939/a126c6a302d81c07e19cf9a9f1260f90_443796350915079936.png",
                "id": "talent16128",
                "key": "Sát Thương Nguyên Tố Thuỷ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Sát Thương Nguyên Tố Thuỷ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Có một số kỹ năng không thể sử dụng trực tiếp, mà cần một số lượt hành động nhất định để tiến hành </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Khi đến lượt của một bài thủ hành động, nếu như \"nhân vật xuất chiến\" của bài thủ này đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng, thì sẽ bỏ qua lượt hành động của bài thủ; Nếu như đã </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> xong, nhân vật sẽ trực tiếp dùng kỹ năng đó vào lúc này. (Loại kỹ năng cần </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> này không thể kích hoạt các hiệu quả \"Sau khi sử dụng\" hay \"Sau khi nhân vật kích hoạt phản ứng nguyên tố\".)</span><br><span style=\"color: rgb(236, 228, 217)\">Chỉ có \"nhân vật xuất chiến\" mới có thể </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng; Nếu như \"nhân vật xuất chiến\" đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng mà bị cho rời trận, thì quá trình </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> của kỹ năng sẽ bị gián đoạn.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Không Bị Đánh Bại</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Một số hiệu quả sẽ khiến nhân vật khi HP giảm còn 0 sẽ </span><strong><span style=\"color: rgb(255, 255, 255)\">không bị đánh bại</span></strong><span style=\"color: rgb(236, 228, 217)\">, và chữa trị cho nhân vật một lượng HP nhất định.</span><br><span style=\"color: rgb(236, 228, 217)\">Lúc này, nhân vật sẽ không bị xem là từng bị </span><strong><span style=\"color: rgb(255, 255, 255)\">đánh bại</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Do vậy trạng thái và trang bị mà nhân vật áp dụng sẽ không bị hủy, năng lượng cũng không bị xóa sạch.)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_4222844149632807521.png",
                "id": "talent80350",
                "key": "Giải Thích Quy Tắc",
                "materials": [],
