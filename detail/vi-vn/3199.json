              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span></p><p>Gây 3 điểm <span style=\"color: rgb(153, 255, 136)\">Sát Thương Nguyên Tố Thảo</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/21/12108544/24c3fc6700c665e8f0e67239c2244d74_2821301733414422017.png",
                "id": "talent79440",
                "key": "Mây Bào Tử Bất Ổn",
