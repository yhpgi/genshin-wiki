    {
      "id": "25",
      "name": "Thông Tin Khác",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p>﻿Thoạt nhìn trông giống một bể nước tinh khiết, nhưng nghe đâu phía dưới đó ẩn chứa những báu vật đủ để khiến tâm trí của con người mê loạn. Đáng tiếc là thế giới này khó có thể tìm được người giải mã các bí ẩn đó.<br><br><span>Nằm ở hồ Lục Hoa Trì, Liyue.<br>Biển Mây ở đây được tạo ra bởi tiên nhân, dùng để chứa những cổ vật cổ xưa (và tà ác) mà Guizhong có được trong quá trình nghiên cứu cơ học của cô ấy.</span></p>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/30/12108544/43dbae1ef08066a1b7c3bd2418934047_8697591950399875764.png",
                "title": "[ Bí Cảnh ] Hoa Thanh Quy Tàng Mật Cung"
              }
            ]
          }
        }
      ]
    },
