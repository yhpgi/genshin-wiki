      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Quan Hệ",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Nhân Vật",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Tóm Tắt",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Nham Vương Đế Quân",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Guizhong là đồng minh của Nham Vương Đế Quân.",
                      "type": "text"
                    },
                    {
                      "text": "Anh ấy hiện đang sống dưới dạng một con người có tên là Zhongli.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 2523,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/npc/Cloud Retainer_icon.png",
                      "name": "Lưu Vân Tá Phong Chân Quân",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Một tiên nhân rất thành thạo về cơ quan thuật, giống như Guizhong. Có một câu chuyện kể rằng Nham Vương Đế Quân đánh giá cơ quan thuật của Guizhong có phần nhỉnh hơn. (*1)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Ca Trần Lãng Thị Chân Quân",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Còn được gọi là",
                      "type": "text"
                    },
                    {
                      "text": "Bình Lão Lão",
                      "type": "text"
                    },
                    {
                      "text": ". Cô từng tranh luận với Guizhong về cơ quan thuật và sáng tác âm nhạc. (*1).",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Marchosius",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "(Ma Thần Bếp)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Thần bếp. Ông ấy là một trong những người bạn của Guizhong, và thậm chí còn được mời đến chỗ của cô ấy. (*2)",
                      "type": "text"
                    },
                    {
                      "text": "Ông ấy hiện đang sống với cái tên Guoba, tên do Xiangling đặt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "right",
                  "content": [
                    {
                      "text": "(1*): Từ Video",
                      "type": "text"
                    },
                    {
                      "text": "Cốt Truyện Genshin Impact - Dư Âm Trong Tim",
                      "type": "text"
                    },
                    {
                      "text": "(2*): Từ Nhiệm Vụ Sự Kiện \" Âm Vang Dạ Tấu\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffe14b"
                      ],
                      "text": "Vật Phẩm/",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Sách",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:#ffe14b"
                      ],
                      "text": "Liên Quan",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 1964,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/weapon/尘世之锁.png",
                      "name": "Khóa Trần Thế",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 1038,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Cleansing Bell_icon.png",
                      "name": "Chuông Tẩy Trần",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 1238,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Stone Tablet Compilations: Vol. I_icon.png",
                      "name": "Thạch Thư Tập Lục (I)",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
