{
  "id": 4045,
  "name": "Nguyên Thể Khe Nứt - Sinh Trưởng",
  "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Sinh mệnh kỳ lạ chủ yếu xuất hiện trong Elynas.<br>Tại Fontaine, lần đầu tiên phát hiện được Nguyên Thể Khe Nứt chính là không lâu sau khi xảy ra tai họa. Lúc đó đã cùng lúc lưu lại ghi chép rằng Nguyên Thể Khe Nứt đã tấn công con người và bảo vệ con người</span></p>",
  "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/23/44749939/44a89e0e023d714c3f74934b4b8da49c_3976149100614723961.png",
  "modules": [
    {
      "id": "11",
      "name": "Thuộc Tính",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "Tên",
                "string_values": [
                  "<p>Nguyên Thể Khe Nứt - Sinh Trưởng</p>"
                ]
              },
              {
                "item_values": [],
                "key": "Loại",
                "string_values": [
                  "<p>Vực Sâu - Khối Sinh Vật Dị Giới</p>"
                ]
              },
              {
                "item_values": [],
                "key": "Giáo Trình",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Sinh mệnh dị hình không có điểm chung với bất kỳ sinh vật nào trên mặt đất. Khi chiến đấu sẽ vào trạng thái kích ứng, dưới sự bảo vệ của </span><strong><span style=\"color: rgb(153, 255, 136)\">nguyên tố Thảo</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> sẽ liên tục tiến hành bắn đạn điên cuồng. Nếu có thể phá hủy lá chắn của nó, sẽ khiến nó tạm thời rơi vào trạng thái tê liệt. Ngoại trừ các </span><strong><span style=\"color: rgb(255, 215, 128)\">phản ứng nguyên tố</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> thông thường ra, thì đòn tấn công có đặc tính </span><strong><span style=\"color: rgb(255, 215, 128)\">Ousia và Pneuma</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> cũng có thể phá hủy lớp phòng ngự của Nguyên Thể Khe Nứt một cách hiệu quả hơn.</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
