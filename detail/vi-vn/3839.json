              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/27/44749939/431a2299d621e943e1a0271667ea602a_6130309771865371850.png",
