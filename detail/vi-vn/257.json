    {
      "id": "41",
      "name": "Nội Dung",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "\"Vậy là, thế giới được cứu rồi sao?\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Cuối câu chuyện, Samurai một mình đi trên sa mạc mênh mông.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kế hoạch của Tháp Thiên Không gần như đã thực sự hoàn thành, và sức sống còn lại trên thế giới cũng đã được thu thập.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Mặc dù không biết có tạo ra thế giới mới hay không, nhưng thế giới này thật sự đã bị hủy diệt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Không hổ là công chúa hủy diệt thế giới.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Cũng có thể hủy diệt thế giới khác...nếu nó tồn tại.\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Samurai đã bắt đầu hành trình mới.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "(Phần còn lại của quyển sách liên quan đến bối cảnh của câu chuyện, nội dung chủ yếu nói về Ma Vương và Ma Thú chưa xuất hiện trong câu chuyện chính của cuốn tiểu thuyết..)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
