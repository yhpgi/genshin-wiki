    {
      "id": "41",
      "name": "Nội Dung",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Những bài thơ đã được lưu hành từ thời của tầng lớp quý tộc cũ được cho là tự thuật của Ragnvindr \"kỵ sĩ bình minh\". Kể lại câu chuyện của anh và cuộc gặp gỡ đầy duyên phận với một người múa kiếm.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Một ngày nào đó ánh ban mai lóe sáng,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Người vũ công dừng chân tại Mondstadt, dùng kiếm làm tiếng hát.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Cho dù toàn thân bị xiềng xích trói buộc,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Thế nhưng vẫn chìm đắm trong tiếng ca.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Đó là bài hát tự do, một bình minh rực rỡ hơn bên ngoài bức tường cao,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Những bài dân ca được cất lên bởi người dân tự do.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Cô là ánh sáng của gánh hát rong,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Cũng là hung thủ mưu sát quý tộc.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tôi từng hỏi cô ấy: \"Sao lại muốn lật đổ quý tộc của chúng tôi,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Bạn có biết, họ là thủ lĩnh của chúng tôi?\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Sao họ lại sai mọi người xây tường cao?\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tiếng nói của cô gái mang theo hơi thở của làn gió nhẹ,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Nếu bạn cho rằng gió là người bạn đồng hành,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Nếu mọi người từng có tự do?\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Cô là người lắng nghe sự cô độc, kể về câu chuyện xưa kia,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nói về giới quý tộc cổ có thần lực,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kể về thiên sứ, các thần và ác long của ngày xưa,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Giảng đến thần linh và con dân của ngài ở mỗi một đất nước,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tất cả truyền kỳ cô đều chuyển thành lời ca,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tiếng hát lại theo gió thổi khắp đất nước.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Trong đấu trường của quý tộc, cô một lần nữa cầm kiếm cất tiếng hát.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Đó là bài hát cuối cùng của cô, nhưng cũng không còn là một mình nữa.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Kỵ sĩ vô danh đem theo thanh kiếm của cô rời khỏi đấu trường đẫm máu,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Chôn ở vùng đất có gió hội tụ.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
