    {
      "id": "41",
      "name": "Nội Dung",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Mèo",
                      "type": "text"
                    },
                    {
                      "text": "Mèo vàng giỏi, mèo trắng hay. Mèo vồ đầu kêu ngao ngao.",
                      "type": "text"
                    },
                    {
                      "text": "Mở to hai mắt, côn trùng có hại chạy không thoát!",
                      "type": "text"
                    },
                    {
                      "text": "Xiao Tổng Quản",
                      "type": "text"
                    },
                    {
                      "text": "Đốc công xưởng thuyền ngủ gà ngủ gật, đã ngủ say còn ngáy khò khò,",
                      "type": "text"
                    },
                    {
                      "text": "Nghe từ xa thì như Nham Vương bị đau dạ dày, nghe gần lại thấy giống heo rừng.",
                      "type": "text"
                    },
                    {
                      "text": "Ngắm biển",
                      "type": "text"
                    },
                    {
                      "text": "Biển cả thật đẹp, mênh mông một màu nước xanh thẳm.",
                      "type": "text"
                    },
                    {
                      "text": "Thuyền lớn có rất nhiều mái chèo, trông như một hàng chân tôm vậy.",
                      "type": "text"
                    },
                    {
                      "text": "Lại ngắm biển",
                      "type": "text"
                    },
                    {
                      "text": "Ngày ngày ngắm biển lòng buồn bã, nhìn lâu khó tránh mắt cay xè.",
                      "type": "text"
                    },
                    {
                      "text": "Làm thơ đã mấy năm ròng mà chưa có ai thưởng thức.",
                      "type": "text"
                    },
                    {
                      "text": "Sẽ có ngày trèo buồm lướt sóng, tựa như cá lớn lật biển.",
                      "type": "text"
                    },
                    {
                      "text": "Không nhìn thấy tài năng thật sự, sớm muộn sẽ có ngày lật thuyền chìm sâu xuống biển.",
                      "type": "text"
                    },
                    {
                      "text": "Cảnh phố ban đêm",
                      "type": "text"
                    },
                    {
                      "text": "Đèn trên phố sáng như sao trời, đồ ăn khắp phố thật nhộn nhịp.",
                      "type": "text"
                    },
                    {
                      "text": "Changchang đáng thương cứ quấy khóc, chỉ tổ hoa mắt thêm phiền lòng.",
                      "type": "text"
                    },
                    {
                      "text": "Thiên Hoành Sơn",
                      "type": "text"
                    },
                    {
                      "text": "Thiên Hoành Sơn giống như một bức tường lớn, bao trọn cảng Liyue.",
                      "type": "text"
                    },
                    {
                      "text": "Ngăn yêu quái, chặn lưu manh, đúng là một bức tường lớn!",
                      "type": "text"
                    },
                    {
                      "text": "Cảnh xuân bến cảng",
                      "type": "text"
                    },
                    {
                      "text": "Hoa nghê thường trong cảng Liyue, vừa đến mùa xuân kết nghê thường.",
                      "type": "text"
                    },
                    {
                      "text": "Chẳng hay là hoa hay nghê thường, hóa ra nghê thường cũng là hoa.",
                      "type": "text"
                    },
                    {
                      "text": "Bài vịnh về món lòng",
                      "type": "text"
                    },
                    {
                      "text": "Lòng Trung Nguyên vừa cay vừa mặn, ta ăn vào mà thở phì phò.",
                      "type": "text"
                    },
                    {
                      "text": "\"Sao món lòng lại mặn thế được?\" Tôi nghi hoặc hỏi.",
                      "type": "text"
                    },
                    {
                      "text": "Tô Nhị Nương trở mặt: \"Không thích thì đừng ăn, nó mặn thế đấy!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
