                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Sau lần đầu bị phá vỡ khiên, Shouki no Kami sẽ tích luỹ sức mạnh để thi triển Setsuna Shoumetsu và triệu hồi",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Cỗ Máy Nirvana",
                      "type": "text"
                    },
                    {
                      "text": "trong trận.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/05/35428890/9e6ed13c7acbdb167a1fca2cf1a09a4d_1113074260436659221.png"
