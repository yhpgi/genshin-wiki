                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Trong thời gian này, sử dụng phản ứng nguyên tố để phá huỷ Cỗ Máy Nirvana sẽ tạo ra",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Khối Năng Lượng",
                      "type": "text"
                    },
                    {
                      "text": "để tích luỹ năng lượng cho",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Trạm Cuối Akasha mới.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
