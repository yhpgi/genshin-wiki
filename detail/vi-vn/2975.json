                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Sau khi đã nạp đầy năng lượng, sử dụng",
