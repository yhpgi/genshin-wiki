          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/04/44749939/f1bbadd2e423a5ed66cad57727277d2c_7228158083700213219.png",
                "key": "Hỏa Ấn",
                "materials": [],
                "points": [
