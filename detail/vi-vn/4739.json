                  }
                ],
                "talent_img": "",
                "title": "Đá Vỡ Dội Đến"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">, nếu xảy ra phản ứng kết tinh, nhân vật sẽ </span><strong><span style=\"color: rgb(255, 255, 255)\">Hấp thụ sức mạnh nguyên tố tương ứng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Nếu trong thời gian kỹ năng mà nhân vật chưa hấp thụ sức mạnh nguyên tố, sẽ áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Bàn Nham Bách Tướng - Kết Tinh Nguyên Tố</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Bàn Nham Bách Tướng - Kết Tinh Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Sau khi </span><strong><span style=\"color: rgb(255, 255, 255)\">nhân vật chịu sát thương nguyên tố </span><span style=\"color: rgb(153, 255, 255)\">Băng</span>/<span style=\"color: rgb(128, 192, 255)\">Thủy</span>/<span style=\"color: rgb(255, 153, 153)\">Hỏa</span>/<span style=\"color: rgb(255, 172, 255)\">Lôi</span>:</strong><span style=\"color: rgb(236, 228, 217)\"> Nếu nhân vật hiện chưa hấp thụ sức mạnh của nguyên tố này, sẽ xóa bỏ trạng thái này, sau đó nhân vật </span><strong><span style=\"color: rgb(255, 255, 255)\">Hấp thụ sức mạnh nguyên tố tương ứng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/22/44749939/23dddc226f4ebf4ef82138e15f9c20d5_7733387677953003238.png",
