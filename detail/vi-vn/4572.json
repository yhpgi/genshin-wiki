                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Hướng Dẫn Đến Ngân Hà",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "\"Thế Giới Muôn Màu\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Trong một lần khiêu chiến, bước vào bụng cá voi hai lần.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
