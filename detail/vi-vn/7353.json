            "list": [
              {
                "desc": "<p><span style=\"color: #FFD780\">Tấn Công Thường</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/30/44749939/cb9cb5122aeda50a5e5265a03e3ea8b9_8630972430624249452.png",
                "id": "talent75702",
                "key": "Xử Lý Giảm Nhiệt",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Xử Lý Giảm Nhiệt"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Áp dụng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Cá Mập Cắn Xé</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">cho bản thân, sau đó tiến vào</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Dạ Hồn Chúc Phúc</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">và nhận</span><span style=\"color: rgb(236, 228, 217)\"> 2 </span><strong><span style=\"color: rgb(255, 255, 255)\">điểm Dạ Hồn</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">. (Sau khi nhân vật tiến vào</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Dạ Hồn Chúc Phúc</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">sẽ không thể dùng kỹ năng này)</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">(Nhân vật áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Cá Mập Cắn Xé</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">có thể sử dụng Đặc Kỹ:</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Ván Cá Mập</span></strong><span style=\"color: rgb(236, 228, 217)\">)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Cá Mập Cắn Xé</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Đặc Kỹ</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi hai phe đổi nhân vật, và Mualani là nhân vật xuất chiến:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Tiêu hao 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">điểm Dạ Hồn</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, khiến nhân vật xuất chiến phe địch áp dụng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Mục Tiêu Gặm Nhấm</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/30/44749939/6eca0515aa0b943ce4863f23e7bac54f_7231271188754702786.png",
                "id": "talent93967",
                "key": "Cá Mập Xuyên Sóng",
                "materials": [],
