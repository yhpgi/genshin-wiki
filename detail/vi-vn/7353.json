              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, triệu hồi</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Tên Lửa Cá Mập</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/30/44749939/de980cad3d9422986776632fa61c2eff_8691408204151471066.png",
