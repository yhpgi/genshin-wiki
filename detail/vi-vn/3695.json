                          {
                            "styles": [
                              "color:rgb(255, 225, 75)"
                            ],
                            "text": "\"Trái Tim Ốc Đảo\"",
                            "type": "text"
                          },
                          {
                            "text": "sẽ liên tục sinh ra ma vật, đánh bại ma vật để thúc đẩy tiến độ hồi phục. Còn khi",
                            "type": "text"
                          },
                          {
                            "styles": [
                              "color:rgb(255, 225, 75)"
                            ],
                            "text": "\"Trái Tim Ốc Đảo\"",
                            "type": "text"
                          },
                          {
                            "text": "bị ma vật tấn công thì",
                            "type": "text"
                          },
                          {
