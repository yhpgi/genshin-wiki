              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 4 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">, rút 1 thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Đánh Thức Gia Quyến</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra 2 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Ốc Đảo Nuôi Dưỡng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Ốc Đảo Nuôi Dưỡng</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi phe ta đánh ra Đánh Thức Gia Quyến:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Giảm tiêu hao 1 Xúc Xắc Nguyên Tố.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng dồn đến 3)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/30/44749939/8677803ca8f5b06b5f304b7873447759_1716507282770687730.png",
                "id": "talent97203",
                "key": "Cảnh Sụp Đổ Cuối Cùng",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
