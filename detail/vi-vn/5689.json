              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">hi đánh ra hoặc Vứt Bỏ thẻ bài này:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Triệu hồi 1 Sinh Mệnh Sinh Sôi độc lập.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/30/44749939/db13288db6b90ec33f8adc2656d2019f_7950248153384350356.png",
