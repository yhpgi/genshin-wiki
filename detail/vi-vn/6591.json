      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/cb9cb5122aeda50a5e5265a03e3ea8b9_7269869446102740785.png",
                "id": "talent37987",
                "key": "Ngôn Từ Hoa Và Gió",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Ngôn Từ Hoa Và Gió"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Bộ Thiên Thê</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Sóng Xung Kích Mây Trôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Bộ Thiên Thê</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi phe ta thực hiện hành động Đổi Nhân Vật:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Giảm tiêu hao 1 Xúc Xắc Nguyên Tố.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng dồn, tối đa dồn đến 2 lần)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Sóng Xung Kích Mây Trôi</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi phe ta đổi sang nhân vật áp dụng:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng đồn, tối đa dồn đến 2 lần)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/2e48f259614cf6bda0733eb4b672c1ce_3515721911149910714.png",
                "id": "talent19874",
                "key": "Mây Trắng Bình Minh",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Mây Trắng Bình Minh"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, chữa trị 1 điểm cho tất cả nhân vật phe ta, sinh ra thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Trúc Tinh</span></strong><span style=\"color: rgb(236, 228, 217)\"> trên tay.</span><br><span style=\"color: rgb(236, 228, 217)\">(Nhân vật trang bị </span><strong><span style=\"color: rgb(255, 255, 255)\">Trúc Tinh</span></strong><span style=\"color: rgb(236, 228, 217)\"> có thể sử dụng Đặc Kỹ: </span><strong><span style=\"color: rgb(255, 255, 255)\">Tiên Lực Trợ Giúp</span></strong><span style=\"color: rgb(236, 228, 217)\">)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Trúc Tinh</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Đặc Kỹ</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đặc Kỹ</span></strong><span style=\"color: rgb(236, 228, 217)\">: Tiên Lực Trợ Giúp</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<br><span style=\"color: rgb(236, 228, 217)\">(Nhân vật tối đa trang bị 1 Đặc Kỹ)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Tiên Lực Trợ Giúp</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Đặc Kỹ</span><br><span style=\"color: rgb(236, 228, 217)\">Chữa trị 2 điểm cho nhân vật áp dụng, khiến lần Tấn Công Thường tiếp theo xem như </span><strong><span style=\"color: rgb(255, 255, 255)\">Tấn Công Khi Đáp</span></strong><span style=\"color: rgb(236, 228, 217)\">, sát thương +1 và sau khi tổng kết kỹ năng sẽ gây 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/7e176cc668aede88f059f2e8ae61ba10_5486479814436468742.png",
                "id": "talent19894",
                "key": "Hái Sao Chạng Vạng",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Hái Sao Chạng Vạng"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Đặc Kỹ</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Đặc Kỹ</span></strong><span style=\"color: rgb(236, 228, 217)\">: Tiên Lực Trợ Giúp</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<br><span style=\"color: rgb(236, 228, 217)\">(Nhân vật tối đa trang bị 1 Đặc Kỹ)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/0f856dc798f6ec0fe14bc547a3f7c20b_9137703999386178936.png",
                "id": "talent27328",
                "key": "Trúc Tinh",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/82c711b2a1c8eb2bb4bc97a0f6f3aeb3_7061151760823885360.png",
                "title": "Trúc Tinh"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Đặc Kỹ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Chữa trị 2 điểm cho nhân vật áp dụng, khiến lần Tấn Công Thường tiếp theo xem như </span><strong><span style=\"color: rgb(255, 255, 255)\">Tấn Công Khi Đáp</span></strong><span style=\"color: rgb(236, 228, 217)\">, sát thương +1 và sau khi tổng kết kỹ năng sẽ gây 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/0a55f17c8440010076312cb5bb6073be_4951616459601522508.png",
                "id": "talent66530",
                "key": "Tiên Lực Trợ Giúp",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "white"
                  }
                ],
                "talent_img": "",
                "title": "Tiên Lực Trợ Giúp"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sản sinh phản ứng nguyên tố với các ấn nguyên tố sau:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(153, 255, 255)\">Băng</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Băng</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(128, 192, 255)\">Thủy</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Thủy</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Hỏa</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Lôi</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/c97292d96456bfe4abeca16bfce801e4_7070246810139897590.png",
                "id": "talent54011",
                "key": "Sát Thương Nguyên Tố Phong",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Phong"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Đặc Kỹ</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Khi nhân vật xuất chiến trang bị thẻ Đặc Kỹ, sẽ có thể sử dụng Đặc Kỹ tương ứng.</span><br><span style=\"color: rgb(236, 228, 217)\">Sử dụng Đặc Kỹ được xem như một Hành Động Chiến Đấu. Khi nhân vật không thể dùng kỹ năng do bị Đóng Băng, Hóa Thạch, Choáng... cũng sẽ đồng thời không thể sử dụng Đặc Kỹ.</span><br><span style=\"color: rgb(236, 228, 217)\">Khi nhân vật dùng Đặc Kỹ sẽ không được xem là sử dụng kỹ năng, không thể kích hoạt các hiệu quả \"sau khi dùng kỹ năng\" hay \"sau khi nhân vật kích hoạt phản ứng nguyên tố\"; Sát thương gây ra khi sử dụng Đặc Kỹ sẽ không được xem là sát thương gây ra bởi nhân vật.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_6373184726624846330.png",
