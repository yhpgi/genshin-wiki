    {
      "id": "41",
      "name": "Nội Dung",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Những bài thơ đã được lưu hành từ thời của tầng lớp quý tộc cũ được cho là tự thuật của Ragnvindr - \"kỵ sĩ bình minh\". Kể lại câu chuyện của anh khi còn là kỵ sĩ phục tùng.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tôi đi qua mỗi một con đường ở Mondstadt",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Trong không khí toát ra hơi thở của sự bất hạnh và mùi vị sự chìm đắm",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tôi nhìn thấy sự quyền quý cao ngạo,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tôi nhìn thấy đám người nghèo đáng thương.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Phố phường đen tối như mạng nhện, phân tách họ thành hai phần,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tiếng kêu nhỏ trong đêm khuya, chính là tiếng xiềng xích của trái tim.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Khi tuần đêm ở phố phường Mondstadt,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Đồng liêu và thượng cấp từng nói rằng:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Chúng ta là kỵ sĩ của ánh sao, hãy luôn ngẩng cao đầu!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Là cờ cao quý trong ánh sao, mới là đạo thủ hộ!\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Thế nhưng tôi chưa từng ngẩng đầu nhìn sao trời, cũng chưa từng nhìn lá cờ ấy,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tôi chỉ không thể làm ngơ những ngõ hẻm bẩn thỉu ấy.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Người bán hàng khóc trong lặng lẽ,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tiếng than kèm theo máu của binh sĩ già,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Trên con đường chết lúc nửa đêm,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Thiếu nữ bị giới quý tộc vứt bỏ đang cầu nguyện lòng thương từ Barbatos.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Gió lạnh thê lương thổi vào giáo đường,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Mang theo ai oán, rạch từng vết lên bức tường cung điện tráng lệ.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tiếng thở dài của mỗi người mẹ,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tiếng khóc than của mỗi đứa trẻ.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Đủ để phá vỡ tấm khiên kiên cố nhất,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Đủ để uốn cong thanh thương sắc bén nhất.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Những âm thanh ấy khiến tôi run lên.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Thế nhưng trong cung điện và thành lũy cao vút,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Trong thánh địa hùng vĩ của gió tây...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tiếng than khóc ấy chẳng ai nghe thấy.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
