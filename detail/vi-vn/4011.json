    {
      "id": "48",
      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><span style=\"color: rgb(236, 228, 217)\">Nếu kỹ năng này là </span><strong><span style=\"color: rgb(255, 255, 255)\">Trọng Kích</span></strong><span style=\"color: rgb(236, 228, 217)\">, sẽ khiến nhân vật xuất chiến phe địch áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Dẫn Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 228, 217)\">Dẫn Lôi</span></strong><br><span style=\"color: #FFD780\">Trạng Thái Chiến Đấu</span><br><span style=\"color: rgb(236, 228, 217)\">Trạng thái này ban đầu có 2 tầng \"Dẫn Lôi\"; khi áp dụng trùng lặp sẽ cộng dồn 1 tầng \"Dẫn Lôi\". \"Dẫn Lôi\" tối đa có thể cộng dồn đến 4 tầng.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Cộng dồn 1 tầng \"Dẫn Lôi\".</span><br><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng chịu sát thương Sấm Giội:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Xóa trạng thái này, mỗi tầng \"Dẫn Lôi\" sẽ +1 sát thương lần đó.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/f1bbadd2e423a5ed66cad57727277d2c_7301303303791800723.png",
                "key": "Sấm Sét Cảm Ứng",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Sấm Sét Cảm Ứng"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">; Nếu nhân vật xuất chiến phe địch chưa áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Dẫn Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">, sẽ khiến mục tiêu áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Dẫn Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 228, 217)\">Dẫn Lôi</span></strong><br><span style=\"color: rgb(255, 215, 128)\">Trạng Thái Chiến Đấu</span><br><span style=\"color: rgb(236, 228, 217)\">Trạng thái này ban đầu có 2 tầng \"Dẫn Lôi\"; khi áp dụng trùng lặp sẽ cộng dồn 1 tầng \"Dẫn Lôi\". \"Dẫn Lôi\" tối đa có thể cộng dồn đến 4 tầng.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Cộng dồn 1 tầng \"Dẫn Lôi\".</span><br><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng chịu sát thương Sấm Giội:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Xóa trạng thái này, mỗi tầng \"Dẫn Lôi\" sẽ +1 sát thương lần đó.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/144212d5a62895627d59999ae4f3841a_2815892160138173036.png",
                "key": "Sấm Giội",
                "materials": [],
