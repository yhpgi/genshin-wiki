                  }
                ],
                "talent_img": "",
                "title": "Sấm Giội"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">, triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Tường Vi Sấm Sét</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/adfb7e4d0569d117e5f832f43485772d_2261674365637628973.png",
                "key": "Tường Vi Sấm Sét",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Tường Vi Sấm Sét"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Vật Triệu Hồi</span></p><p><span style=\"color: rgb(236, 228, 217)\">Tường Vi Sấm Sét</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 2 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/db13288db6b90ec33f8adc2656d2019f_3320312680944323983.png",
                "key": "Tường Vi Sấm Sét",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/2b3f9718f47e31a775816000450f000e_4743898009782851603.png",
                "title": "Tường Vi Sấm Sét"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></p><p>Gán ấn Nguyên Tố Lôi, có thể tạo phản ứng nguyên tố:</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Quá Tải</span>: Sát thương +2, cưỡng chế khiến mục tiêu đổi thành nhân vật tiếp theo.</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sinh Trưởng</span>: Sát thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Khu Vực Xúc Tác</span>] khiến sát thương Thảo/Lôi 3 lần sau +1</p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/11ea6117480145a30b7893f1e8bd7115_1047560201995028338.png",
                "key": "Sát Thương Nguyên Tố Lôi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Lôi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 229, 216)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Trọng Kích</span></strong><br>Trước khi phe ta hành động, nếu tổng số xúc xắc là số chẵn, thì \"Tấn Công Thường\" sẽ được xem là \"Trọng Kích\".</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_2460311821013671510.png",
