                "key": "Cách Nhận",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Nhiệm Vụ Thế Giới - </span><span style=\"color: rgb(219, 222, 225)\">Sách Khải Huyền Soi Rạng</span><br><span style=\"color: rgba(255, 255, 255, 0.65)\">Có thể tìm thấy ở </span><span style=\"color: rgb(219, 222, 225)\">\"Nơi Đặc Biệt Ấm Áp\"</span></p>"
                ]
