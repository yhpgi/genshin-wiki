      "name": "Thư Viện Ảnh",
      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/02/44749939/c3a1348fff6f413180f1cc85f33c8bb2_5627102300470157818.png",
                "imgDesc": "<p><span style=\"color: rgb(222, 220, 217)\">Khối năng lượng được sinh ra từ tự nhiên hoặc nhân tạo, chia làm hai loại Pneuma và Ousia. Sau khi thu thập, lần tiếp theo dùng</span><span style=\"color: #FFE14B\"> tấn công thường, trọng kích hoặc tấn công</span> khi đáp đánh trúng, sẽ phóng thích năng lượng trong đó. Rất hữu ích cho việc thám hiểm ở một nơi như Fontaine.</p>",
                "key": "Trang 1/2"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/02/44749939/50a9265d930b9237ad84b687f08e22ab_2497710108090048216.png",
                "imgDesc": "<p><span style=\"color: rgb(222, 220, 217)\">Mượn sức mạnh này, thì nhân vật dù </span><span style=\"color: #FFE14B\">ở dưới nước</span> cũng có thể thi triển được sức mạnh Ousia hoặc Pneuma.<br>Nhân vật đến từ Fontaine đa phần đều sở hữu \"Sức Mạnh Nền Tảng\", họ không cần dựa vào Khối Pneumousia cũng có thể sử dụng <span style=\"color: #FFE14B\">đặc tính tương ứng</span> ở dưới nước.</p>",
                "key": "Trang 2/2"
              }
            ],
            "pic": ""
          }
        }
      ]
