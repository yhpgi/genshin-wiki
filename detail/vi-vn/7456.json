    {
      "id": "48",
      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">. Nếu có thể, tiêu hao tối đa 3 tầng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Khế Ước Sinh Mệnh</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">của mục tiêu và gia tăng lượng sát thương tương ứng.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Khế Ước Sinh Mệnh</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng nhận chữa trị:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Mỗi 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">hiệu quả này sở hữu, sẽ tiêu hao 1 lần để triệt tiêu 1 điểm chữa trị nhận được.</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">(Không thể triệt tiêu điểm chữa trị kích hoạt từ hồi sinh và phân phối HP)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: <span style=\"color: rgba(255, 255, 255, 0.45)\">1 (Có thể cộng dồn không giới hạn).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/05/44749939/241eba6e4c00020975cf91170050f435_3363688988724519009.png",
                "key": "Lời Mời Trảm Thủ",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Lời Mời Trảm Thủ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Sinh ra 5 tầng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Chỉ Lệnh Nợ Máu</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> trên sân đối phương, sau đó gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Chỉ Lệnh Nợ Máu</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật phe ta chịu sát thương:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Nhân vật chịu sát thương của phe ta và Arlecchino phe địch đều áp dụng 1 tầng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Khế Ước Sinh Mệnh</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: <span style=\"color: rgba(255, 255, 255, 0.45)\">5</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/05/44749939/51dcd771e9be34b266c5d81f26692f2d_2347207980522840256.png",
                "key": "Vạn Vật Hóa Tro",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Vạn Vật Hóa Tro"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 4 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, xóa bỏ tất cả</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Khế Ước Sinh Mệnh</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">của bản thân, mỗi 1 tầng xóa bỏ sẽ chữa trị 1 điểm cho bản thân.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Khế Ước Sinh Mệnh</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng nhận chữa trị:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Mỗi 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">hiệu quả này sở hữu, sẽ tiêu hao 1 lần để triệt tiêu 1 điểm chữa trị nhận được.</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">(Không thể triệt tiêu điểm chữa trị kích hoạt từ hồi sinh và phân phối HP)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: <span style=\"color: rgba(255, 255, 255, 0.45)\">1 (Có thể cộng dồn không giới hạn).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/05/44749939/47325a7a24de844e24403e6fcaa25878_1947277991233967853.png",
                "key": "Ách Nguyệt Trỗi Dậy",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Ách Nguyệt Trỗi Dậy"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Bị Động</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Nhân vật sẽ không nhận chữa trị từ nguồn nào khác ngoài</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Ách Nguyệt Trỗi Dậy</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi bản thân áp dụng Khế Ước Sinh Mệnh:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">nhân vật gây ra chuyển thành</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Ách Nguyệt Trỗi Dậy</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 4 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, xóa bỏ tất cả</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Khế Ước Sinh Mệnh</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">của bản thân, mỗi 1 tầng xóa bỏ sẽ chữa trị 1 điểm cho bản thân.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Khế Ước Sinh Mệnh</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng nhận chữa trị:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Mỗi 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">hiệu quả này sở hữu, sẽ tiêu hao 1 lần để triệt tiêu 1 điểm chữa trị nhận được.</span><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">(Không thể triệt tiêu điểm chữa trị kích hoạt từ hồi sinh và phân phối HP)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: <span style=\"color: rgba(255, 255, 255, 0.45)\">1 (Có thể cộng dồn không giới hạn).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/05/44749939/6e53adea8ee6f59c6af079daaec681f8_4276493419482174708.png",
                "key": "Chỉ Ách Nguyệt Mới Có Thể Thấu Hiểu",
                "materials": [],
                "points": [
