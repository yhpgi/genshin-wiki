                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Sát Thương Nguyên Tố Hoả"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p>",
