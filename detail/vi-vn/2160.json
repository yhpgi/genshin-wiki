              {
                "item_values": [],
                "key": "Giáo Trình",
                "string_values": [
                  "Sử dụng lớp vỏ nặng nề để bảo vệ bản thân, nắm bắt thời cơ khi <span style=\"color:#FFE14BFF\">Hạt Nhân Nguyên Tố</span> lộ ra bên ngoài, mới có thể tấn công một cách hiệu quả. Khi gặp nguy hiểm sẽ tách thành 3 \"Giọt Nước\" di chuyển về phía hạt nhân. <span style=\"color:#FFE14BFF\">Hủy diệt kịp thời những giọt nước này</span> mới có thể ngăn cản Thủy Nguyên Bản hồi sinh."
                ]
              }
            ]
