                ],
                "talent_img": "",
                "title": "Suy Luận Hồi Tố"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Trác Quang Kính</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Trác Quang Kính</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> do nhân vật gây ra đổi thành </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật tấn công thường:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">. Nếu kỹ năng này là </span><strong><span style=\"color: rgb(255, 255, 255)\">Trọng Kích</span></strong><span style=\"color: rgb(236, 228, 217)\">, sẽ +1 </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> của trạng thái này.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: 2<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng dồn, tối đa dồn đến 3 hiệp)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/44749939/694e6198fcb68eb3a0767859ab2e642d_2079954788757132743.png",
                "id": "talent80869",
                "key": "Phổ Quát - Soạn Thảo Theo Mẫu",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "Phổ Quát - Soạn Thảo Theo Mẫu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 4 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">; Tiêu hao </span><strong><span style=\"color: rgb(255, 255, 255)\">Trác Quang Kính</span></strong><span style=\"color: rgb(236, 228, 217)\"> để tăng sát thương dựa trên </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> của </span><strong><span style=\"color: rgb(255, 255, 255)\">Trác Quang Kính</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Nếu </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> tiêu hao của </span><strong><span style=\"color: rgb(255, 255, 255)\">Trác Quang Kính</span></strong><span style=\"color: rgb(236, 228, 217)\"> là 0/1/2, sẽ áp dụng cho nhân vật </span><strong><span style=\"color: rgb(255, 255, 255)\">Trác Quang Kính</span></strong><span style=\"color: rgb(236, 228, 217)\"> với </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> là 3/2/1.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Trác Quang Kính</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> do nhân vật gây ra đổi thành </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật tấn công thường:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">. Nếu kỹ năng này là </span><strong><span style=\"color: rgb(255, 255, 255)\">Trọng Kích</span></strong><span style=\"color: rgb(236, 228, 217)\">, sẽ +1 </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> của trạng thái này.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: 2<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng dồn, tối đa dồn đến 3 hiệp)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/44749939/a3b3108e0046cb101533a3bf6dcbe717_4152451218159855004.png",
                "id": "talent86612",
                "key": "Khu Vực - Xiềng Xích Cảnh Tượng",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Khu Vực - Xiềng Xích Cảnh Tượng"
              },
              {
                "attributes": [],
                "desc": "<p>Gán ấn Nguyên Tố Thảo, có thể tạo phản ứng nguyên tố:</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span>: Sát Thương +1, tạo thành [<span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span>] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Số lần dùng là 1, tối đa cộng dồn đến 2)</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Sinh Trưởng</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Khu Vực Xúc Tác</span>] khiến sát thương Thảo/Lôi 3 lần sau +1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/44749939/e8cff941b5a0ff248efde360ec9e91fe_504362691048397456.png",
                "id": "talent1108",
                "key": "Sát Thương Nguyên Tố Thảo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Thảo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Trọng Kích</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Trước khi phe ta hành động, nếu tổng số xúc xắc là số chẵn, thì \"Tấn Công Thường\" sẽ được xem là \"Trọng Kích\".</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Mỗi Giai Đoạn Kết Thúc, </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> -1.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_7761813083450662063.png",
