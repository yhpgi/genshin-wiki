              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Vòng Cỏ Thánh Hóa</span></strong><span style=\"color: rgb(236, 228, 217)\">. Nếu HP của nhân vật này tối thiểu là 6, sẽ gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho chính bản thân.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/26/44749939/89377e2e3c6c55cd637d0315e24efe98_9149553216737073376.png",
