      "name": "Thuộc Tính",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "Tên",
                "string_values": [
                  "<p>Kẻ Rửa Tội Tàn Ác</p>"
                ]
              },
              {
                "item_values": [],
                "key": "Loại",
                "string_values": [
                  "<p>Vực Sâu</p>"
                ]
              },
              {
                "item_values": [],
                "key": "Giáo Trình",
                "string_values": [
                  "<p>Ma vật của Giáo Đoàn Vực Sâu, có thể điều khiển nhiều loại nguyên tố để chiến đấu, vận dụng lá chắn nguyên tố tương ứng để chống đỡ sát thương. Trong chiến đấu sẽ tạo ra vòng nguyên tố để tụ lực cho đòn tấn công mạnh mẽ. Dùng phản ứng nguyên tố để phá hủy tất cả vòng nguyên tố, từ đó ngăn cản tai họa ập đến.</p>"
                ]
              }
            ]
          }
        }
      ]
