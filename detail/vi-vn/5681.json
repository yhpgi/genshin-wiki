      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/6abee9810b73dd1c04987cd0d893fc25_4250763500709738716.png",
                "id": "talent26232",
                "key": "Liệt Sương Quyền",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Liệt Sương Quyền"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Hàn Băng Phán Quyết</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Hàn Băng Phán Quyết</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật tiến hành Tấn Công Thường:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nếu nhân vật có tối thiểu 6 HP, thì kỹ năng này sẽ giảm tiêu hao 1 </span><strong><span style=\"color: rgb(153, 255, 255)\">Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, sát thương +1, đồng thời gây 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho bản thân.</span><br><span style=\"color: rgb(236, 228, 217)\">Nếu HP nhân vật không nhiều hơn 5, sẽ +1 sát thương này và sau khi tổng kết kỹ năng sẽ chữa trị cho nhân vật 2 điểm.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/d16aaeb6e3d7c751f1ac36d875668e80_8080810339311966634.png",
                "id": "talent28355",
                "key": "Nanh Băng Càn Quét",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Nanh Băng Càn Quét"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Uy Thế Nhũ Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Trong hiệp này, mỗi khi nhân vật này tích lũy nhận 2 lần sát thương hoặc chữa trị</span></strong><span style=\"color: rgb(236, 228, 217)\">: Kỹ năng này giảm tiêu hao 1 Xúc Xắc Nguyên Tố (Tối đa giảm 2).</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Uy Thế Nhũ Băng</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Trước khi phe ta lựa chọn hành động:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 2 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/866bcc4723d1e09e478894bf4d1e70ef_4731153491101211744.png",
                "id": "talent94398",
                "key": "Hắc Kim Lang Cắn Xé",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Hắc Kim Lang Cắn Xé"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Trong hiệp này, mỗi khi nhân vật này tích lũy nhận 2 lần sát thương hoặc chữa trị</span></strong><span style=\"color: rgb(236, 228, 217)\">: Kỹ Năng Nộ giảm tiêu hao 1 Xúc Xắc Nguyên Tố (Tối đa giảm 2).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/db13288db6b90ec33f8adc2656d2019f_2859486075390885019.png",
                "id": "talent24946",
                "key": "Hắc Kim Lang Cắn Xé (Bị Động)",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Hắc Kim Lang Cắn Xé (Bị Động)"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Gán ấn Nguyên Tố Băng, có thể tạo phản ứng nguyên tố:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đóng Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hỏa sẽ giải trừ sớm, nhưng sát thương +2)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/4bcc4b82a9d7ee22770f60afa54e9919_734946645191568455.png",
                "id": "talent54592",
                "key": "Sát Thương Nguyên Tố Băng",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Băng"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát Thương Xuyên Thấu sẽ không được nhận sát thương tăng thêm, nhưng sẽ bỏ qua hiệu quả khiên và miễn dịch sát thương.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_1647614619926983825.png",
