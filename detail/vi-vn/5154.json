          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/07/44749939/464df75643b85d808ea7457d333c2520_4116040722458454334.png",
                "id": "talent76565",
                "key": "Tĩnh Lặng Như Nước",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
