              },
              {
                "item_values": [],
                "key": "Giáo Trình",
                "string_values": [
                  "<p><span style=\"color: rgb(236, 228, 217)\">Vua trong loài Cua Giáp Nặng, đã trải qua vô số năm tháng trưởng thành, vượt qua hầu hết các loài Dị Chủng Biển Sâu. </span><strong><span style=\"color: rgb(255, 225, 75)\">Cặp sừng rực lửa</span></strong><span style=\"color: rgb(236, 228, 217)\"> phía trên cơ thể nó là bộ phận </span><strong><span style=\"color: #FF9999\">nguyên tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">, khiến nó có thể tấn công nguyên tố mãnh liệt hơn, và có sức phòng ngự mạnh hơn. Trong một số đòn tấn công, cặp sừng của nó sẽ </span><strong><span style=\"color: rgb(255, 225, 75)\">tiếp gần đất hơn</span></strong><span style=\"color: rgb(236, 228, 217)\">, là thời cơ tốt để dùng </span><strong><span style=\"color: rgb(255, 225, 75)\">phản ứng nguyên tố</span></strong><span style=\"color: rgb(236, 228, 217)\"> tiêu trừ nguyên tố Hỏa của nó.</span></p>"
                ]
              }
            ]
          }
        }
      ]
