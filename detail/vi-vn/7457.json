    {
      "id": "48",
      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/06/44749939/10316b5178d5109d597f415d6e7903dc_1289883491969719027.png",
                "id": "talent50029",
                "key": "Mặt Trời Đêm",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Mặt Trời Đêm"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Chọn 1 nhân vật phe ta, áp dụng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Liên Kết Dây Móc</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">cho bản thân và tiến vào</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Dạ Hồn Chúc Phúc</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">. Gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, sau đó đổi vị trí với nhân vật đã chọn.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Liên Kết Dây Móc</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi phe địch chịu sát thương phản ứng Thiêu Đốt hoặc nhân vật khác của phe ta dùng Đặc Kỹ:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Nhân vật áp dụng nhận 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">điểm Dạ Hồn</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi điểm Dạ Hồn đạt 2 điểm:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Nhân vật áp dụng sẽ áp dụng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Dây Móc</span></strong><span style=\"color: rgb(236, 228, 217)\">, </span><span style=\"color: rgba(255, 255, 255, 0.45)\">sau đó tiêu hao</span><span style=\"color: rgb(236, 228, 217)\"> 2 </span><strong><span style=\"color: rgb(255, 255, 255)\">điểm Dạ Hồn</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">. (Sau khi áp dụng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Dây Móc</span></strong><span style=\"color: rgb(236, 228, 217)\">, </span><strong><span style=\"color: rgb(255, 255, 255)\">trước khi nhân vật phe ta lựa chọn hành động, nếu nhân vật áp dụng là nhân vật xuất chiến:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 3 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">cho nhân vật phe địch ở gần nhất)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/06/44749939/c48d1d48d6a1dc63a64abf093de4fb1a_1963371046245707466.png",
                "id": "talent61514",
                "key": "Săn Mồi Trên Cao",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Săn Mồi Trên Cao"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 1 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, sinh ra</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Thánh Long Toàn Năng Ajaw</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/06/44749939/9cda2226c805b3b32e9d2136dd6f3b48_7154719996976674452.png",
                "id": "talent66838",
                "key": "Kính Chào Thánh Long Toàn Năng",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Kính Chào Thánh Long Toàn Năng"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Vật Triệu Hồi</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 1 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, sau đó gây 1 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">cho nhân vật kế tiếp của phe địch.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/06/44749939/db13288db6b90ec33f8adc2656d2019f_7334427354001021097.png",
                "id": "talent53973",
                "key": "Thánh Long Toàn Năng Ajaw",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [
                  {
                    "description": "",
                    "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/06/44749939/fd18c308a948557901d1f3291df9535a_8120518918274565379.png"
                  }
                ],
                "title": "Thánh Long Toàn Năng Ajaw"
              },
              {
                "attributes": [],
                "desc": "<p>Gán ấn <span style=\"color: #99FF88\">Nguyên Tố Thảo</span>, có thể tạo phản ứng nguyên tố:</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span>: Sát Thương +1, tạo thành [<span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span>] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Số lần dùng là 1, tối đa cộng dồn đến 2)</p><p>[<span style=\"color: rgb(153, 255, 136)\">Thảo</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Sinh Trưởng</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Khu Vực Xúc Tác</span>] khiến sát thương Thảo/Lôi 3 lần sau +1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/06/44749939/e8cff941b5a0ff248efde360ec9e91fe_1657916951948011673.png",
                "key": "Sát Thương Nguyên Tố Thảo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Sát Thương Nguyên Tố Thảo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Mỗi Giai Đoạn Kết Thúc, </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> -1.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> khi dùng hết sẽ tiêu hủy thẻ bài này.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/06/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_7205360990124196396.png",
