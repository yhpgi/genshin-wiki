                      "ep_id": 4780,
                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2023/12/20/a5b8d23dd3fbe0969cc3ebce78f9c29f_8021351765588020911.png",
                      "name": "Egeria",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4539,
                      "icon_url": "",
                      "name": "Old Finch",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2323,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/book/Heart of Clear Springs_icon.png",
                      "name": "Heart of Clear Springs",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Bài thơ của Callirhoe",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Chúng tôi đến từ một nơi rất xa,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Sông ngòi như giường ngủ, bốn mùa như phục trang.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Tôi tìm về mảnh vườn để an cư,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Rong đuổi theo ánh trăng màu bạc.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Gió Thoảng và Suối Trong mời tôi dừng bước",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "\"Ngủ ngon nhé, ngủ ngon nhé, hành trình đã khiến bước chân mệt mỏi\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "\"Vang vọng nhé, vang vọng nhé, hoa rơi sẽ thêm phần điểm xuyết.\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Buổi sáng tôi đàn ca chảy qua kẽ đá,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Đêm xuống tôi lắng nghe khúc hát của những giấc mơ.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Giọt nước mắt của cậu bé tạo nên làn sóng,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Lãng mạn hơn cả bất kỳ bài ca nào trong đêm sao.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Cậu bé mang quá khứ và tương lai kết thành vòng hoa màu sắc,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Tôi khẽ chạm vào ranh giới của giấc mơ, làm quà trả lễ.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "\"Nhìn xem, nhìn xem, sự ái mộ đó tràn đầy trong ánh mắt,\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "\"Đáp ứng đi, đáp ứng đi, nhân lúc giấc mơ đẹp chưa tan biến.\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Mèo và Đom Đóm hối thúc tôi nhận lời,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Nhưng tôi lại không hiểu giai điệu của nhân gian, thế thì làm sao để hợp tấu chứ?.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Dòng suối và giấc mơ chảy vào biển lớn,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Khoảng khắc tinh diệp chạm mặt hồ, chàng thiếu niên đó đã già đi theo thời gian.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Tôi chập chững học lấy tất cả về con người,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Dùng áng mây kết thành những dòng thơ dịu dàng.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Giống như hạt giống gieo vào thổ nhưỡng, rừng cây đuổi theo mặt trời,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Những giai điệu mơ hồ đó đã dần hòa tấu trong tim,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Đưa tai lắng nghe, thì ra trong đó đều hát vang tên anh.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Giờ đây, em gửi gắm giấc mơ của mình cho anh, chúc đêm tối của anh ngọt ngào như dòng suối chảy.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "Giờ đây, em gửi gắm trái tim của mình cho anh, mong anh nhận lấy lời hứa muộn màng này.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
