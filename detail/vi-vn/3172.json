                      "ep_id": 3186,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/01/148664880/9135fdcb8dc1dca18a13b4f4818cb2d2_5219651368985342821.png",
                      "menu_id": 17,
                      "name": "Keqing",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Điều Kiện Mở Khóa",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
