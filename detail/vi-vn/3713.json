            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span><br>Gây 2 điểm <span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/14/44749939/c369b96fc6417e8fc2bb607e37297ad4_7749836187491418355.png",
                "id": "talent80510",
                "key": "Phá Bỏ Chướng Ngại",
                "materials": [],
                "points": [
                  {
