    {
      "id": "31",
      "name": "Thông Tin Khác",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">...Sẽ là thông đạo liên thông nguyên thủy và hiện tại... </span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">...Phân giải và nghịch chuyển tác dụng của nó, đồng thời nội hóa... </span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">...Từ đó hoàn toàn khống chế... </span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">...Hôn lễ của hóa học, kết hợp mật thiết của nguyên tố... </span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">...Phế tích hình vòng cung, rừng rậm trong gương... </span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">...Sắp xếp Lyris và Jakob đi... </span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Phần lớn nội dung đã tan rã hoàn toàn trước khi có thể hiểu được.)</span></p>",
                "title": ""
              }
            ]
          }
