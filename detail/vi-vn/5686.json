    {
      "id": "48",
      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/17/44749939/615640468a637b86b151187e8a000a85_1942554003625179271.png",
                "id": "talent69571",
                "key": "Sóng Biển Vỡ Tung",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Sóng Biển Vỡ Tung"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, với mỗi 3 điểm HP tối đa cộng thêm từ </span><strong><span style=\"color: rgb(255, 255, 255)\">Dạ Dày Không Đáy</span></strong><span style=\"color: rgb(236, 228, 217)\"> mà nhân vật này sở hữu, sẽ +1 sát thương này (Tối đa +5). Sau đó </span><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><span style=\"color: rgb(236, 228, 217)\"> 1 lá bài có chi phí Xúc Xắc Nguyên Tố vốn có cao nhất trên tay.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/17/44749939/50dd1011292fcdbcc27b9a8e58ac6f34_3933733110127389944.png",
                "id": "talent94618",
                "key": "Mưa Sao Rơi Xuống",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Mưa Sao Rơi Xuống"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, gây 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho tất cả nhân vật dự bị phe địch. Triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Ảo Ảnh Bóng Tối</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/17/44749939/dc43383204065922390d9ff7b564c906_7853733220796206323.png",
                "id": "talent88442",
                "key": "Kình Ngư Cắn Ngang",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Kình Ngư Cắn Ngang"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Khi vào trận:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nhận \"Tấn Công\" bằng với chi phí của lá bài có chi phí Xúc Xắc Nguyên Tố cao nhất trong số các lá bài phe ta nuốt chửng, nhận </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> bằng với số lá bài đã nuốt chửng có mức chi phí này.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc và khi phe ta tuyên bố kết thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\"> tương đương chỉ số \"Tấn Công\" của thẻ này.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật xuất chiến phe ta chịu sát thương:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Giảm 1 điểm sát thương phải chịu, sau đó thẻ bài này -2 </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/17/44749939/db13288db6b90ec33f8adc2656d2019f_785683499786081085.png",
                "id": "talent3130",
                "key": "Ảo Ảnh Bóng Tối",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Ảo Ảnh Bóng Tối"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span></p><p>(Bị động) Khi bắt đầu chiến đấu, sinh ra <strong><span style=\"color: rgb(255, 255, 255)\">Vùng Nuốt Chửng Sâu</span></strong>.</p><p><span>• Vùng Nuốt Chửng Sâu</span><br>Thẻ bài trên tay phe ta bị <strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong> hoặc <strong><span style=\"color: rgb(255, 255, 255)\">Điều Tiết</span></strong> sẽ bị nuốt chửng.<br><strong><span style=\"color: rgb(255, 255, 255)\">Mỗi khi nuốt chửng 3 lá bài</span></strong>: Thôn Tinh Kình Ngư sẽ nhận thêm 1 điểm HP Tối Đa; Nếu trong số đó tồn tại 2 lá bài với chi phí Xúc Xắc Nguyên Tố vốn có giống nhau, sẽ nhận thêm 1 điểm nữa; Nếu cả 3 lá đều giống nhau, sẽ tiếp tục nhận thêm 1 điểm nữa.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/17/44749939/269638d9682c3f4b80a1610a9c690fe9_8080418531048664513.png",
                "id": "talent60460",
                "key": "Dạ Dày Không Đáy",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dạ Dày Không Đáy"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/17/44749939/a126c6a302d81c07e19cf9a9f1260f90_7085296064527083091.png",
                "key": "Sát Thương Nguyên Tố Thuỷ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Thuỷ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Thông qua hiệu quả của Thẻ Hành Động hoặc kỹ năng nhân vật, có thể loại bỏ Thẻ Hành Động trên tay hoặc trong kho bài.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát Thương Xuyên Thấu sẽ không được nhận sát thương tăng thêm, nhưng sẽ bỏ qua hiệu quả khiên và miễn dịch sát thương.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Điều Tiết</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Để tiến hành Điều Tiết Nguyên Tố, sẽ loại bỏ Thẻ Hành Động trên tay.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/17/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_9023513919036219986.png",
                "key": "Giải Thích Quy Tắc",
                "materials": [],
