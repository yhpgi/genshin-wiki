          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/28/44749939/47817b4476bcd8b44c86c87debf042f2_7070032536711967547.png",
                "key": "Vua Sói Tấn Công",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Vua Sói Tấn Công"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Gây 1 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">, nhân vật mục tiêu áp dụng 2 tầng </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Ăn Mòn Hoàng Kim</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">, triệu hồi </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Chó Ma Đầu Đàn</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Ăn Mòn Hoàng Kim</span><br><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> Nếu nhân vật áp dụng đang dự bị, thì với mỗi 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> hiệu quả này sở hữu sẽ gây 1 điểm </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> cho nhân vật áp dụng.<br></span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">: 1 (Có thể cộng dồn, tối đa dồn đến 3 lần)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/28/44749939/88bee9c24128a7b8fae306dd5feecea3_4079443711336690705.png",
                "key": "Hiệu Triệu Ma Thú",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Hiệu Triệu Ma Thú"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">, gây 1 điểm </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> cho tất cả nhân vật dự bị phe địch, và khiến tất cả nhân vật phe địch áp dụng </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Ăn Mòn Hoàng Kim</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Ăn Mòn Hoàng Kim</span><br><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> Nếu nhân vật áp dụng đang dự bị, thì với mỗi 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> hiệu quả này sở hữu sẽ gây 1 điểm </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> cho nhân vật áp dụng.<br></span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">: 1 (Có thể cộng dồn, tối đa dồn đến 3 lần)</span><br><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/28/44749939/54fafafd3720e95ffa305f16d15dbfca_6428816779426574615.png",
