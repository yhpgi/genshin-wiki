    {
      "id": "31",
      "name": "Thông Tin Khác",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Mọi thứ đều trở nên vô cùng rõ ràng. Những trở ngại vô nghĩa đã hoàn toàn biến mất. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lần thử này rất thành công. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Tôi đã hiểu chuyện mà chúng ta phải làm. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Trong quá trình này, dường như tôi đã mất đi một quãng thời gian và kinh nghiệm. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Nhưng cũng chẳng sao, vì tôi sẽ có được tất cả thời gian của vũ trụ. Tôi đã trở thành Narzissenkreuz. </span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">... </span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Trí nhớ và ghi chép hình như có chút không khớp nhau. Có lẽ... </span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Phần lớn nội dung đã tan rã hoàn toàn trước khi có thể hiểu được.)</span></p>",
                "title": ""
              }
            ]
          }
        }
      ]
