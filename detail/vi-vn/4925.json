                      "display_style": "card",
                      "ep_id": 4936,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/24/55631176/700e67317f0fc5bc48976ea8ca9fbfda_8697225191933672492.png",
                      "name": "Lễ Hội Fontinalia",
                      "type": "custom_entry"
