      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/a360ce6a562e9559d28383ea05cbef26_1885510923346741716.png",
                "key": "Dòng Chảy Xoáy",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Dòng Chảy Xoáy"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, nếu nhân vật chưa có </span><strong><span style=\"color: rgb(255, 255, 255)\">Thời Khắc Của Pers</span></strong><span style=\"color: rgb(236, 228, 217)\">, sẽ khiến nhân vật này áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Thời Khắc Của Pers</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Thời Khắc Của Pers</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Mỗi khi phe ta rút 1 lá bài:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Thẻ bài này tích lũy 1 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Cấp Áp Lực</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng dùng Băng Giá Điều Áp:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nếu có tối thiểu 2 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Cấp Áp Lực</span></strong><span style=\"color: rgb(236, 228, 217)\">, sẽ xóa hiệu quả này và khiến kỹ năng giảm tiêu hao 1 Xúc Xắc Nguyên Tố, đồng thời nếu có tối thiểu 4 tầng Cấp Áp Lực sau khi tổng kết kỹ năng, thì sẽ gây thêm 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/21be3c910a3d0a458897acbbbc134d35_6021532353004208582.png",
                "key": "Băng Giá Điều Áp",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Băng Giá Điều Áp"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 4 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Chế Độ Lén Lút</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Chế Độ Lén Lút</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi phe ta rút 3 lá bài:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Cung cấp 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\">, bảo vệ nhân vật áp dụng. (Có thể cộng dồn, tối đa dồn đến 2 điểm).</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật áp dụng dùng Tấn Công Thường hoặc Kỹ Năng Nguyên Tố:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Đưa tối đa 2 lá bài có chi phí Xúc Xắc Nguyên Tố cao nhất trên tay vào dưới cùng kho bài, sau đó rút số lá bài tương ứng.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/dcca15a3f38151e6935029088d75b103_517591984573166272.png",
                "key": "Ảo Ảnh Công Phá",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ảo Ảnh Công Phá"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Gán ấn Nguyên Tố Băng, có thể tạo phản ứng nguyên tố:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đóng Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hỏa sẽ giải trừ sớm, nhưng sát thương +2)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/4bcc4b82a9d7ee22770f60afa54e9919_7758553778315601522.png",
                "key": "Sát Thương Nguyên Tố Băng",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Băng"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Mỗi Giai Đoạn Kết Thúc, </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> -1.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_4547045257440738184.png",
                "key": "Giải Thích Quy Tắc",
                "materials": [],
