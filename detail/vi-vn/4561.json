      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/08/44749939/94aa30ae75b8c7c6a9c64ab05bd5dda7_9188453459266428857.png",
                "id": "talent56487",
                "key": "Vũ Điệu Samser",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Vũ Điệu Samser"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, nếu trong đội có </span><strong><span style=\"color: rgb(128, 192, 255)\">nhân vật Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\"> và nhân vật </span><strong><span style=\"color: rgb(126, 194, 54)\">Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">, đồng thời không bao gồm nhân vật nguyên tố khác, sẽ sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Phước Lành Ly Vàng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">• </span><strong><span style=\"color: rgb(236, 228, 217)\">Phước Lành Ly Vàng</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật phe địch chịu phải phản ứng Sum Suê:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Phe ta không sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\"> nữa, mà chuyển sang triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Căng Tràn</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/08/44749939/c82a120ef3389c55999b6069de0c8ddc_5304820093094447887.png",
                "id": "talent83185",
                "key": "Vũ Điệu Haftkarsvar",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Vũ Điệu Haftkarsvar"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật mục tiêu áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Dòng Nước Vĩnh Hằng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Dòng Nước Vĩnh Hằng</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 3 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật bị áp dụng.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/08/44749939/e701a5d9dee57abe1f108242af52b000_4748080806593270142.png",
                "id": "talent4516",
                "key": "Vũ Điệu Abzendegi - Viễn Mộng Linh Tuyền",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Vũ Điệu Abzendegi - Viễn Mộng Linh Tuyền"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/08/44749939/a126c6a302d81c07e19cf9a9f1260f90_456910037481840430.png",
                "id": "talent33819",
                "key": "Sát Thương Nguyên Tố Thuỷ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Thuỷ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p><br><strong><span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Căng Tràn</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 2 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số lần sử dụng</span></strong>: 1 <span style=\"color: rgb(236, 228, 217)\">(Có thể cộng dồn, tối đa dồn đến 3 lần)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi phe ta tuyên bố kết thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nếu </span><strong><span style=\"color: rgb(255, 255, 255)\">số lần có thể sử dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> thẻ bài này tối thiểu là 2, sẽ gây 2 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Cần tiêu hao </span><strong><span style=\"color: rgb(255, 255, 255)\">số lần sử dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/08/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_6167527321641865136.png",
