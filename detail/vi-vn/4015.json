              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, tạo ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Bùa Độ Ách Chân</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 228, 217)\">Bùa Độ Ách Chân</span></strong><br><span style=\"color: #FFD780\">Hiệu Ứng Xuất Chiến</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật phe ta dùng kỹ năng:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nếu nhân vật này chưa đầy HP, sẽ chữa trị 2 điểm cho nhân vật này.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 3<br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/9850fd4e8dc8c44201f77421fb24ecf4_535547365759629033.png",
                "key": "Tiên Pháp - Cứu Khổ Độ Ách",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Tiên Pháp - Cứu Khổ Độ Ách"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Vật Triệu Hồi</span></p><p><span style=\"color: rgb(236, 228, 217)\">Hàn Bệnh Quỷ Sai</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 3<br><strong><span style=\"color: rgb(255, 255, 255)\">Khi vật triệu hồi này trong trận, sau khi Qiqi dùng Tấn Công Thường:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Chữa trị 1 điểm cho nhân vật chịu sát thương nhiều nhất của phe ta.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/db13288db6b90ec33f8adc2656d2019f_374854440239142155.png",
                "key": "Hàn Bệnh Quỷ Sai",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/971b05c02dd20b662457e953c3c1ce93_2665264805420749905.png",
                "title": "Hàn Bệnh Quỷ Sai"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Gán ấn Nguyên Tố Băng, có thể tạo phản ứng nguyên tố:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đóng Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hỏa sẽ giải trừ sớm, nhưng sát thương +2)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/4bcc4b82a9d7ee22770f60afa54e9919_1714508523764594238.png",
                "key": "Sát Thương Nguyên Tố Băng",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Băng"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
