                  }
                ],
                "talent_img": "",
                "title": "Mũi Nhọn Thiêu Đốt"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Bị Động</span></p><p>(Bị Động) Khi bắt đầu chiến đấu, nhân vật này nhận <span style=\"color: rgb(255, 255, 255)\">Hành Động Lén Lút</span>.</p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Hành Động Lén Lút</span></p><p><span style=\"color: rgb(255, 215, 128)\">Trạng Thái</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Nhân vật áp dụng sẽ -1 sát thương phải chịu, +1 sát thương gây ra.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/16/12108544/7b7664a897ad4ff44a0fa76b2b5d1507_3250655449410349768.png",
                "id": "talent48024",
                "key": "Bậc Thầy Ẩn Mình",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Bậc Thầy Ẩn Mình"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(204, 191, 173)\">Sát Thương Vật Lý</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Sát Thương Vật Lý sẽ không đính kèm bất kì Nguyên tố nào, cũng như không thể tham gia vào Phản ứng Nguyên tố</span></p><p></p><p><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hoả</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Hoả, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">] Quá Tải</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">Sát thương +2, mục tiêu bị buộc phải đổi thành nhân vật kế tiếp</span></p><p>[<span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span>: Sát Thương +1, tạo thành [<span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span>] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Có thể dùng 1 lần, tối đa cộng dồn 2 lần)</p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/16/12108544/07bae546ac7c69ef6402170b283840c5_8028356342984394384.png",
