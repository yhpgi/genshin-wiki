              {
                "item_values": [],
                "key": "Giáo Trình",
                "string_values": [
                  "Ma vật Nguyên Tố mạnh mẽ sử dụng lớp vỏ hình vuông chắc chắn để bảo vệ bản thân và chiến đấu, nắm bắt thời cơ khi <span style=\"color:#FFE14BFF\">hạt nhân Nguyên Tố</span> lộ ra bên ngoài, mới có thể tấn công một cách hiệu quả. Lợi dụng <span style=\"color:#FFE14BFF\">vật thể Nguyên Tố Nham </span>đặc thù để chiến đấu, và hồi phục HP khi nguy cấp. Nếu như không nhanh chóng phá hủy những vật thể này thì khó có thể đánh bại nó..."
                ]
              }
