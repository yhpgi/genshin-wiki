          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/11/44749939/47817b4476bcd8b44c86c87debf042f2_1730983136372986322.png",
                "id": "talent20992",
                "key": "Kẹp Càng Nghiền Nát",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Kẹp Càng Nghiền Nát"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">. Nếu nhân vật này có áp dụng ít nhất 7 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Mai Cua Giáp Nặng</span></strong><span style=\"color: rgb(236, 228, 217)\">, sẽ +1 sát thương này.</span><br><span style=\"color: rgb(236, 228, 217)\">Sau đó, nhân vật này áp dụng 2 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Mai Cua Giáp Nặng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 228, 217)\">Mai Cua Giáp Nặng</span></strong><br><span style=\"color: #FFD780\">Khiên</span><br><span style=\"color: rgb(236, 228, 217)\">Mỗi tầng cung cấp 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\">, bảo vệ nhân vật áp dụng.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/11/44749939/0ae22e52af3cd0693c58a452cef1d284_7444394547220128281.png",
                "id": "talent27671",
                "key": "Lửa Mạnh Bùng Cháy",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Lửa Mạnh Bùng Cháy"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Nhân vật này </span><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><span style=\"color: rgb(236, 228, 217)\">: </span><strong><span style=\"color: rgb(255, 255, 255)\">Vụ Nổ Nóng Rực</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/11/44749939/a9c20ff9f809e176b5b49857c4ad1153_216459765210755560.png",
                "id": "talent9911",
                "key": "Chiến Tuyến Bùng Nổ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Chiến Tuyến Bùng Nổ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Cần chuẩn bị 1 lượt hành động)</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">, gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho tất cả nhân vật dự bị phe địch. Mỗi 2 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Mai Cua Giáp Nặng</span></strong><span style=\"color: rgb(236, 228, 217)\"> nhân vật này áp dụng, sẽ +1 </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\"> gây ra bởi kỹ năng này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/11/44749939/a9c20ff9f809e176b5b49857c4ad1153_9073565000835789597.png",
                "id": "talent34335",
                "key": "Vụ Nổ Nóng Rực",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Vụ Nổ Nóng Rực"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Bị động) </span><strong><span style=\"color: rgb(255, 255, 255)\">Khi bắt đầu chiến đấu:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Ban đầu áp dụng 5 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Mai Cua Giáp Nặng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi phe ta chấp hành hành động bất kỳ:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nếu trong trận phe ta tồn tại trạng thái </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\"> hoặc trạng thái </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\"> xuất chiến ngoài Mai Cua Giáp Nặng, thì sẽ giải trừ toàn bộ, mỗi 1 trạng thái bị giải trừ sẽ khiến nhân vật áp dụng 2 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Mai Cua Giáp Nặng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 228, 217)\">Mai Cua Giáp Nặng</span></strong><br><span style=\"color: rgb(255, 215, 128)\">Khiên</span><br><span style=\"color: rgb(236, 228, 217)\">Mỗi tầng cung cấp 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\">, bảo vệ nhân vật áp dụng.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/11/44749939/926ad2c8e8892093800da58cea01f2ad_1038456709675613507.png",
                "id": "talent14552",
                "key": "Giáp Trụ Đế Vương",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Giáp Trụ Đế Vương"
              },
              {
                "attributes": [],
                "desc": "<p>Gán ấn Nguyên Tố Hỏa, có thể tạo phản ứng nguyên tố:<br>[<span style=\"color: rgb(255, 153, 153)\">Hoả </span>+ <span style=\"color: rgb(153, 255, 255)\">Băng</span>]: <strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong>: Sát Thương +2<br>[<span style=\"color: rgb(255, 153, 153)\">Hoả </span>+ <span style=\"color: rgb(128, 192, 255)\">Thuỷ</span>]: <strong><span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span></strong>: Sát Thương +2<br>[<span style=\"color: rgb(255, 153, 153)\">Hoả </span>+ <span style=\"color: rgb(255, 172, 255)\">Lôi</span>]: <strong><span style=\"color: rgb(255, 255, 255)\">Quá Tải</span></strong>: Sát Thương +2, mục tiêu bị buộc phải đổi thành nhân vật kế tiếp<br>[<span style=\"color: rgb(255, 153, 153)\">Hoả </span>+ <span style=\"color: rgb(153, 255, 136)\">Thảo</span>]: <strong><span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span></strong>: Sát Thương +1, tạo thành [<strong><span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span></strong>] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Có thể dùng 1 lần, tối đa cộng dồn 2 lần)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/44749939/d714b3b669cc08d1d8e34464fd7a3630_7963068619640206675.png",
                "id": "talent85323",
                "key": "Sát Thương Nguyên Tố Hoả",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Hoả"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Có một số kỹ năng không thể sử dụng trực tiếp, mà cần một số lượt hành động nhất định để tiến hành </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Khi đến lượt của một bài thủ hành động, nếu như \"nhân vật xuất chiến\" của bài thủ này đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng, thì sẽ bỏ qua lượt hành động của bài thủ; Nếu như đã </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> xong, nhân vật sẽ trực tiếp dùng kỹ năng đó vào lúc này. (Loại kỹ năng cần </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> này không thể kích hoạt các hiệu quả \"Sau khi sử dụng\" hay \"Sau khi nhân vật kích hoạt phản ứng nguyên tố\".)</span><br><span style=\"color: rgb(236, 228, 217)\">Chỉ có \"nhân vật xuất chiến\" mới có thể </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng; Nếu như \"nhân vật xuất chiến\" đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng mà bị cho rời trận, thì quá trình </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> của kỹ năng sẽ bị gián đoạn.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát Thương Xuyên Thấu sẽ không được nhận sát thương tăng thêm, nhưng sẽ bỏ qua hiệu quả khiên và miễn dịch sát thương.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_8794686538924968457.png",
                "id": "talent19850",
                "key": "Giải Thích Quy Tắc",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Giải Thích Quy Tắc"
              }
            ]
          }
        }
      ]
