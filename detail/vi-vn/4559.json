                  }
                ],
                "talent_img": "",
                "title": "Chẩn Đoán Phổ Quát"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span><br><span style=\"color: rgb(236, 228, 217)\">Sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Mạch Nhiếp Tuyên Minh</span></strong><span style=\"color: rgb(236, 228, 217)\"> và </span><strong><span style=\"color: rgb(255, 255, 255)\">Vô Khích Khí Thuẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Mạch Nhiếp Tuyên Minh</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi bắt đầu Giai Đoạn Hành Động:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Vô Khích Khí Thuẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Vô Khích Khí Thuẫn</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Khiên</span><br><span style=\"color: rgb(236, 228, 217)\">Cung cấp </span><strong><span style=\"color: rgb(255, 255, 255)\">1 điểm Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\">, bảo vệ nhân vật xuất chiến phe ta.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi hiệu quả này bị xóa hoặc được sinh ra trùng lặp:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">, chữa trị 1 điểm cho nhân vật xuất chiến phe ta.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/44749939/ed10b8e3def17c518055b3421bfcb94a_7427877549355228122.png",
                "id": "talent39322",
                "key": "Trị Liệu Toàn Thư",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
