                "string_values": [
                  "<p>Cơ Quan Tự Động</p>"
                ]
              },
              {
                "item_values": [],
                "key": "Giáo Trình",
                "string_values": [
                  "<p><span style=\"color: rgb(219, 222, 225)\">Thiết bị cỡ lớn đã bị mất kiểm soát của Viện Nghiên Cứu Khoa Học Công Trình Động Năng Fontaine. Trong chiến đấu sẽ dùng thuộc tính năng lượng Ousia để triển khai Vùng Giảm Trọng Lực chiến đấu. Trong vùng này, khả năng nhảy cao của nhân vật sẽ tăng vượt bậc. Trong trạng thái này, sau khi hạt nhân bị tấn công </span><span style=\"color: #FFD780\">thuộc tính Pneuma</span><span style=\"color: rgb(219, 222, 225)\"> hủy diệt, sẽ đóng Vùng Giảm Trọng Lực lại.</span></p>"
                ]
              }
            ]
          }
        }
