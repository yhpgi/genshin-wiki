                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Kêu Gọi Sương Mù"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 5 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này bị </span><strong><span style=\"color: rgb(153, 255, 255)\">Gán ấn Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, tạo ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Lá Chắn Cicin</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><br><span style=\"color: rgb(236, 228, 217)\">Lá Chắn Cicin</span><br><span style=\"color: #FFD780\">Khiên</span><br><span style=\"color: rgb(236, 228, 217)\">Cung cấp cho nhân vật xuất chiến phe ta </span><strong><span style=\"color: rgb(255, 255, 255)\">1 điểm Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi được tạo ra:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nếu phe ta có </span><strong><span style=\"color: rgb(255, 255, 255)\">Cicin Băng</span></strong><span style=\"color: rgb(236, 228, 217)\"> trong trận, sẽ cung cấp thêm </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\"> từ </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> của nó. (Tối đa cung cấp thêm 3 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\">)</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/30/44749939/62d79fe04d2cd6e3bbc2aa144c177b8c_7625134621250616231.png",
                "key": "Cành Băng Hoa Trắng",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Cành Băng Hoa Trắng"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Cicin Băng</span><br><span style=\"color: #FFD780\">Vật Triệu Hồi</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng dồn, tối đa cộng dồn 3 lần)</span><br><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi Fatui - Thuật Sĩ Cicin Băng Tấn Công Thường:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Thẻ bài này +1 </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật phe ta chịu sát thương từ phản ứng nguyên tố:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Thẻ bài này -1 </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/30/44749939/db13288db6b90ec33f8adc2656d2019f_9122626827355979460.png",
                "key": "Cicin Băng",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/30/44749939/1467dd7dd3fec80047e77cc996621508_475472224706712977.png",
                "title": "Cicin Băng"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Gán ấn Nguyên Tố Băng, có thể tạo phản ứng nguyên tố:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đóng Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hỏa sẽ giải trừ sớm, nhưng sát thương +2)</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span><br></p><p><strong><span style=\"color: rgb(153, 255, 255)\">Gán ấn Nguyên Tố Băng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Khi gán ấn Nguyên Tố Băng mà không gây sát thương, phản ứng nguyên tố sẽ bỏ qua khả năng gây sát thương:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong><span style=\"color: rgb(236, 228, 217)\">: Không có hiệu quả</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">: Không có hiệu quả</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đóng Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">: Khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hỏa sẽ giải trừ sớm, nhưng sát thương +2)</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/31/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_8219166135040227278.png",
