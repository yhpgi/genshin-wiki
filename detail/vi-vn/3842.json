                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Cicin Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/30/44749939/a43f22fdabc427ff3a56839fd05297bb_2861764088412245320.png",
