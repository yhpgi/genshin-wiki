          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Các Mối Quan Hệ",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4811,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/11/237301566/93cd2bc9b90c8b87b1f8cbdbe95b4b9d_7086984801760748.png",
                      "menu_id": 22,
                      "name": "Khaenri'ah",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Rhinedottir sống ở Khaenri'ah trong thời kỳ Vương Triều Nhật Thực. Cô là một trong sáu người đáng lẽ phải ngăn chặn thảm họa và ngăn chặn Irmin  tiếp tục làm rung chuyển thế giới. Cô, cùng với bốn người trong số họ, không thể cưỡng lại lời kêu gọi của Vực Sâu và chia sẻ với nhau một sức mạnh có thể hủy diệt thế giới. Cô trở thành Tội Đồ, một thực thể siêu việt có sức mạnh làm rung chuyển thế giới. Những sáng tạo của cô đã xâm lược Teyvat trong Thảm Hoạ 500 năm trước.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5748,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/07/237301566/9637c661f54d176aea6cc2ef4dca351c_2778320722856346548.png",
                      "menu_id": 23,
