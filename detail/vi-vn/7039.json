                  "content": [
                    {
                      "text": "Vị Đầu Tiên đã tạo ra Ronova.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
