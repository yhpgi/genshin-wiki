                      "ep_id": 7086,
                      "icon_url": "",
                      "name": "Shades",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Ronova là một trong bốn Cái Bóng.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7073,
                      "icon_url": "",
                      "menu_id": 10,
                      "name": "Владыка Ночи",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Dưới sự chỉ dẫn của Ronova, Dạ Thần đã tạo ra Vương Quốc Dạ Thần ở Natlan.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7074,
                      "icon_url": "",
                      "name": "Шбаланке",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Ronova đã trao sức mạnh cho Hoả Thần. Với sức mạnh ấy, luật lệ của Natlan đã được thiết lập: Bài Ca Phục Sinh và Nghi Lễ Hành Hương Về Lửa Thánh",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7299,
                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2024/12/30/2f098b1f15854fd9dafc54998795a59e_864981592196815761.png",
                      "menu_id": 2,
                      "name": "Mavuika",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Hoả Thần cuối cùng dùng sức mạnh của Thiên Lý và sức mạnh của Ronova để chiến đấu với Vực Sâu. Cái giá cho việc sử dụng sức mạnh của Ronova là \"Cái Chết\".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7417,
                      "icon_url": "",
                      "name": "Capitano",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Chấp Chính Của Cái Chết đã nguyền rủa lời nguyền bất tử lên những người dân Khaenri'an. Khi Hoả Thần sử dụng sức mạnh của Ronova, cái giá phải trả chính là cái chết, The Captain đã hi sinh bản thân mình thay cho Mavuika. Anh ấy muốn dùng chính luật lệ của Ronova để đối đấu với chính cô ta. Để duy trì lời nguyền về cái chết, Chấp Chính của Cái Chết đã từ bỏ yêu cầu của cô ta về cái \"chết.\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
