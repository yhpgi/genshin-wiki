              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Xúc Xắc Tinh Tế</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Xúc Xắc Tinh Tế</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật phe ta tấn công thường:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 2 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/18/44749939/82a43911270e2e8fea01fef061c9f03f_2516494853471739347.png",
                "id": "talent15457",
                "key": "Xúc Xắc Toan Tính",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
