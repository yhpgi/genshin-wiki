    {
      "id": "41",
      "name": "Nội Dung",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Bài Ca Ánh Sáng",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nagarjuna à,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Được linh quang của muôn loài giúp đỡ, tôi đã che chở mặt đất khỏi tai họa muôn kiếp.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Khi bùn bẩn từ đáy vực làm vấy bẩn vương quốc nguyên sơ,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ánh sáng linh hồn của vì vua trí tuệ đã hòa vào muôn loài.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tôi lội ngược dòng sông khổ đau, uống nước cam lộ qua cơn khát.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Mở đường cho những linh hồn lương thiện, để ánh sáng trí tuệ tỏa sáng khắp tứ phương.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nagarjuna à,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Được linh quang của muôn loài giúp đỡ, tôi đã nuôi dưỡng những linh hồn lương thiện của biển hoa.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nhìn kìa, tinh hồn được linh quang chỉ ra, hậu duệ của thần cỏ cây.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nhìn kìa, chiến binh sống sót sau trăm trận, kẻ thù của chúng ma Dev.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Đám mây đen trên trời cũng không thể ăn mòn thân hình của chúng.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nagarjuna à,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Được linh quang của muôn loài giúp đỡ, tôi đã siêu độ cho những kẻ chết trong rác rưởi.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Rửa sạch tội nghiệp của người vô tội, vãng sinh trong một vùng đất không đau khổ.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Trong địa mạch của mặt đất, chất chứa tất thảy các loại nghiệp chủng.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Sự thăng trầm tạm thời của thế gian chẳng qua chỉ là ảo ảnh của hạt giống hiện tại.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nagarjuna à,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Được linh quang của muôn loài giúp đỡ, tôi đã thanh tẩy vực thẳm của trời cao.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Bùn lầy tràn ra từ đáy vực thẳm cuối cùng cũng rút đi,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Di sản của Dahri cũng khuất phục trước chính pháp.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Ngàn câu hát đồng thanh, mưa dầm sẽ ngừng rơi.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nagarjuna à,",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Nếu sóng ngầm xuất hiện trở lại, vực thẳm đen tối sẽ lại quay về.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Cất vang bài thơ ca tụng này, truy điệu cho những linh quang lang thang kia thôi.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Linh quang vĩnh hằng sẽ dẫn lối cho chúng ta tiến bước.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
  ],
