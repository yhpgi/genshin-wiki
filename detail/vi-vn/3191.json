                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span></p><p>Gây 1 điểm <span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/27215281/1ce09211f025bf5470682189e0837732_5354413411129931592.png",
                "id": "talent29486",
                "key": "Ngàn Vàng Lấp Lánh",
