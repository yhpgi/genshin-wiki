                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Ngàn Vàng Lấp Lánh"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span></p><p>Gây 2 điểm <span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span>, tạo ra <span style=\"color: rgb(255, 255, 255)\">Vách Toàn Cơ</span>.</p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Vách Toàn Cơ</span></p><p><span style=\"color: rgb(255, 215, 128)\">Hiệu Ứng Xuất Chiến</span></p><p><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật xuất chiến phe ta chọi sát thương tối thiểu là 2:</span> Giảm bớt 1 điểm sát thương phải chịu.</p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/27215281/2a1c2baa706dfc49f86033be36f170e9_6520782818947989402.png",
                "id": "talent5124",
                "key": "Vách Toàn Cơ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Vách Toàn Cơ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nộ</span></p><p>Gây 6 điểm <span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span>; Nếu <span style=\"color: rgb(255, 255, 255)\">Vách Toàn Cơ</span> trong trận sẽ khiến sát thương này +2.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/27215281/55dfd3944aa4091c2684c17412739558_3726218429609678442.png",
                "id": "talent83594",
                "key": "Thiên Quyền Băng Ngọc",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Thiên Quyền Băng Ngọc"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></p><p>Sản sinh phản ứng nguyên tố với các ấn nguyên tố sau:</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Băng)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Thủy)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Hỏa)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Lôi)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p></p><p><span style=\"color: #ECE5D8\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/27215281/07bae546ac7c69ef6402170b283840c5_6858866418592361876.png",
