      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 2 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/31/44749939/062c781664704b008a65aef338111d6d_494615257070967184.png",
                "id": "talent36205",
                "key": "Lời Thề Marechaussee",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Lời Thề Marechaussee"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Áp dụng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Gác Đêm</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">cho bản thân, xóa bỏ toàn bộ</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Khế Ước Sinh Mệnh</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">của bản thân. Sau đó, gây</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">và tự chữa trị dựa trên số tầng đã xóa bỏ. (Sát thương và chữa trị tối đa 4 điểm)</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Gác Đêm</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">Khi nhân vật nhận chữa trị từ nguồn khác ngoài</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Thanh Trừng Bóng Tối</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, sẽ chuyển thành áp dụng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Khế Ước Sinh Mệnh</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">với lượng tương đương.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng dùng Tấn Công Thường:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">gây ra chuyển thành</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, và áp dụng 2 tầng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Khế Ước Sinh Mệnh</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">cho bản thân.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: <span style=\"color: rgba(255, 255, 255, 0.45)\">1</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Khế Ước Sinh Mệnh</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng nhận chữa trị:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Mỗi 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">hiệu quả này sở hữu, sẽ tiêu hao 1 lần để triệt tiêu 1 điểm chữa trị nhận được. (Không thể triệt tiêu điểm chữa trị kích hoạt từ hồi sinh và phân phối HP)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: <span style=\"color: rgba(255, 255, 255, 0.45)\">1 (Có thể cộng dồn không giới hạn).</span><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/31/44749939/70bb86e334df44b81fb951c1078035de_3683315394511834671.png",
                "id": "talent55164",
                "key": "Thanh Trừng Bóng Tối",
                "materials": [],
                "points": [
                  {
                    "point_count": 2,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Thanh Trừng Bóng Tối"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Gây 3 điểm</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\">, áp dụng 4 tầng</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Khế Ước Sinh Mệnh</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">cho bản thân.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Khế Ước Sinh Mệnh</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng nhận chữa trị:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Mỗi 1</span><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">hiệu quả này sở hữu, sẽ tiêu hao 1 lần để triệt tiêu 1 điểm chữa trị nhận được. (Không thể triệt tiêu điểm chữa trị kích hoạt từ hồi sinh và phân phối HP)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: <span style=\"color: rgba(255, 255, 255, 0.45)\">1 (Có thể cộng dồn không giới hạn).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/31/44749939/93972fd46d424779d00a8265f9c3cf84_8182597620022785329.png",
                "id": "talent1131",
                "key": "Tia Sáng Cuối Cùng",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Tia Sáng Cuối Cùng"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></p><p>Gán ấn Nguyên Tố Lôi, có thể tạo phản ứng nguyên tố:</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Quá Tải</span>: Sát thương +2, cưỡng chế khiến mục tiêu đổi thành nhân vật tiếp theo.</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sinh Trưởng</span>: Sát thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Khu Vực Xúc Tác</span>] khiến sát thương Thảo/Lôi 3 lần sau +1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/31/44749939/11ea6117480145a30b7893f1e8bd7115_9217516882668478538.png",
                "id": "talent25693",
                "key": "Sát Thương Nguyên Tố Lôi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Sát Thương Nguyên Tố Lôi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">• </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">• </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Mỗi Giai Đoạn Kết Thúc, </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> -1.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">• </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/31/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_7084233487842021445.png",
