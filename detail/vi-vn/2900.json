                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Các thế lực loài người khác</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Giáo Trình",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Nữ thợ săn của đoàn thể lính đánh thuê riêng lẻ đến từ sa mạc. Sau khi chịu một lượng sát thương nhất định, sẽ giải phóng ác linh diều hâu phong ấn trong cơ thể để cùng đối phó kẻ địch, đồng thời vào </span><span style=\"color: #FFE14B\">trạng thái Ma Hóa</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Sau khi </span><span style=\"color: #FFE14B\">đánh bại ác linh diều hâu</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, cô ta sẽ rơi vào trạng thái suy yếu trong một thời gian nhất định.</span></p>"
                ]
              }
