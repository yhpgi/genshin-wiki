          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng.</span></strong></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/16/44749939/6abee9810b73dd1c04987cd0d893fc25_7683215469392013508.png",
                "id": "talent83246",
                "key": "Nhũ Băng Xạ Kích",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Nhũ Băng Xạ Kích"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Nhũ Băng Bùng Nổ</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Nhũ Băng Bùng Nổ</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật tiến hành Tấn Công Thường:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho tất cả nhân vật dự bị phe địch.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/16/44749939/b46f9d1ced9b19fc2f6cb25aa18fc898_3226487313546005164.png",
                "id": "talent34114",
                "key": "Vòng Băng Nhảy Múa",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Vòng Băng Nhảy Múa"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">, gây 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho tất cả nhân vật dự bị phe địch, triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Trụ Băng Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/16/44749939/9589beffeb1ed5baf7123d4b51377988_2039426041762772387.png",
                "id": "talent46126",
                "key": "Trụ Băng Trút Xuống",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Trụ Băng Trút Xuống"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Vật Triệu Hồi</span></p><p><span style=\"color: rgb(236, 228, 217)\">Trụ Băng Xuyên Thấu</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho </span><strong><span style=\"color: rgb(255, 255, 255)\">Nhân Vật Gần Với Nhân Vật Xuất Chiến Phe Ta Nhất</span></strong><span style=\"color: rgb(236, 228, 217)\"> của phe địch.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/16/44749939/db13288db6b90ec33f8adc2656d2019f_3356846851043177946.png",
                "id": "talent19624",
                "key": "Trụ Băng Xuyên Thấu",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/16/44749939/9a3a650b50940ebaf9e842bccc80f213_3634640342628202560.png",
                "title": "Trụ Băng Xuyên Thấu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span><br><span style=\"color: rgb(236, 228, 217)\">(Bị Động) Khi bắt đầu chiến đấu, áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Băng Tinh</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Hạt Nhân Băng Tinh</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng bị đánh bại:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Xóa hiệu quả này, khiến nhân vật </span><strong><span style=\"color: rgb(255, 255, 255)\">Không Bị Đánh Bại</span></strong><span style=\"color: rgb(236, 228, 217)\">, và chữa trị cho nhân vật này đến 1 điểm HP.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/16/44749939/324d6d7db2e94c14b71b8913d679d174_740792946926735074.png",
                "id": "talent55458",
                "key": "Hạt Nhân Băng Tinh",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Hạt Nhân Băng Tinh"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Gán ấn Nguyên Tố Băng, có thể tạo phản ứng nguyên tố:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đóng Băng</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hỏa sẽ giải trừ sớm, nhưng sát thương +2)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/16/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_656257408540404827.png",
                "id": "talent9171",
                "key": "Sát Thương Nguyên Tố Băng",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Băng"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát Thương Xuyên Thấu sẽ không được nhận sát thương tăng thêm, nhưng sẽ bỏ qua hiệu quả khiên và miễn dịch sát thương.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Nhân Vật Gần Với Nhân Vật Xuất Chiến Phe Ta Nhất</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật trong trận của đối phương ở \"gần nhất\" với nhân vật xuất chiến phe ta, chính là chỉ nhân vật phe địch có vị trí gần nhất.</span><br><span style=\"color: rgb(236, 228, 217)\">Nếu tồn tại nhiều nhân vật có vị trí gần nhất, thì nhân vật nào ở phía trước hơn sẽ được xem là \"gần nhất\".</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Không Bị Đánh Bại</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Một số hiệu quả sẽ khiến nhân vật khi HP giảm còn 0 sẽ </span><strong><span style=\"color: rgb(255, 255, 255)\">không bị đánh bại</span></strong><span style=\"color: rgb(236, 228, 217)\">, và chữa trị cho nhân vật một lượng HP nhất định.</span><br><span style=\"color: rgb(236, 228, 217)\">Lúc này, nhân vật sẽ không bị xem là từng bị </span><strong><span style=\"color: rgb(255, 255, 255)\">đánh bại</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Do vậy trạng thái và trang bị mà nhân vật áp dụng sẽ không bị hủy, năng lượng cũng không bị xóa sạch.)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/16/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_4155982366099334249.png",
                "id": "talent82263",
                "key": "Giải Thích Quy Tắc",
