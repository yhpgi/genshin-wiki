          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/24/44749939/615640468a637b86b151187e8a000a85_3408485230862820687.png",
                "key": "Móng Vuốt Kẹp Chặt",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Móng Vuốt Kẹp Chặt"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Sinh ra 1 thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Khối Năng Lượng Nhai Xương</span></strong><span style=\"color: rgb(236, 228, 217)\">, ngẫu nhiên đưa vào trong số 2 thẻ bài trên cùng của kho bài phe ta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/24/44749939/352eb10d44f4fdb27294c3c2b2383ea2_4421192684901719379.png",
                "key": "Gai Đuôi Đâm Chích",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Gai Đuôi Đâm Chích"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">, </span><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><span style=\"color: rgb(236, 228, 217)\"> tối đa 3 thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Khối Năng Lượng Nhai Xương</span></strong><span style=\"color: rgb(236, 228, 217)\"> trên tay, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Cạm Bẫy Gai Sét</span></strong><span style=\"color: rgb(236, 228, 217)\"> trên sân đối phương.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Cạm Bẫy Gai Sét</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật phe sở tại dùng kỹ năng:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 2 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến của phe sở tại.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">: Bắt đầu với số thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Khối Năng Lượng Nhai Xương</span></strong><span style=\"color: rgb(236, 228, 217)\"> đã loại bỏ khi khởi tạo. (Tối đa cộng dồn đến 3)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/24/44749939/03059fca2705a2302a5a000cf2a5e755_3271885414086299715.png",
                "key": "Gai Sét Tán Xạ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Gai Sét Tán Xạ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Bị động) Khi kết thúc hiệp, sinh ra 2 thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Khối Năng Lượng Nhai Xương</span></strong><span style=\"color: rgb(236, 228, 217)\">, ngẫu nhiên đưa vào trong số 10 thẻ bài trên cùng của kho bài phe ta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/24/44749939/1b54121571cccc9b669a2c91ea750de4_2556937859268250267.png",
                "key": "Di Cốt Bất Diệt - Lôi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Di Cốt Bất Diệt - Lôi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Ngẫu nhiên </span><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><span style=\"color: rgb(236, 228, 217)\"> 1 thẻ có chi phí Xúc Xắc Nguyên Tố vốn có cao nhất trên tay, sinh ra 1 Xúc Xắc Nguyên Tố cùng loại với nhân vật xuất chiến phe ta. Nếu nhân vật xuất chiến phe ta là Thánh Hóa Thú, thì sẽ nhận 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Năng Lượng</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Mỗi hiệp tối đa đánh ra 1 thẻ)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/24/44749939/db13288db6b90ec33f8adc2656d2019f_4665353858138508624.png",
                "key": "Khối Năng Lượng Nhai Xương",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/24/44749939/531ed6322b0a8f721e6080da7fcd72ce_1532529410816027935.png",
                "title": "Khối Năng Lượng Nhai Xương"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></p><p>Gán ấn Nguyên Tố Lôi, có thể tạo phản ứng nguyên tố:</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Quá Tải</span>: Sát thương +2, cưỡng chế khiến mục tiêu đổi thành nhân vật tiếp theo.</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sinh Trưởng</span>: Sát thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Khu Vực Xúc Tác</span>] khiến sát thương Thảo/Lôi 3 lần sau +1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/25/44749939/11ea6117480145a30b7893f1e8bd7115_4801295167681310136.png",
                "key": "Sát Thương Nguyên Tố Lôi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Lôi"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Thông qua hiệu quả của Thẻ Hành Động hoặc kỹ năng nhân vật, có thể loại bỏ Thẻ Hành Động trên tay hoặc trong kho bài.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Năng Lượng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Khi nhân vật dùng \"Kỹ Năng Nộ\" cần tiêu hao Năng Lượng.</span><br><span style=\"color: rgb(236, 228, 217)\">Sau khi nhân vật sử dụng Kỹ Năng Nguyên Tố hoặc tấn công thường sẽ nhận 1 điểm Năng Lượng.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/25/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_1064799687870254727.png",
                "key": "Giải Thích Quy Tắc",
