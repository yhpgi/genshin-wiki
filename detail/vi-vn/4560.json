              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Vật Triệu Hồi</span></p><p><span style=\"color: rgb(236, 228, 217)\">Tên Lửa Hậu Mãi</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/08/44749939/db13288db6b90ec33f8adc2656d2019f_2324251594817493180.png",
