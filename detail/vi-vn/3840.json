                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">, triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Vách Đá</span></strong><span style=\"color: rgb(236, 228, 217)\">, tạo ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên Ngọc</span></strong><br><br><span style=\"color: rgb(236, 228, 217)\">Khiên Ngọc</span><br><span style=\"color: #FFD780\">Hiệu ứng xuất chiến</span><br><span style=\"color: rgb(236, 228, 217)\">Cung cấp </span><strong><span style=\"color: rgb(255, 255, 255)\">2 điểm Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe ta.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/44749939/a61989f512943dced4d946e14554c7d8_489044979138301937.png",
