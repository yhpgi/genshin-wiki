                  }
                ],
                "talent_img": "",
                "title": "Tâm Trái Đất - Hùng Vĩ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 4 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật mục tiêu bị </span><strong><span style=\"color: rgb(255, 255, 255)\">Hóa Thạch</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Hóa Thạch</span><br><span style=\"color: rgb(255, 215, 128)\">Trạng Thái</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Nhân vật không thể sử dụng kỹ năng.</span></strong><span style=\"color: rgb(236, 228, 217)\"> (Duy trì đến kết thúc hiệp)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/44749939/959a0bae714994c668ab650cb0d7995a_2898772839255762395.png",
                "id": "talent38142",
                "key": "Thiên Tinh",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Thiên Tinh"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Vật Triệu Hồi</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/44749939/db13288db6b90ec33f8adc2656d2019f_1683330960976818686.png",
                "id": "talent64262",
                "key": "Vách Đá",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/44749939/905fb3dd007f1806491f7e9df8812d45_7403277309307919110.png",
                "title": "Vách Đá"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 229, 216)\">Sát Thương Vật Lý</span></p><p>Sát thương vật lý sẽ không gắn ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</p><p></p><p><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></p><p>Sản sinh phản ứng nguyên tố với các ấn nguyên tố sau:</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Băng)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Thủy)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Hỏa)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Lôi)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p></p><p><strong><span style=\"color: rgb(204, 191, 173)\">Khiên</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span></p><p></p><p><span style=\"color: rgb(236, 229, 216)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/29/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_6281521228424435134.png",
