          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/09/44749939/df35e6d9f76e2da17f6640d03a6309f8_7592631234938907719.png",
                "imgDesc": "<p>﻿  Sau khi tương tác với \"Temari\" bên cạnh Tiểu Đệ Kujirai là có thể chơi trò chơi này. Trong cách chơi của Trò Chơi Temari sẽ chia làm hai bên là \"Người Bảo Vệ Temari\" và \"Kẻ Trộm Temari\".</p>",
                "key": "Trang 1/3"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/09/44749939/08b2cfb511deb0cd1a99a1f7f6477dcf_1191678706943135198.png",
                "imgDesc": "<p>﻿  Người làm chủ tiến độ trò chơi là \"Người Bảo Vệ Temari\" và cần phải đưa Temari vào nơi bản thân cho là an toàn nhất trong khoảng thời gian nhất định.</p>",
                "key": "Trang 2/3"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/09/44749939/84a09de15c090d1ad157f196705e1eb0_7279044111173640022.png",
                "imgDesc": "<p>﻿  Còn người đến từ thế giới khác sẽ đóng vai trò là \"Kẻ Trộm Temari\" và yêu cầu trong thời gian nhất phải tìm ra Temari.</p>",
                "key": "Trang 3/3"
              }
            ],
