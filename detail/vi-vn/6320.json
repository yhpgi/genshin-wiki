                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Bom Chùm Oanh Tạc"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span></p><p><span style=\"color: rgb(236, 228, 217)\">(Bị động) </span><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi nhân vật phe địch nhận sát thương phản ứng Quá Tải:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Sinh ra thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Đầu Đạn Quá Tải</span></strong><span style=\"color: rgb(236, 228, 217)\"> trên tay (Mỗi hiệp 1 lần)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/76df17bba3bf1373be8cfce8dbbb7473_8298353897115526143.png",
                "id": "talent43205",
                "key": "Phối Hợp Vũ Lực Xuyên Thấu",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Phối Hợp Vũ Lực Xuyên Thấu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Thẻ Sự Kiện</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Hành Động Chiến Đấu</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây 1 điểm </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe địch.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi thẻ bài này bị Vứt Bỏ:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe địch.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/db13288db6b90ec33f8adc2656d2019f_4136006063242084298.png",
                "id": "talent43708",
                "key": "Đầu Đạn Quá Tải",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/5dca55a012526872199ffb25f0129241_7220559382965101058.png",
                "title": "Đầu Đạn Quá Tải"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Gán ấn Nguyên Tố Hỏa, có thể tạo phản ứng nguyên tố:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Quá Tải</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2, mục tiêu bị buộc phải đổi thành nhân vật kế tiếp</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, tạo thành [</span><strong><span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span></strong><span style=\"color: rgb(236, 228, 217)\">] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Có thể dùng 1 lần, tối đa cộng dồn 2 lần)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/d714b3b669cc08d1d8e34464fd7a3630_3552968996191138050.png",
                "id": "talent74063",
                "key": "Sát Thương Nguyên Tố Hoả",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Hoả"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Hành Động Chiến Đấu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Phe ta sau một lần Hành Động Chiến Đấu sẽ đến lượt phe địch.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đánh ra thẻ bài có quy tắc này sẽ tính là Hành Động Chiến Đấu, không tính Hành Động Nhanh.</span></strong></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Thông qua hiệu quả của Thẻ Hành Động hoặc kỹ năng nhân vật, có thể loại bỏ Thẻ Hành Động trên tay hoặc trong kho bài.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/02/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_9066633602009717500.png",
