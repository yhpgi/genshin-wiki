                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Hoa Mặt Trời</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/60505ed6e377954b3dedbf52c2f53488_6415689489846068137.png",
