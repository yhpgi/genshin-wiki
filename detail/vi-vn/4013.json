                  }
                ],
                "talent_img": "",
                "title": "Thuật Sáng Thế - Chế Tạo Mặt Trời"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 4 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">, nếu </span><strong><span style=\"color: rgb(255, 255, 255)\">Hoa Mặt Trời</span></strong><span style=\"color: rgb(236, 228, 217)\"> trong trận, sẽ +2 sát thương này.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/17620f858cac7f7f6b6a3e27d15e651c_2354642590179502729.png",
                "key": "Chiêu Giáng Sinh - Sóng Vỗ Đại Lục",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Chiêu Giáng Sinh - Sóng Vỗ Đại Lục"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Vật Triệu Hồi</span><br><span style=\"color: rgb(236, 228, 217)\">Hoa Mặt Trời</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 3<br><strong><span style=\"color: rgb(255, 255, 255)\">Khi vật triệu hồi này trong trận:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nhân vật phe ta tiến hành </span><strong><span style=\"color: rgb(255, 255, 255)\">Tấn Công Khi Đáp</span></strong><span style=\"color: rgb(236, 228, 217)\"> sẽ giảm tiêu hao 1 </span><strong><span style=\"color: rgb(255, 255, 255)\">Nguyên Tố Không Màu</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Mỗi hiệp 1 lần).</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/db13288db6b90ec33f8adc2656d2019f_3007739440752297357.png",
                "key": "Hoa Mặt Trời",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/02297af9d3309f3e4e40eca8911a19f6_3999604774760756095.png",
                "title": "Hoa Mặt Trời"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></p><p>Sản sinh phản ứng nguyên tố với các ấn nguyên tố sau:</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Băng)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Thủy)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Hỏa)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Lôi)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/fd37cbfdd3b1b2c16e6e83fb0aa96889_248498407335513922.png",
                "key": "Sát Thương Nguyên Tố Nham",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Nham"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 229, 216)\">Sát Thương Vật Lý</span></p><p>Sát thương vật lý sẽ không gắn ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</p><p></p><p><span style=\"color: rgb(236, 229, 216)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.<br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Tấn Công Khi Đáp</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi nhân vật được đổi thành \"Nhân Vật Xuất Chiến\", hành động chiến đấu tiếp theo trong hiệp này nếu là \"Tấn Công Thường\" sẽ được xem như \"Tấn Công Khi Đáp\".</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/07/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_8591474647846227419.png",
