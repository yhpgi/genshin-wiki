    {
      "id": "48",
      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/03/44749939/f5eb694e111c2b8f922cc66202883f06_539622069504670168.png",
                "key": "Thương Thuật Lấp Lánh - Thế Thủ",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Thương Thuật Lấp Lánh - Thế Thủ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật này nhận </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên Vạc Trời</span></strong><span style=\"color: rgb(236, 228, 217)\"> và </span><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><span style=\"color: rgb(236, 228, 217)\">: </span><strong><span style=\"color: rgb(255, 255, 255)\">Vạc Trời Công Kích</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><br><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Khiên Vạc Trời</span></strong><br><span style=\"color: #FFD780\">Khiên</span><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật này trong lần hành động sau sẽ trực tiếp dùng kỹ năng: </span><strong><span style=\"color: rgb(255, 255, 255)\">Vạc Trời Công Kích</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Trong thời gian chuẩn bị kỹ năng: Cung cấp 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\">, bảo vệ cho nhân vật áp dụng.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Vạc Trời Công Kích</span></strong><br><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">(Cần chuẩn bị 1 lượt hành động)</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/03/44749939/f29906bd4bd440e395d78eab4d982983_8446047573781438419.png",
                "key": "Nghi Thức Thần Thánh - Vạc Trời Bảo Hộ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Nghi Thức Thần Thánh - Vạc Trời Bảo Hộ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, tạo 1 </span><strong><span style=\"color: rgb(255, 255, 255)\">Lời Chúc Vương Miện Đỏ</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Lời Chúc Vương Miện Đỏ</span></p><p><span style=\"color: #FFD780\">Hiệu Ứng Xuất Chiến</span><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật phe ta </span><strong><span style=\"color: rgb(255, 255, 255)\">Tấn Công Thường</span></strong><span style=\"color: rgb(236, 228, 217)\"> sẽ +1 sát thương gây ra.</span><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật Kiếm Đơn, Trọng Kiếm hoặc Vũ Khí Cán Dài của phe ta tạo ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> sẽ biến thành </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi phe ta đổi nhân vật:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Mỗi hiệp 1 lần)</span><br><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/03/44749939/5bae1a9026fdaca7d838b12a46a67f26_241353815829125512.png",
                "key": "Nghi Thức Thần Thánh - Thủy Triều Chìa Vôi",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Nghi Thức Thần Thánh - Thủy Triều Chìa Vôi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Khi</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">gán ấn Nguyên Tố Thuỷ mà không gây sát thương, phản ứng nguyên tố sẽ bỏ qua khả năng gây sát thương:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Không có hiệu quả</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Không có hiệu quả</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/03/44749939/a126c6a302d81c07e19cf9a9f1260f90_7770913511529992212.png",
                "key": "Sát Thương Nguyên Tố Thuỷ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Thuỷ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Có một số kỹ năng không thể sử dụng trực tiếp, mà cần một số lượt hành động nhất định để tiến hành </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Khi đến lượt của một bài thủ hành động, nếu như \"nhân vật xuất chiến\" của bài thủ này đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng, thì sẽ bỏ qua lượt hành động của bài thủ; Nếu như đã </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> xong, nhân vật sẽ trực tiếp dùng kỹ năng đó vào lúc này. (Loại kỹ năng cần </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> này không thể kích hoạt hiệu quả \"sau khi sử dụng\".)</span><br><span style=\"color: rgb(236, 228, 217)\">Chỉ có \"nhân vật xuất chiến\" mới có thể </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng; Nếu như \"nhân vật xuất chiến\" đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng mà bị cho rời trận, thì quá trình </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> của kỹ năng sẽ bị gián đoạn.</span></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Mỗi Giai Đoạn Kết Thúc, </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> -1.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Hiệp Duy Trì</span></strong><span style=\"color: rgb(236, 228, 217)\"> khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/03/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_3964281052802630104.png",
                "key": "Giải Thích Quy Tắc",
                "materials": [],
