                  }
                ],
                "talent_img": "",
                "title": "Thần Biến - Ánh Chớp Tà Ác"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">, các nhân vật khác của phe ta nhận 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Năng Lượng</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/44749939/eb1b3de9921267c97b14c8faef8ed1ac_1464591770585834889.png",
                "id": "talent43895",
                "key": "Bí Kỹ - Mộng Tưởng Chân Thuyết",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Bí Kỹ - Mộng Tưởng Chân Thuyết"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Bị Động</span><br><span style=\"color: rgb(236, 228, 217)\">Khi bắt đầu chiến đấu, nhân vật này nhận </span><strong><span style=\"color: rgb(255, 255, 255)\">Ước Nguyện Chakra</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><br><span style=\"color: rgb(236, 228, 217)\">Ước Nguyện Chakra</span></p><p><span style=\"color: rgb(255, 215, 128)\">Trạng Thái</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sau khi các nhân vật khác của phe ta dùng Kỹ Năng Nộ:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Tích lũy 1 điểm Ý Lực. (Tối đa tích lũy 3 điểm)</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng dùng Bí Kỹ - Mộng Tưởng Chân Thuyết:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Tiêu hao tất cả Ý Lực, mỗi điểm Ý Lực sẽ +1 sát thương gây ra.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/44749939/7b275947adca3e80fec904f5991eb51d_5062361798097324030.png",
                "id": "talent43631",
                "key": "Ước Nguyện Chakra",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Ước Nguyện Chakra"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Con Mắt Lôi Phạt</span><br><span style=\"color: rgb(255, 215, 128)\">Vật Triệu Hồi</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 3<br><strong><span style=\"color: rgb(255, 255, 255)\">Khi vật triệu hồi này trong trận:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Sát thương do Kỹ Năng Nộ của nhân vật phe ta gây ra sẽ +1.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/44749939/db13288db6b90ec33f8adc2656d2019f_8871294351970462685.png",
                "id": "talent8145",
                "key": "Con Mắt Lôi Phạt",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/44749939/75f1d2ef52221da67ee1c52ce97af966_1826864866660307167.png",
                "title": "Con Mắt Lôi Phạt"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 229, 216)\">Sát Thương Vật Lý</span></p><p>Sát thương vật lý sẽ không gắn ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</p><p></p><p><span style=\"color: rgb(236, 229, 216)\">Sát Thương Xuyên Thấu</span></p><p>Sát Thương Xuyên Thấu sẽ không được nhận sát thương tăng thêm, nhưng sẽ bỏ qua hiệu quả khiên và miễn dịch sát thương.</p><p></p><p><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></p><p>Gán ấn Nguyên Tố Lôi, có thể tạo phản ứng nguyên tố:</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Quá Tải</span>: Sát thương +2, cưỡng chế khiến mục tiêu đổi thành nhân vật tiếp theo.</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p>[<span style=\"color: rgb(255, 172, 255)\">Lôi</span> + <span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sinh Trưởng</span>: Sát thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Khu Vực Xúc Tác</span>] khiến sát thương Thảo/Lôi 3 lần sau +1</p><p></p><p><span style=\"color: rgb(236, 229, 216)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Năng Lượng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Khi nhân vật dùng \"Kỹ Năng Nộ\" cần tiêu hao Năng Lượng.</span><br><span style=\"color: rgb(236, 228, 217)\">Sau khi nhân vật sử dụng Kỹ Năng Nguyên Tố hoặc tấn công thường sẽ nhận 1 điểm Năng Lượng.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_5486261585395313090.png",
