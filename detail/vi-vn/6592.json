    {
      "id": "48",
      "name": "Kỹ Năng",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/254054ed843e3d461bb69427e8b98742_7039290335234691571.png",
                "id": "talent10270",
                "key": "Lưỡi Liềm Vung Xoáy",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Lưỡi Liềm Vung Xoáy"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Nếu có nhân vật phe địch đang áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Đóng Băng</span></strong><span style=\"color: rgb(236, 228, 217)\"> hoặc </span><strong><span style=\"color: rgb(255, 255, 255)\">Bong Bóng Bao Vây</span></strong><span style=\"color: rgb(236, 228, 217)\">, thì nhân vật này sẽ nhận 1 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Năng Lượng</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Mỗi hiệp 1 lần)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Đóng Băng</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Không thể hành động</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Nhân vật không thể sử dụng kỹ năng.</span></strong><span style=\"color: rgb(236, 228, 217)\"> (Duy trì đến kết thúc hiệp)</span><br><span style=\"color: rgb(236, 228, 217)\">Khi nhân vật chịu </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\"> hoặc </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">, sẽ xóa hiệu quả này, khiến sát thương này +2.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Bong Bóng Bao Vây</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Không thể hành động</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Nhân vật không thể sử dụng kỹ năng.</span></strong><span style=\"color: rgb(236, 228, 217)\"> (Duy trì đến kết thúc hiệp)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/8483dd91a30a7192b58125a94ab54491_4392165428803409975.png",
                "id": "talent53378",
                "key": "Nhát Chém Sóng Trào",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Nhát Chém Sóng Trào"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra 1 thẻ </span><strong><span style=\"color: rgb(255, 255, 255)\">Slime Bong Bóng</span></strong><span style=\"color: rgb(236, 228, 217)\"> trên tay.</span><br><span style=\"color: rgb(236, 228, 217)\">(Nhân vật trang bị </span><strong><span style=\"color: rgb(255, 255, 255)\">Slime Bong Bóng</span></strong><span style=\"color: rgb(236, 228, 217)\"> có thể sử dụng Đặc Kỹ: </span><strong><span style=\"color: rgb(255, 255, 255)\">Chiến Pháp Bong Bóng</span></strong><span style=\"color: rgb(236, 228, 217)\">)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Slime Bong Bóng</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Đặc Kỹ</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đặc Kỹ</span></strong><span style=\"color: rgb(236, 228, 217)\">: Chiến Pháp Bong Bóng</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<br><span style=\"color: rgb(236, 228, 217)\">(Nhân vật tối đa trang bị 1 Đặc Kỹ)</span><br></p><p><span style=\"color: rgb(236, 228, 217)\">Chiến Pháp Bong Bóng</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Đặc Kỹ</span><br><span style=\"color: rgb(236, 228, 217)\">(Cần chuẩn bị 1 lượt hành động) Gây 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Bong Bóng Bao Vây</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe địch.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/160aadbc1bfd447eaf0689fa72cab94d_942725980317922046.png",
                "id": "talent39681",
                "key": "Tấn Công Trôi Nổi",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Tấn Công Trôi Nổi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Đặc Kỹ</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đặc Kỹ</span></strong><span style=\"color: rgb(236, 228, 217)\">: Chiến Pháp Bong Bóng</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<br><span style=\"color: rgb(236, 228, 217)\">(Nhân vật tối đa trang bị 1 Đặc Kỹ)</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Chiến Pháp Bong Bóng</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Đặc Kỹ</span><br><span style=\"color: rgb(236, 228, 217)\">(Cần chuẩn bị 1 lượt hành động) Gây 1 điểm </span><strong><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thủy</span></strong><span style=\"color: rgb(236, 228, 217)\">, áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Bong Bóng Bao Vây</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe địch.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/b129887ff77afc4936437b276dd6e645_215448749386627865.png",
                "id": "talent60948",
                "key": " Slime Bong Bóng",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/47f0e77e4279d21ba6bb0062db34d677_9197484555441216343.png",
                "title": " Slime Bong Bóng"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_7309028848135493684.png",
                "id": "talent52710",
                "key": "Sát Thương Nguyên Tố Thuỷ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Thuỷ"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Năng Lượng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Khi nhân vật dùng \"Kỹ Năng Nộ\" cần tiêu hao Năng Lượng.</span><br><span style=\"color: rgb(236, 228, 217)\">Sau khi nhân vật sử dụng Kỹ Năng Nguyên Tố hoặc tấn công thường sẽ nhận 1 điểm Năng Lượng.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Đặc Kỹ</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Khi nhân vật xuất chiến trang bị thẻ Đặc Kỹ, sẽ có thể sử dụng Đặc Kỹ tương ứng.</span><br><span style=\"color: rgb(236, 228, 217)\">Sử dụng Đặc Kỹ được xem như một Hành Động Chiến Đấu. Khi nhân vật không thể dùng kỹ năng do bị Đóng Băng, Hóa Thạch, Choáng... cũng sẽ đồng thời không thể sử dụng Đặc Kỹ.</span><br><span style=\"color: rgb(236, 228, 217)\">Khi nhân vật dùng Đặc Kỹ sẽ không được xem là sử dụng kỹ năng, không thể kích hoạt các hiệu quả \"sau khi dùng kỹ năng\" hay \"sau khi nhân vật kích hoạt phản ứng nguyên tố\"; Sát thương gây ra khi sử dụng Đặc Kỹ sẽ không được xem là sát thương gây ra bởi nhân vật.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_52914332506035291.png",
