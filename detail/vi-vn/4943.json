              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Muji-Muji Daruma</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/12/44749939/ea3a31ad66e61a0ccc0051422daae0f8_7802730581943860714.png",
                "key": "Trường Phái Yoohoo - Mujina Bối Rối",
                "materials": [],
