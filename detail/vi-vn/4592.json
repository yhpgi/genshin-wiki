    {
      "id": "10",
      "name": "Câu Chuyện",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p>Suốt đường đi là những khoảnh khắc tương phùng rồi ly biệt.</p><p>Người bạn đồng hành trung thành không hề bỏ rơi lữ khách, </p><p>E rằng chỉ là mộng tưởng của trường kiếm và viễn hành.</p><p></p><p>Trước khi già đi, Nhà Lữ Hành vĩnh hằng sẽ vượt qua nhiều thế giới.</p><p>Để lại vô số những câu chuyện cùng tương lai tươi sáng chút xíu vậy thôi. </p>",
                "title": ""
              }
            ]
          }
        }
      ]
