                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Cổ Hoa Kiếm Pháp"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span></p><p>Gây 2 điểm  <span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thuỷ</span>, nhân vật này nhận <span style=\"color: #80C0FF\">Gán ấn Nguyên Tố Thuỷ</span>, tạo 1 <span style=\"color: #FFFFFF\">Vũ Liêm Kiếm</span></p><p></p><p><span style=\"color: #FFFFFF\">Vũ Liêm Kiếm</span></p><p><span style=\"color: rgb(255, 215, 128)\">Hiệu Ứng Xuất Chiến</span></p><p><span style=\"color: #FFFFFF\">Khi nhân vật xuất chiến phe ta chịu sát thương tối thiểu là 3:</span> Giảm bớt 1 điểm sát thương phải chịu.</p><p><span style=\"color: #FFFFFF\">Số Lần Khả Dụng: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/bd2e37ed99962256b135c189ea1fdea3_5588206272421593232.png",
                "id": "talent44137",
                "key": "Hoạ Vũ Lung Sơn",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Hoạ Vũ Lung Sơn"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nộ</span></p><p>Gây 1 điểm <span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thuỷ</span>, nhân vật này nhận <span style=\"color: rgb(128, 192, 255)\">Gán ấn Nguyên Tố Thuỷ</span>, tạo ra <span style=\"color: #FFFFFF\">Kiếm Cầu Vồng</span>.</p><p></p><p><span style=\"color: #FFFFFF\">Kiếm Cầu Vồng</span></p><p><span style=\"color: rgb(255, 215, 128)\">Hiệu Ứng Xuất Chiến</span></p><p><span style=\"color: #FFFFFF\">Sau khi nhân vật phe ta tấn công thường:</span> Gây 2 điểm <span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thuỷ</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/9172b918a3681c2684b228115e32a819_949055038517308595.png",
                "id": "talent62378",
                "key": "Tài Vũ Lưu Hồng",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Tài Vũ Lưu Hồng"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(204, 191, 173)\">Sát Thương Vật Lý</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Sát Thương Vật Lý sẽ không đính kèm bất kì Nguyên tố nào, cũng như không thể tham gia vào Phản ứng Nguyên tố</span></p><p></p><p><span style=\"color: rgb(128, 192, 255)\">Sát Thương Nguyên Tố Thuỷ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Sát thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sát Thương +1, sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Thuỷ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Khi</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">gán ấn Nguyên Tố Thuỷ mà không gây sát thương, phản ứng nguyên tố sẽ bỏ qua khả năng gây sát thương:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Không có hiệu quả</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span>: Không có hiệu quả</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span> <span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p>[<span style=\"color: rgb(128, 192, 255)\">Thủy </span><span style=\"color: rgb(204, 191, 173)\">+</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Sum Suê</span>: Sinh ra [<span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Thảo</span>] khiến sát thương Hỏa/Lôi lần sau +2</p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/07bae546ac7c69ef6402170b283840c5_2395464034052828160.png",
