            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span></p><p>Gây 2 điểm <span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/14/12108544/26b9736a2d14fc4162b2448963f45695_6340973492248565801.png",
                "id": "talent28020",
                "key": "Cổ Hoa Kiếm Pháp",
                "materials": [],
                "points": [
