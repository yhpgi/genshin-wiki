      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/14/44749939/c369b96fc6417e8fc2bb607e37297ad4_4815298018884638833.png",
                "id": "talent15023",
                "key": "Tiễn Thuật Parthian",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Tiễn Thuật Parthian"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, nhân vật này áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Lốc Xoáy Hiển Hiện</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Lốc Xoáy Hiển Hiện</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng tiến hành Trọng Kích:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Giảm tiêu hao 1 </span><strong><span style=\"color: rgb(255, 255, 255)\">Nguyên Tố Không Màu</span></strong><span style=\"color: rgb(236, 228, 217)\">, </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\"> gây ra biến thành </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, đồng thời áp dụng </span><strong><span style=\"color: rgb(255, 255, 255)\">Áp Suất Sụp Đổ</span></strong><span style=\"color: rgb(236, 228, 217)\"> lên nhân vật mục tiêu.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/44749939/6f3f1e66aac8d91ecca768d4a7f48e56_3799367893287930603.png",
                "id": "talent34178",
                "key": "Phi Tưởng Phong Thiên",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Phi Tưởng Phong Thiên"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">, triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Khối Đa Diện Sáng Chói</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/44749939/bec3c6e3c0067cc3e0340d50df63f27e_2328029702285815826.png",
                "id": "talent7075",
                "key": "Lối Đi Riêng Của Gió",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Lối Đi Riêng Của Gió"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 3<br><strong><span style=\"color: rgb(255, 255, 255)\">Khi vật triệu hồi này trong trận:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span></strong><span style=\"color: rgb(236, 228, 217)\"> nhân vật phe địch phải chịu +1.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/16/44749939/db13288db6b90ec33f8adc2656d2019f_7523508143650427401.png",
                "id": "talent23121",
                "key": "Khối Đa Diện Sáng Chói",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/16/44749939/7c29f5ce38f0d332fbd3113f1b605a5c_7386422736036395570.png",
                "title": "Khối Đa Diện Sáng Chói"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Sản sinh phản ứng nguyên tố với các ấn nguyên tố sau:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(153, 255, 255)\">Băng</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Băng</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(128, 192, 255)\">Thủy</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Thủy</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(255, 153, 153)\">Hỏa</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Hỏa</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khuếch Tán (</span><span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">)</span></strong><span style=\"color: rgb(236, 228, 217)\">: Gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Lôi</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/16/44749939/c97292d96456bfe4abeca16bfce801e4_7461957208460441727.png",
                "key": "Sát Thương Nguyên Tố Phong",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Phong"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Trọng Kích</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Trước khi phe ta hành động, nếu tổng số xúc xắc là số chẵn, thì \"Tấn Công Thường\" sẽ được xem là \"Trọng Kích\".</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Áp Suất Sụp Đổ</span></strong><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Đổi nhân vật áp dụng thành Nhân Vật Xuất Chiến.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1<br><span style=\"color: rgb(236, 228, 217)\">(Một phe tối đa chỉ tồn tại 1 trạng thái này)</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Nguyên Tố Không Màu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Có thể dùng nhóm Xúc Xắc Nguyên Tố tùy ý để chi trả cho loại phí này.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/16/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_7680057997041478056.png",
