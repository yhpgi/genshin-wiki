              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span><br>Gây 1 điểm <span style=\"color: rgb(128, 255, 215)\">Sát Thương Nguyên Tố Phong</span>.</p>",
