      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/44749939/21c9c0d770664b542298dce44e554611_2126178839637220631.png",
                "key": "Viêm Vũ",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Viêm Vũ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">, ngẫu nhiên </span><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><span style=\"color: rgb(236, 228, 217)\"> 1 thẻ có chi phí Xúc Xắc Nguyên Tố vốn có cao nhất trên tay, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Tấm Khiên Nhiệt Tình</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Tấm Khiên Nhiệt Tình</span><br><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Khiên</span><br><span style=\"color: rgb(236, 228, 217)\">Cung cấp </span><strong><span style=\"color: rgb(255, 255, 255)\">2 điểm Khiên</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho nhân vật xuất chiến phe ta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/44749939/ed35c6c5df0d284bd10d2d6b9fd9d38c_6042929493181630146.png",
                "key": "Khuấy Động Nhiệt Huyết",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Khuấy Động Nhiệt Huyết"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><span style=\"color: rgb(236, 228, 217)\">, gây 2 điểm </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><span style=\"color: rgb(236, 228, 217)\"> cho tất cả nhân vật dự bị phe địch; </span><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><span style=\"color: rgb(236, 228, 217)\"> toàn bộ thẻ bài trên tay phe ta, sinh ra </span><strong><span style=\"color: rgb(255, 255, 255)\">Không Khí Rực Lửa</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Không Khí Rực Lửa</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi phe ta tuyên bố kết thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Nếu thẻ bài của phe ta không nhiều hơn 1, sẽ gây 1 điểm </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/44749939/b2a1de2cf8da38478668b508de9fb2e2_4471562317905569141.png",
                "key": "Cung Đàn Ngỗ Ngược",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Cung Đàn Ngỗ Ngược"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Gán ấn Nguyên Tố Hỏa, có thể tạo phản ứng nguyên tố:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Quá Tải</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2, mục tiêu bị buộc phải đổi thành nhân vật kế tiếp</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, tạo thành [</span><strong><span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span></strong><span style=\"color: rgb(236, 228, 217)\">] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Có thể dùng 1 lần, tối đa cộng dồn 2 lần)</span><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/44749939/d714b3b669cc08d1d8e34464fd7a3630_7993952588214308661.png",
                "key": "Sát Thương Nguyên Tố Hoả",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Sát Thương Nguyên Tố Hoả"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát thương vật lý sẽ không gán ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Khiên</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Vứt Bỏ</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Thông qua hiệu quả của Thẻ Hành Động hoặc kỹ năng nhân vật, có thể loại bỏ Thẻ Hành Động trên tay hoặc trong kho bài.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.'</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Sát Thương Xuyên Thấu</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sát Thương Xuyên Thấu sẽ không được nhận sát thương tăng thêm, nhưng sẽ bỏ qua hiệu quả khiên và miễn dịch sát thương.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/09/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_3802546632795273076.png",
