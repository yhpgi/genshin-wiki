                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Mưa Tên"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 228, 217)\">Bá Tước Thỏ</span></p><p><span style=\"color: #FFD780\">Vật Triệu Hồi</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật xuất chiến phe ta chịu sát thương:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Giảm bớt 2 điểm sát thương phải chịu.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1<span style=\"color: rgb(236, 228, 217)\">, khi dùng hết sẽ không hủy bỏ thẻ bài này.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Trong giai đoạn kết thúc, nếu Số Lần Khả Dụng đã hết:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Hủy bỏ thẻ bài này để gây 2 điểm </span><strong><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hỏa</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/44749939/db13288db6b90ec33f8adc2656d2019f_3417246551009698217.png",
                "id": "talent87401",
                "key": "Bá Tước Thỏ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/44749939/73a2f9790672a39cb2f9a87b5f09ed6b_33912145425905477.png",
                "title": "Bá Tước Thỏ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 153, 153)\">Sát Thương Nguyên Tố Hoả</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gán ấn Nguyên Tố Hoả, có thể tạo phản ứng nguyên tố:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Bốc Hơi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">] Quá Tải</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">Sát thương +2, mục tiêu bị buộc phải đổi thành nhân vật kế tiếp</span></p><p>[<span style=\"color: rgb(255, 153, 153)\">Hỏa </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(153, 255, 136)\">Thảo</span>] <span style=\"color: rgb(255, 255, 255)\">Thiêu Đốt</span>: Sát Thương +1, tạo thành [<span style=\"color: rgb(255, 255, 255)\">Lửa Thiêu Đốt</span>] gây 1 điểm Sát Thương Hỏa khi kết thúc hiệp (Có thể dùng 1 lần, tối đa cộng dồn 2 lần)</p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p><p></p><p><span style=\"color: rgb(236, 229, 216)\">Sát Thương Vật Lý</span></p><p>Sát thương vật lý sẽ không gắn ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_3517968075073395868.png",
