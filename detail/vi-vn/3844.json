          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Tấn Công Thường</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/01/44749939/f1bbadd2e423a5ed66cad57727277d2c_4546193731986521785.png",
                "key": "Lôi Tinh Chiếu Rọi",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Lôi Tinh Chiếu Rọi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">, sau đó lần lượt </span><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><span style=\"color: rgb(236, 228, 217)\">: </span><strong><span style=\"color: rgb(255, 255, 255)\">Tam Liên Kích Oẳn Tù Tì - Kéo</span></strong><span style=\"color: rgb(236, 228, 217)\"> và </span><strong><span style=\"color: rgb(255, 255, 255)\">Tam Liên Kích Oẳn Tù Tì - Bao</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><br><span style=\"color: rgb(236, 228, 217)\">Tam Liên Kích Oẳn Tù Tì - Kéo</span><br><span style=\"color: #FFD780\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">, sau đó </span><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><span style=\"color: rgb(236, 228, 217)\">: </span><strong><span style=\"color: rgb(255, 255, 255)\">Tam Liên Kích Oẳn Tù Tì - Bao</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Tam Liên Kích Oẳn Tù Tì - Bao</span><br><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/01/44749939/0e809f0cd877c453ef4eb86e7d1b8cbf_5176025635605855298.png",
                "key": "Tam Liên Kích Oẳn Tù Tì",
                "materials": [],
                "points": [
                  {
                    "point_count": 5,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Tam Liên Kích Oẳn Tù Tì"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span><br><span style=\"color: rgb(236, 228, 217)\">Gây 2 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">, triệu hồi </span><strong><span style=\"color: rgb(255, 255, 255)\">Lôi Tỏa Trấn Vực</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/01/44749939/4baa599d0dc30449e310756e218280e2_9046581788267599190.png",
                "key": "Tích Lịch Trấn Tỏa",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Tích Lịch Trấn Tỏa"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Vật Triệu Hồi</span></p><p><span style=\"color: rgb(236, 228, 217)\">Lôi Tỏa Trấn Vực</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Giai Đoạn Kết Thúc:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Gây 1 điểm </span><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<br><strong><span style=\"color: rgb(255, 255, 255)\">Khi vật triệu hồi này trong trận:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Phe địch khi thực hiện hành động Đổi Nhân Vật, sẽ +1 Xúc Xắc Nguyên Tố cần tiêu hao. (Mỗi hiệp 1 lần)</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/01/44749939/db13288db6b90ec33f8adc2656d2019f_351370809302322252.png",
                "key": "Lôi Tỏa Trấn Vực",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/01/44749939/6f0d7b0b3f0cda9d42d38485a7202bcc_9066180692878136146.png",
                "title": "Lôi Tỏa Trấn Vực"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Kỹ Năng Bị Động</span><br><span style=\"color: rgb(236, 228, 217)\">(Bị Động) Khi bắt đầu chiến đấu, nhân vật này nhận </span><strong><span style=\"color: rgb(255, 255, 255)\">Hạt Nhân Lôi Tinh</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Hạt Nhân Lôi Tinh</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi nhân vật áp dụng bị đánh bại:</span></strong><span style=\"color: rgb(236, 228, 217)\"> Xóa hiệu quả này, khiến nhân vật </span><strong><span style=\"color: rgb(255, 255, 255)\">không bị đánh bại</span></strong><span style=\"color: rgb(236, 228, 217)\">, và chữa trị cho nhân vật này đến 1 điểm HP.</span><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/01/44749939/e810a8c5cbf997dc227fbf2bafa2512b_475938921703997917.png",
                "key": "Hạt Nhân Lôi Tính",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Hạt Nhân Lôi Tính"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 172, 255)\">Sát Thương Nguyên Tố Lôi</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Gán ấn Nguyên Tố Lôi，có thể tạo phản ứng nguyên tố:</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Quá Tải</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +2, cưỡng chế khiến mục tiêu đổi thành nhân vật tiếp theo</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Siêu Dẫn</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Điện Cảm</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Sinh Trưởng</span></strong><span style=\"color: rgb(236, 228, 217)\">: Sát Thương +1, sinh ra [</span><strong><span style=\"color: rgb(255, 255, 255)\">Khu Vực Xúc Tác</span></strong><span style=\"color: rgb(236, 228, 217)\">] khiến sát thương Thảo/Lôi 2 lần sau +1</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Chuẩn Bị Kỹ Năng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Có một số kỹ năng không thể sử dụng trực tiếp, mà cần một số lượt hành động nhất định để tiến hành </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span><br><span style=\"color: rgb(236, 228, 217)\">Khi đến lượt của một bài thủ hành động, nếu như \"nhân vật xuất chiến\" của bài thủ này đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng, thì sẽ bỏ qua lượt hành động của bài thủ; Nếu như đã </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> xong, nhân vật sẽ trực tiếp dùng kỹ năng đó vào lúc này. (Loại kỹ năng cần </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> này không thể kích hoạt hiệu quả \"sau khi sử dụng\".)</span><br><span style=\"color: rgb(236, 228, 217)\">Chỉ có \"nhân vật xuất chiến\" mới có thể </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng; Nếu như \"nhân vật xuất chiến\" đang </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> kỹ năng mà bị cho rời trận, thì quá trình </span><strong><span style=\"color: rgb(255, 255, 255)\">chuẩn bị</span></strong><span style=\"color: rgb(236, 228, 217)\"> của kỹ năng sẽ bị gián đoạn.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\">;</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</span><br></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Không bị đánh bại</span></strong><br><span style=\"color: rgb(236, 228, 217)\">Một số hiệu quả sẽ khiến nhân vật khi HP giảm còn 0 sẽ </span><strong><span style=\"color: rgb(255, 255, 255)\">không bị đánh bại</span></strong><span style=\"color: rgb(236, 228, 217)\">, và chữa trị cho nhân vật một lượng HP nhất định.</span><br><span style=\"color: rgb(236, 228, 217)\">Lúc này, nhân vật sẽ không bị xem là từng bị </span><strong><span style=\"color: rgb(255, 255, 255)\">đánh bại</span></strong><span style=\"color: rgb(236, 228, 217)\">. (Do vậy trạng thái và trang bị mà nhân vật áp dụng sẽ không bị hủy, năng lượng cũng không bị xóa sạch.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/01/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_4789992634054172103.png",
                "key": "Giải Thích Quy Tắc",
                "materials": [],
