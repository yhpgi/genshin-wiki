                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Đột Kích Băng Giá"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gây 1 điểm </span><span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, tạo 1</span> <span style=\"color: rgb(255, 255, 255)\">Nhũ Băng Lạnh Giá</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Nhũ Băng Lạnh Giá</span></p><p><span style=\"color: rgb(255, 255, 255)\">Sau khi phe ta đổi nhân vật</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Gây 2</span> <span style=\"color: rgb(153, 255, 255)\">Sát Thương Nguyên Tố Băng</span></p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/10/148664880/8c97595e1862a7f3d9d0b707c3143148_3505098960093569212.png",
                "id": "talent9925",
                "key": "Vũ Điệu Giá Rét",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Vũ Điệu Giá Rét"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(204, 191, 173)\">Sát Thương Vật Lý</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Sát Thương Vật Lý sẽ không đính kèm bất kì Nguyên tố nào, cũng như không thể tham gia vào Phản ứng Nguyên tố</span></p><p></p><p><span style=\"color: #99FFFF\">Sát Thương Nguyên Tố Băng</span></p><p>Gán ấn Nguyên tố Băng, có thể tạo phản ứng nguyên tố:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Băng</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Tan Chảy</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Băng</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span><span style=\"color: rgb(255, 255, 255)\">] Siêu Dẫn</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1 gây cho tất cả kẻ địch ngoài mục tiêu 1 điểm Sát Thương Xuyên Thấu</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Băng</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span><span style=\"color: rgb(255, 255, 255)\">] Đóng Băng</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Sát thương +1, khiến mục tiêu hiệp đó không thể hành động. (Khi chịu sát thương vật lý hoặc nguyên tố Hoả sẽ giải trừ sớm, nhưng sát thương +2)</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/10/148664880/07bae546ac7c69ef6402170b283840c5_7403934491098990768.png",
