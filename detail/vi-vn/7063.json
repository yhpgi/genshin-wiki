                "title": "Diệp Luân Càn Quét"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nguyên Tố</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 3 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">, sinh ra 1 tầng </span><strong><span style=\"color: rgb(255, 255, 255)\">Chúc Phúc Linh Xà</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p><p></p><p><span style=\"color: rgb(236, 228, 217)\">Chúc Phúc Linh Xà</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Khi phe ta dùng Đặc Kỹ của Ách Linh - Thảo Linh Xà:</span></strong><span style=\"color: rgb(236, 228, 217)\"> </span><strong><span style=\"color: rgb(255, 255, 255)\">Đặc Kỹ</span></strong><span style=\"color: rgb(236, 228, 217)\"> này +1 sát thương gây ra và không tiêu hao </span><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong><span style=\"color: rgb(236, 228, 217)\"> của Ách Linh - Thảo Linh Xà.</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 1<span style=\"color: rgb(236, 228, 217)\"> (Có thể cộng dồn không giới hạn)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/14/44749939/3423c1e9b5666ace686ab000fb4449b1_665758850844396982.png",
                "id": "talent38299",
                "key": "Vũ Điệu Lan Tràn",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Vũ Điệu Lan Tràn"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Kỹ Năng Nộ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 4 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">. Cả ván đấu giới hạn 1 lần, thêm 1 lá </span><strong><span style=\"color: rgb(255, 255, 255)\">Ách Linh - Thảo Linh Xà</span></strong><span style=\"color: rgb(236, 228, 217)\"> vào bộ bài trên tay.</span><br><span style=\"color: rgb(236, 228, 217)\">(Nhân vật trang bị </span><strong><span style=\"color: rgb(255, 255, 255)\">Ách Linh - Thảo Linh Xà</span></strong><span style=\"color: rgb(236, 228, 217)\"> có thể sử dụng Đặc Kỹ: </span><strong><span style=\"color: rgb(255, 255, 255)\">Dây Leo Sắc Bén</span></strong><span style=\"color: rgb(236, 228, 217)\">)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/14/44749939/c26c17cce52ff41d5b978fd4d248efea_4442336407294209963.png",
