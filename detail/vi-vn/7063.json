              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(211,188,142,var(--tw-text-opacity))\">Đặc Kỹ</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Đặc Kỹ</span></strong><span style=\"color: rgb(236, 228, 217)\">: Dây Leo Sắc Bén</span><br><strong><span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span></strong>: 2<br><span style=\"color: rgb(236, 228, 217)\">(Nhân vật tối đa trang bị 1 Đặc Kỹ)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/14/44749939/db13288db6b90ec33f8adc2656d2019f_3364149880806319399.png",
