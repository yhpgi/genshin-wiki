              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(211, 188, 142)\">Đặc Kỹ</span></p><p><span style=\"color: rgb(236, 228, 217)\">Gây 1 điểm </span><strong><span style=\"color: rgb(126, 194, 54)\">Sát Thương Nguyên Tố Thảo</span></strong><span style=\"color: rgb(236, 228, 217)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/14/44749939/86b01f7358a08b03bb712ccefea15285_8497078747996339515.png",
                "id": "talent55033",
                "key": "Dây Leo Sắc Bén",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
