          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tấn Công Thường</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Gây 2 điểm</span> <span style=\"color: rgb(255, 255, 255)\">Sát Thương Vật Lý</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/15/44749939/d576e47ec29592a74d7f18040459665c_1172474792351906881.png",
                "id": "talent4949",
                "key": "Huyền Thoại Đấm Nhau",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Huyền Thoại Đấm Nhau"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nguyên Tố</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Gây 1 điểm</span> <span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span><span style=\"color: rgba(255, 255, 255, 0.85)\">,triệu hồi </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Ushi</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\">, nhân vật này áp dụng </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Quỷ Lực Vô Song</span></strong><br></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Quỷ Lực Vô Song</span></strong><br><span style=\"color: rgb(255, 215, 128)\">Trạng thái</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Khi nhân vật áp dụng tiến hành Trọng Kích: Sát thương gây ra +1. Nếu Số Lần Khả Dụng tối thiểu là 2, thì sẽ giảm tiêu hao 1 </span><em><span style=\"color: rgba(255, 255, 255, 0.85)\">Nguyên Tố Không Màu</span></em></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Số Lần Khả Dụng: 1 ( Có thể cộng dồn, tối đa dồn 3 lần)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/15/44749939/c75ed9237fb342dae8cd65729ddc0bba_8461783040753279125.png",
                "id": "talent8964",
                "key": "Tuyệt Kỹ Masatsu - Akaushi Công Phá",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Tuyệt Kỹ Masatsu - Akaushi Công Phá"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Kỹ Năng Nộ</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Gây 5 điểm</span> <span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham, </span><span style=\"color: rgba(255, 255, 255, 0.85)\">nhân vật này áp dụng</span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\"> Nộ Mục Quỷ Vương</span></strong><br><br><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Nộ Mục Quỷ Vương</span></strong><br><span style=\"color: rgb(255, 215, 128)\">Trạng thái</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Nhân vật áp dụng sẽ +2 sát thương do </span><em><span style=\"color: rgba(255, 255, 255, 0.85)\">Tấn Công Thường</span></em><span style=\"color: rgba(255, 255, 255, 0.85)\"> gây ra, </span><em><span style=\"color: rgba(255, 255, 255, 0.85)\">Sát Thương Vật Lý</span></em><span style=\"color: rgba(255, 255, 255, 0.85)\"> gây ra sẽ chuyển thành </span><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Số hiệp duy trì: 2</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Sau khi nhân vật áp dụng tiến hành tấn công thường: Áp dụng Quỷ Lực Vô Song cho nhân vật đó (Mỗi hiệp 1 lần)</span><br></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Quỷ Lực Vô Song</span></strong><br><span style=\"color: rgb(255, 215, 128)\">Trạng thái</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Khi nhân vật áp dụng tiến hành Trọng Kích: Sát thương gây ra +1. Nếu Số Lần Khả Dụng tối thiểu là 2, thì sẽ giảm tiêu hao 1 </span><em><span style=\"color: rgba(255, 255, 255, 0.85)\">Nguyên Tố Không Màu</span></em></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Số Lần Khả Dụng: 1 ( Có thể cộng dồn, tối đa dồn 3 lần)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/15/44749939/d5b0f60e30da0341b4165d1a76b3c73b_1378949268255640792.png",
                "id": "talent28474",
                "key": "Siêu Cấp Quỷ Vương - Itto Giáng Lâm!",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Siêu Cấp Quỷ Vương - Itto Giáng Lâm!"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Vật Triệu Hồi</span><br>﻿Khi nhân vật xuất chiến phe ta chịu sát thương: Giảm bớt 1 điểm sát thương phải chịu.</p><p>Số Lần Khả Dụng: 1, khi dùng hết không hủy bỏ thẻ bài này.</p><p>Trong thời gian vật triệu hồi này ở trong trận có thể kích hoạt 1 lần: Sau khi nhân vật xuất chiến phe ta chịu sát thương, sẽ áp dụng <strong>Quỷ Lực Vô Song</strong> cho Arataki Itto.</p><p></p><p><strong>Quỷ Lực Vô Song</strong><br><span style=\"color: rgb(255, 215, 128)\">Trạng thái</span><br>Khi nhân vật áp dụng tiến hành Trọng Kích: Sát thương gây ra +1. Nếu Số Lần Khả Dụng tối thiểu là 2, thì sẽ giảm tiêu hao 1 <em>Nguyên Tố Không Màu</em></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Số Lần Khả Dụng: 1 ( Có thể cộng dồn, tối đa dồn 3 lần)</span></p><p>Giai Đoạn Kết Thúc: Hủy bỏ thẻ bài này, gây 1 điểm -<span style=\"color: rgb(255, 230, 153)\"> Sát Thương Nguyên Tố Nham.</span></p><p></p><p></p><p><br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/15/44749939/db13288db6b90ec33f8adc2656d2019f_1633180402286728474.png",
                "id": "talent13746",
                "key": "Ushi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/15/44749939/ea059a3f7bee2dea6bcee851752339c3_8386372625638728505.png",
                "title": "Ushi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(236, 229, 216)\">Sát Thương Vật Lý</span></p><p>Sát thương vật lý sẽ không gắn ấn nguyên tố, cũng không xảy ra phản ứng nguyên tố.</p><p></p><p><span style=\"color: rgb(255, 230, 153)\">Sát Thương Nguyên Tố Nham</span></p><p>Sản sinh phản ứng nguyên tố với các ấn nguyên tố sau:</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(153, 255, 255)\">Băng</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Băng)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(128, 192, 255)\">Thủy</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Thủy)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(255, 153, 153)\">Hỏa</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Hỏa)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p>[<span style=\"color: rgb(255, 230, 153)\">Nham</span> + <span style=\"color: rgb(255, 172, 255)\">Lôi</span>] <span style=\"color: rgb(255, 255, 255)\">Kết Tinh (Lôi)</span>: Sát thương +1, nhân vật xuất chiến phe ta nhận được 1 điểm Khiên (Có thể cộng dồn, tối đa 2 điểm.)</p><p></p><p><strong><span style=\"color: rgb(204, 191, 173)\">Khiên</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Nhân vật được Khiên bảo vệ khi chịu sát thương sẽ tiêu hao Khiên trước.</span></p><p></p><p><span style=\"color: rgb(236, 229, 216)\">Số Lần Khả Dụng</span></p><p>Sau khi hiệu quả của thẻ bài này kích hoạt, sẽ tiêu hao 1 lần <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span>; <span style=\"color: rgb(255, 255, 255)\">Số Lần Khả Dụng</span> sau khi dùng hết sẽ tiêu hủy thẻ bài này.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/15/44749939/245c229cf6f7364c7c9a7aea3db1a1ad_210030355432862107.png",
