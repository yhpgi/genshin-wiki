              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">召唤物</span></p><p><span style=\"color: #FFFFFF\">结束阶段：</span>造成1点<span style=\"color: rgb(153, 255, 136)\">草元素伤害</span>，治疗我方出战角色1点。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次数：1</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/157749474/db13288db6b90ec33f8adc2656d2019f_3124432675488369362.png",
