                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "2023年6月21日",
                      "type": "text"
                    },
                    {
                      "text": "山石奇景，巍巍难撼。",
                      "type": "text"
                    },
                    {
                      "text": "商港熙荣，阅尽千帆。",
                      "type": "text"
                    },
                    {
                      "styles": [
