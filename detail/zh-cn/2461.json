                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/47826599/5bc9df1fb67391e4c8080da3d855de53_1068083666965189960.png",
                      "name": "瑶瑶",
                      "type": "custom_entry"
