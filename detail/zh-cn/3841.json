                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "所闻遍计"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素战技</span></p><p>造成3点<span style=\"color: rgb(153, 255, 136)\">草元素伤害</span>，所有敌方角色附属<span style=\"color: #FFFFFF\">蕴种印</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/88072335/a50ede7c08761d3a5bd17f505692ff2b_1045108544082574867.png",
                "id": "talent66512",
                "key": "所闻遍计 · 真如",
                "materials": [],
                "points": [
                  {
                    "point_count": 5,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "所闻遍计 · 真如"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素爆发</span></p><p>造成4点<span style=\"color: rgb(153, 255, 136)\">草元素伤害</span>，生成<span style=\"color: #FFFFFF\">摩耶之殿</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/27/88072335/515a0e68e314c5e829e7ec91e8721797_7764510008354370238.png",
                "id": "talent69643",
                "key": "心景幻成",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "心景幻成"
              },
              {
                "attributes": [],
                "desc": "<p>附着草元素，可发生元素反应：</p><p>【<span style=\"color: rgb(153, 255, 136)\">草元素</span>+<span style=\"color: rgb(128, 192, 255)\">水元素</span>】<span style=\"color: white\">绽放</span>：本伤害+1，生成使下次火元素或雷元素伤害+2的[<span style=\"color: white\">草原核</span>]</p><p>【<span style=\"color: rgb(153, 255, 136)\">草元素</span>+<span style=\"color: rgb(255, 153, 153)\">火元素</span>】<span style=\"color: white\">燃烧</span>：本伤害+1，生成回合结束时造成1点火元素伤害的[<span style=\"color: white\">燃烧烈焰</span>]（可用次数1，最多叠加到2）</p><p>【<span style=\"color: rgb(153, 255, 136)\">草元素</span>+<span style=\"color: rgb(255, 172, 255)\">雷元素</span>】<span style=\"color: white\">原激化</span>：本伤害+1，生成使下2次草元素或雷元素伤害+1的[<span style=\"color: white\">激化领域</span>]</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/27/88072335/e8cff941b5a0ff248efde360ec9e91fe_8216139961575598866.png",
                "id": "talent68817",
                "key": "草元素伤害",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "草元素伤害"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">蕴种印</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">状态</span></p><p><span style=\"color: rgb(255, 255, 255)\">任意具有「蕴种印」的所在阵营角色受到元素反应伤害后：</span>对所附属角色造成1点<span style=\"color: rgb(255, 255, 255)\">穿透伤害</span>。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次数：2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">穿透伤害</span></strong></p><p>穿透伤害无法受到伤害加成，但是也无法被护盾、伤害免疫等效果抵消。</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">可用次数</span></strong></p><p>此牌效果触发后，会消耗1次<span style=\"color: rgb(255, 255, 255)\">可用次数</span>；</p><p><span style=\"color: rgb(255, 255, 255)\">可用次数</span>耗尽后，立刻弃置此牌。</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">摩耶之殿</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">出战状态</span></p><p><span style=\"color: rgb(255, 255, 255)\">我方引发元素反应时：</span>伤害额外+1。</p><p><span style=\"color: rgb(255, 255, 255)\">持续回合：2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">持续回合</span></strong></p><p>每回合结束阶段，<span style=\"color: rgb(255, 255, 255)\">持续回合</span>-1；</p><p><span style=\"color: rgb(255, 255, 255)\">持续回合</span>耗尽后，立刻弃置此牌。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/27/88072335/07bae546ac7c69ef6402170b283840c5_8488808051783578979.png",
