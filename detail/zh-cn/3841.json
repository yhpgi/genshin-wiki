              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成1点<span style=\"color: rgb(153, 255, 136)\">草元素伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/88072335/1ce09211f025bf5470682189e0837732_6466579516191353115.png",
