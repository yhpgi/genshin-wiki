                      "ep_id": 4262,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/28/151578876/0e20d4f6e2bfde9b348bbc5082622a46_8620498779813669574.png",
                      "name": "Green Feather Accessory",
