                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3521,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/31/47826599/61275d8b97a9c5e4055ed07a4d34c4fa_1718300299164901093.png",
                      "name": "浮舍",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3518,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/31/47826599/2a70abcd41f1c25b94da6c18901fc863_6939628724811528098.png",
                      "name": "弥怒",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3520,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/31/47826599/7280f8fc2afecab369f640ed8370390d_1746627869451140690.png",
                      "name": "应达",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2314,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/book/Yakshas: The Guardian Adepti_icon.png",
                      "name": "护法仙众夜叉录",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
