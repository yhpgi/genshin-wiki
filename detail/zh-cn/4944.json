                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻击</span></p><p>造成1点<span style=\"color: #99FFFF\">冰元素伤害</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/17/157749474/1ce09211f025bf5470682189e0837732_666619782506266739.png",
                "id": "talent39531",
                "key": "冰锥迸射",
                "materials": [],
                "points": [
                  {
