              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆发</span></p><p>造成1点<span style=\"color: rgb(153, 255, 136)\">草元素伤害</span>，生成<span style=\"color: rgb(255, 255, 255)\">桂子仙机</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/27/88072335/37972e3c3e9c9134cd6b1357f57aa711_7937051133390133256.png",
                "id": "talent12513",
                "key": "玉颗珊珊月中落",
                "materials": [],
                "points": [
