                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "火元素伤害"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">物理伤害</span></strong></p><p>物理伤害不会附着元素，也不会发生元素反应。</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">旋火轮</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">出战状态</span></p><p><span style=\"color: rgb(255, 255, 255)\">我方角色使用技能后：</span>造成2点<span style=\"color: rgb(255, 153, 153)\">火元素伤害</span>。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次数：2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">可用次数</span></strong></p><p>此牌效果触发后，会消耗1次<span style=\"color: rgb(255, 255, 255)\">可用次数</span>；</p><p><span style=\"color: rgb(255, 255, 255)\">可用次数</span>耗尽后，立刻弃置此牌。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/24/47826599/07bae546ac7c69ef6402170b283840c5_4965587629010156261.png",
