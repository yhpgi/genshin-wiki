              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">召唤物</span></p><p><span style=\"color: #FFFFFF\">结束阶段：</span>造成2点<span style=\"color: #FF9999\">火元素伤害</span>。</p><p><span style=\"color: #FFFFFF\">可用次数：2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/24/47826599/db13288db6b90ec33f8adc2656d2019f_3434943503249847693.png",
