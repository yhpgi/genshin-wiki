              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">召唤物</span></p><p><span style=\"color: rgb(255, 255, 255)\">结束阶段：</span>造成2点<span style=\"color: rgb(255, 172, 255)\">雷元素伤害</span>，我方出战角色附属<span style=\"color: #FFFFFF\">鸣煌护持</span>。</p><p><span style=\"color: #FFFFFF\">可用次数：2</span></p>",
