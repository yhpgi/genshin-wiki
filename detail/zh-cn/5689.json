            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻击</span></p><p>造成2点<span style=\"color: #FFFFFF\">物理伤害</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/14/157749474/47817b4476bcd8b44c86c87debf042f2_5503547827909893346.png",
                "id": "talent83166",
                "key": "失乡重击",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "失乡重击"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素战技</span></p><p>造成2点<span style=\"color: #99FF88\">草元素伤害</span>，抓1张<span style=\"color: #FFFFFF\">唤醒眷属</span>，生成1层<span style=\"color: #FFFFFF\">绿洲之滋养</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/14/157749474/b5c63ab0dca603b7744290cd57df7ba6_816310664578986400.png",
                "id": "talent46466",
