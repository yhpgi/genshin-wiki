                "title": "售后服务弹"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">召唤物</span></p><p><span style=\"color: #FFFFFF\">结束阶段：</span>治疗我方出战角色2点，并使其获得1点<span style=\"color: #FFFFFF\">充能</span>。</p><p><span style=\"color: #FFFFFF\">可用次数：2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/157749474/db13288db6b90ec33f8adc2656d2019f_926286870722120046.png",
