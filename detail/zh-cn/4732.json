              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">召喚物</span></p><p><span style=\"color: rgb(255, 255, 255)\">结束阶段：</span>造成1点<span style=\"color: rgb(255, 230, 153)\">岩元素伤害</span>；如果队伍中存在2名<span style=\"color: rgb(255, 230, 153)\">岩元素</span>角色，则生成<span style=\"color: rgb(255, 255, 255)\">结晶</span>。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次数：2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/157749474/db13288db6b90ec33f8adc2656d2019f_7929881331890961261.png",
