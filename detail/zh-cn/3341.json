    {
      "id": "33",
      "name": "画廊",
      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/c2868aeb5ca6327bb10f99c79970aa22_5146868801890008126.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">寻找</span><span style=\"color: #FFE14B\">大世界的牌手</span><span style=\"color: rgba(255, 255, 255, 0.85)\">、或是在牌手等级到达2级后与酒馆中</span><span style=\"color: #FFE14B\">每周来访</span><span style=\"color: rgba(255, 255, 255, 0.85)\">的来客进行七圣召唤的对局，就可以获得牌手经验，提升牌手等级。随着牌手等级的提升，可以解锁更多功能和不同的对局。到达一定牌手等级后，还能和「小王子」对局，完成突破挑战，以提升等级上限。</span></p>",
                "key": "七圣召唤·系统教学 1"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/bb0c3bbd1166b98abaf01141d44ed267_1172695278234186298.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">七圣召唤是相当流行的卡牌游戏，</span><span style=\"color: #FFE14B\">在各地都有许多的牌手</span><span style=\"color: rgba(255, 255, 255, 0.85)\">。与他们对局并获得胜利，可以获得</span><span style=\"color: #FFE14B\">牌手经验和幸运牌币</span><span style=\"color: rgba(255, 255, 255, 0.85)\">，有的牌手还会在对局后进行卡牌的赠送。随着牌手等级提升，愿意进行对局的牌手和可以进行的挑战牌局也会逐渐增多…</span></p>",
                "key": "七圣召唤·系统教学 2"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/d597346abb50c24691738a064c011cec_5081796874155191932.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">可以通过</span><span style=\"color: #FFE14B\">邀请板</span><span style=\"color: rgba(255, 255, 255, 0.85)\">，向牌手名册中的牌手发送对局邀请函以进行邀约对局。在此对局中获得胜利，可以得到相应的</span><span style=\"color: #FFE14B\">角色牌及其天赋牌</span><span style=\"color: rgba(255, 255, 255, 0.85)\">。</span></p>",
                "key": "七圣召唤·系统教学 3"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/25342b3e238e883ae1d4eea8b6240f10_7029408813781212427.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">可以通过邀请板，邀请联机状态下的好友进行对决。随着牌手等级的提升，还能与远方的陌生牌手进行对局。</span></p>",
                "key": "七圣召唤·系统教学 4"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/d92e65db154e2ee58c42c7432e9e18c7_8473649645738783524.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">在七圣召唤的对局中获得的「幸运牌币」能够在猫尾酒馆的卡牌商店处使用，可以用于购买</span><span style=\"color: #FFE14B\">卡牌和影幻牌面</span><span style=\"color: rgba(255, 255, 255, 0.85)\">等。</span></p>",
                "key": "七圣召唤·系统教学 5"
              }
            ],
            "pic": ""
          }
        }
      ]
