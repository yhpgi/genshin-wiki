            "circlet_of_logos": {
              "desc": "平时能在行医时绑住乱发，紧急情况下也能用来托起扭伤、折断的手臂。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Traveling Doctor/circlet_of_logos_icon.png",
              "position": "理之冠",
              "title": "游医的方巾"
            },
            "flower_of_life": {
              "desc": "是珍贵的药材，但存放了这么久已经失去了药用价值。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Traveling Doctor/flower_of_life_icon.png",
              "position": "生之花",
              "title": "游医的银莲"
            },
            "goblet_of_eonothem": {
              "desc": "原本装满了提炼后极浓的药汁，如今只剩下浓烈的药味。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Traveling Doctor/goblet_of_eonothem_icon.png",
              "position": "空之杯",
              "title": "游医的药壶"
            },
            "plume_of_death": {
              "desc": "枭的坚硬羽毛，夜间行医时用夜行猛禽的意象鼓舞自己。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Traveling Doctor/plume_of_death_icon.png",
              "position": "死之羽",
              "title": "游医的枭羽"
            },
            "sands_of_eon": {
              "desc": "用来精确计时的道具。对医者而言，即使是一秒的时间也不能浪费。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Traveling Doctor/sands_of_eon_icon.png",
