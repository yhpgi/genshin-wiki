            "list": [
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/10/21/36540823/e3f34910bb9f1fa3a5de29ba7cd43a90_5296538259125663468.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">生物受到</span><span style=\"color: rgb(255, 225, 75)\">水元素</span><span style=\"color: rgba(255, 255, 255, 0.65)\">与</span><span style=\"color: rgb(255, 225, 75)\">草元素</span><span style=\"color: rgba(255, 255, 255, 0.65)\">影响后，将会引发「绽放」反应，产生</span><span style=\"color: rgb(255, 225, 75)\">草原核</span><span style=\"color: rgba(255, 255, 255, 0.65)\">。</span></p>",
                "key": "元素反应：绽放1"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/10/21/36540823/b83f2a187d0c6d0e860156a91811ca17_5286455296461555284.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">同时至多存在一定数量的草原核。在数量达到上限后再产生新的草原核，或在草原核的持续时间结束后，草原核将会爆发，造成草元素范围伤害…</span></p>",
                "key": "元素反应：绽放2"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/10/21/36540823/d9d9d076f631cfd9624bdfb6a927c5b0_5270443794750341953.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">草原核接触</span><span style=\"color: #FFE14B\">火元素</span><span style=\"color: rgba(255, 255, 255, 0.65)\">时，将会引发「烈绽放」，造成更强的草元素范围伤害；遇到</span><span style=\"color: #FFE14B\">雷元素</span><span style=\"color: rgba(255, 255, 255, 0.65)\">则会发生「超绽放」反应，将草原核转化为具有追踪能力的蔓生弹。</span></p>",
                "key": "元素反应：绽放3"
              }
            ],
