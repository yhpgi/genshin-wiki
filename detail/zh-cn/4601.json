                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/06/157749474/be516a2c9005727dcfd1fe45662a826d_6010914369077855390.png",
                      "name": "卡特皮拉",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
