                      "ep_id": 4227,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/06/157749474/7a4364ee7ecfbf1eb2b78fbf7b6607ed_462316718205257228.png",
                      "name": "安",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4255,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/06/157749474/7ac751c3fd3892141d972392696a414b_511123877057432813.png",
                      "name": "「玛丽安」",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
