            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成2点<span style=\"color: #FFFFFF\">物理伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/88072335/241eba6e4c00020975cf91170050f435_2744923127742534197.png",
