                ],
                "talent_img": "",
                "title": "源流"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素战技</span></p><p>召唤<span style=\"color: #FFFFFF\">雷罚恶曜之眼</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/88072335/c29fd0841f95e044bae32d03dc31765a_7030134102902265200.png",
