      "name": "技能",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成1点<span style=\"color: rgb(153, 255, 255)\">冰元素伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/88072335/47817b4476bcd8b44c86c87debf042f2_8357542995653405519.png",
