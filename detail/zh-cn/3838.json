              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素战技</span></p><p>造成2点<span style=\"color: rgb(128, 255, 215)\">风元素伤害</span>，<span style=\"color: #FFFFFF\">生成风域</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/88072335/5462e680a1901ee99a16d6f6476e47a9_6618402251901296773.png",
                "id": "talent8201",
