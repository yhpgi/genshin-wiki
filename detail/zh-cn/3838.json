          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成2点<span style=\"color: rgb(255, 255, 255)\">物理伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/88072335/c369b96fc6417e8fc2bb607e37297ad4_1335733949332211341.png",
