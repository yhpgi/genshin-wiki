                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆发</span></p><p>造成1点<span style=\"color: rgb(153, 255, 255)\">冰元素伤害</span>，生成<span style=\"color: rgb(255, 255, 255)\">寒冰之棱</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/47826599/8c97595e1862a7f3d9d0b707c3143148_4078680797025260774.png",
