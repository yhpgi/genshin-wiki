              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素战技</span></p><p>造成1点<span style=\"color: #FFE699\">岩元素伤害</span>，召唤<span style=\"color: #FFFFFF\">阿丑</span>，本角色附属<span style=\"color: #FFFFFF\">乱神之怪力</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/11/88072335/c75ed9237fb342dae8cd65729ddc0bba_5640044073285438358.png",
