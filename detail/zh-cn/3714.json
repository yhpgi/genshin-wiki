              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成2点<span style=\"color: #FFFFFF\">物理伤害</span><span style=\"color: rgb(255, 255, 255)\">。</span></p>",
