            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成2点<span style=\"color: #FFFFFF\">物理伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/88072335/240a7dfccb5e733342507e896ab68a90_938467566328757582.png",
                "id": "talent98056",
                "key": "西风剑术 · 白",
                "materials": [],
                "points": [
                  {
