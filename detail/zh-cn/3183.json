          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻击</span></p><p>造成2点<span style=\"color: #FFFFFF\">物理伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/47826599/c369b96fc6417e8fc2bb607e37297ad4_7259649583693769290.png",
                "id": "talent28204",
                "key": "烟火打扬",
                "materials": [],
                "points": [
