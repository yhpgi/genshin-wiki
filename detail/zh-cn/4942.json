              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆发</span></p><p>造成2点<span style=\"color: #FF9999\">火元素伤害</span>，生成<span style=\"color: #FFFFFF\">烈烧佑命护盾</span>和<span style=\"color: #FFFFFF\">炽火大铠</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/17/157749474/47b82b01f63f39b206ba0c985d5de119_3997156394201981314.png",
