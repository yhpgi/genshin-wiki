                      "display_style": "card",
                      "ep_id": 4521,
                      "icon_url": "",
                      "name": "莉诺尔",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
