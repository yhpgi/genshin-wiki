                      "ep_id": 4780,
                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2023/12/20/a5b8d23dd3fbe0969cc3ebce78f9c29f_8021351765588020911.png",
                      "name": "Egeria",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4539,
                      "icon_url": "",
                      "name": "Old Finch",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2323,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/book/Heart of Clear Springs_icon.png",
                      "name": "Heart of Clear Springs",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "卡莉露的诗",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "我来自遥远的地方",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "山河是我眠床",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "四季予我衣裳",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "我寻找栖身的花圃",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "随着银砂般的月光一齐飘荡",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "流风与清泉邀我停驻",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "「安睡吧，安睡吧，旅途令你疲惫。」",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "「回荡吧，回荡吧，落花为你点缀。」",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "我晨间弹奏幽涧的石琴",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "夜晚倾听梦乡的歌吹",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "一位男孩的泪珠泛起波澜",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "比星空下任何歌声都要浪漫",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "他将过往与将来织成多彩的花冠",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "我则消融梦境的边界",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "作为报偿",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "「看哪，看哪，他的爱慕溢于眼眉。」",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "「答应吧，快答应吧，趁着美梦未褪。」",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "猫儿与流萤催我应允",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "可我不懂人间的曲调",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "又怎能与它和鸣？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "溪流与梦想汇入沧洋",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "晶蝶点水的须臾",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "星河下的少年白发成长",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "我蹒跚学习人类的一切",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "将易碎的云朵拼成柔软的诗行",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "正如种子向往土壤，林木追逐太阳",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "曾经懵懂的曲调在心中奏响",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "侧耳听去",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "原来它声声都唱着你的名字",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "现在，我将我的梦送给你",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "愿你的夜晚似泉水般甘甜",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "现在，我将我的心送给你",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "愿你接受这份",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(219, 222, 225)",
                        "italic"
                      ],
                      "text": "迟来的诺言",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
