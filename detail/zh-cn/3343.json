    {
      "id": "33",
      "name": "画廊",
      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/baccb633e0372d63119d8a828893f91b_7742360850511207032.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">《七圣召唤》是一款节奏紧凑、对抗激烈的卡牌类桌面对战游戏。<br>使用由「角色牌」和「行动牌」组成的牌组，在牌桌上挑战各种各样的对手吧！</span></p>",
                "key": "《七圣召唤》规则概述 1"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/4e8593d5eb0eccb68aa2063c60cc6694_2470047333720445815.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">投掷阶段。</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">在每个回合的开始，你会获得并投掷8个「元素骰」。<br>投掷后，你还有1次机会选择任意数量元素骰进行「重投」。</span></p>",
                "key": "《七圣召唤》规则概述 2"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/cbe643422f507fba0f19fef3b5e28b99_6435797751296196965.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">元素骰<br>「元素骰」是一个8面骰，可以投出冰、水、火、雷、风、岩、草7种元素，以及可以当作任何元素使用的「万能元素」。<br>各种各样的行动，都需要支付「元素骰」作为费用。</span></p>",
                "key": "《七圣召唤》规则概述 3"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/407470a7ffcb31d44e16ed73db2ff50b_2705354124509664943.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">行动：使用技能<br>在行动阶段中，可以花费「元素骰」来使用我方</span><span style=\"color: #FFE14B\">「出战角色」</span><span style=\"color: rgba(255, 255, 255, 0.85)\">的技能，<br>以攻击对方牌手的「出战角色」。<br>击倒所有对方角色，即可赢得对局的胜利！</span></p>",
                "key": "《七圣召唤》规则概述 4"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/3bd515d0ebc5bd7faffc7fbc530d5770_1569856761951699187.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">行动：切换角色<br>在行动阶段中，可以花费一个任意「元素骰」来切换</span><span style=\"color: #FFE14B\">「出战角色」</span><span style=\"color: rgba(255, 255, 255, 0.85)\">。</span></p>",
                "key": "《七圣召唤》规则概述 5"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/7ed0eff33da45c6fc9f1fcb905c5b33b_2008709088462009466.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">行动：打出手牌<br>在行动阶段中，可以花费「元素骰」来</span><span style=\"color: #FFE14B\">打出「行动牌」</span><span style=\"color: rgba(255, 255, 255, 0.85)\">。<br>其中，「装备牌」可以强化特定的角色；「支援牌」可以持续提供增益效果；「事件牌」可以在打出后立刻结算一次性的效果。</span></p>",
                "key": "《七圣召唤》规则概述 6"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/0ec55b201061198f170bf35245937619_1540100821971265989.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">行动：元素调和<br>在行动阶段中，可以丢弃手牌来</span><span style=\"color: #FFE14B\">转换「元素骰」的类型</span><span style=\"color: rgba(255, 255, 255, 0.85)\">。<br>每丢弃一张手牌，就能将一颗「元素骰」转换为我方当前「出战角色」的元素类型。</span></p>",
                "key": "《七圣召唤》规则概述 7"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/05/36540823/427ff5b27c802d6ed2ae947d327671e4_6635608584296312473.png",
                "imgDesc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">行动：宣布回合结束<br>本回合行动完毕后，即可</span><span style=\"color: #FFE14B\">「宣布回合结束」</span><span style=\"color: rgba(255, 255, 255, 0.85)\">。<br>先「宣布回合结束」的牌手会成为「先手牌手」。<br>双方都「宣布回合结束」后：本回合结束，双方各抓2张牌，开始新的回合。</span></p>",
                "key": "《七圣召唤》规则概述 8"
              }
            ],
            "pic": ""
          }
        }
      ]
    },
