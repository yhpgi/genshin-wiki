          "data": {
            "circlet_of_logos": {
              "desc": "制式的教官帽子。是拒绝了晋升的军官才能获得的殊荣。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Instructor/circlet_of_logos_icon.png",
