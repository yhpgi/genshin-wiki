          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成1点<span style=\"color: #FF9999\">火元素伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/17/47826599/1ce09211f025bf5470682189e0837732_7903277367953406273.png",
