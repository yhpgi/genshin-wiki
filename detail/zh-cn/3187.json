              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆发</span></p><p>造成3点<span style=\"color: rgb(255, 172, 255)\">雷元素伤害</span>，本角色附属<span style=\"color: rgb(255, 255, 255)\">雷狼</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/47826599/898eb03f9942b7b7833a3c082a86fdef_7264651820563472221.png",
