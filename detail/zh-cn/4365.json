              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素战技</span></p><p>造成2点<span style=\"color: rgb(128, 255, 215)\">风元素伤害</span>，本角色附属<span style=\"color: #FFFFFF\">优风倾姿</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/27/88072335/052cd901b44cef8359f0bebb98404194_9182858128010032259.png",
