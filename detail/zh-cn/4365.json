                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "羽画 · 风姿华歌"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆发</span></p><p>造成7点<span style=\"color: rgb(128, 255, 215)\">风元素伤害</span>；如果角色附属有<span style=\"color: #FFFFFF\">优风倾姿</span>，则将其移除并使此伤害+1。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/27/88072335/5a55e705974f27b8bb86c628019d5ad9_8968364068972800392.png",
                "id": "talent73074",
                "key": "狂言 · 式乐五番",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "狂言 · 式乐五番"
              },
              {
                "attributes": [],
                "desc": "<p>和已附着的元素发生元素反应：</p><p>【<span style=\"color: rgb(128, 255, 215)\">风元素</span>+<span style=\"color: rgb(153, 255, 255)\">冰元素</span>】<span style=\"color: rgb(255, 255, 255)\">扩散（冰）</span>：对目标以外的所有敌方角色造成1点冰元素伤害</p><p>【<span style=\"color: rgb(128, 255, 215)\">风元素</span>+<span style=\"color: rgb(128, 192, 255)\">水元素</span>】<span style=\"color: rgb(255, 255, 255)\">扩散（水）</span>：对目标以外的所有敌方角色造成1点水元素伤害</p><p>【<span style=\"color: rgb(128, 255, 215)\">风元素</span>+<span style=\"color: rgb(255, 153, 153)\">火元素</span>】<span style=\"color: rgb(255, 255, 255)\">扩散（火）</span>：对目标以外的所有敌方角色造成1点火元素伤害</p><p>【<span style=\"color: rgb(128, 255, 215)\">风元素</span>+<span style=\"color: rgb(255, 172, 255)\">雷元素</span>】<span style=\"color: rgb(255, 255, 255)\">扩散（雷）</span>：对目标以外的所有敌方角色造成1点雷元素伤害</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/27/88072335/c97292d96456bfe4abeca16bfce801e4_1488052308383145511.png",
                "id": "talent42376",
                "key": "风元素伤害",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "风元素伤害"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">优风倾姿</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">状态</span></p><p><span style=\"color: rgb(255, 255, 255)\">所附属角色进行「普通攻击」时：</span>造成的伤害+2；如果敌方存在后台角色，则此技能改为对下一个敌方后台角色造成伤害。</p><p><span style=\"color: rgb(255, 255, 255)\">可用次数：2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">可用次数</span></strong></p><p>此牌效果触发后，会消耗1次<span style=\"color: rgb(255, 255, 255)\">可用次数</span>；</p><p><span style=\"color: rgb(255, 255, 255)\">可用次数</span>耗尽后，立刻弃置此牌。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/27/88072335/07bae546ac7c69ef6402170b283840c5_5289332040768752401.png",
