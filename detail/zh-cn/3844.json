            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成1点<span style=\"color: rgb(255, 172, 255)\">雷元素伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/88072335/47817b4476bcd8b44c86c87debf042f2_1964736377249994041.png",
                "id": "talent71204",
                "key": "雷晶投射",
                "materials": [],
