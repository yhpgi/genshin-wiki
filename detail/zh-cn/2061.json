          "data": {
            "circlet_of_logos": {
              "desc": "束在额前的饰带，吸满了汗液、覆盖着尘土。但脏污难以遮掩冒险家的骄傲。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/circlet_of_logos_icon.png",
              "position": "理之冠",
              "title": "冒险家头带"
            },
            "flower_of_life": {
              "desc": "从深邃的古都寻得的绝境求生的小花，被当做骄傲的勋章佩在胸前。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/flower_of_life_icon.png",
              "position": "生之花",
              "title": "冒险家之花"
            },
            "goblet_of_eonothem": {
              "desc": "冒险家某次出征的战利品，虽然有缺口，仍然是值得骄傲的猎获。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/goblet_of_eonothem_icon.png",
              "position": "空之杯",
              "title": "冒险家金杯"
            },
            "plume_of_death": {
              "desc": "异国的奇妙鸟类的羽毛，在这片大陆上非常罕见。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/plume_of_death_icon.png",
              "position": "死之羽",
              "title": "冒险家尾羽"
            },
            "sands_of_eon": {
              "desc": "常在不见天日的巨渊还是失落的古都流连的冒险家，会经常忘记时间。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/sands_of_eon_icon.png",
              "position": "时之沙",
              "title": "冒险家怀表"
            }
          }
        }
      ]
