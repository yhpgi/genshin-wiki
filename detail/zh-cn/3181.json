              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻击</span></p><p>造成2点<span style=\"color: #FFFFFF\">物理伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/47826599/10316b5178d5109d597f415d6e7903dc_3591948575125266547.png",
                "id": "talent29779",
                "key": "淬炼之剑",
                "materials": [],
                "points": [
