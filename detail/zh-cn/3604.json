          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">普通攻击</span></p><p>造成2点<span style=\"color: rgb(255, 255, 255)\">物理伤害。</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/24/88072335/d239457501846014cb4c545b50959bd9_6921872882658464863.png",
