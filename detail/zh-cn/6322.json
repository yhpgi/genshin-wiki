            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻击</span></p><p>造成2点<span style=\"color: rgb(255, 255, 255)\">物理伤害</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/17/157749474/47817b4476bcd8b44c86c87debf042f2_8148410094631362432.png",
