              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆发</span></p><p>造成1点<span style=\"color: #FFACFF\">雷元素伤害</span>，本角色附属<span style=\"color: #FFFFFF\">原海明珠</span>，召唤<span style=\"color: #FFFFFF\">共鸣珊瑚珠</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/17/157749474/14274ea236c0c28ce99979f7fceb56a9_8008036299367666871.png",
