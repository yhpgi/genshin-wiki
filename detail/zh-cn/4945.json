              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFFFFF\">结束阶段：</span>造成1点<span style=\"color: #FFACFF\">雷元素伤害</span>。<br><span style=\"color: #FFFFFF\">可用次数：2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/17/157749474/db13288db6b90ec33f8adc2656d2019f_4716435836606151490.png",
                "id": "talent68777",
                "key": "共鸣珊瑚珠",
                "materials": [],
                "points": [
