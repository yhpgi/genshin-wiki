                "title": "原海古雷"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">被动技能</span></p><p>【被动】战斗开始时，本角色附属<span style=\"color: #FFFFFF\">原海明珠</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/17/157749474/fa578f3705c431012e2d1447eda1f030_4544279280974294841.png",
