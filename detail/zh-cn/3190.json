          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻击</span></p><p>造成2点<span style=\"color: #FFFFFF\">物理伤害</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/47826599/10316b5178d5109d597f415d6e7903dc_4124721397933011917.png",
                "id": "talent74645",
                "key": "西风剑术·女仆",
                "materials": [],
                "points": [
