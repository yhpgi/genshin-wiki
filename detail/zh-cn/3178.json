              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素战技</span></p><p>造成1点<span style=\"color: rgb(128, 192, 255)\">水元素伤害</span>，召唤<span style=\"color: #FFFFFF\">虚影</span>。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/47826599/a0074558f99c36e32c2a642c89000de2_5960690159093405210.png",
