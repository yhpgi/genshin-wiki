            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">普通攻击</span></p><p>造成2点<span style=\"color: rgb(255, 255, 255)\">物理伤害</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/157749474/94aa30ae75b8c7c6a9c64ab05bd5dda7_4757964398720490436.png",
                "id": "talent94350",
                "key": "迅捷礼刺剑",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "迅捷礼刺剑"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素战技</span></p><p>造成3点<span style=\"color: #80FFD7\">风元素伤害</span>，本回合第一次使用此技能、且自身生命值不多于8时治疗自身2点，但是附属<span style=\"color: #FFFFFF\">攻袭余威</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/157749474/42bfd225eedc984bb1d4a4af99e3dcae_8757034282368267776.png",
                "id": "talent14329",
