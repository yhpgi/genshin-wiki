              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素战技</span></p><p>造成2点<span style=\"color: #FF9999\">火元素伤害</span>，并使目标角色附属<span style=\"color: #FFFFFF\">炽热</span>。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/157749474/9893e5160645321019bda81ec8ac1125_7445510108977551594.png",
                "key": "烬灭之鞭",
                "materials": [],
