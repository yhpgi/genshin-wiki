                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5223,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/26/237301566/615412682c0d3edc7483b9452030aa64_4315552892343881539.png",
                      "menu_id": 23,
                      "name": "Marechaussee Phantom",
                      "type": "custom_entry"
