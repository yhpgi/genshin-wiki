      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/241eba6e4c00020975cf91170050f435_4379983635020986052.png",
                "id": "talent2112",
                "key": "Affondo Albastella",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Affondo Albastella"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, crea 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Aculeo di ghiaccio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Aculeo di ghiaccio</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Stato di combattimento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il tuo personaggio infligge </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +1 (include i DAN da reazioni di </span><span style=\"color: #99FFFF\">Turbinio di Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">)<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/af48cc3ce2404a2ad32b4632074daafc_8792877479029929732.png",
                "id": "talent50495",
                "key": "Evocazione dello spirito primaverile",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Evocazione dello spirito primaverile"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoca 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Spirito talismano</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/0af9611ff900342f560004bd85d6e766_5392720915514375378.png",
                "id": "talent98364",
                "key": "Salvezza della divina damigella",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Salvezza della divina damigella"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infliggi 1 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2<br>Quando questa invocazione è in campo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: i personaggi avversari subiscono </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +1.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/db13288db6b90ec33f8adc2656d2019f_5053343649596134259.png",
                "id": "talent84332",
                "key": "Spirito talismano",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/48fc5942249b75b9a938f06c0f87edf3_4743840761388942658.gif",
                "title": "Spirito talismano"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Cryo e può innescare le seguenti reazioni elementali:<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve danni fisici o da Pyro, nel caso subisce DAN +2).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/4bcc4b82a9d7ee22770f60afa54e9919_4570519212722069060.png",
                "id": "talent69401",
                "key": "DAN da Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/245c229cf6f7364c7c9a7aea3db1a1ad_3446466262250828253.png",
