                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2265,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/22/35428890/497dd6fac3d3c652a367c67428550747_306268558608889633.png",
                      "name": "Tighnari",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Quest'arco, oltre a potenziare il",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Tasso di CRIT",
                      "type": "text"
                    },
                    {
                      "text": ", ha un'abilità che potenzia di molto gli",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "attacchi caricati",
                      "type": "text"
                    },
                    {
                      "text": "del personaggio che la equipaggia.",
                      "type": "text"
                    },
                    {
                      "text": "Tighnari",
                      "type": "text"
                    },
                    {
                      "text": "è perfetto per l'",
                      "type": "text"
                    },
                    {
                      "text": "Erede del sole ardente",
                      "type": "text"
                    },
                    {
                      "text": "perché gli permette di sfruttare al massimo il suo",
                      "type": "text"
                    },
                    {
                      "text": "punto di forza",
                      "type": "text"
                    },
                    {
                      "text": ", ovvero i suoi",
