                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Trailer sul gameplay di Fontaine",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/07/237301566/0226c125790005a96a6ed9fc554b713a_6325224006201757152.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "23 Agosto 2023",
                      "type": "text"
                    },
                    {
                      "text": "Abbiamo affrontato ogni sorta di pericolo senza mai perdere il coraggio di continuare ad esplorare.",
                      "type": "text"
                    },
                    {
                      "text": "Una regione nuova di zecca con un'esperienza di gioco altrettanto nuova.",
                      "type": "text"
                    },
                    {
                      "text": "Intraprendi questo nuovo viaggio su Genshin Impact con il nuovo trailer sul gameplay di Fontaine.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
