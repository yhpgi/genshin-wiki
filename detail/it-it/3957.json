    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: #FFFFFF\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/09/190184121/241eba6e4c00020975cf91170050f435_1167557925645300248.png",
                "id": "talent26057",
                "key": "Lancia splendente - Posizione del guardiano",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Lancia splendente - Posizione del guardiano"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Associa </span><span style=\"color: rgb(255, 255, 255)\">Scudo dell'airone</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">a questo personaggio e Prepara abilità:</span> <span style=\"color: rgb(255, 215, 128)\">Colpo dell'airone</span>.</p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Colpo dell'airone</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Prepara per 1 turno)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3</span> <span style=\"color: rgb(128, 192, 255)\">DAN da Hydro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/09/190184121/0c573bed12aa14547684a1c4d1c71439_2198765714527124122.png",
                "id": "talent43384",
                "key": "Rito sacro: Santuario dell'airone",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Rito sacro: Santuario dell'airone"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2</span> <span style=\"color: rgb(128, 192, 255)\">DAN da Hydro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">e crea Lode della Corona cremisi.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Lode della Corona cremisi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gli </span><span style=\"color: rgb(255, 255, 255)\">attacchi normali</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">dei tuoi personaggi infliggono DAN +1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I </span><span style=\"color: rgb(255, 255, 255)\">DAN fisici</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">inflitti dai tuoi personaggi che usano la spada, la claymore o la lancia sono convertiti in</span> <span style=\"color: rgb(128, 192, 255)\">DAN da Hydro</span>.</p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo aver cambiato personaggio, infliggi 1</span> <span style=\"color: rgb(128, 192, 255)\">DAN da Hydro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">(una volta per turno).</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Durata (in turni)</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">2.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/09/190184121/70709f7ac94263c2ab6af82889072211_6432166882757256351.png",
                "id": "talent76601",
                "key": "Rito sacro: Marea della cutrettola",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Rito sacro: Marea della cutrettola"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica </span><span style=\"color: rgb(128, 192, 255)\">Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e può innescare le seguenti Reazioni Elementali:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Vaporizzazione: </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DAN inflitti +2.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Electrocarica</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DAN inflitti +1, infligge 1</span><span style=\"color: #FFFFFF\"> DAN da perforazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> a tutti i personaggi nemici tranne al bersaglio.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Congelamento</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DAN inflitti +1, impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve</span> <span style=\"color: rgb(255, 255, 255)\">DAN fisici</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">o da</span> <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, nel caso subisce DAN +2).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fioritura</span>:<span style=\"color: rgba(255, 255, 255, 0.65)\"> DAN inflitti +1, crea un nucleo di</span> <span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">che infligge DAN +2 la volta successiva che vengono inflitti danni da</span> <span style=\"color: rgb(255, 153, 153)\">Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">o </span><span style=\"color: rgb(255, 172, 255)\">Electro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/09/190184121/a126c6a302d81c07e19cf9a9f1260f90_5576081172871390874.png",
                "id": "talent28524",
                "key": "DAN da Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Scudo</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo scudo verrà consumato per proteggere il personaggio che lo equipaggia dai DAN.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Prepara abilità</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Alcune abilità non possono essere usate direttamente, devono invece essere preparate per un certo numero di turni.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando è il turno di un giocatore e il suo personaggio attivo sta preparando un'abilità, il giocatore salterà il turno. Se l'abilità ha terminato la preparazione, il personaggio userà direttamente l'abilità in quel momento (le abilità che richiedono preparazione non possono attivare gli effetti innescati dall'uso di queste).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Solo i personaggi attivi possono preparare le abilità, e se un personaggio attivo che sta preparando un'abilità diventa inattivo, la sua preparazione verrà interrotta.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Durata (in turni)</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ogni volta che raggiungi la fase finale, la durata (in turni) verrà ridotta di 1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando la durata (in turni) sarà esaurita, questa carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/09/190184121/245c229cf6f7364c7c9a7aea3db1a1ad_3357609191235753399.png",
                "id": "talent36929",
                "key": "Spiegazione delle regole",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Spiegazione delle regole"
              }
            ]
          }
        }
      ]
