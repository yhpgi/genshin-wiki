                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "•",
                      "type": "text"
                    },
                    {
                      "text": "Durante questo periodo, utilizzate le Reazioni Elementali per distruggere il Motore Nirvana, per generare blocchi di energia e caricare il Terminale Neo Akasha.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
