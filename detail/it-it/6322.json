              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 4 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Associa </span><span style=\"color: #FFFFFF\">Porizione d'assalto</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> a questo personaggio.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/22/45954971/25e4bcd70e5c79ed88012c83939e6a12_2045508915769990446.png",
                "id": "talent15314",
                "key": "Assalto trafiggente",
                "materials": [],
