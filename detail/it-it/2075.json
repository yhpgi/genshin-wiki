            "goblet_of_eonothem": {
              "desc": "<p>Un'urna ornamentale appartenuta agli antichi aristocratici di Mondstadt. Venti funesti sembrano soffiare al suo interno.</p><p></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Noblesse Oblige/goblet_of_eonothem_icon.png",
              "id": "artifact39709",
