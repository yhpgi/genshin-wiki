    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/241eba6e4c00020975cf91170050f435_5920894189789865257.png",
                "id": "talent74821",
                "key": "Origine",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Origine"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Invoca 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Occhio del giudizio tempestoso</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/c29fd0841f95e044bae32d03dc31765a_8066558799510029118.png",
                "id": "talent13825",
                "key": "Trascendenza: Presagio minaccioso",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Trascendenza: Presagio minaccioso"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #FFACFF\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Tutti i tuoi altri personaggi ottengono 2 punti di </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Energia</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/8d02cb476ba0314a99ce5e7ecc3b4904_7088445031868075755.png",
                "id": "talent80968",
                "key": "Arte segreta: Musou Shinsetsu",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Arte segreta: Musou Shinsetsu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Passiva</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passiva) Quando inizia la battaglia, il personaggio ottiene </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Chakra Desiderata</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Chakra Desiderata</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Status</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Dopo che gli altri tuoi personaggi usano i Tripudi elementali</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: ottiene 1 Risoluzione (massimo 3 accumuli).<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando il personaggio associato utilizza Arte segreta</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Musou Shinsetsu: consuma tutti gli accumuli di Risoluzione e infligge DAN +1 per ciascun accumulo.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/f18816cd4d10b81b8610917baa51d71a_1523122855424053314.png",
                "id": "talent45398",
                "key": "Chakra Desiderata",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Chakra Desiderata"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: infliggi 1 </span><span style=\"color: #FFACFF\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 3<br></span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando questa invocazione è in campo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: i Tripudi elementali dei tuoi personaggi infliggono DAN +1.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/db13288db6b90ec33f8adc2656d2019f_8334551438156444502.png",
                "id": "talent92770",
                "key": "Occhio del giudizio tempestoso",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/75f1d2ef52221da67ee1c52ce97af966_4623244121917582277.png",
                "title": "Occhio del giudizio tempestoso"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Electro e può innescare le seguenti reazioni elementali:<br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2, scambia il bersaglio con il personaggio successivo.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Electrocarica</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Vivificazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, crea un [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Campo catalizzante</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] che aumenta di 1 i DAN da Dendro o Electro inflitti per le prossime 2 volte.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/11ea6117480145a30b7893f1e8bd7115_5026791167653740547.png",
                "id": "talent29044",
                "key": "DAN da Electro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Electro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Energia</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I personaggi devono consumare punti di energia per usare i loro Tripudi elementali.<br>Quando usano un'abilità elementale o un attacco normale, otterranno 1 punto di energia.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/245c229cf6f7364c7c9a7aea3db1a1ad_5681243610223609930.png",
                "id": "talent54498",
                "key": "Spiegazione delle regole",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Spiegazione delle regole"
              }
            ]
          }
        }
      ]
