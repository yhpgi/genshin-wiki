      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il nome completo di questa spada è straordinario:<br>Messaggera dell'alba trionfante che punta alla vittoria.<br>Solo una persona è caduta in battaglia usando questa lama.<br>Una notte, estrasse la spada in modo trionfale.<br>Il cielo notturno s'illuminò a giorno,<br>indicando la sua precisa ubicazione.<br>Su di lui cadde una pioggia di frecce.</span><br></p>",
                "id": "story12890",
                "img": "",
                "title": ""
              }
            ]
          }
        }
      ]
    },
