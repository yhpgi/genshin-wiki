          "component_id": "reliquary_set_effect",
          "data": {
            "four_set_effect": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un personaggio equipaggiato con questo set di manufatti ottiene</span> l'<span style=\"color: rgb(255, 215, 128)\">effetto Curiosità</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">come segue: quando è in campo, riceve 1 accumulo colpendo un avversario con un attacco di</span> <span style=\"color: rgb(255, 230, 153)\">Geo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, fino a una volta ogni</span> <span style=\"color: rgb(255, 215, 128)\">0,3 s</span><span style=\"color: rgba(255, 255, 255, 0.65)\">; quando non è in campo, riceve 1 accumulo ogni </span><span style=\"color: rgb(255, 215, 128)\">3 s</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. L'</span><span style=\"color: #FFD780\">effetto Curiosità</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> è cumulabile fino a 4 volte, e ciascun accumulo fornisce un</span> <span style=\"color: rgb(55, 255, 255)\">6%</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">di </span><span style=\"color: rgb(255, 215, 128)\">DIF</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e di </span><span style=\"color: rgb(255, 230, 153)\">bonus DAN da Geo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Per ogni</span> <span style=\"color: rgb(255, 215, 128)\">6 s</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> trascorsi senza ottenere un accumulo, ne perderai 1.</span></p>",
            "two_set_effect": "<p><span style=\"color: rgb(255, 215, 128)\">DIF </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+30%.</span></p>"
          }
        }
      ]
