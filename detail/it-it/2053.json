                "key": "Giustizia",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Aumenta i </span><span style=\"color: #FFE14B\">DAN</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> inflitti da attacchi normali e caricati di un </span><span style=\"color: rgb(55, 255, 255)\">20%/25%/30%/35%/40%</span><span style=\"color: rgba(255, 255, 255, 0.85)\">. Inoltre, rigenera</span><span style=\"color: #FFE14B\"> PS</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> pari a un </span><span style=\"color: rgb(55, 255, 255)\">60%/70%/80%/90%/100%</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> dell'</span><span style=\"color: rgb(255, 225, 75)\">ATT</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> quando gli attacchi normali e caricati mettono a segno un colpo </span><span style=\"color: #FFE14B\">CRIT</span><span style=\"color: rgba(255, 255, 255, 0.85)\">. Quest'effetto si può verificare una volta ogni </span><span style=\"color: #FFE14B\">5 s</span><span style=\"color: rgba(255, 255, 255, 0.85)\">.</span></p>"
                ]
