                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Soggiogamento: Koukou Sendou"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: infligge 1 </span><span style=\"color: #FFACFF\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e applica </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Copertura della Piuma corvina</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> al personaggio alleato attivo.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 1</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Copertura della Piuma corvina</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il personaggio associato a questa carta infligge DAN da </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Abilità elementale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e da </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Tripudio elementale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +1.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/db13288db6b90ec33f8adc2656d2019f_4653271723527412178.png",
                "id": "talent94880",
                "key": "Tengu Juurai: Imboscata",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/1ce18b0d1d4b2b162276892a85feea79_6369704626350907001.png",
                "title": "Tengu Juurai: Imboscata"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: infligge 1 </span><span style=\"color: rgb(255, 172, 255)\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e applica </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Copertura della Piuma corvina</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> al personaggio alleato attivo.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Copertura della Piuma corvina</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il personaggio associato a questa carta infligge DAN da </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Abilità elementale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e da </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Tripudio elementale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +1.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/db13288db6b90ec33f8adc2656d2019f_6493247940635528645.png",
                "id": "talent64077",
                "key": "Tengu Juurai: Ammassatempesta",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/7a1026e18244fc72af3873f6a6dc44ab_8253486698768911113.png",
                "title": "Tengu Juurai: Ammassatempesta"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Electro e può innescare le seguenti reazioni elementali:<br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2, scambia il bersaglio con il personaggio successivo.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Electrocarica</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Vivificazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, crea un [</span><span style=\"color: rgba(255, 255, 255, 0.85)\">Campo catalizzante</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] che aumenta di 1 i DAN da Dendro o Electro inflitti per le prossime 2 volte.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/11ea6117480145a30b7893f1e8bd7115_869542672258582246.png",
                "id": "talent73981",
                "key": "DAN da Electro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Electro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/95525664/245c229cf6f7364c7c9a7aea3db1a1ad_1303423908638763050.png",
