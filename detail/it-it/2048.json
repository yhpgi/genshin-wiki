    {
      "id": "10",
      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il maestro spadaccino Cavalcacieli discese dagli imponenti Monti di Jueyun con un salto.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Squarciò le nuvole mentre i venti gli echeggiavano tra le orecchie,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">ma ciò che seguì fu solo il rumore di ossa che si frantumavano.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quello che aveva sperato era qualcosa che l&#39;arte della spada non poteva garantirgli.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Diede in pegno la spada in cambio di medicine,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">tuttavia il suo sogno di volare non morì.</span></p>",
                "title": "Spada del Cavalcacieli"
              }
            ]
          }
        }
      ]
    },
