            "circlet_of_logos": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una corona superba, un tempo appartenuta alla Cacciatrice smeraldo. Verde e rigogliosa come la brezza nella natura più selvaggia.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Viridescent Venerer/circlet_of_logos_icon.png",
