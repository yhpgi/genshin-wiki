    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">DAN fisici</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/190184121/241eba6e4c00020975cf91170050f435_8792959388806541929.png",
                "id": "talent28960",
                "key": "Lancia spasmodica",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Lancia spasmodica"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Invoca 1 </span><span style=\"color: #FFD780\">Yuegui: Modalità di lancio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/13/190184121/c587e90a155d07517365218aff66911c_6845301457107759080.png",
                "id": "talent8567",
                "key": "Ravanelli a grappolo",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "Ravanelli a grappolo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #99FF88\">DAN da Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, genera 1 </span><span style=\"color: #FFD780\">Eredità adeptica</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Eredità adeptica</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo aver cambiato personaggio: infliggi 1 </span><span style=\"color: #99FF88\">DAN da Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e ripristina 1 PS del tuo personaggio attivo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Utilizzi: 3</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/13/190184121/37972e3c3e9c9134cd6b1357f57aa711_2704480905627932948.png",
                "key": "Cascata di giada lunare",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Cascata di giada lunare"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Evocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: infliggi 1 </span><span style=\"color: #99FF88\">DAN da Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, ripristina 1 PS del personaggio della tua squadra che ha subito la quantità di DAN maggiore.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Utilizzi: 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/13/190184121/db13288db6b90ec33f8adc2656d2019f_562847379308830318.png",
                "key": "Yuegui: Modalità di lancio",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/13/190184121/0f3a979856a1d439f1f85900b98bf648_4790028500141473866.png",
                "title": "Yuegui: Modalità di lancio"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica </span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e può innescare le seguenti reazioni elementali:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Fioritura</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, crea un nucleo di Dendro che infligge DAN +2 la prossima volta in cui vengono inflitti</span> <span style=\"color: rgb(255, 153, 153)\">DAN da Pyro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">o</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span>.</p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Ustione</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DAN inflitti +1, crea una</span> <span style=\"color: rgb(255, 215, 128)\">Fiammardente </span><span style=\"color: rgba(255, 255, 255, 0.65)\">che infligge 1</span> <span style=\"color: rgb(255, 153, 153)\">DAN da Pyro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">alla fine del turno (ha effetto 1 volta, cumulabile fino a 2 volte)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Vivificazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN +1 inflitti ora, crea un</span><span style=\"color: rgb(255, 215, 128)\"> Campo catalizzante</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">che aumenta di 1 i </span><span style=\"color: rgb(153, 255, 136)\">DAN da Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">o </span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">inflitti per le prossime 2 volte</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/13/190184121/e8cff941b5a0ff248efde360ec9e91fe_4499586275981091124.png",
                "key": "DAN da Dendro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Dendro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 Utilizzo.<br>Quando tutti gli Utilizzi saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/13/190184121/245c229cf6f7364c7c9a7aea3db1a1ad_5836365268672544285.png",
