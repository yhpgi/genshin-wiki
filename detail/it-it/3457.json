    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/17/35428890/1ce09211f025bf5470682189e0837732_3120237439942245318.png",
                "id": "talent26773",
                "key": "Megaboom!",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Megaboom!"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, questo personaggio ottiene </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Scintilla esplosiva</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Scintilla esplosiva</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Status</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando il personaggio associato usa Attacco caricato</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: spende 1 </span><span style=\"color: #FF9999\">Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">in meno e infligge DAN +1.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/17/35428890/ce0014e0d25cd397fef22aafb4b411c0_4795600972942897374.png",
                "id": "talent52541",
                "key": "Coniglio Bumbum",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Coniglio Bumbum"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, genera 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Schizzi e scintille</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> nel campo avversario.</span></p><p></p><p><strong>Schizzi e scintille</strong></p><p><span style=\"color: rgb(255, 215, 128)\">Stato di combattimento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando un personaggio della squadra a cui è associato Schizzi e scintille usa un'abilità</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infligge 2 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> al personaggio attivo della squadra.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/17/35428890/3f2b5db15d922d53d7d4db8261138f17_5326885056128373040.png",
                "id": "talent51547",
                "key": "Schizzi e scintille",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Schizzi e scintille"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Pyro e può innescare le seguenti reazioni elementali:</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Vaporizzazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2, scambia il bersaglio con il personaggio successivo.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Ustione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, crea una Fiammardente che infligge 1 DAN da Pyro alla fine del turno (ha effetto 1 volta, cumulabile fino a 2 volte).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35428890/d714b3b669cc08d1d8e34464fd7a3630_5917957699084193299.png",
                "id": "talent44273",
                "key": "DAN da Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Attacco caricato</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Prima della tua fase di azione, se il numero totale dei tuoi dadi elementali è pari, il tuo attacco normale verrà considerato come un attacco caricato.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_8149006113654367416.png",
                "id": "talent96019",
                "key": "Spiegazione delle regole",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Spiegazione delle regole"
              }
            ]
          }
        }
      ]
