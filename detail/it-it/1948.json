      "name": "Personaggi consigliati",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Personaggio",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Motivazione",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 51,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Xiao_icon.png",
                      "name": "Xiao",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Questa è l'arma di riferimento per",
                      "type": "text"
                    },
                    {
                      "text": "Xiao",
                      "type": "text"
                    },
                    {
                      "text": ". Gli",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "attacchi in picchiata",
                      "type": "text"
                    },
                    {
                      "text": ", fulcro del suo stile di gioco, si distinguono per la loro lentezza in confronto ad altri tipi di attacco e, sebbene potenziati, richiedono",
                      "type": "text"
                    },
                    {
                      "text": "danni critici",
                      "type": "text"
                    },
                    {
                      "text": ". La",
                      "type": "text"
                    },
                    {
                      "text": "Lancia di Giada Primordiale",
                      "type": "text"
                    },
                    {
                      "text": "non solo offre un sostanziale incremento di",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Tasso di CRIT",
                      "type": "text"
                    },
                    {
                      "text": ", ma garantisce anche un notevole aumento di",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "ATT",
                      "type": "text"
                    },
                    {
                      "text": "e",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "DAN",
                      "type": "text"
                    },
                    {
                      "text": ". Questi elementi sono fondamentali per assicurare all'",
                      "type": "text"
                    },
                    {
                      "text": "adepto di",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 3797,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/11/95525664/5968bc73f375ee1e3704302541c83c7f_1737337864582622329.png",
                      "name": "Liyue",
                      "type": "custom_entry"
                    },
                    {
                      "text": "la massima potenza d'attacco possibile, consentendogli di infliggere danni devastanti.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 34,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Hu Tao_icon.png",
                      "name": "Hu Tao",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Hu Tao",
                      "type": "text"
                    },
                    {
                      "text": "si distingue come un'attaccante di punta capace di infliggere",
                      "type": "text"
                    },
                    {
                      "text": "DAN",
                      "type": "text"
                    },
                    {
                      "text": "considerevoli grazie ai suoi",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "attacchi caricati",
                      "type": "text"
                    },
                    {
                      "text": "e al suo",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Tripudio elementale",
                      "type": "text"
                    },
                    {
                      "text": ". La sua efficacia è legata anche alla statistica di attacco, la quale riceve un notevole potenziamento da questa lancia. Inoltre, essa offre",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Tasso di CRIT",
                      "type": "text"
                    },
                    {
                      "text": ", completando così il",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "DAN da CRIT",
                      "type": "text"
                    },
                    {
                      "text": "ottenuto attraverso l'ascensione del personaggio. Quest'arma non solo amplifica la potenza di quest'attaccante",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ff9999"
                      ],
                      "text": "Pyro",
                      "type": "text"
                    },
                    {
                      "text": ", ma contribuisce anche ad ottimizzare la sua capacità di infliggere",
                      "type": "text"
                    },
                    {
                      "text": "danni critici",
                      "type": "text"
                    },
                    {
                      "text": ", rendendola una scelta cruciale per massimizzare il suo potenziale offensivo.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 46,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Zhongli_icon.png",
                      "name": "Zhongli",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Questa lancia si dimostra eccellente per",
                      "type": "text"
                    },
                    {
                      "text": "Zhongli",
                      "type": "text"
                    },
                    {
                      "text": ", soprattutto quando viene impiegato come attaccante secondario nel team. Il suo imponente",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Tripudio elementale",
                      "type": "text"
                    },
                    {
                      "text": "evoca un meteorite, il cui impatto richiede alcuni secondi, \"rubando\" preziosi istanti in cui è possibile infliggere",
                      "type": "text"
                    },
                    {
                      "text": "DAN",
                      "type": "text"
                    },
                    {
                      "text": ". Quest'arma non solo amplifica la capacità dell'",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffe699"
                      ],
                      "text": "Archon Geo",
                      "type": "text"
                    },
                    {
                      "text": "di infliggere",
                      "type": "text"
                    },
                    {
                      "text": "DAN critici",
                      "type": "text"
                    },
                    {
                      "text": ", ma si rivela anche fondamentale per massimizzare l'efficacia del suo potente",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Tripudio elementale",
                      "type": "text"
                    },
                    {
                      "text": ", contribuendo in modo significativo al suo ruolo nel team.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    }
