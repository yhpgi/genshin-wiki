      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/10/190184121/1ce09211f025bf5470682189e0837732_2834419467564128849.png",
                "id": "talent41153",
                "key": "Sigillo d'approvazione",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Sigillo d'approvazione"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: rgb(255, 153, 153)\">DAN da Pyro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">e associa </span><span style=\"color: #FFFFFF\">Sigillo scarlatto</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> a questo personaggio.</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Sigillo Scarlatto</span></strong></p><p><span style=\"color: #FFD780\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando il personaggio usa Attacco caricato: DAN inflitti +2.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Utilizzi: 1.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/10/190184121/ac66eaa1e741e27adcc6912a7d776c59_6127319591274114999.png",
                "id": "talent89268",
                "key": "Editto firmato",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Editto firmato"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3</span> <span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, associa Sigillo scarlatto e Fulgore a questo personaggio.</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Fulgore</span></strong></p><p><span style=\"color: #FFD780\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando il personaggio usa </span><span style=\"color: #FFFFFF\">Attacco caricato</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: spendi 1 dado di </span><span style=\"color: #FF9999\">Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">in meno (una volta per turno).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: associa </span><span style=\"color: #FFFFFF\">Sigillo scarlatto</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> a questo personaggio.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Durata (in turni): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/10/190184121/1c2e868964c7f6362b63332f33a6b087_8559184107940708671.png",
                "id": "talent82983",
                "key": "Affare fatto",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Affare fatto"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica </span><span style=\"color: #FF9999\">Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e può innescare le seguenti reazioni elementali:</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Vaporizzazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2, scambia il bersaglio con il personaggio successivo.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Ustione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, crea una Fiammardente che infligge 1 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> alla fine del turno (ha effetto 1 volta, cumulabile fino a 2 volte).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/10/190184121/d714b3b669cc08d1d8e34464fd7a3630_659761674841594257.png",
                "id": "talent88123",
                "key": "DAN da Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Attacco caricato</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Prima della tua fase di azione, se il numero totale dei tuoi dadi elementali è pari, il tuo attacco normale verrà considerato come un </span><span style=\"color: rgb(255, 255, 255)\">attacco caricato</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Durata (in turni)</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ogni volta che raggiungi la fase finale, la </span><span style=\"color: rgb(255, 255, 255)\">durata (in turni)</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> verrà ridotta di 1.<br>Quando la </span><span style=\"color: rgb(255, 255, 255)\">durata (in turni)</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> sarà esaurita, questa carta verrà eliminata.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgb(255, 255, 255)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgb(255, 255, 255)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/10/190184121/245c229cf6f7364c7c9a7aea3db1a1ad_7602798704475429303.png",
