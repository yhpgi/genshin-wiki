                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/02/237301566/9dcea984518b90140639272ad6ff252e_6217239460355895326.png"
