                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 4811,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/04/20856775/826332c1b0fb525a54df5442ee996c76_6724346575240518905.png",
                      "menu_id": 22,
                      "name": "Khaenri'ah",
                      "type": "custom_entry"
                    },
                    {
                      "text": "senza dirlo ad Ei. Non essendo una grande guerriera morì.",
