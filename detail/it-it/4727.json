    {
      "id": "25",
      "name": "Ulteriori informazioni",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">L&#39;espulsione dall&#39;Ordine della Frutta è stata un bel colpo per il mio morale. Per fortuna ho trovato un nuovo gruppo, quindi mi sento un po&#39; meglio.<br>Le operazioni di questo nuovo gruppo sono un po&#39; diverse... A ogni modo, Baccaduta l&#39;Intrepido non molla!</span></p>",
                "title": "Diario di una lotta valorosa (I)"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Bulle Scaltro, fratello mio, sei sempre nei miei pensieri.<br>Non posso credere che i piani alti abbiano mandato Giglio di calla a darti la caccia solo per la formula di quella stupida pozione. Immagino che tu sia cascato dal pero, eh?<br>Ma non preoccuparti, ho creato un gran trambusto nell&#39;Ordine della Frutta in tua difesa. Forse era questo il motivo per l&#39;espulsione, ma non ho rimpianti. Spero solo che la tua anima possa riposare in pace.<br>Nessun altro lo sa, ma ho riempito la mia nuova casa di Bulle per ricordarmi di te.<br>Sembra che i Cinque grandi agenti dell&#39;Ordine della Frutta siano rimasti in quattro.</span></p>",
                "title": "Diario di una lotta valorosa (II)"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Alla fine ho ricevuto la mia prima missione: recuperare denaro da un tizio di nome Rocher.<br>Quel vecchiaccio non sa cosa sia la vergogna per rifiutarsi di ripagare i debiti in quel modo. L&#39;ho dovuto colpire due volte e non ha fatto che sputare un mucchio di roba inutile.<br>L&#39;unica cosa che sembrava poter valere qualcosa era questo medaglione. Sembrava appartenere a una donna... Di certo non a sua moglie, eh? Incredibile.<br>Quale persona sana di mente sposerebbe un tizio del genere?</span></p>",
                "title": "Diario di una lotta valorosa (III)"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Sembra che oggi sia successo qualcosa. I Direttori dal 2 al 41 sono stati tutti portati via. A quanto pare l&#39;Uccello a vapore ha portato alla luce la nostra attività e ha coinvolto lo Spettro Maréchaussée.<br>Per fortuna sono qui da poco, quindi per ora dovrei essere al sicuro. Però non capisco... non ci occupiamo di semplici posate?<br>Beh, non importa. Per ripagare la gentilezza del capo, per prima cosa farò una visitina a quel giornale.</span></p>",
                "title": "Diario di una lotta valorosa (IV)"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">L&#39;espulsione dall&#39;Ordine della Frutta è stata un bel colpo per il mio morale. Per fortuna ho trovato un nuovo gruppo, quindi mi sento un po&#39; meglio.<br>Le operazioni di questo nuovo gruppo sono un po&#39; diverse... A ogni modo, Baccaduta l&#39;Intrepido non molla!</span></p>",
                "title": "Diario di una lotta valorosa"
              }
            ]
          }
        }
      ]
