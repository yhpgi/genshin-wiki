                {
                  "content": [
                    {
                      "text": "Amico di Baccaduta l'Intrepido dell'Ordine della Frutta, che Baccaduta l'Intrepido considera morto.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4724,
                      "icon_url": "",
                      "name": "Rocher",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Rocher era debitore dell'Elegante Tavola Confrerie, e",
                      "type": "text"
                    },
                    {
                      "text": "Baccaduta l'Intrepido",
                      "type": "text"
                    },
                    {
                      "text": "fu mandato a riscuotere il debito.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
