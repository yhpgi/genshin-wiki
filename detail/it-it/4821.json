                "key": "Utilizzo",
                "string_values": [
                  "<p><span style=\"color: #ECE5D8\">Riduce di un </span><span style=\"color: #37FFFF\">25% </span><span style=\"color: #ECE5D8\">il </span><span style=\"color: #FFE14B\">consumo di vigore </span><span style=\"color: #ECE5D8\">di tutti i membri del gruppo durante le arrampicate e gli scatti per </span><span style=\"color: #FFFFFF\">1500 s</span><span style=\"color: #ECE5D8\">. In modalità cooperativa, si applica solo ai tuoi personaggi. </span></p>"
