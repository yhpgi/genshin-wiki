          "data": {
            "list": [
              {
                "desc": "A lightweight catalyst carved out of emerald-green jade. It is durable and affordable, which makes it a popular item all around.</br>Small but exquisitely made, it is colloquially referred to by the people of Liyue as the &#34;jade ball.&#34;</br>It is a highly efficient defensive Catalyst as well as a good-looking accessory.</br>",
                "title": ""
              }
            ]
          }
