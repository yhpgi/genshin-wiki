                {
                  "content": [
                    {
                      "text": "Studenti dell'Istituto Narcissenkreutz.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Laureato dell'Istituto Narcissenkreuz e membro dell'Ordo Narcissenkreutz.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4600,
                      "icon_url": "",
                      "name": "Jakob",
                      "type": "custom_entry"
