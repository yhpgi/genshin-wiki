      "name": "Attributi",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "Nome",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Suite del vento glaciale</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Tipo",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Automi</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Tutorial",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ora è il turno delle fantastiche esibizioni dei Mekautomi Coppelia e Coppelius, presentate da Maillardet. Prima di iniziare la sfida, </span><span style=\"color: #FFD780\">parla con Maillardet</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e seleziona il nome dello spettacolo oggetto della sfida. \"Trenodia di Coppelia\" vede come protagonista la Mekautoma caricata con polarità </span><span style=\"color: #FFD780\">Ousia</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. \"Nemesi di Coppelius\", invece, segue le vicende del Mekautoma con polarità </span><span style=\"color: #FFD780\">Pneuma</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Le risorse riscattate dal </span><span style=\"color: #FFD780\">Fiore geomantico</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> dopo il completamento della sfida dipenderanno da quale selezioni.</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
