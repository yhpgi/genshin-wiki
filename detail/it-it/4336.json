{
  "id": 4336,
  "name": "Trivella mineraria",
  "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una trivella dotata di una lunga impugnatura che al giorno d'oggi risulta particolarmente rara. Veniva usata comunemente per scavare nella roccia ed esplorare i cunicoli sotterranei.</span></p>",
  "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/08/190184121/4bfc21303d8ff98cd546aae980b55090_7683119585510765591.png",
