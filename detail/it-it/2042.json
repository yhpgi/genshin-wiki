                      "name": "Beidou",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "L'arma Fendiluvio risulta essere una valida alternativa per Beidou.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Quest'arma si rivela particolarmente efficace perché Beidou, grazie ai suoi",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "talenti elementali",
                      "type": "text"
                    },
                    {
                      "text": "riesce a mantenere attivo lo stato di",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffacff"
                      ],
                      "text": "Electro",
                      "type": "text"
                    },
                    {
                      "text": "sul nemico, così da beneficiare al meglio dell'",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "abilità passiva",
                      "type": "text"
                    },
                    {
                      "text": "dell'arma. Inoltre anche l'aumento alla statistica della",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Maestria elementale",
                      "type": "text"
                    },
                    {
                      "text": "potenzia molto i",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "DAN",
                      "type": "text"
                    },
                    {
                      "text": "di Beidou, soprattutto quelli innescati con reazioni elementali come",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ff88"
                      ],
                      "text": "Accentuazione",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 21,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Sayu_icon.png",
                      "name": "Sayu",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Fendiluvio viene consigliata per Sayu in quanto il suo",
