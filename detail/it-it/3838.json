      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/c369b96fc6417e8fc2bb607e37297ad4_7970696753685300183.png",
                "id": "talent62036",
                "key": "Precisione divina",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Precisione divina"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: rgb(128, 255, 215)\">DAN da Anemo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, genera 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Zona di burrasca</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Zona di burrasca</span></strong></p><p><span style=\"color: #FFD780\">Stato di combattimento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando usi Cambia personaggio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: spendi 1 dado elementale in meno.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/71cd4eef4f88d0d2fbe713bdb4f10bc7_8771625247316030318.png",
                "id": "talent52499",
                "key": "Sonetto celeste",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Sonetto celeste"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: #80FFD7\">DAN da Anemo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoca 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">In mezzo alla tempesta</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/52a73655dbebbf779e51d5f3e2bae59a_3759988887666406429.png",
                "id": "talent43012",
                "key": "Ode all'Archon di Anemo",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ode all'Archon di Anemo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infliggi 2 </span><span style=\"color: #80FFD7\">DAN da Anemo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. L'avversario passa al </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Personaggio avversario più vicino al tuo personaggio attivo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2<br></span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Dopo che il tuo personaggio o l'invocazione innesca reazioni di Turbinio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: converti il tipo elementale di questa carta e infliggi DAN elementali dell'elemento del Turbinio (si può convertire una sola volta prima di abbandonare il campo).</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Personaggio avversario più vicino al tuo personaggio attivo</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Si intende il personaggio avversario la cui posizione è più vicina a quella del tuo personaggio attivo.<br>Se ne esiste più di uno, quello con la posizione più avanzata verrà identificato come il \"più vicino\".</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/db13288db6b90ec33f8adc2656d2019f_2777461025790675636.png",
                "id": "talent56027",
                "key": "In mezzo alla tempesta",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/481ff844d1ba46461024c9ade7a0e5db_7712201576938475410.png",
                "title": "In mezzo alla tempesta"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Innesca delle reazioni con gli elementi già applicati:<br>[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Turbinio di Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infligge 1 DAN da Cryo a tutti i personaggi nemici tranne al bersaglio.<br>[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Turbinio di Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infligge 1 DAN da Hydro a tutti i personaggi nemici tranne al bersaglio.<br>[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Turbinio di Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infligge 1 DAN da Pyro a tutti i personaggi nemici tranne al bersaglio.<br>[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Turbinio di Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infligge 1 DAN da Electro a tutti i personaggi nemici tranne al bersaglio.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/c97292d96456bfe4abeca16bfce801e4_1593187620490677199.png",
                "id": "talent97833",
                "key": "DAN da Anemo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Anemo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/30/95525664/245c229cf6f7364c7c9a7aea3db1a1ad_4169476926793977796.png",
