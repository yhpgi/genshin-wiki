    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/10316b5178d5109d597f415d6e7903dc_7597794524846042368.png",
                "id": "talent8002",
                "key": "Spada temprata",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Spada temprata"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Se nello stesso turno questa abilità è usata per 3 volte, infligge DAN +2.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/d0e27bc7054292e95c673e6f491ff677_3729784084901709977.png",
                "id": "talent61859",
                "key": "Assalto fiammante",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Assalto fiammante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 8 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, questo personaggio ottiene </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Infusione di Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Infusione di Pyro</span></strong><span style=\"color: rgba(255, 255, 255, 0.85)\"><br></span><span style=\"color: rgb(255, 215, 128)\">Status</span><br><span style=\"color: rgba(255, 255, 255, 0.65)\">I </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> inflitti dal personaggio associato sono convertiti in </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Durata (in turni): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/7f35364dc83b6694a3200aae53f6670f_6972509467247254536.png",
                "id": "talent50184",
                "key": "Alba",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Alba"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Pyro e può innescare le seguenti reazioni elementali:</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Vaporizzazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2, scambia il bersaglio con il personaggio successivo.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Ustione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, crea una Fiammardente che infligge 1 DAN da Pyro alla fine del turno (ha effetto 1 volta, cumulabile fino a 2 volte).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/05/77454259/d714b3b669cc08d1d8e34464fd7a3630_3135645163697502884.png",
                "id": "talent15289",
                "key": "DAN da Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Durata (in turni)</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ogni volta che raggiungi la fase finale, la </span><span style=\"color: rgba(255, 255, 255, 0.85)\">durata (in turni)</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> verrà ridotta di 1.<br>Quando la </span><span style=\"color: rgba(255, 255, 255, 0.85)\">durata (in turni)</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> sarà esaurita, questa carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_2735958786086240694.png",
                "id": "talent31238",
                "key": "Dettagli regole",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dettagli regole"
              }
            ]
          }
        }
      ]
