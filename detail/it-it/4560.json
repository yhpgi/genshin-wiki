              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #FFACFF\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoca 1 </span><span style=\"color: #FFD780\">Djinn</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
