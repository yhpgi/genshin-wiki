      "components": [
        {
          "component_id": "artifact_list",
          "data": {
            "circlet_of_logos": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">La corona conferita al Domatore di tuoni per aver sconfitto la Bestia tonante che aveva scatenato il caos sulla terraferma.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/circlet_of_logos_icon.png",
              "id": "artifact1949",
              "key": "circlet_of_logos",
              "posKey": "circlet_of_logos",
              "posName": "Corona della ragione",
              "position": "Corona della ragione",
              "title": "Diadema del Domatore di tuoni"
            },
            "flower_of_life": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un fiore che sboccia persino in balia di tuoni e fulmini. Ancora oggi conferisce coraggio ai viaggiatori che affrontano le tempeste.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/flower_of_life_icon.png",
              "id": "artifact28297",
              "key": "flower_of_life",
              "posKey": "flower_of_life",
              "posName": "Fiore della vita",
              "position": "Fiore della vita",
              "title": "Cuore del Domatore di tuoni"
            },
            "goblet_of_eonothem": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il calice da vino da cui una volta il Domatore di tuoni, che sconfisse la bestia tonante, bevve dei fulmini viola.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/goblet_of_eonothem_icon.png",
              "id": "artifact63856",
              "key": "goblet_of_eonothem",
              "posKey": "goblet_of_eonothem",
              "posName": "Calice eonotemo",
              "position": "Calice eonotemo",
              "title": "Calice del Domatore di tuoni"
            },
            "plume_of_death": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">La piuma di un uccello predatore che si libra attraverso tempeste di fulmini. Si dice che sia divenuta il simbolo dell'eroe leggendario che pacificò i tuoni e i fulmini.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/plume_of_death_icon.png",
              "id": "artifact67149",
              "key": "plume_of_death",
              "posKey": "plume_of_death",
              "posName": "Piuma della morte",
              "position": "Piuma della morte",
              "title": "Piuma del Domatore di tuoni"
            },
            "sands_of_eon": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una clessidra custodita dall'eroe che conquistò tuoni e fulmini. I minuscoli frammenti di Cristalli di Electro scorrono avanti e indietro con il passare del tempo.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/sands_of_eon_icon.png",
              "id": "artifact24935",
              "key": "sands_of_eon",
              "posKey": "sands_of_eon",
              "posName": "Sabbie del tempo",
              "position": "Sabbie del tempo",
              "title": "Clessidra del Domatore di tuoni"
            }
          }
        }
      ]
    },
    {
      "id": "16",
      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un fiore viola raccolto durante un temporale.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Chiunque lo indossi non teme più tuoni e fulmini.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo fiore sboccia solo durante i temporali, e non appassisce mai nonostante la pioggia costante.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo è il fiore del tuono. Con un inchino, il Domatore di tuoni lo raccolse con riverenza.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando affrontava indomito tuoni e fulmini, il Domatore di tuoni portava sempre questo fiore sul petto.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Anche durante lo scontro con la feroce Bestia tonante, la sua determinazione non vacillò mai.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Per il Domatore di tuoni, indossare questo fiore viola sarà anche stato un semplice atto vanesio,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">ma per i viaggiatori, il fiore era fonte della tenace risolutezza in grado di piegare il tuono.</span></p>",
                "img": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/flower_of_life_icon.png",
                "title": "Cuore del Domatore di tuoni"
              },
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un diadema molto antico.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Risplende della luce del fulmine placato.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">La feroce Bestia tonante</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">ridusse in schiavitù il popolo con i suoi fulmini potenti.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ma così come il fulmine durò solo un istante,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">anche la sua potenza scomparve in breve tempo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il Domatore di tuoni sconfisse la bestia durante una tempesta di fulmini.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Rivendicò questo diadema come suo trofeo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il passato, tuttavia, non può mai pacificarsi del tutto.</span></p>",
                "img": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/circlet_of_logos_icon.png",
                "title": "Diadema del Domatore di tuoni"
              },
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un calice un tempo appartenuto al Domatore di tuoni.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Forse il suo precedente proprietario lo usava per abbeverarsi del tuono.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Per quanto potente, il Domatore di tuoni non era che un semplice mortale con sentimenti umani.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">La rabbia e l&#39;estasi si susseguivano in un lampo, proprio come il martellare di un tuono.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo calice non è stato solo testimone delle prodezze del Domatore di tuoni, ma anche del suo dolore e delle sue risate.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo calice serviva a bere il vino usato in occasione dell&#39;uccisione sacrificale della famiglia del Domatore di tuoni.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Da questo calice deriva il coraggio che ha aiutato il Domatore di tuoni ad avventurarsi nella caverna della bestia.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo calice era l&#39;unica fonte di compagnia del Domatore di tuoni, che trascorse i suoi ultimi giorni in solitudine.</span></p>",
                "img": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/goblet_of_eonothem_icon.png",
                "title": "Calice del Domatore di tuoni"
              },
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un emblema a forma della piuma d&#39;un falco solito volare nelle tempeste.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Chi lo indossa è come se riuscisse a sentire il rimbombo di un tuono e il calore di un vulcano.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Non temendo né il tuono né il vulcano,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">il falco lasciò la piuma nel bosco bruciato.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il Domatore di tuoni ricreò un emblema di ametista a forma di piuma.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">L&#39;emblema viola risplendeva di luce sotto lo sguardo dei nemici.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Su questo piccolo oggetto risplendeva un fulmine,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">come a presagire la caduta della Bestia tonante.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Come il falco, il Domatore di tuoni riuscì a soggiogare sia il tuono che le fiamme,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">finendo con il decapitare la Bestia tonante.</span></p>",
                "img": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/plume_of_death_icon.png",
                "title": "Piuma del Domatore di tuoni"
              },
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una clessidra un tempo usata dal Domatore di tuoni. Al suo interno non scorre sabbia, ma minuscoli frammenti di Electro.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I frammenti si frantumano e scendono con il passare del tempo, per poi fondersi insieme sul fondo della clessidra.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il Domatore di tuoni che ha sconfitto la Bestia tonante ha realizzato questa clessidra con l&#39;ametista.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il passare del tempo è proprio come un fulmine. Irrompe nel cielo e scompare in un lampo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Persino il Domatore di tuoni non è stato in grado di dominare il fulmineo scorrere del tempo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">All&#39;interno di questa clessidra, anche il tuono e il fulmine devono obbedire alle immutabili leggi del tempo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">All&#39;interno della clessidra, i frammenti si frantumano e si fondono innumerevoli volte mentre il tempo scorre silenzioso.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dall&#39;osservazione di questo fenomeno, il Domatore di tuoni ha appreso il ciclo della vita e della morte. Forte di questa conoscenza, è riuscito a sconfiggere la bestia.</span></p>",
                "img": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Thundersoother/sands_of_eon_icon.png",
                "title": "Clessidra del Domatore di tuoni"
              }
            ]
          }
        }
      ]
    },
