      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Sii felice nel dividere la cenere dalle fiamme; rendi raffinati i materiali grezzi.<br>Poiché tutto nell&#39;universo ha la stessa origine, e ogni cosa potrebbe provenire da un singolo pensiero.<br>Devi realizzare ciò in cui tuo fratello maggiore, ovvero il cavallo bianco con un corno solo, ha fallito.<br>Raggiungi il limite più estremo della filosofia e crea un nuovo destino per me e per i tuoi fratelli...</span></p>",
                "title": "Spada cinabrica"
              }
            ]
          }
        }
      ]
