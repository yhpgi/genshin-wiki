              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 4</span> <span style=\"color: #B28659\">Dan da Geo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, il personaggio bersaglio subisce </span><span style=\"color: rgb(255, 255, 255)\">Pietrificazione.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/157266935/6081ca47e02027c0bb6a6931f17baff1_5217906532465465740.png",
