    {
      "id": "15",
      "name": "Set",
      "components": [
        {
          "component_id": "artifact_list",
          "data": {
            "circlet_of_logos": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una tiara indossata da chi offriva sacrifici nei tempi antichi. Dopo aver ascoltato il fragore dei tuoni per lungo tempo, possiede una resistenza straordinaria.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Prayers for Wisdom/circlet_of_logos_icon.png",
              "id": "artifact23446",
              "key": "circlet_of_logos",
              "posKey": "circlet_of_logos",
              "posName": "Corona della ragione",
              "position": "Corona della ragione",
              "title": "Tiara dei tuoni"
            }
          }
        }
      ]
    },
    {
      "id": "16",
      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Si dice che,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">un tempo, la gente del posto ricevesse le rivelazioni direttamente dal cielo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gli emissari degli dèi camminavano tra i retrivi esseri umani e le acque s&#39;evaporarono con l&#39;arrivo dei primi tuoni che squarciavano il cielo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">La gente godeva di una saggezza smisurata, e questa saggezza era la loro manna.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">La loro prosperità era fonte di orgoglio e ambizione, così come di interrogativi.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Così misero in dubbio l&#39;autorità dei cieli e tramarono per entrare nel giardino degli dèi.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">E sebbene avessero promesso al popolo amore divino, prosperità e saggezza, gli emissari del cielo s&#39;infuriarono.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Mettere in dubbio l&#39;eternità era proibito,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">che la terra osasse sfidare il cielo, inespiabile.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Così il sommo sacerdote con la corona di rami bianchi andò a placare gli emissari divini,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">e raggiunse le profondità della terra, in cerca della saggezza nascosta dell&#39;albero argenteo nell&#39;antica capitale...</span></p>",
                "img": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Prayers for Wisdom/circlet_of_logos_icon.png",
                "title": "Tiara dei tuoni"
              }
            ]
          }
        }
      ]
    },
