                  }
                ],
                "talent_img": "",
                "title": "Rito arcano: Guida delle anime del baratro"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(204, 191, 173)\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 4 </span><span style=\"color: rgb(255, 172, 255)\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.45)\">,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Aumenta di 2 il livello di Possessione di </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Precorritore giurato</span></p><p></p><p><span style=\"color: rgb(204, 191, 173)\">Precorritore giurato</span></p><p><span style=\"color: rgb(255, 215, 128)\">Status</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> ottieni 1 livello di Possessione.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Crea i seguenti effetti sulla base del livello di Possessione:</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">- se è pari o superiore a 2, i </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> inflitti sono convertiti in </span><span style=\"color: rgb(255, 172, 255)\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.45)\">;</span></p><ul><li><p><span style=\"color: rgba(255, 255, 255, 0.45)\">- se è pari o superiore a 4, DAN inflitti +2;</span></p></li><li><p><span style=\"color: rgba(255, 255, 255, 0.45)\">- se è pari o superiore a 6, livello Possessione -4.</span></p></li></ul>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/b6ab0891aede70ddf48bfa3859de14ea_8504213223073492021.png",
                "id": "talent60721",
                "key": "Rito sacro: Destrezza del lupo",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Rito sacro: Destrezza del lupo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(204, 191, 173)\">Abilità passiva</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">(Passiva) Quando inizia la battaglia, ottiene </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Precorritore giurato</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p><p></p><p><span style=\"color: rgb(204, 191, 173)\">Precorritore giurato</span></p><p><span style=\"color: rgb(255, 215, 128)\">Status</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> ottieni 1 livello di Possessione.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Crea i seguenti effetti sulla base del livello di Possessione:</span><br><span style=\"color: rgba(255, 255, 255, 0.45)\">- se è pari o superiore a 2, i </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> inflitti sono convertiti in </span><span style=\"color: rgb(255, 172, 255)\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.45)\">;</span></p><ul><li><p><span style=\"color: rgba(255, 255, 255, 0.45)\">- se è pari o superiore a 4, DAN inflitti +2;</span></p></li><li><p><span style=\"color: rgba(255, 255, 255, 0.45)\">- se è pari o superiore a 6, livello Possessione -4.</span></p></li></ul>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/8a173f8df2e58a9df74a6c3a74d385eb_7856491351343439898.png",
                "id": "talent3228",
                "key": "Tutore della legge",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Tutore della legge"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Applica Electro e può innescare le seguenti reazioni elementali:</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: DAN inflitti +2, scambia il bersaglio con il personaggio successivo.</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Electrocarica</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br>[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Vivificazione</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: DAN inflitti +1, crea un [Campo catalizzante] che aumenta di 1 i DAN da Dendro o Electro inflitti per le prossime 2 volte.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/05/35428890/11ea6117480145a30b7893f1e8bd7115_1940805754092367287.png",
