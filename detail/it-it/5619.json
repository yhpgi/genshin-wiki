                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5578,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/24/190184121/7557f4558ab243d82e8b6b9994fc97ee_4714692879599082052.png",
                      "menu_id": 5,
                      "name": "Scheggia di estro armonico",
                      "type": "custom_entry"
                    },
                    {
