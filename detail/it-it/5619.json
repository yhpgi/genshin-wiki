                      "ep_id": 4813,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/22/362377527/99c13f06508b070f0306b92f7c77ad20_229410702872619825.png",
                      "menu_id": 22,
                      "name": "Remuria",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
