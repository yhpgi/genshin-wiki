              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Invoca 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Sakura Sesshou</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/95525664/7e9f291d99b3519d86302e803782b2f7_5998304892722010383.png",
