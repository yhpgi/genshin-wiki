                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Evocazione di Yakan: Sakura Sesshou"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 4 </span><span style=\"color: #FFACFF\">DAN da Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Se sul tuo lato del campo è presente un </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Sakura Sesshou</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, viene distrutto, e si generano delle </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Saette Tenko</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/95525664/56f64a44b1ccee62527e2a18a46de27f_5078330880576033861.png",
                "id": "talent99807",
