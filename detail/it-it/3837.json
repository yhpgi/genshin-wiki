                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Grande arte segreta: Tenko Kenshin"
              },
              {
                "attributes": [],
                "desc": "<p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/95525664/db13288db6b90ec33f8adc2656d2019f_3289677318700632920.png",
                "id": "talent50494",
