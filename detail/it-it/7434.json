                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7301,
                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2025/01/17/02a299cec38b4ef4f21952c37a624258_5744396397316809821.png",
                      "menu_id": 2,
