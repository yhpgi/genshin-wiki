          "data": {
            "circlet_of_logos": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo copricapo intarsiato d'oro veniva un tempo usato dai sacerdoti del deserto. Erano creati a immagine di quello indossato in antichità da un leggendario sovrano dei popoli del deserto.</span></p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/23/194600931/892e17a4a5d0b9438bf3581d88bf209e_5156145824649592405.png",
              "id": "artifact85407",
              "key": "circlet_of_logos",
              "posKey": "circlet_of_logos",
              "posName": "Corona della ragione",
              "position": "Corona della ragione",
              "title": "Ombra del re delle sabbie"
            },
            "flower_of_life": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un bocciolo forgiato in oro battuto dalle tinte dorate. Il suo cuore cremisi è avvolto da petali che non si schiuderanno mai.</span></p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/23/194600931/ae8a2c6f24df66e1bd7cc2dbd83d330d_9176911893609858619.png",
              "id": "artifact44582",
              "key": "flower_of_life",
              "posKey": "flower_of_life",
              "posName": "Fiore della vita",
              "position": "Fiore della vita",
              "title": "Fiordacciaio sognante"
            },
            "goblet_of_eonothem": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una coppa per il vino che venne usata durante un antico e maestoso banchetto. Ha perso gran parte del suo lustro.</span></p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/23/194600931/3668bbfcc8d7242aa295b7e073e71d9f_7101477128624132500.png",
              "id": "artifact17769",
              "key": "goblet_of_eonothem",
              "posKey": "goblet_of_eonothem",
              "posName": "Calice eonotemo",
              "position": "Calice eonotemo",
              "title": "Banchetto mielato"
            },
            "plume_of_death": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questa piuma speciale veniva usata per pesare il cuore dei colpevoli, ma ha da tempo perso la sua funzione originaria.</span></p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/23/194600931/b195ea9ea3c908859ea4e09e409305a2_7989292675371443357.png",
              "id": "artifact93862",
              "key": "plume_of_death",
              "posKey": "plume_of_death",
              "posName": "Piuma della morte",
              "position": "Piuma della morte",
              "title": "Piuma del giudizio"
            },
            "sands_of_eon": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Sembra che questa meridiana dorata dalle tinte scure racconti antiche storie sul deserto.</span></p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/23/194600931/8842156fb124596d6a0d7aa56f8483e0_4775343880342950871.png",
