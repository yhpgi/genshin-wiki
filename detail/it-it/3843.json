              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/5472faa96cc230f0c6a742c278748e91_7034339129938839730.png",
                "id": "talent98655",
                "key": "Precetto rovente",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Precetto rovente"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoca 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fornace di fuoco oscuro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/1cfb4a644ede1096bcf61f228e14be0a_7911301973912642771.png",
                "id": "talent33009",
                "key": "Stella nefasta",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Stella nefasta"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Passiva</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passiva) Quando inizia la battaglia, ottiene </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Rinascita fiammeggiante</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Rinascita fiammeggiante</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Status</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando il personaggio associato a questa carta viene sconfitto</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: rimuovi questo effetto, conferisci </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Resilienza </span><span style=\"color: rgba(255, 255, 255, 0.65)\">al personaggio e ripristina 3 PS.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Immunità alla sconfitta</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Alcuni effetti concederanno ai personaggi un'</span><span style=\"color: rgba(255, 255, 255, 0.85)\">immunità alla sconfitta</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> quando i loro PS arrivano a 0, e ripristineranno una certa quantità in seguito. Quando ciò avviene, i personaggi non verranno considerati come </span><span style=\"color: rgba(255, 255, 255, 0.85)\">sconfitti</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>(Pertanto, il loro equipaggiamento associato e gli status non verranno rimossi, e la loro energia non verrà eliminata.)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/241466b9ccdefb6219ef6bf74cd493e2_7387328089439949026.png",
                "id": "talent66959",
                "key": "Rinascita fiammeggiante",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Rinascita fiammeggiante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infliggi 1 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN da perforazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> a tutti i personaggi inattivi avversari.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/db13288db6b90ec33f8adc2656d2019f_5919149643715397497.png",
                "id": "talent76118",
                "key": "Fornace di fuoco oscuro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Fornace di fuoco oscuro"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Pyro e può innescare le seguenti reazioni elementali:</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Vaporizzazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2, scambia il bersaglio con il personaggio successivo.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Ustione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, crea una Fiammardente che infligge 1 DAN da Pyro alla fine del turno (ha effetto 1 volta, cumulabile fino a 2 volte).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/d714b3b669cc08d1d8e34464fd7a3630_2163035818438468250.png",
                "id": "talent94942",
                "key": "DAN da Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN da perforazione</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN da perforazione non possono ricevere bonus, ma non possono essere ridotti usando degli scudi, immunità ai DAN o altri effetti.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/245c229cf6f7364c7c9a7aea3db1a1ad_571754026118664347.png",
                "id": "talent30432",
                "key": "Dettagli regole",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/2cce1877020bad6ed9476a8bb8db436c_4949773142147633382.png",
                "title": "Dettagli regole"
              }
            ]
          }
        }
      ]
