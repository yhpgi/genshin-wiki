                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio elementale</span></p><p>Infligge 6 <span style=\"color: #FF9999\">DAN da Pyro</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/07/20577441/5779f79888d140f222ce693c329228d8_3817609924289518797.png",
