    {
      "id": "10",
      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Colui che desiderava migliorare la portata e la precisione delle fionde scoprì che<br>la potenza aumentava la portata, ma a spese della precisione.<br>Quindi le pietre della fionda furono sostituite con dei lunghi paletti di legno che avevano delle piume per aumentare la stabilità.<br>I bracci della fionda furono allungati e le estremità presero una forma ricurva per aumentare la tensione.<br>Poi si rese conto di aver realizzato un arco.</span></p>",
                "title": "Fionda"
              }
            ]
          }
        }
      ]
    },
