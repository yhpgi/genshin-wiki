              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infliggi 1 </span><span style=\"color: #FFE699\">DAN da Geo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando Chiori usa un attacco normale:</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> consuma 1 dado in meno. Solo una volta per turno.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/19/157266935/db13288db6b90ec33f8adc2656d2019f_803634712207315607.png",
