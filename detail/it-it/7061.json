                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Elemento Geo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #BFBFBF\">DAN fisici</span><br></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">I </span><span style=\"color: #BFBFBF\">DAN fisici</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> non applicano alcun elemento né innescano reazioni elementali.</span><br><br><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong><br><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 Utilizzo. <br>Quando tutti gli Utilizzi saranno stati consumati, la carta verrà eliminata.</span><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/19/157266935/245c229cf6f7364c7c9a7aea3db1a1ad_4688535074147477693.png",
