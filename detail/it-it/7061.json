      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span><br><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2</span> <span style=\"color: rgb(255, 255, 255)\">DAN Fisici</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/18/157266935/94aa30ae75b8c7c6a9c64ab05bd5dda7_3608578626873721343.png",
