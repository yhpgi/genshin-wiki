                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Lama intrecciata"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità elementale<br></span><span style=\"color: rgba(255, 255, 255, 0.65)\">Seleziona 1 invocazione tra 3 </span><span style=\"color: #FFFFFF\">Robobambole di Chiori</span></p><p></p><p><span style=\"color: #FFFFFF\">Robobambole di Chiori</span><br><span style=\"color: #CCBFAD\">Invocazione</span><br><span style=\"color: rgba(255, 255, 255, 0.65)\">Diversi autonomi umanoidi realizzati da Chiori. Non solo sono in grado di attaccare autonomamente</span><br></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/19/157266935/a52ecdd3a48e6905794b67bb0225f33b_591573834780674132.png",
