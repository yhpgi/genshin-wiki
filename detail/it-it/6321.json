                "desc": "<p><span style=\"color: #FFD780\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 2</span> DAN fisici.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/18/45954971/1d3f0f9fd865748a9d08ae6ed24ba848_3617172527617370516.png",
