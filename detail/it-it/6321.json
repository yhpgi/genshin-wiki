                "title": "Netto rifiuto"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #FFD780\">DAN da Geo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e associa </span><span style=\"color: #FFFFFF\">Infusione di Geo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">a questo personaggio. Poi, </span><span style=\"color: #FFFFFF\">rimuovi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">fino a 5 carte </span><span style=\"color: #FFFFFF\">Bossolo di cristallo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> dalla tua mano.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Per ogni carta </span><span style=\"color: #FFFFFF\">rimossa </span><span style=\"color: rgba(255, 255, 255, 0.65)\">questa abilità infligge DAN +1 e ti permette di pescare 1 carta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/18/45954971/d13eff9275ac9df191b4e1f83bdd18c7_5002079829562936368.png",
                "key": "Salva cristallina",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Salva cristallina"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #FFD780\">DAN da Geo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, infligge 1 </span><span style=\"color: #FFFFFF\">DAN da perforazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> a tutti i personaggi avversari inattivi. Invoca 1 </span><span style=\"color: #FFFFFF\">Saluto della Rosula dorata</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e crea una carta </span><span style=\"color: #FFFFFF\">Bossolo di cristallo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> che viene poi aggiunta alla tua mano.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/18/45954971/628f95403aa06294879f92c054efe42d_4666725954017753513.png",
