    {
      "id": "10",
      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">I viaggi sono pieni di incontri e commiati.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Forse gli unici compagni fidati e inseparabili di chi viaggia</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">sono la spada nella mano e il sogno nel cuore.</span><br></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Prima di invecchiare, l&#39;eterno viaggiatore attraverserà una moltitudine di mondi,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">lasciandosi alle spalle solo mille storie e un futuro un po&#39; più luminoso.</span></p>",
                "title": "Spada di Narzissenkreuz"
              }
            ]
          }
        }
      ]
    },
