                    {
                      "amount": 1,
                      "display_style": "text",
                      "ep_id": 3331,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/08/77454259/03b60aec345461dae970832766ebacf8_7995216038721705213.png",
