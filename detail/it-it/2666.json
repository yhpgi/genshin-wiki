                "item_values": [],
                "key": "Spaccareti",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo aver utilizzato un'</span><span style=\"color: rgb(255, 215, 128)\">abilità elementale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, attiva l'effetto </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Cavalcaflusso</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> che infligge </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN ad area</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> pari a un </span><span style=\"color: rgb(55, 255, 255)\">80%</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> dell'ATT quando si colpisce un avversario. </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Cavalcaflusso</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> viene rimosso dopo 15 s o dopo aver inflitto i </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN ad area</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> per 3 volte. Ciascuna iterazione dei </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN ad area</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> può innescarsi ogni 2 s. Cavalcaflusso può essere attivato una volta ogni 12 s.</span></p>"
                ]
              },
