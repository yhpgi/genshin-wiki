                      ],
                      "text": "attacco caricato",
                      "type": "text"
                    },
                    {
                      "text": ". La passiva, oltre a diminuire il",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ccbfad"
                      ],
                      "text": "vigore",
                      "type": "text"
                    },
                    {
                      "text": "durante la planata, conferire un aumento dei",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "DAN",
                      "type": "text"
                    },
                    {
                      "text": "d'",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "attacco caricato",
                      "type": "text"
                    },
                    {
                      "text": "durante la mira. Questo effetto e cumulabile fino",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ccbfad"
                      ],
                      "text": "6 volte",
                      "type": "text"
                    },
                    {
                      "text": "e rimane attivo per 10 s dopo aver smesso di mirare con l'arma.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
