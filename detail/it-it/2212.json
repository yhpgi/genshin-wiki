                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Completa la Missione dell'Archon \"Capitolo I: Atto IV - Saremo di nuovo insieme\"</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Completa la Missione storia \"Capitolo dell'Historia Antiqua: Atto II - Molto più che una pietra\"</span></p>"
