              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p>Invoca 1 <span style=\"color: #FFD780\">Baron Coniglio</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/24/190184121/76c87309abe7b2f8ce49af09ba50fa38_3714720432011175243.png",
                "id": "talent47310",
