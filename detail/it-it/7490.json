                      "ep_id": 7494,
                      "icon_url": "",
                      "name": "Менелик",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Uno dei sei eroi di Natlan, guerriero del",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 6999,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/29/237301566/b3db302029d76613e2bfa33f036c565c_4703083528994467732.png",
                      "menu_id": 23,
                      "name": "Клан Цветочного Пера",
                      "type": "custom_entry"
                    },
                    {
                      "text": ". Assieme al compagno, Ngoubou, fu il secondo ad unirsi a Tenoch.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7495,
                      "icon_url": "",
                      "name": "Санхадж",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Sanhaj Kompore dei",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 6998,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/24/237301566/0ed9af441ff862c8caccc8ba87d3f4e8_3382131558213222413.png",
                      "menu_id": 23,
                      "name": "Повелители Ночного Ветра",
                      "type": "custom_entry"
                    },
                    {
                      "text": "aveva predetto l'eroica fine di sé stesso e di Tenoch, era stato persino in grado di visualizzare come, un giorno, sarebbe nato un posto che avrebbe preso il nome di \"Mare Jivari\". Nonostante tutto, egli decise di unirsi a Tenoch assieme al proprio compagno Mahamba. Dato che Tenoch aveva perso il suo Nome antico, l'Ode della resurrezione non fu in grado di riportarlo indietro.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7496,
                      "icon_url": "",
                      "name": "Буркина",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Uno dei sei eroi di Natlan, corriere dei",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 6996,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/05/237301566/79ebff2a0e10528e9129a10ee3043668_5764817952363516280.png",
                      "menu_id": 23,
                      "name": "Потомки Крон",
                      "type": "custom_entry"
                    },
                    {
                      "text": ". Egli fu il quarto ad unirsi a Tenoch, assieme al compagno Kongamato.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7492,
                      "icon_url": "",
                      "name": "Сундиата",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Capotribù dei",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 6995,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/05/237301566/eb438f45c1b23162d4b17505fc6b0205_4048251979466285119.png",
                      "menu_id": 23,
                      "name": "Дети Эха",
                      "type": "custom_entry"
                    },
                    {
                      "text": "ed uno dei sei eroi di Natlan. Prima del Cataclisma, egli convinse l'Archon di Pyro a votare per l'espulsione di Tenoch, a causa della sua passione per il combattimento. Sundjatta fu il quinto ad unirsi a Tenoch nella battaglia contro l'Abisso, assieme al compagno Muhuru.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7491,
                      "icon_url": "",
                      "name": "Тупак",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Il peggior nemico di Tenoch in gioventù, un gigante del",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 6997,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/05/237301566/bf4346b2af8799209a3a494f359067a7_8906688900072372819.png",
                      "menu_id": 23,
                      "name": "Народ Родников",
                      "type": "custom_entry"
                    },
                    {
                      "text": ". Tenoch gli inflisse delle ferite che gli lasciarono più di trecento cicatrici, gli ruppe venti ossa e lo lasciò con più di cento frammenti d'ossidiana conficcati nella carne. Tupac fu l'ultimo ad unirsi a Tenoch.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
