                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Grande velocista della",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 7000,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/29/237301566/34cbc5aa060896e731bea85173816bed_7751929454071826209.png",
                      "menu_id": 23,
                      "name": "Удел Благодатных Земель",
                      "type": "custom_entry"
                    },
                    {
                      "text": "ed eroina di Natlan, fu la prima ad unirsi a Tenoch assieme al proprio compagno, Kayeke.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
