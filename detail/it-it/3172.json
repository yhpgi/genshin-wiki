                ],
                "talent_img": "",
                "title": "Freccia Fiocco di ghiaccio"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(204, 191, 173)\">Abiltà elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 1 </span><span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, crea un </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Loto di ghiaccio</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p><p></p><p><span style=\"color: rgb(204, 191, 173)\">Loto di ghiaccio</span></p><p><span style=\"color: rgb(255, 215, 128)\">Stato di combattimento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando il tuo personaggio attivo subisce DAN</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: riduce di 1 i DAN subiti.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/30/35428890/d3562dc7ee1b952be23d991318822774_2521139183377710700.png",
                "id": "talent15939",
                "key": "Scia del Qilin",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Scia del Qilin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(204, 191, 173)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 2 </span><span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, infligge 2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN da perforazione</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> a tutti i personaggi inattivi avversari.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/30/35428890/c369b96fc6417e8fc2bb607e37297ad4_5607944934828138724.png",
                "id": "talent21404",
                "key": "Frostflake Arrow",
                "materials": [],
                "points": [
                  {
                    "point_count": 5,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Frostflake Arrow"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(204, 191, 173)\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 2 </span><span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, infligge 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN da perforazione</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> a tutti i personaggi inattivi avversari, invoca una </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Perla sacra di Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/30/35428890/6b78c979575a782c1625dce67992cf90_6743611143073519014.png",
                "id": "talent8165",
                "key": "Celestial Shower",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Celestial Shower"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(204, 191, 173)\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: infliggi 1</span><span style=\"color: rgb(153, 255, 255)\"> DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> e 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN da perforazione </span><span style=\"color: rgba(255, 255, 255, 0.45)\">a tutti i personaggi inattivi avversari.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/35428890/db13288db6b90ec33f8adc2656d2019f_929897109187337777.png",
                "id": "talent1020",
                "key": "Sacred Cryo Pearl",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/35428890/5768b83a04afeb8e581b0f7864fd39d9_2020195863022109967.png",
                "title": "Sacred Cryo Pearl"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Applica Cryo e può innescare le seguenti reazioni elementali:</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">DAN inflitti +2.</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: DAN inflitti +1, impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve danni fisici o da Pyro, nel caso subisce DAN +2).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/11/35428890/4bcc4b82a9d7ee22770f60afa54e9919_927810827928561880.png",
                "id": "talent71109",
                "key": "DAN da Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><span style=\"color: rgb(236, 229, 216)\">Dan da perforazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">I DAN da perforazione non possono ricevere bonus, ma possono essere ridotti usando degli scudi, immunità ai DAN o altri effetti.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br></span><span style=\"color: rgba(255, 255, 255, 0.45)\">Quando tutti gl</span><span style=\"color: rgba(255, 255, 255, 0.65)\">i </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.45)\">saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_4667047790094514977.png",
