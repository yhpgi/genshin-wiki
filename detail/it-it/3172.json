                "attributes": [],
                "desc": "<p><span style=\"color: rgb(204, 191, 173)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 2 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/30/35428890/c369b96fc6417e8fc2bb607e37297ad4_2446716701394848626.png",
                "id": "talent75893",
