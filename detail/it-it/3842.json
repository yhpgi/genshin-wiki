    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/1ce09211f025bf5470682189e0837732_5747740400110858400.png",
                "key": "Stalattite Cicin",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Stalattite Cicin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoca </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Cicin di Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/1a979041a9881649ba69332b20dd5820_1196373501293714082.png",
                "key": "Invocazioni offuscate",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Invocazioni offuscate"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio Elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 5 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, questo personaggio riceve </span><span style=\"color: #99FFFF\">Applicazione di Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e genera 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Scudo fluttuante Cicin</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Scudo fluttuante Cicin</span></strong></p><p><span style=\"color: #FFD780\">Stato di combattimento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Conferisce </span><span style=\"color: rgba(255, 255, 255, 0.85)\">1 punto di scudo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> al tuo personaggio attivo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando viene creato</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: se hai </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Cicin di Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> in campo, potenzia ulteriormente lo </span><span style=\"color: rgba(255, 255, 255, 0.85)\">scudo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">in base alla quantità di Utilizzi in suo possesso (aggiunge un massimo di 3 ulteriori </span><span style=\"color: rgba(255, 255, 255, 0.85)\">scudo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/8d60085e1f79ee9a2bb87006d7f2d32c_6180235206508763057.png",
                "key": "Tormenta, ramo, fioritura",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Tormenta, ramo, fioritura"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infliggi 1 DAN da Cryo.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2 </span><span style=\"color: rgba(255, 255, 255, 0.65)\">(cumulabile fino a un massimo di 3 volte)<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando Maga Cicin di Cryo dei Fatui esegue un attacco normale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: questa carta ottiene </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+1.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Se il tuo personaggio subisce DAN da reazione elementale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: questa carta subisce </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/db13288db6b90ec33f8adc2656d2019f_8863487817206622080.png",
                "key": "Cicin di Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/1467dd7dd3fec80047e77cc996621508_4906638253345221385.png",
                "title": "Cicin di Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Cryo e può innescare le seguenti reazioni elementali:<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve danni fisici o da Pyro, nel caso subisce DAN +2).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/4bcc4b82a9d7ee22770f60afa54e9919_7926306300901233565.png",
                "key": "DAN da Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Scudo</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo scudo verrà consumato per proteggere il personaggio che lo equipaggia dai DAN.</span></p><p></p><p><strong><span style=\"color: #99FFFF\">Applicazione di Cryo</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando Cryo viene applicato senza infliggere DAN, la reazione elementale innescata ignorerà gli effetti che infliggono DAN:<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: nessun effetto.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: nessun effetto.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve danni fisici o da Pyro, nel caso subisce DAN +2).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/17/95525664/245c229cf6f7364c7c9a7aea3db1a1ad_1308119078253391093.png",
