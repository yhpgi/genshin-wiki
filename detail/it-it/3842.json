                {
                  "content": [
                    {
                      "text": "Regola speciale: la Maga Cicin di Cryo dei Fatui comincia già equipaggiata con la carta talento Sguardo gelido della Cicin.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Formazione avversaria",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
