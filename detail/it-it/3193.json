              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elemental Burst</span></p><p>Deals 1 <span style=\"color: #80FFD7\">Anemo DMG</span>, summons 1 <span style=\"color: #FFFFFF\">Large Wind Spirit</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/05/35428890/28de70f699de4ba7cf0f77f2fcfb1483_7492732585692338762.png",
