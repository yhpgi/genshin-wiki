      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #99FF88\">DAN da Dendro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/24/190184121/95142c2955e1896817dc3d6ff9639ac5_9040600767404435791.png",
                "id": "talent96859",
                "key": "Agopuntura classica",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Agopuntura classica"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1</span><span style=\"color: rgb(153, 255, 136)\"> DAN da Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoca 1</span><span style=\"color: rgb(255, 215, 128)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Armonispirito</span><span style=\"color: rgb(255, 215, 128)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/24/190184121/02943d17a2ad29f325fdac70651d2bae_7056106784333742995.png",
                "id": "talent50667",
                "key": "Diagnosi universale",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "Diagnosi universale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Crea 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Purezza pulsante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e </span><span style=\"color: #99FF88\">Scudo assoluto</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Purezza pulsante</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">All'inizio della fase di azione: crea </span><span style=\"color: rgb(153, 255, 136)\">Scudo assoluto</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: 2</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Scudo assoluto</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fornisce 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">punto Scudo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, proteggendo il tuo personaggio attivo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando quest'effetto viene rimosso o generato nuovamente: infliggi </span><span style=\"color: rgb(153, 255, 136)\">1 DAN da Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e ripristina i </span><span style=\"color: rgb(255, 215, 128)\">PS </span><span style=\"color: rgba(255, 255, 255, 0.65)\">del tuo personaggio di 1.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/24/190184121/ed10b8e3def17c518055b3421bfcb94a_7546834567150318006.png",
                "id": "talent16738",
                "key": "Rinascita olistica",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Rinascita olistica"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: infliggi 1 </span><span style=\"color: #99FF88\">DAN da Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e ripristina 1 </span><span style=\"color: #FFD780\">PS </span><span style=\"color: rgba(255, 255, 255, 0.65)\">del tuo personaggio attivo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/24/190184121/db13288db6b90ec33f8adc2656d2019f_4673096107626403905.png",
                "id": "talent44476",
                "key": "Armonispirito",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Armonispirito"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e può innescare le seguenti reazioni elementali:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fioritura</span>:<span style=\"color: rgba(255, 255, 255, 0.65)\"> DAN inflitti +1, crea un </span><span style=\"color: #99FF88\">nucleo di Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> che infligge DAN +2 la prossima volta in cui vengono inflitti</span> <span style=\"color: rgb(255, 153, 153)\">DAN da Pyro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">o </span><span style=\"color: rgb(255, 172, 255)\">Electro</span>.</p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Ustione</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DAN inflitti +1, crea una</span> <span style=\"color: rgb(255, 215, 128)\">Fiammardente </span><span style=\"color: rgba(255, 255, 255, 0.65)\">che infligge 1 </span><span style=\"color: rgb(255, 153, 153)\">DAN da Pyro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">alla fine del turno (ha effetto 1 volta, cumulabile fino a 2 volte)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Vivificazione</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DAN +1 inflitti ora, crea un</span><span style=\"color: rgb(255, 215, 128)\"> Campo catalizzante</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">che aumenta di 1 i</span> <span style=\"color: rgb(153, 255, 136)\">DAN da Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">o </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> inflitti per le prossime 2 volte</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/24/190184121/e8cff941b5a0ff248efde360ec9e91fe_1923542621068414960.png",
                "id": "talent89110",
                "key": "DAN da Dendro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Dendro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 Utilizzo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando tutti gli Utilizzi saranno stati consumati, la carta verrà eliminata.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Scudo</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo scudo verrà consumato per proteggere il personaggio che lo equipaggia dai DAN.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/24/190184121/245c229cf6f7364c7c9a7aea3db1a1ad_3713434671846531098.png",
