    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">DAN fisici</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/94aa30ae75b8c7c6a9c64ab05bd5dda7_8399165211108399836.png",
                "key": "Spada del Sentiero radioso",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Spada del Sentiero radioso"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Crea 1 </span><span style=\"color: rgb(255, 215, 128)\">Scudo della Cortina onirica </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e 1 </span><span style=\"color: rgb(255, 215, 128)\">Stella cadente</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Scudo della Cortina onirica</span></strong></p><p><span style=\"color: #FFD780\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Conferisce 2 punti </span><span style=\"color: rgb(255, 215, 128)\">Scudo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">per difendere il tuo personaggio attivo.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Stella cadente</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che un tuo personaggio usa un'abilità: accumula 1 </span><span style=\"color: rgb(255, 215, 128)\">Stella notturna</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Se hai almeno 4 Stelle notturne, consuma 4 Stelle notturne e infliggi 1 </span><span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> (anche l'abilità che causa questo stato di combattimento innesca questo effetto).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando questo stato di combattimento viene causato di nuovo: accumula 2 Stelle notturne.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/de48c78ad3dc782b2dfe98bbe645f7cd_4941815211624613247.png",
                "key": "Concentrazione solenne",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Concentrazione solenne"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoca 1 </span><span style=\"color: #FFD780\">Onirisfera celestiale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/1af1d6edbe77aedd11a2e57551afb598_4277685381239998417.png",
                "key": "Culla dei sogni stellati",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Culla dei sogni stellati"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Evocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: Infliggi 1 </span><span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Se </span><span style=\"color: rgb(255, 215, 128)\">Stella cadente</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> è in gioco, può ottenere 1 Stella notturna.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Utilizzi: 2</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Stella cadente</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che un tuo personaggio usa un'abilità: accumula 1 </span><span style=\"color: rgb(255, 215, 128)\">Stella notturna</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Se hai almeno 4 Stelle notturne, consuma 4 Stelle notturne e infliggi 1 </span><span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> (anche l'abilità che causa questo stato di combattimento innesca questo effetto).</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando questo stato di combattimento viene causato di nuovo: accumula 2 Stelle notturne.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/db13288db6b90ec33f8adc2656d2019f_3656942921134509394.png",
                "key": "Onirisfera celestiale",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/8fae1317e614df75bd7911789c244c1f_2017711604889668822.png",
                "title": "Onirisfera celestiale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica </span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e può innescare le seguenti reazioni elementali:<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve danni fisici o da </span><span style=\"color: #FF9999\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, nel caso subisce DAN +2).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/4bcc4b82a9d7ee22770f60afa54e9919_4013168946834020236.png",
                "key": "DAN da Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 Utilizzo.<br>Quando tutti gli Utilizzi saranno stati consumati, la carta verrà eliminata.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Scudo</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo scudo verrà consumato per proteggere il personaggio che lo equipaggia dai DAN.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/245c229cf6f7364c7c9a7aea3db1a1ad_31902841429208208.png",
                "key": "Dettagli regole",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dettagli regole"
              }
            ]
          }
        }
      ]
