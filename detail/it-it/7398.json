                },
                {
                  "items": [
                    [
                      {
                        "content": [
                          {
                            "text": "Raccogli i materiali per allestire l'accampamento",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Trova un modo per comunicare con Re Cocco e l'altro Saurico",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Perlustra l'area dove lavorano i bracconieri di Saurici",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Attendi che il tuo compagno Saurico agisca",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Infiltrati nell'accampamento e indaga sulla situazione",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sconfiggi il capo avversario",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Torna all'accampamento dove si trova Re Cocco",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
