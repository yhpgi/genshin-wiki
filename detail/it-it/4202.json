                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Aumenta di un </span><span style=\"color: #37FFFF\">15%</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> il </span><span style=\"color: #FFD780\">Tasso di CRIT</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> di tutti i membri del gruppo per</span><span style=\"color: #37FFFF\"> 300 s.</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> In modalità cooperativa, si applica solo ai tuoi personaggi.</span></p>"
