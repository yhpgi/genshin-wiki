                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Vortice di dispersione"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità passiva</span></p><p>(Passiva) All'inizio del duello, crea 6 carte <span style=\"color: rgba(255, 255, 255, 0.85)\">Blocco di energia del Frantumaossa</span> e distribuiscile equamente nel tuo mazzo.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/27/20577441/1f7f5486da184cb626eb0891eeb2a204_754780540352746755.png",
