                  }
                ],
                "title": "Blocco di energia del Frantumaossa"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Innesca delle reazioni con gli elementi già applicati:</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br>[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Turbinio di Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> infligge 1 DAN da </span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.45)\">a tutti i personaggi nemici tranne al bersaglio.</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br>[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Turbinio di Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">infligge 1 DAN da </span><span style=\"color: rgb(128, 192, 255)\">Hydro </span><span style=\"color: rgba(255, 255, 255, 0.45)\">a tutti i personaggi nemici tranne al bersaglio.</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br>[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Turbinio di Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> infligge 1 DAN da </span><span style=\"color: rgb(255, 153, 153)\">Pyro </span><span style=\"color: rgba(255, 255, 255, 0.45)\">a tutti i personaggi nemici tranne al bersaglio.</span><span style=\"color: rgba(255, 255, 255, 0.65)\"><br>[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Turbinio di Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">infligge 1 DAN da </span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgba(255, 255, 255, 0.45)\">a tutti i personaggi nemici tranne al bersaglio.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/09/27/20577441/c97292d96456bfe4abeca16bfce801e4_3030130142899577041.png",
