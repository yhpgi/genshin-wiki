                "key": "Dominaonde di Watatsumi",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Per ogni punto dell'energia massima totale del gruppo,</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">i </span><span style=\"color: rgb(255, 215, 128)\">DAN</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">da </span><span style=\"color: rgb(255, 215, 128)\">Tripudio elementale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">del personaggio equipaggiato con quest'arma aumentano di uno</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(55, 255, 255)\">0,12%/0.15%/0.18%/0.21%/0.24%</span>. <span style=\"color: rgba(255, 255, 255, 0.85)\">In questo modo è possibile ottenere fino a un</span> <span style=\"color: rgb(55, 255, 255)\">40%/50%/60%/70%/80%</span> <span style=\"color: rgba(255, 255, 255, 0.85)\">di aumento dei</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgb(255, 215, 128)\">DAN</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">da </span><span style=\"color: rgb(255, 215, 128)\">Tripudio elementale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>"
