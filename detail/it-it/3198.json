                "desc": "<p><span style=\"color: #FFD780\">Elemental Skill</span></p><p>Deals 3 <span style=\"color: #FFFFFF\">Physical DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/b81f8bd6ae1e5b5f53807a4cd0704469_1730998430710820813.png",
