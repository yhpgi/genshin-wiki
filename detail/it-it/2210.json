                "item_values": [],
                "key": "Come si sblocca",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Completa la Missione dell'Archon \"L'onnipresenza sui mortali: Capitolo II: Atto III - L'onnipresenza sui mortali\"</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Completa la Missione storia \"Capitolo dell'Imperatrix Umbrosa: Atto II - Sogni effimeri\"</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Dominio della conquista: Fine dell'eutimia onirica",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un tempo, innumerevoli sogni fluttuavano qui come petali al vento, senza mai realizzarsi. Questa è l'origine dell'Eternità, ma anche la sua fine.</span></p>"
                ]
              }
