      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong><span style=\"color: rgb(255, 215, 128)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/30/190184121/47817b4476bcd8b44c86c87debf042f2_82522854588042528.png",
                "key": "Taglio ondulato",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Taglio ondulato"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: rgb(128, 192, 255)\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, poi esegue Preparazione abilità per </span><span style=\"color: rgb(255, 215, 128)\">Lame ondulate</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Lame ondulate</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: rgb(128, 192, 255)\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/30/190184121/d93cfa2833ead49715475616489de21c_6093993594167627285.png",
                "key": "Lama del vortice",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Lama del vortice"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #80C0FF\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e crea 1 </span><span style=\"color: #FFD780\">Maledizione delle correnti profonde</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> sul lato dell'avversario.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Maledizione delle correnti profonde</span></strong></p><p><span style=\"color: #FFD780\">evocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando i personaggi su questo lato del campo usano un'abilità elementale o un Tripudio elementale devono spendere 1 dado elementale aggiuntivo.<br></span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">Utilizzi</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">: 2</span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\"><br></span></strong></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/30/190184121/09d978772c4b7b95a9b3896de9e32f9a_7774990253664635021.png",
                "key": "Scossa torrenziale",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Scossa torrenziale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passiva) All'inizio del duello, questo personaggio ottiene Rinascita acquatica.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Rinascita acquatica</span></strong></p><p><span style=\"color: #FFD780\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando il personaggio associato viene sconfitto: rimuovi questo effetto, conferisci </span><span style=\"color: #FFD780\">Immunità alla sconfitta </span><span style=\"color: rgba(255, 255, 255, 0.65)\">al personaggio e ripristina 4 </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">PS</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">. Dopo l'attivazione dell'effetto, i </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">DAN fisici</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\"> inflitti da questo personaggio vengono convertiti in </span><span style=\"color: #80C0FF\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, e  </span><span style=\"color: #80C0FF\">DAN da Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+1.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/30/190184121/1bbe84955410406904930648b9a4dd36_6844140064438403956.png",
                "key": "Rinascita acquatica",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Rinascita acquatica"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Hydro e può innescare le seguenti Reazioni Elementali:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">+</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 255, 255)\"> Vaporizzazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN +2 per questa istanza</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">+</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 255, 255)\"> Electrocarica</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN +1 per questa istanza, infligge 1 DAN da perforazione a tutti i personaggi avversari tranne che al bersaglio.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">+</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 255, 255)\"> Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN +1 per questa istanza, il bersaglio non è in grado di eseguire alcuna azione in questo turno (può essere rimosso in anticipo dopo che il bersaglio ha ricevuto +2 DAN fisici o pirotecnici)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">+</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 255, 255)\"> Fioritura</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN+1 per questa istanza, crea un [Nucleo di Dendro] che conferisce +2 DAN alla prossima istanza di DAN da Pyro/Electro</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/30/190184121/a126c6a302d81c07e19cf9a9f1260f90_7345823993816589075.png",
                "key": "DAN da Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Preparazione abilità</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Alcune abilità non possono essere usate direttamente, devono invece essere preparate per un certo numero di turni.<br>Quando è il turno di un giocatore e il suo personaggio attivo sta preparando un'abilità, il giocatore salterà il turno. Se l'abilità ha terminato la preparazione, il personaggio userà direttamente l'abilità in quel momento (le abilità che richiedono preparazione non possono attivare gli effetti innescati da \"dopo aver usato un'abilità\", \"dopo aver innescato una reazione elementale\" e altri effetti simili).<br>Solo i personaggi attivi possono preparare le abilità, e se un personaggio attivo che sta preparando un'abilità diventa inattivo, la sua preparazione verrà interrotta.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 Utilizzo.<br>Quando tutti gli Utilizzi saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/30/190184121/245c229cf6f7364c7c9a7aea3db1a1ad_4970221525717385115.png",
                "key": "Dettagli regole",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dettagli regole"
              }
            ]
          }
        }
      ]
