    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">2</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">DAN fisici</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/248396191/c369b96fc6417e8fc2bb607e37297ad4_6330240183098927241.png",
                "id": "talent75749",
                "key": "Stile Kätzlein",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Stile Kätzlein"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2</span> <span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, crea uno</span> <span style=\"color: #FFD780\">Scudo felino</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Scudo felino</span></strong><br><span style=\"color: rgb(255, 215, 128)\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Conferisce 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">punto Scudo</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\"> al tuo personaggio attivo.</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/248396191/e0be64da66db784af5d4f957d93b6fad_64541825980148024.png",
                "id": "talent27380",
                "key": "Zampe glaciali",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Zampe glaciali"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, ripristina 2 PS di questo personaggio, invoca 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">Foschia ubriaca</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/248396191/e4f93c5be05671f9b5a666361ad4812a_2504578341379306671.png",
                "id": "talent17824",
                "key": "Miscela d'autore",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Miscela d'autore"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Evocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: infligge 1 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e ripristina 2 PS del tuo personaggio attivo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/db13288db6b90ec33f8adc2656d2019f_2504032674282208523.png",
                "id": "talent95801",
                "key": "Foschia ubriaca",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/998d17590e24d8a0adee347db3a6940a_8433519426754091820.png",
                "title": "Foschia ubriaca"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica </span><span style=\"color: #99FFFF\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e può innescare le seguenti reazioni elementali:<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve danni fisici o da Pyro, nel caso subisce DAN +2).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/4bcc4b82a9d7ee22770f60afa54e9919_5233779379245811813.png",
                "id": "talent86982",
                "key": "DAN da Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Scudo</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo scudo verrà consumato per proteggere il personaggio che lo equipaggia dai DAN.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando tutti gli </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">Utilizzi </span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_8402408491807862621.png",
