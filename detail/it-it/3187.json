                "desc": "<p><span style=\"color: #FFD780\">Elemental Skill</span></p><p>Deals 3 <span style=\"color: #FFACFF\">Electro DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/5a7f4821eca7816e8d923684ccee651c_5472608320432600513.png",
                "id": "talent11750",
