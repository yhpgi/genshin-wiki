    {
      "id": "10",
      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Una spada affidabile ed equilibrata realizzata con fine acciaio.<br>L&#39;unico aspetto negativo è la struttura parziale del suo codolo che la rende meno durevole delle sue controparti con codolo intero.<br>Tuttavia, il codolo parziale permette di nascondere all&#39;interno dell&#39;elsa coltelli, forbici, acciarini e altri oggetti.<br>Da qui il nome: Spada del viaggiatore. Contiene qualsiasi tipo di oggetto utile per i viaggiatori.</span></p>",
                "title": "Spada del viaggiatore"
              }
            ]
          }
        }
      ]
    },
