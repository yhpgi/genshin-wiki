      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p>Uno strumento persuasivo, in grado di ribaltare le sorti di un&#39;accesa discussione in favore del suo detentore. Aggiunge sicuramente peso alle parole.</p><p>Utile in qualsiasi discussione a far ragionare l&#39;avversario, indipendentemente da chi sia.</p><p>La gente tende ad ascoltare le perle di saggezza.</p><p>Alla fine, la produzione venne forzatamente interrotta a causa delle proteste di massa.</p><p>I bisogni dei più superano i bisogni del singolo.<br></p>",
                "title": ""
              }
            ]
          }
        }
      ]
