                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/01ccafbe27188aef259b0286fd0b4545_5821415811604590793.png",
                "title": "Lamaombra: Burrasca solitaria"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocazione</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale:</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infliggi 1 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br></span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/db13288db6b90ec33f8adc2656d2019f_2317053597213363343.png",
                "id": "talent73263",
                "key": "Lamaombra: Gelo galoppante",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/e7a414623d5d709d441b0ca6779155bf_3917648203763179978.png",
                "title": "Lamaombra: Gelo galoppante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Innesca delle reazioni con gli elementi già applicati:</span><br><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Turbinio di Cryo</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1</span> <span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">a tutti i personaggi nemici tranne al bersaglio</span><br><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Turbinio di Hydro: </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1</span><span style=\"color: rgb(128, 192, 255)\"> DAN da Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">a tutti i personaggi nemici tranne al bersaglio</span><br><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Turbinio di Pyro</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1</span> <span style=\"color: rgb(255, 153, 153)\">DAN da Pyro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">a tutti i personaggi nemici tranne al bersaglio</span><br><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anemo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Turbinio di Electro</span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1</span> <span style=\"color: rgb(255, 172, 255)\">DAN da Electro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">a tutti i personaggi nemici tranne al bersaglio</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/c97292d96456bfe4abeca16bfce801e4_6681933097716502143.png",
                "id": "talent1702",
                "key": "DAN da Anemo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Anemo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica Cryo e può innescare le seguenti reazioni elementali:<br>[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2<br>[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio<br>[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve danni fisici o da Pyro, nel caso subisce DAN +2)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/4bcc4b82a9d7ee22770f60afa54e9919_1147109571799907491.png",
                "id": "talent22490",
                "key": "DAN da Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che l'effetto di questa carta è stato innescato, viene consumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.<br>Quando tutti gli </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_1137416361430477944.png",
