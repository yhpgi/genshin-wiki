              {
                "item_values": [],
                "key": "Utilizzo",
                "string_values": [
                  "<p>Aumenta di un <span style=\"color: #ECE5D8\">20%</span> il <span style=\"color: #FFD780\">tasso di CRIT</span> e i <span style=\"color: #FFD780\">DAN da CRIT</span> di tutti i membri del gruppo per <span style=\"color: #ECE5D8\">300 s</span>. In modalità cooperativa, si applica solo ai tuoi personaggi.</p>"
