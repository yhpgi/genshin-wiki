          "data": {
            "circlet_of_logos": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una tiara indossata da chi offriva sacrifici nei tempi antichi. Dopo essere stata immersa nell'acqua per lungo tempo, possiede una resistenza straordinaria.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Prayers for Destiny/circlet_of_logos_icon.png",
              "id": "artifact9928",
              "key": "circlet_of_logos",
