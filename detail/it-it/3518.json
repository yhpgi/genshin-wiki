                      "text": "Trailers and teasers della storia",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Teaser della storia - Yaksha, gli Adepti Guardiani",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/12/12694555/0b73555458e426e544cc52fb4f7524f1_4897541340004208652.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "27 Gennaio 2021",
                      "type": "text"
                    },
                    {
                      "text": "Alatus è il re dalle ali dorate e anche il conquistatore dei demoni. Nessuno sa da dove sia venuto, né dove sia andato. Solo in primavera, durante l'offerta notturna delle lanterne, la gente potrebbe vedere il bagliore di Guyun e dire: \"Ecco, il vigile Yaksha pone fine al dominio dei demoni!\" Oppure potrebbero sentire il suono di un flauto tra le canne palustri, ma non trovare nessuno che suoni il flauto, e quindi diri: \"Ascolta, lo yaksha chiama per convocare i suoi vecchi amici nella loro terra natale\".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Teaser della storia: Ricordi del Passato",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/23/237301566/68227850eb221e54dc2b6c91f89e1436_291937187263281196.png"
