              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(204, 191, 173)\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 2 </span><span style=\"color: rgb(153, 255, 136)\">DAN da Dendro</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, invoca 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Cuilein-Anbar</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/203f06aaab30d1a11fe235682c8bf13e_6289507987694219937.png",
