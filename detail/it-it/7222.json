    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: #FFD780\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 2 </span><span style=\"color: #FFFFFF\">DAN fisici</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/06/45954971/241eba6e4c00020975cf91170050f435_3735709089148229318.png",
                "key": "Lancia della Chiesa",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Lancia della Chiesa"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 1 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, crea 2 accumuli di </span><span style=\"color: #FFFFFF\">Esaminare i punti deboli </span><span style=\"color: rgba(255, 255, 255, 0.45)\">(quando l'effetto di Esaminare i punti deboli viene innescato, crea </span><span style=\"color: #FFFFFF\">Colpisci dove fa più male</span><span style=\"color: rgba(255, 255, 255, 0.45)\">).</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Esaminare i punti deboli</span></strong></p><p><span style=\"color: #FFD780\">Stato di combattimento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Dopo che il tuo personaggio ha utilizzato un'abilità: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">per ogni accumulo di questo effetto, esiste un 10% di probabilità di creare lo stato </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Colpisci dove fa più male. </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Dopodiché, il numero di accumuli di questo effetto viene dimezzato (arrotondato per difetto).</span></p><p></p><p><strong><span style=\"color: #FFFFFF\">Colpisci dove fa più male</span></strong></p><p><span style=\"color: #FFD780\">Stado di combattimento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando infliggi DAN da abilità: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">rimuovi questo stato e raddoppia i DAN inflitti.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/06/45954971/9ec392a13f4b379cb1bf584823f2ccf6_1579292165470454698.png",
                "key": "Confessione devastante",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Confessione devastante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 1 </span><span style=\"color: rgb(153, 255, 255)\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, crea 2 accumuli di </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Esaminare i punti deboli</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> e invoca </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Lancia del gelo eterno</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Esaminare i punti deboli</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Stato di combattimento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Dopo che il tuo personaggio ha utilizzato un'abilità: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">per ogni accumulo di questo effetto, esiste un 10% di probabilità di creare lo stato </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Colpisci dove fa più male. </span><span style=\"color: rgba(255, 255, 255, 0.45)\">Dopodiché, il numero di accumuli di questo effetto viene dimezzato (arrotondato per difetto).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/06/45954971/ae16855c8b660cd79949ed838a7d0ea4_3788302643163000031.png",
                "key": "Sacramento finale",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Sacramento finale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocazione</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Fase finale: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">infliggi 1 </span><span style=\"color: #99FFFF\">DAN da Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> e crea 1 accumulo di </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Esaminare i punti deboli </span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi: 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/06/45954971/db13288db6b90ec33f8adc2656d2019f_5455512792859357096.png",
                "key": "Lancia del gelo eterno",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [
                  {
                    "description": "",
                    "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/06/45954971/9c8d0f6e6f09b7685da506b0948c1e47_2603602895938677111.png"
                  }
                ],
                "title": "Lancia del gelo eterno"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Applica </span><span style=\"color: #99FFFF\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.45)\">e può innescare le seguenti reazioni elementali:<br>[</span><span style=\"color: #99FFFF\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #FF9999\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: #FFFFFF\">Fusione</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: DAN inflitti +2.<br>[</span><span style=\"color: #99FFFF\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #FFACFF\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: #FFFFFF\">Superconduzione</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: DAN inflitti +1, infligge 1 DAN da perforazione a tutti i personaggi nemici tranne al bersaglio.<br>[</span><span style=\"color: #99FFFF\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.45)\">+ </span><span style=\"color: #80C0FF\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.45)\">] </span><span style=\"color: #FFFFFF\">Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.45)\">: DAN inflitti +1, impedisce al bersaglio di eseguire azioni durante il turno corrente (può essere rimosso in anticipo se riceve danni fisici o da </span><span style=\"color: #FF9999\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.45)\">, nel caso subisce DAN +2).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/06/45954971/4bcc4b82a9d7ee22770f60afa54e9919_3199132442554157399.png",
                "key": "DAN da Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "DAN da Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(255, 255, 255)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Dopo che l'effetto di questa carta è stato innescato, viene cosumato 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Quando tutti gli Utilizzi saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/12/06/45954971/245c229cf6f7364c7c9a7aea3db1a1ad_5268311932469626857.png",
