      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una notte, un ufficiale dei Milleliti bevve con un poeta e portò con sé la sua caratteristica alabarda dal pennacchio bianco.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">L&#39;inchiostro del poeta venne versato.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">E il pennacchio bianco dell&#39;alabarda si tinse di nero.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">&#34;Non è che una storia di un soldato armato di lancia e di un poeta.&#34;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">&#34;Non ha niente a che vedere con la mia lancia dal pennacchio nero.&#34;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il vecchio fabbro diede uno schiaffo al suo apprendista.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Aveva preteso che tingesse di nero il pennacchio dell&#39;ascia appena realizzata.</span></p>",
                "title": "Pennacchio nero"
              }
            ]
          }
        }
      ]
    },
