                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Obiettivi della missione",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "items": [
                    [
                      {
                        "content": [
                          {
                            "text": "Segui il",
                            "type": "text"
                          },
                          {
                            "amount": 0,
                            "display_style": "text",
                            "ep_id": 5084,
                            "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/18/237301566/f8b14cc4415930d04b94be9318be76c2_7088199573100602624.png",
                            "name": "Little Mao",
                            "type": "custom_entry"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Prova a entrare nella cascata",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Esplora il dominio",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Ripulisci la pittura rupestre",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Parla col Piccolo Mao",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Raggiungi la torre di guardia del",
                            "type": "text"
                          },
                          {
                            "styles": [
                              "color:rgb(236, 229, 216)"
                            ],
                            "text": "Pontile Yilong",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Parla col Piccolo Mao",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Sali a bordo della zattera di bambù e raggiungi la",
                            "type": "text"
                          },
                          {
                            "styles": [
                              "color:rgb(236, 229, 216)"
                            ],
                            "text": "Bocca di Giada",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Ascolta le storie del passato",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Raggiungi la",
                            "type": "text"
                          },
                          {
                            "styles": [
                              "color:rgb(236, 229, 216)"
                            ],
                            "text": "Bocca di Giada",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Parla col Piccolo Mao",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Perlustra il santuario di pietra (0/2)",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Torna al di sotto della giada",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Prova a usare la tua energia adeptica...",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Salta nel vortice",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Segui la carpa",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Parla con la Carpa dorata",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Raccogli l'energia adeptica dispersa (0/4)",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Torna dalla Giada pluviale votiva",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Parla col Piccolo Mao",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "text": "Raggiungi il luogo indicato",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ]
