                      "name": "Yanfei",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Tra i personaggi consigliati per quest'arma, sicuramente",
                      "type": "text"
                    },
                    {
                      "text": "Yanfei",
                      "type": "text"
                    },
                    {
                      "text": "è la più indicata, visto che sia il suo",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "attacco normale",
                      "type": "text"
                    },
                    {
                      "text": "che quello",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "caricato",
                      "type": "text"
                    },
                    {
                      "text": "ricoprono un ruolo importante quando la si utilizza sul campo.",
                      "type": "text"
                    },
                    {
                      "text": "Yanfei sarà in grado di sfruttare a pieno l'",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "abilità passiva",
                      "type": "text"
                    },
                    {
                      "text": "dell'arma che andrà a potenziare i due attacchi, oltre a ottenere un",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "bonus",
                      "type": "text"
                    },
                    {
                      "text": "alla",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "Ricarica di energia",
                      "type": "text"
                    },
                    {
                      "text": "grazie alla statistica secondaria.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4023,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/09/27/157266935/0513aa7f482dbb4778545d02f94956fe_7174467864028517893.png",
                      "name": "Neuvillette",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Questo catalizzatore non rientra tra le scelte principali per",
                      "type": "text"
                    },
                    {
                      "text": "Neuvillete",
                      "type": "text"
                    },
                    {
                      "text": ", in quanto è preferibile concentrarsi sul danno per la statistica secondaria, ma può ritenersi una valida alternativa data la forza del suo",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "attacco caricato",
                      "type": "text"
                    },
                    {
                      "text": "che verrebbe ulteriormente potenziata dall'",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "abilità passiva",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    },
                    {
                      "text": "Importante",
                      "type": "text"
                    },
                    {
                      "text": ": qualora si equipaggiasse quest'arma, bisognerà spendere più risorse per trovare i manufatti che coprano le statistiche principali di Neuvillette.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4022,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/14/190184121/58c492a324aed90aaf6f73edf9422e24_2773739058760974963.png",
                      "name": "Wriothesley (In arrivo)",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Wriothesley",
                      "type": "text"
                    },
                    {
                      "text": "è tra i personaggi che potrebbe beneficiare molto di questo catalizzatore in quanto il suo set di mosse dà un ruolo importante agli",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "attacchi normali e caricati",
                      "type": "text"
                    },
                    {
                      "text": ", come per Yanfei.",
                      "type": "text"
                    },
                    {
                      "text": "Inoltre la statistica secondaria di",
