    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">DAN fisici</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/ad8a357fa8480f61f3fe665b69d9c263_1992358770801761366.png",
                "key": "Tiro furtivo",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Tiro furtivo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 3 </span><span style=\"color: #80C0FF\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, questo personaggio ottiene 2 accumuli di </span><span style=\"color: #FFD780\">Squarcio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Squarcio</span></strong></p><p><span style=\"color: #FFD780\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo stato comincia con 1 accumulo di </span><span style=\"color: #FFD780\">Squarcio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Quando viene associato di nuovo, aggiungine 1, fino a un massimo di 3.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: ottieni 1 accumulo di </span><span style=\"color: #FFD780\">Squarcio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando il personaggio associato usa un attacco normale: se li possiede, consuma 2 accumuli di </span><span style=\"color: #FFD780\">Squarcio </span><span style=\"color: rgba(255, 255, 255, 0.65)\">per convertire i </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">DAN fisici</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\"> inflitti in </span><span style=\"color: #80C0FF\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e pescare 1 carta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/b0033b9dfbdff746cfb03c7b73792a34_3259919564425901989.png",
                "key": "Linea persistente",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Linea persistente"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 1 </span><span style=\"color: #80C0FF\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, crea 1 </span><span style=\"color: #FFD780\">Dado raffinato</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Dado raffinato</span></strong></p><p><span style=\"color: #FFD780\">Stato</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo che il tuo personaggio usa un </span><span style=\"color: #FFD780\">attacco normale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: infliggi 2 </span><span style=\"color: #80C0FF\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Durata (in turni): 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/f92e763ec4e356d65ffc75d9443b7d22_5749178443309364093.png",
                "key": "Dado Chiaroprofondo",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Dado Chiaroprofondo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità passiva</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passiva) All'inizio del duello, questo personaggio ottiene </span><span style=\"color: #FFD780\">Squarcio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Questo stato comincia con 1 accumulo di </span><span style=\"color: rgb(255, 215, 128)\">Squarcio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Quando viene associato di nuovo, aggiungine 1, fino a un massimo di 3.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fase finale: ottieni 1 accumulo di </span><span style=\"color: rgb(255, 215, 128)\">Squarcio</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando il personaggio associato usa un attacco normale: se li possiede, consuma 2 accumuli di </span><span style=\"color: rgb(255, 215, 128)\">Squarcio </span><span style=\"color: rgba(255, 255, 255, 0.65)\">per convertire i </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">DAN fisici</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\"> inflitti in </span><span style=\"color: rgb(128, 192, 255)\">DAN da Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> e pescare 1 carta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/9c5eb94adf31a35a1dcf456b08342b00_5109793289218490551.png",
                "key": "Squarcio",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Squarcio"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica </span><span style=\"color: rgb(128, 192, 255)\">Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e può innescare le seguenti Reazioni Elementali:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">+</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 255, 255)\"> Vaporizzazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN +2 per questa istanza</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">+</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 255, 255)\"> Electrocarica</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN +1 per questa istanza, infligge 1 DAN da perforazione a tutti i personaggi avversari tranne che al bersaglio.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">+</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 255, 255)\"> Congelamento</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN +1 per questa istanza, il bersaglio non è in grado di eseguire alcuna azione in questo turno (può essere rimosso in anticipo dopo che il bersaglio ha ricevuto +2 DAN fisici o pirotecnici)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">+</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">]</span><span style=\"color: rgb(255, 255, 255)\"> Fioritura</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN+1 per questa istanza, crea un [</span><span style=\"color: rgb(153, 255, 136)\">Nucleo di Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] che conferisce +2 DAN alla prossima istanza di </span><span style=\"color: rgb(255, 153, 153)\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> o </span><span style=\"color: rgb(255, 172, 255)\">Electro</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/a126c6a302d81c07e19cf9a9f1260f90_7762074402201077861.png",
                "key": "DAN da Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Durata (in turni)</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ogni volta che raggiungi la fase finale, la durata (in turni) verrà ridotta di 1.<br>Quando la durata (in turni) sarà esaurita, questa carta verrà eliminata.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/15/190184121/245c229cf6f7364c7c9a7aea3db1a1ad_8238402497384558897.png",
