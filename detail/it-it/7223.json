                  }
                ],
                "title": "Bollaschiuma rinvigorente grande"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Carta evento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando peschi questa carta: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">infliggi 2 </span><span style=\"color: #80C0FF\">Dan da Hydro </span><span style=\"color: rgba(255, 255, 255, 0.45)\">al personaggio attivo sul lato del campo su cui si trova questa carta. Crea 1 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Bollaschiuma rinvigorente piccola </span><span style=\"color: rgba(255, 255, 255, 0.45)\">e aggiungila in cima al mazzo del tuo avversario.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/25/45954971/db13288db6b90ec33f8adc2656d2019f_2071639851345829377.png",
