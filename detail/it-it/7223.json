                  }
                ],
                "title": "Bollaschiuma rinvigorente media"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Carta evento</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">Quando peschi questa carta: </span><span style=\"color: rgba(255, 255, 255, 0.45)\">ripristina 1 PS di tutti i tuoi personaggi. Crea una </span><span style=\"color: rgba(255, 255, 255, 0.85)\">Goccia d'acqua sorgiva.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/25/45954971/db13288db6b90ec33f8adc2656d2019f_1501114172229387129.png",
