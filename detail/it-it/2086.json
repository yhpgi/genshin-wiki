    {
      "id": "15",
      "name": "Set",
      "components": [
        {
          "component_id": "artifact_list",
          "data": {
            "circlet_of_logos": {
              "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una tiara indossata da chi offriva sacrifici nei tempi antichi. Dopo aver sopportato il freddo glaciale per lungo tempo, possiede una resistenza straordinaria.</span></p>",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Prayers to Springtime/circlet_of_logos_icon.png",
              "id": "artifact38094",
              "key": "circlet_of_logos",
              "posKey": "circlet_of_logos",
              "posName": "Corona della ragione",
              "position": "Corona della ragione",
              "title": "Tiara del gelo"
            }
          }
        }
      ]
    },
    {
      "id": "16",
      "name": "Descrizione",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Si dice che,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">la stirpe dei sommi sacerdoti fosse solita vedere sempre questo stesso spettacolo quando i loro giorni volgevano al termine:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">una montagna di corone in un luogo segreto, al di sotto di un albero appassito...</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">...Ognuna con un&#39;esistenza di segreti custoditi.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ogni sommo sacerdote che si ritira offre la sua corona di rami bianchi a questo mondo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un giorno, ogni potente e antica città e ogni austero luogo di sacrificio dovranno tornare nelle profondità della terra.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un giorno, tutta la prosperità dovrà finire.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ma ciò non significa che non esista nulla di eterno.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Alla fine di un ciclo, la terra sarà rinnovata. L&#39;eternità è ciclica.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">La ricerca della verità è il frutto della prosperità, e non il seme che la pianta.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Si dice che</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">un tempo, la gente del posto ricevesse direttamente le rivelazioni di Celestia.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Gli emissari degli dèi camminavano tra i retrivi esseri umani. In quei giorni, la vita era tenue e la terra ricoperta di un ghiaccio senza fine.</span></p>",
                "img": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Prayers to Springtime/circlet_of_logos_icon.png",
                "title": "Tiara del gelo"
              }
            ]
          }
        }
      ]
    },
