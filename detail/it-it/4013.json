                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Descrizione sfida",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Un duello esaltante è il prodotto del contributo di entrambi i giocatori, quindi per favore dai il massimo.\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#ece5d8"
                      ],
                      "text": "Regola speciale: \"Albedo\" inizia il duello con la Carta Talento \"Discesa divina\" equipaggiata.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Formazione avversaria",
                      "type": "text"
                    }
