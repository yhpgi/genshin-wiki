            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFE699\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Infligge 2</span> DAN fisici<span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p>",
