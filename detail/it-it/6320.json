    {
      "id": "48",
      "name": "Abilità",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Attacco normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: #FFFFFF\">DAN fisici.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/19/45954971/ac85f420fede2390c2e850f3061458c4_2389434705846492416.png",
                "id": "talent79297",
                "key": "Baionetta d'avanguardia modificata",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Baionetta d'avanguardia modificata"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: #FFFFFF\">Al termine dell'abilità</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: se nella tua mano c'è una carta </span><span style=\"color: #FFFFFF\">Pallottola sovraccarica</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, </span><span style=\"color: #FFFFFF\">rimuovi </span><span style=\"color: rgba(255, 255, 255, 0.65)\">1 di queste carte e ripristina i PS del personaggio del tuo gruppo che ha subito la maggior quantità di DAN.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/19/45954971/52cd1e5b70e7ea798b5a41cd9a51fbef_2178156913490585941.png",
                "id": "talent34586",
                "key": "Fuoco d'interdizione rapido a corto raggio",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Fuoco d'interdizione rapido a corto raggio"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Tripudio elementale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligge 2 </span><span style=\"color: #FF9999\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, crea 1 </span><span style=\"color: #FFFFFF\">Scoppio ausiliario </span><span style=\"color: rgba(255, 255, 255, 0.65)\">sul lato dell'avversario.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/19/45954971/a36c7a9c9512124baf0b482d8dc69912_855129234437492620.png",
                "id": "talent96058",
                "key": "Cerchio di deflagrazione",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Cerchio di deflagrazione"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Abilità passiva</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passiva) </span><span style=\"color: #FFFFFF\">Dopo che un personaggio avversario subisce DAN da Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: crea 1 carta </span><span style=\"color: #FFFFFF\">Pallottola sovraccarica</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> nella tua mano (una volta per turno).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/19/45954971/4b48c030ba601eab2fe4d2375057a617_381464881823124811.png",
                "id": "talent7799",
                "key": "Coordinazione della forza verticale",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Coordinazione della forza verticale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applica </span><span style=\"color: rgb(255, 153, 153)\">Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">e può innescare le seguenti reazioni elementali:</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Fusione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Vaporizzazione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +</span> <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Sovraccarico</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +2, scambia il bersaglio con il personaggio successivo.</span><br><span style=\"color: rgba(255, 255, 255, 0.85)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+</span> <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">] Ustione</span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DAN inflitti +1, crea una Fiammardente che infligge 1 </span><span style=\"color: rgb(255, 153, 153)\">DAN da Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> alla fine del turno (ha effetto 1 volta, cumulabile fino a 2 volte).</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/20/45954971/d714b3b669cc08d1d8e34464fd7a3630_1400284466395385508.png",
                "key": "DAN da Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DAN da Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">DAN fisici</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">I DAN fisici non applicano alcun elemento né innescano reazioni elementali.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Azione di combattimento</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Una volta completata un'azione di combattimento, il turno passerà all'avversario.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Giocare una carta della mano con questa regola significa eseguire un'azione di combattimento, anziché un'azione rapida.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Rimozione</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Usa le carte azione o gli effetti delle abilità dei personaggi per rimuovere le carte azione dalla tua mano o dal mazzo.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Utilizzi</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dopo l'effetto di questa carta è stato innescato, viene consumato 1 Utilizzo.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando tutti gli Utilizzi saranno stati consumati, la carta verrà eliminata.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/20/45954971/245c229cf6f7364c7c9a7aea3db1a1ad_2551387065994521327.png",
                "key": "Spiegazione delle regole",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Spiegazione delle regole"
              }
            ]
          }
        }
      ]
    },
