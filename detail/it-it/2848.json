                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3608,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/01/114296447/2270aba02b92034d7d76b4426be8f53b_7075080426658357718.png",
