                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "DAN",
                      "type": "text"
                    },
                    {
                      "text": "prodotto dall'esplosione dei",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "nuclei di Dendro",
                      "type": "text"
                    },
                    {
                      "text": "da lui creati, sia sulle",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "cure",
                      "type": "text"
                    },
                    {
                      "text": "che il personaggio riceve grazie al suo primo talento passivo \"",
                      "type": "text"
                    },
                    {
                      "text": "Impresa dell'architetto",
                      "type": "text"
                    },
                    {
                      "text": "\". Inoltre il",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "bonus all'ATT",
                      "type": "text"
                    },
                    {
                      "text": ", fornito dalla passiva dell'arma sia al personaggio attivo che agli alleati, consente all'architetto di amplificare in modo generale il suo",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "DAN",
                      "type": "text"
                    },
                    {
                      "text": "di attaccante in campo, andando ad aumentare anche i",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "DAN",
                      "type": "text"
                    },
                    {
                      "text": "di tutto il gruppo.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
