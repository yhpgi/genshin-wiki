                {
                  "content": [
                    {
                      "text": "Per",
                      "type": "text"
                    },
                    {
                      "text": "Kaveh",
                      "type": "text"
                    },
                    {
                      "text": ", la",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Maestria elementale",
                      "type": "text"
                    },
                    {
                      "text": "gioca un ruolo fondamentale sia sul",
