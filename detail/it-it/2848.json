                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "ATT",
                      "type": "text"
                    },
                    {
                      "text": ". Questo rende l'",
                      "type": "text"
                    },
                    {
                      "text": "Acquamarina di Makhaira",
                      "type": "text"
                    },
                    {
                      "text": "un'arma molto utile per la piccola ninja di",
                      "type": "text"
