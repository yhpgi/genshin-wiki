                      "ep_id": 3798,
                      "icon_url": "",
                      "name": "Inazuma",
                      "type": "custom_entry"
                    },
                    {
                      "text": ", in quanto la",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Maestria elementale,",
                      "type": "text"
                    },
                    {
                      "text": "offerta dall'arma come attributo secondario, incrementa i danni della Reazione",
