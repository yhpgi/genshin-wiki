                      "text": "Trailer della Versione 2.4 \"Fleeting Colors in Flight\"",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/30/35428890/5436bc37c9fa8bbe7f08a76db7291394_2765378202140216845.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "26 Dicembre 2021",
                      "type": "text"
                    },
                    {
                      "text": "Dove la luce giunge a malapena, tra le ombre si nasconde un infido nemico.",
                      "type": "text"
                    },
                    {
                      "text": "In un reame privo della luce del sole, gli incendi rimasti bruciano ancora.",
                      "type": "text"
                    },
                    {
                      "text": "Dove il sole brilla, la speranza delle persone fiorisce eternamente.",
                      "type": "text"
                    },
                    {
                      "text": "Questi desideri provenienti dal profondo del cuore, brillano luminosi come i fuochi d'artificio nel cielo.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Illustrazioni e Emoji",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Panoramica generale della Versione 2.4",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/01/25/237301566/fe15d6fb7dd3d9e2ffd20bae3d76a5f3_5191856518630880492.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "26 Dicembre 2021",
                      "type": "text"
                    },
                    {
                      "text": "Durante l'evento, potrai accettare una commissione da parte di Ioroi e accompagnare il tanuki Kichiboushi in un viaggio a Mondstadt e Liyue per ottenere arredi esclusivi dell'evento, primogemme, Ingegno dell'eroe, materiali per l'aumento di livello dei talenti, materiali per l'ascensione delle armi e altri premi.",
                      "type": "text"
