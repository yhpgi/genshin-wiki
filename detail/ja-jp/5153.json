              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素スキル</span></p><p><span style=\"color: #99FFFF\">氷元素ダメージ</span>を1与え、目標に<span style=\"color: #FFFFFF\">スナップシルエット</span>を付与する。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/224893084/54adbd6e0af44cff009737afb67b0409_5315989546459822499.png",
