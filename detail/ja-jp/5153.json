          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">通常攻撃</span></p><p><span style=\"color: #99FFFF\">氷元素ダメージ</span>を1与える。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/224893084/464df75643b85d808ea7457d333c2520_4814393943652906225.png",
