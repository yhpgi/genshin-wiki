                ],
                "talent_img": "",
                "title": "万民のカルナバル"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">固有スキル</span></p><p>【固有】戦闘開始時、手札<span style=\"color: #FFFFFF\">聖俗の座客</span>を生成する。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/02/224893084/be37947534ecad684025e9577469afa4_2535793572668195634.png",
