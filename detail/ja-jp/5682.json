                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "サロン・ソリティア"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素爆発</span></p><p><span style=\"color: #80C0FF\">水元素ダメージ</span>を2与え、<span style=\"color: #FFFFFF\">もろびとこぞりて</span>を生成する。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/02/224893084/e5d9f5e8170236ccfb246be6a8bee57f_5020789010279332868.png",
                "id": "talent95383",
                "key": "万民のカルナバル",
