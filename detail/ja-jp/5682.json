      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">通常攻撃</span></p><p><span style=\"color: rgb(255, 255, 255)\">物理ダメージ</span>を2与える。</p><p><span style=\"color: #FFFFFF\">各ラウンドで1回のみ</span>：手札に<span style=\"color: #FFFFFF\">聖俗の座客</span>がない場合、手札<span style=\"color: #FFFFFF\">聖俗の座客</span>を生成する。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/02/224893084/26b9736a2d14fc4162b2448963f45695_6199271936750620333.png",
                "id": "talent1606",
                "key": "ソリストの誘い",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "ソリストの誘い"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素スキル</span></p><p><span style=\"color: #FFFFFF\">フリーナ</span>は現在「アルケー：ウーシア」状態で、<span style=\"color: #FFFFFF\">サロンメンバー</span>を召喚する。</p><p>（「アルケー：プネウマ」状態の時は、<span style=\"color: #FFFFFF\">衆の水の歌い手</span>を召喚する）</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/02/224893084/47e3b8a03c0e9406c19655e1aa7c3b30_6180604051750053189.png",
