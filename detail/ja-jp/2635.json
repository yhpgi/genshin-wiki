      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/13/86506456/71d97abb7c1e3533cfd493ebcfd26a97_4821568466626317235.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">「ウェーブボート」は不思議な海の乗り物。「ボートポイント」を通して主のところに戻ることができ、ウェーブボートに近寄ると乗ることができます。<br>1人につき1台しか所有できません。</span></p>",
                "key": "ページ　1/3"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/13/86506456/27cb10d6befdbf0de4cf23413fd442b8_7292320404366399971.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">ウェーブボートは「加速」で航行速度を上げることができます。</span></p><p><span style=\"color: #FFFFFF\">ウェーブボートには「迅撃砲」と「重砲」の2種類の魔法武装が設置されています。重砲は威力が大きいですが、発射後にクールタイムがあります。</span></p>",
                "key": "ページ　2/3"
              },
              {
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/13/86506456/9e5bcab788d15a66331bb8a4c6b8756b_3778482410140797383.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">ジャンプボタン長押しで操縦を停止し、ウェーブボートから離れることができます。</span></p><p><span style=\"color: #FFFFFF\">ウェーブボートから離れた後、再び近寄ることで操縦可能になります。また、「ボートポイント」を使えば自分のそばに召喚することができます。</span></p>",
                "key": "ページ　3/3"
              }
            ],
            "pic": ""
          }
        }
