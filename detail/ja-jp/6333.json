      "name": "ギャラリー",
      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "id": "gallery_character3396",
                "img": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2024/07/17/160b26d9fbc7cd327e4d7461378cb76e_3306124380288880987.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">「幻想シアター」の公演挑戦で一定の条件を満たすと、軌跡の鍵を受け取れます。<br>軌跡の鍵を2本消費するたびに、1名のキャラクターの「空想の軌跡」挑戦ステージが開放されます。挑戦をクリアすると、対応キャラクターの軌跡外観報酬を獲得できます。</span></p>",
                "key": "チュートリアル"
              },
