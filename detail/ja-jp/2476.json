    {
      "id": "36",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "いいものね…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "宝児：",
                      "type": "text"
                    },
                    {
                      "text": "こんにちは、旅人。君も古跡の見学？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "なにしてるの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "宝児：",
                      "type": "text"
                    },
                    {
                      "text": "下見…コホン、考古中だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "…下見？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "宝児：",
                      "type": "text"
                    },
                    {
                      "text": "えっと、君の聞き間違いだ。私は考古学学者、今帰離原の古代建築と遺物を研究している。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "考古？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "宝児：",
                      "type": "text"
                    },
                    {
                      "text": "うん、今君が踏んでる土地は数千年前の魔神戦争の戦場だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "宝児：",
                      "type": "text"
                    },
                    {
                      "text": "つまり岩王帝君が敵を倒した戦場だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "宝児：",
                      "type": "text"
                    },
                    {
                      "text": "この地下には、きっと無数の宝物がまだ埋まっている。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "宝児：",
                      "type": "text"
                    },
                    {
                      "text": "どんなお宝があるか知りたいな…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "宝児：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、元気でな！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
