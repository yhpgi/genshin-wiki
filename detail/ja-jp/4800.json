    {
      "id": "93",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "助手がいれば…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "はぁ…こんな時に助手がいれば…ああ、すみません。ただの独り言です。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "冒険挑戦",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "七聖召喚対戦へ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "対戦の勝敗で分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "勝利時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "カードゲームには負けたし、研究も進まないし。ああ…もう、一体どうしたら！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "敗北時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "本気でぶつかり合えて嬉しかったです。気分上々で、活力が湧いてきました。今後の研究もうまくいくと思います！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "なにか悩み事？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "グ…実は僕、古代歴史を研究する学者です…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "この前、玉霞姉さんおかげである文献を手に入れましたが、とても勉強になりました！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "玉霞姉さんはこの雪山で文献を見つけたらしいです。きっとまだたくさんの孤本がここに隠されているでしょう…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "文献の量が増えると、きっと僕の研究も一層進めることができると思います。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "古代の金貨や武器よりも、文献のほうがよほど貴重です！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "会話報酬の分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "何か収穫はあった？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "はあ、玉霞姉さんがあまりにも忙しかったから、仕方なく一人で山に入りましたが…文献を見つけるところか、危うく命を落としかけましたよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "ですが、まったく収穫がなかったわけではありません。ほら、この冠を見てください。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "これは恐らく雪山を征服しようとした先人が残したものでしょう。彼らが一体どのような困難と試練に立ち向かったのか、今となってはもう分かりません…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "…それを知りたいのなら、このようなものから垣間見るしかないでしょう…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "あ、すみません、お喋りがすぎましたね…これについての研究はもう終わりましたので、あなたに差し上げますよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "遠慮しないでください。僕よりも、あなたが持っている方が役に立つでしょう。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2062,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Blizzard Strayer/flower_of_life_icon.png",
                      "menu_id": 5,
                      "name": "氷風を彷徨う勇士",
                      "type": "custom_entry"
                    },
                    {
                      "text": "(氷雪を踏む音★4)を獲得",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "スティーブンス：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。お気を付けください。ここは異常に危険な地です…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
