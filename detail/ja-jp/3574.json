    {
      "id": "68",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "19:00～06:00のみ",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "特別な品…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "ハリソン：",
                      "type": "text"
                    },
                    {
                      "text": "シーッ！お客さん「仕入れ」に来たのか？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ハリソン：",
                      "type": "text"
                    },
                    {
                      "text": "静かに、いい物を見せてやる…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "いい物…？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ハリソン：",
                      "type": "text"
                    },
                    {
                      "text": "もちろん、俺たち「万国雑貨」の品物は、各国の商人から手に入れた選りすぐりの品物だ。気に入るものがきっとあるはずだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "まさか密…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ハリソン：",
                      "type": "text"
                    },
                    {
                      "text": "シーッ！おいおい、バカ言っちゃいけねぇ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ハリソン：",
                      "type": "text"
                    },
                    {
                      "text": "これは外国の品物だ、密輸なわけないだろ？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ハリソン：",
                      "type": "text"
                    },
                    {
                      "text": "君も外国人なんだ、分かるだろ、な？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ハリソン：",
                      "type": "text"
                    },
                    {
                      "text": "何か必要があれば、うちに来て買い物するといい。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ハリソン：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、何か必要な時は真っ先にここに来てくれよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
