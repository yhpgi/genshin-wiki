                      ],
                      "text": "概要",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3535,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/20/224893084/129d362656b40d0e6d16e7f1248ff3cc_8175722068698837202.png",
                      "menu_id": 10,
                      "name": "ノーラ",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "パットンの娘",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中1：",
                      "type": "text"
                    },
                    {
                      "text": "蒲公英酒…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中2：",
                      "type": "text"
                    },
                    {
                      "text": "酒場サービスタイム中！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "さあ、入って入って？「エンジェルズシェア」サービスタイム中！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "冒険挑戦",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "七聖召喚対戦へ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "対戦の勝敗で分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "勝利時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "こ、こんなミスを！なんで！？くっ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "敗北時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "勝った！今回はミスしてないぞ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "「エンジェルズシェア」について。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "かなり前に…アカツキワイナリーが創設された時かな、オープンしたんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "今の「エンジェルズシェア」もワイナリーのオーナーのディルック様が管理してる。しかも昔よりも繁盛してるんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "モンド一だと言ってもいいかな？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "ディルック様は機嫌がいい時は、バーテンダーになってくれるんだ。いつも担当してるチャールズが休めるようにね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "彼がバーテンダーとして仕事してる時はマナーに気を付けて！彼はモンドで一番のお金持ちだからね…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "モンドの酒造業について。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "モンドの気候、水源と農作物、酒作りにとって最高な環境だ…風神のご加護と言えるのだろう！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "リンゴ酒やさくらんぼ酒はかなり美味しいんだ。そうだ、特に蒲公英酒がおすすめ！あれはまさに美味だよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "璃月の商会を通じて、モンドの酒は大陸中に輸出されるんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "どこでもいい値段売れるし、「モラの瓶」という言葉もあるんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "だからこそ「アカツキワイナリー」のオーナーはお金持ちなんだろうね…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:君 ♀:あなた)自身について。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "忠告するよ…この店の酒瓶には触れないほうがいい…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "この前僕が割ったやつは前のオーナーが大事にしてた特製ワインだ…北の方に別荘があるのが見えるかな？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "…あの別荘と同じ値段のワインだよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "ざっと計算すると、僕はあと48年もバイトしないといけない…もちろん、飲まず食わず休まずという前提でね…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "うん、望みがないわけじゃないみたいだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "もう話はおしまい。自由のために働かないといけないからね、はははは…コホン…うっ…うううう…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "大丈夫、ありがとう。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "もう行くのかい？モンドのお酒を嗜むところはここ以外ないよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "会話報酬の分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "最近何か割引とかない？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "今なら鳥肉と野生キノコの串焼きをプレゼントしてるよ、最高の酒のお供だよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "パットン：",
                      "type": "text"
                    },
                    {
                      "text": "さあ、ちゃんと持って、中へどうぞ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
