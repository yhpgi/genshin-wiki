            "list": [
              {
                "id": "gallery_character83429",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/08/86506456/c076652355b38d8969065098a25e825f_6787084209512335476.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">「プライマル光錐」は、キングデシェレト遺跡にある不思議なエネルギーブロックです。近づくと一緒に移動するようになります。</span></p>",
                "key": "ページ　1/3"
              },
              {
                "id": "gallery_character27223",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/08/86506456/2ca7b42123c19d00ea8f4df331c1e56d_4345114299256393582.png",
                "imgDesc": "<p><span style=\"color: rgb(255, 255, 255)\">「擬造基石」は特殊な足場です。プライマル光錐を持って擬造基石に近づくと、</span><span style=\"color: rgb(255, 225, 75)\">遺跡機械を作り出して</span><span style=\"color: rgb(255, 255, 255)\">冒険の手助けをしてくれます。この方法により作り出した機械は、操作に特殊な権能を必要としません。</span></p>",
                "key": "ページ　2/3"
              },
              {
                "id": "gallery_character72427",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/08/86506456/7392fa15353989e290978ab9f5a313bd_2774070183585964336.png",
                "imgDesc": "<p><span style=\"color: rgb(255, 255, 255)\">擬造基石が作り出せる遺跡機械は常光ユニット、減光ユニット、秘匿ユニット、正体ユニット、プライマル燭台、プライマル砂時計です。プライマル光錐と擬造基石を利用して、遺跡の奥深くまで進んでみましょう…</span></p>",
                "key": "ページ　3/3"
              }
            ],
