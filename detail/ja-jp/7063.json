          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: #FFD780\">通常攻撃</span></p><p><span style=\"color: #FFFFFF\">物理ダメージ</span>を2与える。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/09/346851886/3e35605b5b8ba7b28cc8f4394de0d690_8973424658670874984.png",
                "id": "talent39650",
                "key": "薙ぎ払うフローラルリング",
                "points": [
                  {
                    "point_count": 1,
