              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素爆発</span></p><p><span style=\"color: #FF9999\">炎元素ダメージ</span>を6与える。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/16/94675339/08fa1c00d9cb1a8beffa180bf1427e18_4825067713730400232.png",
                "id": "talent36921",
                "key": "旋回烈焔",
                "materials": [],
                "points": [
