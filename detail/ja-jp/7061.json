              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">召喚物</span></p><p><span style=\"color: rgb(255, 255, 255)\">エンドフェーズ：</span><span style=\"color: rgb(255, 230, 153)\">岩元素ダメージ</span>を1与える。</p><p><span style=\"color: rgb(255, 255, 255)\">使用可能回数：2</span></p><p><span style=\"color: #FFFFFF\">このカードがフィールドに存在する時、千織以外の味方キャラがスキルを発動した後、</span><span style=\"color: rgb(255, 230, 153)\">岩元素ダメージ</span>を1与える。（各ラウンドで1回のみ）</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/09/346851886/db13288db6b90ec33f8adc2656d2019f_2854834955505872452.png",
