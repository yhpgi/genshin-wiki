    {
      "id": "93",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "もつ焼き…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "出来立ての中原のもつ焼き、美味しいわよ！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "某バカ以外は、みんな美味しいって言ってくれたわ！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "少し食べ物を買いたい。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "ええ、全部出来立て熱々よ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ショップ画面へ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "もつ焼き…？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "あら、もつ焼きを知らないの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "この中原のもつ焼きはチ虎岩のご当地グルメよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "動物の内臓を細かくして、チ虎魚のゼラチンとデンプンと調味料を入れて肉団子にするの。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "揚げると美味しくてね、生臭さは一切なく、いい香りがするのよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "ただもつ焼きを知らない人に説明するのは毎回疲れるけどね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "会話報酬の分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "内臓…？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "安心しな、ちゃんと処理してるから、綺麗よ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "内臓系を食べないお客さんも、一口食べたら手放せない人が多いわよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "食べてみな、金は取らないわ。美味しかったらまたおいで！",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 242,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Zhongyuan Chop Suey_icon.png",
                      "menu_id": 9,
                      "name": "中原のもつ焼き",
                      "type": "custom_entry"
                    },
                    {
                      "text": "×4を獲得",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "バカって？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "倉庫管理者の犬三以外、他にないでしょ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "彼がひとりで倉庫の管理してるのを見て、せっかく料理を作って差し入れたのに…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "美味しいかって聞いたら、食べ物はしょっぱさと辛さがあればいいって言ったのよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "お客さん、そんなのあんまりじゃない！せっかく作ってあげたのに！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "考えると腹が立ってきたわ！料理に対する考え方を絶対に変えてやるわ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "蘇二おば：",
                      "type": "text"
                    },
                    {
                      "text": "今度は友達も呼びなさい、割引してあげるわよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
