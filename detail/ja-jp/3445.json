                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "text",
                      "ep_id": 2960,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/28/86506456/2b53e6df68fddc3e675b83ad7339db61_3783531626890303375.png",
                      "name": "赤砂の石板",
                      "type": "custom_entry"
                    },
                    {
                      "text": "を研究する学者。ジェブラエルとジェイドを傭兵として雇った。",
