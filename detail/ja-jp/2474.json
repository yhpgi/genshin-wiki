                      ],
                      "text": "概要",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2475,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/07/194600931/d25b3be1004cca5f06e520fdf13e6ab3_8280936964401159101.png",
                      "menu_id": 10,
                      "name": "アナ",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "アンソニーの妹",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "（アナの病気が治る前）19:00～06:00",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中1：",
                      "type": "text"
                    },
                    {
                      "text": "アナ…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中2：",
                      "type": "text"
                    },
                    {
                      "text": "いい収穫だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "今日はいい感じだ…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "うわっ！？夜中になにするんだ！びっくりした！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "なんだよ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "な、なんでもないよ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "いいや、見られたし…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "この池はただの池なのに、いつの間にか願いが叶う池になったんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "金がここで無駄になるより、俺が使ったほうがいいだろ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "そうだ、金が必要だ…だから秘密にしてほしいんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "コイン拾ってなにするの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "アナ…俺の妹だ。お前も昼間に会ったことがあるかもしれない。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "あの子は難しい病気にかかっている…だからよくこの嚊水に来てコインを投げて願い事するんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "はあ、なんであの子なんだろう。そんなやさしくていい子なのに…そんなことなら俺が…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "このコインは薬代になるんだ。もちろん昼間もちゃんと働いてる！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "本当に神がいるんだったら、許してくれるはずだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "大丈夫。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "用がないならあまり驚かすなよ。心臓に悪い…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "（アナの病気が治った後）19:00～06:00",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "（アナが冒険者になった後）06:00～19:00",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "一歩ずつ着実に…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "また護送任務なの…これでもう何回目…？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "私の実力を発揮できるような…そんな依頼はないのかな…？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "一歩ずつ進んでいくことも大切だと思うぞ。そう焦らないほうがいいんじゃないか。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "最近はどう？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "あっ、旅人！こんにちは。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "私は…「一歩ずつ」地道に冒険活動をしてるよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "「護送依頼」、「護送依頼」、それが終わるとまた「護送依頼」。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "そうそう、アナはこういった依頼が得意なんだよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "俺が見る限り、もはや「護送依頼」の達人とも言えるレベルだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "お兄ちゃん！もう何日もこんな任務ばっかりなんだよ！私は大冒険がしたいの！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "だから、一歩ずつ着実に、な？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "うぅ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "今はもう体調は大丈夫なの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "私？うん、とっても元気だよ！むしろ、体力が有り余ってるくらい！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "そうだな、食事の量を見ても元気なのが分かるくらいだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "お兄ちゃん！ちょ…ちょっと多く食べただけでしょ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "それに、お兄ちゃんの料理が美味しいせいだもん！私のせいにしないで！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "じゃあ、今晩は何が食べたい？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "鳥肉のスイートフラワー漬け焼きっ！それからパンケーキと…鳥肉と野生キノコの串焼きも！あとは…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アナ：",
                      "type": "text"
                    },
                    {
                      "text": "うん、ばいばい。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "またな。えっと、その…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "アンソニー：",
                      "type": "text"
                    },
                    {
                      "text": "ありがとう、旅人。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
