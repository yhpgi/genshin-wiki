    {
      "id": "36",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "06:00～19:00のみ",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "へへっ、怪談聞くかい？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "やあ、若者よ。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:君 ♀:あなた)は…？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "ハハッ…村のガキたちには鬼じぃと呼ばれてるよ。怪談を話すのは得意だからね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "なに？お前さんも聞きたいのかい？ちゃんと心の準備をして、腰を抜かさないようにな！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "分かった。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "冥ちゃんというお嬢さんがいてな、とても可愛らしいが、運がよくなくてな、病気でなくなったんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "その母君はショックのあまり、毎日泣いて泣いて、家にこもるようになったんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "しかしある日、ノックの音が聞こえてな…ドン、ドン、ドン…母君はビクビクしながら、ドアを開けてみたんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "そこには熱々のスープと一皿の肉が置いてあって、しかし人の姿が全くないんだ…冥ちゃんの母君は困惑しながら、匂いを辿って探したんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "気付いたら母君はヒルチャールの集落にいた！ヒルチャールたちはすぐさま彼女を包囲して、彼女は思わず目を閉じてしまったんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "しばらくし、「タタッ…タタッ…」という音が聞こえた…母君がゆっくりと目を開けると、そこにいたのは…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "冥ちゃん生前最も好きなダンスを踊っているヒルチャールたちだ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "その時、彼女の背中は何かに優しくぶつけられたが、そこには誰もいなくて、ただ甘く、懐かしい匂いがしたんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "母君の目から涙が落ちた。死んだ冥ちゃんはひとりぼっちじゃない、友達がたくさんいるんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "温かい話だった…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "何バカなことを言ってるんだい。冥ちゃんは幽霊だぞ、怖くないのかい？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "全く、お前さんの考えが分からないよ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "ビックリした。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "へへっ…わしの一番得意な怪談だ、失敗したことはないぞ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "何よりもすごいのは…この話、嘘じゃないからな…へへへっ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "やめておく…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "ハッ…お前さんなら村のガキたちよりは度胸があると思ったけどな…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "まあよい…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "鬼じぃ：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、怪談が聞きたくなったらまた来てくれ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
