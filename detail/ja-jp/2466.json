    {
      "id": "36",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "貯金…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "：",
                      "type": "text"
                    },
                    {
                      "text": "あっ！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "急に話しかけてこないでくれないか、ビックリした…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "お前のせいで、せっかく決めたことを忘れてしまったじゃないか…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "：",
                      "type": "text"
                    },
                    {
                      "text": "岩王帝君の死について…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "はぁ、俺たち商売人は誰に祈ればいいんだ？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "岩王帝君が亡くなって神託が消えた今、俺みたいなやつが商売を続けるなんて無理に決まってる！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "まあ、お前に言っても意味はないけどな。さっさと金を貯めるかどうか考えるとするか…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "：",
                      "type": "text"
                    },
                    {
                      "text": "なにしてるの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "はあ、俺はただの船員で、苦労して稼いだ金を貯金したほうがいいかについて考えている…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "なあ、俺は金を貯めたほういい？貯めないほうがいい？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "：",
                      "type": "text"
                    },
                    {
                      "text": "貯めれば？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "しかし貯めれば、商機を見逃すかもしれない…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "この岩王帝君の領士で商売するのは結構儲かるからな…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "この金を商売に使って、更に多くの金を稼いだら、いつか凝光様と同じ船を買えるかもしれない…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "：",
                      "type": "text"
                    },
                    {
                      "text": "貯めないようにすれば？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "しかし、もし商売が失敗したら、何も残らないぞ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "それに七星は今、市場の動向をコントロールしてるから、万が一方向性を間違えたら…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "俺が苦労して手に入れた金が全部水の泡だ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "呉船長：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、もう邪魔するな…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
