              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素スキル</span></p><p><span style=\"color: rgb(255, 172, 255)\">雷元素ダメージ</span>を2与え、<span style=\"color: rgb(255, 255, 255)\">アフターサービス弾</span>を召喚する。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/06/75248538/3cb2c89592400bfe33db1c94218adcb0_1340235856383871235.png",
