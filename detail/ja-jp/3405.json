                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Ver.5.1限定イベント「キャンディと薔薇の歌」期間中",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "不思議な手触り…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルハーム：",
                      "type": "text"
                    },
                    {
                      "text": "こんにちは。えっと…ちょっとお聞きしたいのですが…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルハーム：",
                      "type": "text"
                    },
                    {
                      "text": "あの特別なキャンディを持っていますか？キャンディタワーから落とされたあれです。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルハーム：",
                      "type": "text"
                    },
                    {
                      "text": "友達から少しもらったんですけど…美味しさより、どんな材料を使っているのかが気になりまして。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルハーム：",
                      "type": "text"
                    },
                    {
                      "text": "触った感じは柔らかいのに、散らばった時の衝撃で砕けていない。もしかしたら、服にも使えるんじゃないかと思ってるんです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
