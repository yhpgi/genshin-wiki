      "name": "ギャラリー",
      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "id": "gallery_character67926",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/12/132746206/079d5486fd57171b1184c705c3c339b9_7312007651369690643.png",
                "imgDesc": "<p><span style=\"color: rgb(255, 255, 255)\">セットで設置するギミック。通常、構成要素には以下のものが含まれます。</span></p><p><span style=\"color: rgb(255, 255, 255)\">軌道、晶塊、晶塊の台座、晶塊の移動を制御する装置(例えば調整弁、弾性弁)。また、軌道にはディスパッチスイッチもあります。</span></p><p><span style=\"color: rgb(255, 225, 75)\">調整弁</span><span style=\"color: rgb(255, 255, 255)\">などの装置を通して、すべての晶塊を</span><span style=\"color: rgb(255, 225, 75)\">晶塊の台座におさめる</span><span style=\"color: rgb(255, 255, 255)\">ことが、この種の「挑戦」の目標です。</span></p>",
                "key": "ページ　1/2"
              },
              {
                "id": "gallery_character17479",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/12/132746206/383dd587ce62a2779f8e4cdff7953bf7_8666708665608271803.png",
                "imgDesc": "<p><span style=\"color: #FFE14B\">ディスパッチスイッチ</span><span style=\"color: #FFFFFF\">を起動すると、</span><span style=\"color: #FFE14B\">軌道が遮断され</span><span style=\"color: #FFFFFF\">、軌道上を移動するものは通過できなくなります。この機能を利用して、連動して動く複数の晶塊の位置を調整し、すべてを晶塊の台座の上に停止させることができます。</span></p>",
                "key": "ページ　2/2"
              }
            ],
