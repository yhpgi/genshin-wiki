            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">通常攻撃</span></p><p><span style=\"color: #80C0FF\">水元素ダメージ</span>を1与える。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/194600931/1ce09211f025bf5470682189e0837732_3771066531338244239.png",
