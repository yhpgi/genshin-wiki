      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "id": "gallery_character12277",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/16/171031298/e04b7fb02b57a34bc6194e9fcd1d715d_6981564339917535662.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">アシパトラ・ヴァナの沼は長年にわたり穢れた力で浸食され続け、そこには危険な紫色の煙霧が立ちこめています。</span></p>",
                "key": "ページ　1/3"
              },
              {
                "id": "gallery_character93604",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/16/171031298/51e7aa8a251b883c2b3cec352e990381_8924382841292034562.png",
                "imgDesc": "<p><span style=\"color: #FFE14B\">ソルシュ</span><span style=\"color: #FFFFFF\">は自身の力を発動することで、</span><span style=\"color: #FFE14B\">いばらの枝に流れる霊光の力を呼び起こす</span><span style=\"color: #FFFFFF\">ことができます。<br>枝の力を利用して紫色の霧を払うと、その中に隠されていた穢れの実体が現れます…</span></p>",
                "key": "ページ　2/3"
              },
              {
                "id": "gallery_character76561",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/16/171031298/f3c7596edb7d0a09484e924bfb0a4d5a_1219124541146839195.png",
                "imgDesc": "<p><span style=\"color: rgb(255, 255, 255)\">沼の下に潜む穢れの実体は紫色の霧の発生源であり、それを破壊することで紫色の霧は消えます。</span><br><span style=\"color: rgb(255, 255, 255)\">しかし、一般的な攻撃ではそれらに影響を与えられないようです。</span><span style=\"color: rgb(255, 225, 75)\">「ニローダの実」の力</span><span style=\"color: #FFFFFF\">によってのみ、それらを根本から浄化できます。</span></p>",
                "key": "ページ　3/3"
              }
            ],
