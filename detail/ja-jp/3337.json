      "name": "ギャラリー",
      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "id": "gallery_character47071",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/16/132746206/8345b5002575d49c1170d70e81f1f77e_7607164366720186918.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">秘典の箱から、</span><span style=\"color: rgb(255, 225, 75)\">デッキを編集する</span><span style=\"color: #FFFFFF\">ことができます。また、付近にいる同じく秘典の箱を持っているキャラを検索し、</span><span style=\"color: rgb(255, 225, 75)\">対戦可能な相手の位置を特定する</span><span style=\"color: #FFFFFF\">こともできます。</span></p>",
                "key": "ページ　1/3"
              },
              {
                "id": "gallery_character20683",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/16/132746206/cd9233378da8516d0fcc340478e360bc_1498176469223072220.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">秘典の箱からデッキ画面を開き、編集したいデッキを選択すると、</span><span style=\"color: rgb(255, 225, 75)\">デッキを編集</span><span style=\"color: #FFFFFF\">できます。</span></p>",
                "key": "ページ　2/3"
              },
              {
                "id": "gallery_character30064",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/16/132746206/36db614fa0e7bf420dedc17d6097cd9d_8618641696864714262.png",
                "imgDesc": "<p><span style=\"color: rgb(255, 255, 255)\">プレイヤー検索機能を起動するとマップが自動的に開き、同じく秘典の箱を持っているプレイヤーがマークされます。これで誰がプレイヤーなのか一目瞭然です…秘典の箱でプレイヤーを探す時、未クリアのプレイヤーが優先的に選択されます。</span></p>",
                "key": "ページ　3/3"
              }
            ],
            "pic": ""
          }
        }
