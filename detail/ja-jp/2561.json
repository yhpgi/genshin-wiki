    {
      "id": "68",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "坊ちゃまは一体どこに…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "坊ちゃまは一体どこに…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "あ、すみません、旦那方。飛雲商会に何かご用でしょうか？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "旦那…？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、あなた様のことですよ。飛雲商会にいらっしゃる方のほとんどは経営者の方々ですから。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "商売は礼儀が肝心だと、うちの坊ちゃまも言っています…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "見た目で人を判断するのはよくありませんから。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "これが飛雲商会のモットーです、ハハッ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "坊ちゃまは…？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、私の独り言を聞いてましたか。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "飛雲商会の商売の多くは今坊ちゃまが対応してます。最も重要な絹もそうですね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "坊ちゃまは経営の天才ですが、商売に関心がないようで、時々姿を消したりするんです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "でもすごいのは…商売に悪影響を及ぼすどころか、むしろ売り上げが増えているんです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "旦那も説教したくてもできなくて困っています。なにせ説教されるようなことはありませんから。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、分かりませんね…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "阿旭：",
                      "type": "text"
                    },
                    {
                      "text": "ええ、飛雲商会をよろしくお願いします。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
