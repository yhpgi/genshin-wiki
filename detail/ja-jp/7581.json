          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: #FFD780\">通常攻撃</span></p><p><span style=\"color: #FFFFFF\">物理ダメージ</span>を2与える。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/04/02/346851886/241eba6e4c00020975cf91170050f435_1291405232823799168.png",
                "key": "影追いの槍術・改",
                "points": [
