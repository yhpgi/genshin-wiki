                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "影追いの槍術・改"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素スキル</span></p><p><span style=\"color: #FFFFFF\">ルミドゥースの瓶・ランク1</span>を召喚する。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/04/02/346851886/5c8e8e82855e154dd9f232a0b9a9e5b1_1205511832677284879.png",
                "key": "フレグランス・アコード",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "フレグランス・アコード"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素爆発</span></p><p><span style=\"color: #99FF88\">草元素ダメージ</span>を<span>1</span>与える。<span style=\"color: #FFFFFF\">ルミドゥースの瓶・ランク3</span>を召喚する。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/04/02/346851886/73b7160daa847cfde43da61c67312844_5529453621996156646.png",
                "key": "アロマティック・アナライズ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "アロマティック・アナライズ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">固有スキル</span></p><p><span style=\"color: #FFFFFF\">味方の燃焼烈焔登場時</span>、双方のキャラが次にスキルを使用した後、<span style=\"color: #FFFFFF\">燃焼烈焔</span>のラウンド終了効果を<span>1</span>回発動する。（各ラウンド最大<span>2</span>回まで）</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/04/02/346851886/376d809c0de41d4b9c23cfceb8f433ab_1340002252429413575.png",
                "key": "余香",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "余香"
              },
              {
                "attributes": [],
                "desc": "<p>草元素付着では、以下の元素反応を起こすことができます。</p><p>【<span style=\"color: rgb(153, 255, 136)\">草</span>+<span style=\"color: rgb(128, 192, 255)\">水</span>】<span style=\"color: rgb(255, 255, 255)\">開花</span>：ダメージ+1、次の炎元素または雷元素ダメージを2アップできる「<span style=\"color: rgb(255, 255, 255)\">草原核</span>」を生成する</p><p>【<span style=\"color: rgb(153, 255, 136)\">草</span>+<span style=\"color: rgb(255, 153, 153)\">炎</span>】<span style=\"color: rgb(255, 255, 255)\">燃焼</span>：ダメージ+1、ラウンド終了時に炎元素ダメージを1与える「<span style=\"color: rgb(255, 255, 255)\">燃焼烈焔</span>」を生成する（使用可能回数1回、最大2回まで重ね掛け可能）</p><p>【<span style=\"color: rgb(153, 255, 136)\">草</span>+<span style=\"color: rgb(255, 172, 255)\">雷</span>】<span style=\"color: rgb(255, 255, 255)\">原激化</span>：ダメージ+1、次の草元素または雷元素ダメージを2回まで+1できる「<span style=\"color: rgb(255, 255, 255)\">激化領域</span>」を生成する</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/04/02/346851886/e8cff941b5a0ff248efde360ec9e91fe_7032843516923588360.png",
                "key": "草元素ダメージ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "草元素ダメージ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">召喚物</span></p><p><span style=\"color: #FFFFFF\">エンドフェーズ：</span><span style=\"color: #99FF88\">草元素ダメージ</span>を1与える。</p><p><span style=\"color: #FFFFFF\">味方が燃焼反応によるダメージを与えた後</span>、このカードが<span style=\"color: #FFFFFF\">ルミドゥースの瓶・ランク2</span>へと変わる。</p><p><span style=\"color: #FFFFFF\">使用可能回数：3</span>（最大6まで重ねられる）</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/04/02/346851886/db13288db6b90ec33f8adc2656d2019f_7014518827288577502.png",
                "key": "ルミドゥースの瓶・ランク1",
                "materials": [],
