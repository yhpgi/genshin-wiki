                  }
                ],
                "title": "ルミドゥースの瓶・ランク1"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">召喚物</span></p><p><span style=\"color: #FFFFFF\">エンドフェーズ：</span><span style=\"color: #99FF88\">草元素ダメージ</span>を2与える。</p><p><span style=\"color: #FFFFFF\">使用可能回数：3</span>（最大<span>6</span>まで重ねられる）</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/04/02/346851886/db13288db6b90ec33f8adc2656d2019f_6971808197477580137.png",
                "key": "ルミドゥースの瓶・ランク2",
                "materials": [],
