              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素スキル</span></p><p><span style=\"color: #99FFFF\">氷元素ダメージ</span>を3与える。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/01/194600931/c815c3f7cfd5d0658dd94a1e28beda8b_1231677282446114229.png",
