                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "概要",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2521,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/06/169177528/af964fe79dfdb389e5b3e38aa5d30e8a_6558667563237559290.png",
                      "menu_id": 10,
                      "name": "ワーグナー",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "シュッツの師匠。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3567,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/20/224893084/9b96299342e0a98088bc64df78b0a4ff_466290290706142105.png",
                      "menu_id": 10,
                      "name": "ヘルマン",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "エリンへ剣をプレゼントしたいヘルマンのために剣を作ろうと考えている。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中1：",
                      "type": "text"
                    },
                    {
                      "text": "さすが師匠…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中2：",
                      "type": "text"
                    },
                    {
                      "text": "力がまだ足りない…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "武器を買いに来たんですか？ワーグナー師匠に直接言ってください。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "ここは何を売ってるの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "どうぞご自由に選んでください。これらの武器は師匠の作品です、不良品はありません。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ショップ画面へ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "龍災について…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "はあ、今回騎士団のほうから注文が一気に増えてて、師匠一人だと厳しいから、手伝おうと思ったんですが…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "…結局僕が作った武器は鋭さが足りないだけでなく、振っただけでバラバラになった剣もありました。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "師匠にえらく怒られましてね、そんなものはお客さんを危険な目に遭わせるだけでなく、師匠の看板を汚すんだって。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "僕も反省しました。師匠の言った通り、急がば回れということもあるんです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "剣も僕自身も、まだまだ鍛錬が必要ですね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "何してるの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "僕はワーグナー師匠の弟子、シュッツです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "鉄を打つ師匠の動きは完璧で、何度見ても素晴らしいです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "普段僕は店で雑用しながら、師匠の腕を観察してます。僕にとってそれが報酬みたいなものです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "自分の作品を持ってる？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "僕のは…半製品としか言えないですね、師匠に回収されることが多いんです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "1振りだけ、よくできてるんですけど、師匠は看板が汚れると言って、どうして店に置かせてくれないんです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "それである日、僕は城の側門のほうで試しに数回素振りした後、剣をそこに刺したんです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "最近はその剣に興味がある子供たちがいるみたいですが…まあ、僕とは関係ありません。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "最近の予定？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "ヘルマンさんは最近娘さんに剣をプレゼントしたいみたいです。彼の独り言を聞いてしまったんです。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "ワーグナー師匠の剣が高くて買えないなら、僕が作ってあげようかなと思ってます。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "優しさとかじゃないです、僕の作品はお金になりませんから。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "会話報酬の分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "剣の腕前はどうなった？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "以前より上手くなりましたが、まだまだ鋭さが足りません。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "よろしければ、この剣を使ってみてください。護身用としては使えますが、ヘルマンさんへの剣に関しては…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "…やっぱもっと強い剣、彼の心意気に相応しい剣を彼に渡したいと思ってます。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2039,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/weapon/银剑.png",
                      "menu_id": 4,
                      "name": "銀の剣",
                      "type": "custom_entry"
                    },
                    {
                      "text": "×3を獲得",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "師匠について。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "ワーグナー師匠と話したんですよね？怖いでしょ？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "でも鉄のことになると、彼は素晴らしい師匠です。武器たちから彼の真面目な一面が伝わってきます。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "僕が師匠のことを認め、師匠が僕のことを弟子として認める。それで充分です、",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "他は…そうですね、僕がいなかったら、師匠は寂しいかもしれないですね。前回僕が実家に戻った時…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "…やっぱやめよう…シーッ、この話は師匠に聞かれてはいけませんよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "シュッツ：",
                      "type": "text"
                    },
                    {
                      "text": "ええ、またいつでもいらしてください。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
