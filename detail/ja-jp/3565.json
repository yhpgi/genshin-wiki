    {
      "id": "68",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "冒険者協会…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "ねえ、冒険に興味はある？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "サバイバル、潜水、風の翼スピード勝負が好きなら、冒険者協会にいらっしゃい！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:君 ♀:あなた)は？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "私は冒険者協会の新米宣伝員！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "上に言われて新人募集してるの！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "…そうだ、もし野外探検、登山などに興味があるなら、加入していいからね！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "冒険者協会はそんなこともしてるの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "もちろんだよ、だから「冒険」者協会なんでしょ？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "フン、こう見えて、私は冒険のプロだからね！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "…万文集舎の「冒険」に関する本を全部読んだんだから！間違いないよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "冒険者は依頼を完了させるべきでは？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "依頼…分かった、事故は怖い、でもスリリングを体験したいお金持ちがお金を出して私たちを一緒にサバイバルするという依頼でしょ？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "私を信じて、ナイフさえあれば、どんな環境でも生きていける自信がある！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "あなたも冒険者協会に入ったら、きっと私みたいになれるよ！依頼なんて楽勝だよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "テンテン：",
                      "type": "text"
                    },
                    {
                      "text": "興味があるなら入ってみて！面白いから！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
