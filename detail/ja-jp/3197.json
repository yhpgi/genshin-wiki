                "title": "剣影・孤風"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">召喚物</span></p><p><span style=\"color: rgb(255, 255, 255)\">エンドフェーズ：</span><span style=\"color: rgb(153, 255, 255)\">氷元素ダメージ</span>を1与える。</p><p><span style=\"color: rgb(255, 255, 255)\">使用可能回数：2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/194600931/db13288db6b90ec33f8adc2656d2019f_7131979100276420487.png",
