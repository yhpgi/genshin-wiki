    {
      "id": "68",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "関連アイテム",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 1344,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Letter for Dongdong_icon.png",
                      "menu_id": 9,
                      "name": "トントンへの手紙",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2347,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/book/Someone's Diary_icon.png",
                      "menu_id": 12,
                      "name": "誰かの日誌",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "わあ、君、旅人でしょ？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "冒険挑戦",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "七聖召喚対戦へ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "対戦の勝敗で分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "勝利時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "すごいや、君には勝てっこないよ…僕が負けたこと、他の人にはナイショにしてもらえないかな。特に南十字船隊の船員には言わないで！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "敗北時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "僕…軽策荘の外の人に勝ったぞ！父さんが知ったら、きっと褒めてくれる！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "はい。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "わあ、すごい！じゃあいろんなところに行って、いろんなすごいことを見てきたんでしょ？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "僕の父さんは南十字船隊の船員で、仲間たちといろんな国に行って、毎日冒険してる英雄なんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "あまり帰ってこないけど、いつも手紙を送ってくれるんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "あと数年したら、僕も南十字船隊に入って、父さんが見てきたすごいものを見るんだ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "会話報酬の分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "頑張れ、きっとうまくいく。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "ありがとう！君はここでは数少ない僕を励ましてくれる人だよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "大人たちには父さんのようなヒーローにはなれないって言われた、僕は牛乳が嫌いだから…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "…別に牛乳を飲まないとヒーローになれないわけじゃないでしょ…あの味は本当に無理だよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "でも全部捨てたらもったいないし…そうだ、君にあげるよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "シッ、内緒だよ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 1104,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Milk_icon.png",
                      "menu_id": 9,
                      "name": "牛乳",
                      "type": "custom_entry"
                    },
                    {
                      "text": "×7を獲得",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "トントン：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。君も僕の父さんみたいに強くなってね、へへ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
