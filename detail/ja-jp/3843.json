                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">通常攻撃</span><br><span style=\"color: #FF9999\">炎元素ダメージ</span>を1与える。</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/132746206/1ce09211f025bf5470682189e0837732_8752476295751206778.png",
