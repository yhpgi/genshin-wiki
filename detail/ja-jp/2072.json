            "flower_of_life": {
              "desc": "磐陀巨岩に咲いた金石の花。花びらが風と踊り、生気が宿るように感じられる。",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Archaic Petra/flower_of_life_icon.png",
