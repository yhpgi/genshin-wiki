          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">通常攻撃</span></p><p><span style=\"color: #FFFFFF\">物理ダメージ</span>を2与える。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/15/75248538/c369b96fc6417e8fc2bb607e37297ad4_8611100283902933272.png",
