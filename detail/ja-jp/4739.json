                ],
                "talent_img": "",
                "title": "威厳に満ちた気配"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素スキル</span></p><p><span style=\"color: #99FFFF\">氷元素ダメージ</span>を3与え、本キャラに<span style=\"color: #FFFFFF\">磐岩百相・元素凝晶</span>を付与する。</p>",
