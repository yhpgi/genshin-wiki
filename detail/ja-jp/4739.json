      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">通常攻撃</span></p><p><span style=\"color: #FFFFFF\">物理ダメージ</span>を2与える。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/132746206/47817b4476bcd8b44c86c87debf042f2_1130772049216687727.png",
                "id": "talent90245",
                "key": "砕岩衝撃",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "砕岩衝撃"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">元素スキル</span></p><p><span style=\"color: #FFE699\">岩元素ダメージ</span>を3与える。</p><p>結晶反応を起こした場合、キャラは<span style=\"color: #FFFFFF\">対応元素の力を吸収する</span>。</p><p>今回のスキル発動でキャラが元素の力を吸収しなかった場合、<span style=\"color: #FFFFFF\">磐岩百相・元素凝晶</span>を付与する。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/132746206/23dddc226f4ebf4ef82138e15f9c20d5_5831110066401466281.png",
                "id": "talent49547",
                "key": "威厳に満ちた気配",
                "materials": [],
                "points": [
                  {
