              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">元素スキル</span></p><p><span style=\"color: #FF9999\">炎元素ダメージ</span>を3与え、本キャラに<span style=\"color: rgb(255, 255, 255)\">磐岩百相・元素凝晶</span>を付与する。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/20/132746206/20c4252607f4b7d6f51530c4e80a08ac_1254284105340839332.png",
