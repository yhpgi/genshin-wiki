    {
      "id": "68",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中1：",
                      "type": "text"
                    },
                    {
                      "text": "冒険に興味はない？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中2：",
                      "type": "text"
                    },
                    {
                      "text": "星と深淵を目指せ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "やあ、冒険者協会情報部のエルフィだよ！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "なにか知りたい情報はない？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "聞きたいことがある。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "なんでも聞くといいよ。新人の質問に答えるのも情報部の仕事だからね、へへっ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "冒険者協会について。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "星と深淵を目指せ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "簡単にいうと、冒険が好きな人たちが集まる場所で、人々を助けたりするんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "もちろん冒険者も生活があるから、「依頼」を達成すると報酬がもらえるよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "この先にある噴水広場から左に行くと、緑色の建物が見えるけど、あれが冒険者協会だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "興味があったら、ぜひ行ってみて！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:君 ♀:あなた)について。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "私？大したことはないよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "強いて言えば…このテイワットに私が知らない人はいない、くらいかな。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "ん？すごいの…？実はそれも冒険者協会情報部のおかげだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "私も情報部のメンバーだ。連絡と案内の仕事の他に、情報収集も私の仕事だよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "こんなに話したわけだし、もう友達だよね？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "さあ、君の話を聞かせて！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "情報部について…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "情報部はほとんどの場合、依頼に参加せず、情報を提供するという形で、依頼を行ってる冒険者たちを支援するんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "簡単に説明すると、我々情報部には「収集」と「整理」のニつに分けられる。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "情報収集は「調査員」と呼ばれる者が担当する。例えばフィッシュル、彼女はとても優秀な調査員だよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "私みたいな支援スタッフは集めた情報を整理し、冒険者たちに提供するんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "だから冒険者たちの成功の裏には、情報部の努力があるんだよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:俺 ♀:私)にそっくりな人を見かけた？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "君のことは知ってるよ。最近モンドに来た異邦人だよね？城に入ってきた時から注目してたんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "君にそっくりな人がもう1人いるってこと？同じ異邦人の旅人なの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "…おかしいな、このテイワット大陸に私の知らない人がいるなんて。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エルフィ：",
                      "type": "text"
                    },
                    {
                      "text": "あれ？私の協力はいらないんだ？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
