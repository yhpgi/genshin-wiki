      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "id": "gallery_character53042",
                "img": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2024/09/05/2868fbf7148ccc04e1c5a36e9ca5717d_6091100740016137488.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">固体燃素の釘挑戦では、</span><span style=\"color: #FFE14B\">「光の石柱」を破壊</span><span style=\"color: #FFFFFF\">する必要があります。その中に散らばった</span><span style=\"color: #FFE14B\">刻印の力</span><span style=\"color: #FFFFFF\">を集めて「光の刻印」を修復し、宙に浮かぶ固体燃素の釘を再び地面に打ち込みましょう。<br>刻印の力を集めるたびに、「光の刻印」の修復進捗が増えます。</span></p>",
                "key": "ページ　1/3"
              },
              {
                "id": "gallery_character36601",
                "img": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2024/09/05/6bba5db2a14385b35fab6c04437a4a8d_8065494840195506723.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">ただし、固体燃素の釘の下に封印された</span><span style=\"color: #FFE14B\">漆黒の力</span><span style=\"color: #FFFFFF\">が、「光の刻印」の修復を阻止します。<br>漆黒の力が侵蝕しきる前に、刻印の力を十分に集めて、「光の刻印」を修復しましょう！</span></p>",
                "key": "ページ　2/3"
              },
              {
                "id": "gallery_character89500",
                "img": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2024/09/05/ddb68850b0c2320c8d120fa27a514628_4720182559384020798.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">刻印の力と漆黒の力の衝突は、地形にも影響を及ぼすほど激しいものです。</span><span style=\"color: #FFE14B\">近づくと爆発する</span><span style=\"color: #FFFFFF\">「不安定な固体燃素結晶」が現れることもあるので、挑戦中は注意しましょう。</span></p>",
                "key": "ページ　3/3"
              }
            ],
            "pic": ""
          }
        }
      ]
