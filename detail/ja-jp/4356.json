    {
      "id": "93",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "すばらしい題材…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "外海の深部にいる漆黒の巨鯨。この題材なら必ず大ヒットする！",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "釣り具が欲しい。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "ちょうど協会のが残ってるから、適当なものがないか探してみてくれ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ショップ画面へ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:君 ♀:あなた)は…？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "私はナンタック、モンドの釣り協会の責任者の一人だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "おや？もしかして、一発で私のもう一つの身分が分かったのか？やっぱり人は有名になると大変だな、ハハッ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "ならばもう隠す必要ない。そう、私は有名海洋作家ナンタックだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "私の本を読んだことないか？まあ、まだ発売してないからね。安心して、もうすぐで買えるようになる。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "うむ…君なら、発売記念会で優先でサインしてあげてもいいよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "漆黒の巨鯨ってなに？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "しーっ！大きな声を出さないで。これは私が構想しているもう一つの作品なんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "そこまで興味があるのなら、少し教えてあげてもいい。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "豪胆な漁師が海で漆黒の巨鯨を追いかけるという壮大な物語なんだ。大ヒットするに間違いない！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "極秘情報だから、誰にも言わないでくれ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "こんな素晴らしいアイデア、他の奴らに知られたらマズイ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ナンタック：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。今回の題材はきっと大人気になる！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
