    {
      "id": "10",
      "name": "ストーリー",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "伝説によると、ある有名な英雄が毒龍を斬った後、</br>龍の血を全身に浴びて、刀も槍も通さない体を手に入れようとした。</br>龍の血の力の賜物か、洗礼を受けた体は、</br>数え切れないほどの剣と槍を折った。</br>飛んできた無数の矢を嘲笑いながら、その全てを弾き飛ばした。</br>だが最後、彼の弱点を敵が発見する。</br>彼は愛用していた大剣を背負いながら、龍の血を浴びていた。</br>そのため、背中には大剣と同じ大きさの弱点があった。</br>",
                "title": ""
              }
            ]
          }
        }
      ]
