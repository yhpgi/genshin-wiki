                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/03/194600931/ddce86d688c5ca39f5e653e613827ec3_2784231256221455657.png",
                      "menu_id": 10,
                      "name": "ナイトパイロット",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "「キャッツテール」所属",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "06:00～19:00のみ",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中1：",
                      "type": "text"
                    },
                    {
                      "text": "星拾いの崖の風景…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中2：",
                      "type": "text"
                    },
                    {
                      "text": "モンドの酒…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "（ジンの伝説任務「仔獅子の章・第一幕」クリア前）",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "もう、今更話しかけてくるなんて。君のことはとっくに気付いていたわよ——広場でうろうろする異邦人は目立つからね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "（ジンの伝説任務「仔獅子の章・第一幕」クリア後）",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "また我慢できずに…私とお話したいのかしら？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "…ふふっ、構わないわ、この前は「リトルプリンス」の件で世話になったもの。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "龍災について…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "やっと安心できるけど、少し悔しい気持ちもあるわね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "「エンジェルズシェア」は龍災の影響で、人気商品の多くは品切れになったと閒いてね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "うちの「キャッツテール」は割引作戦を前面に出したのに…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "…それでも売り上げは「エンジェルズシェア」に負けてる、まったく…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "まあ、アカツキワイナリーの直営店舗だし、仕方ないわね…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "なにしてるの？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "誰かが飲みに誘ってくれるのを待っているの。君は誘ってくれる？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "冗談よ、そんなに身構えないで。モンドはロマン溢れる牧歌の城よ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "えっと…(♂:君 ♀:あなた)自身について…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "私？ただの酒場のオーナーよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "あっちから来たのなら、キャッツテールという酒場は見かけたよね？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "酒場について。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "悔しいけど、モンドの一番の酒場は「エンジェルズシェア」よ——",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "でもかわいいディオナちゃんがバーテンダーになってから、「キャッツテール」は昔より繁盛したわ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "客人たちの目当ては酒なのかバーテンダーなのかは置いておいて…少なくとも私はお金には困らなくなったわ、ふふっ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "会話報酬の分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "最近何かイベントはない？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "ええ、最近「エンジェルズシェア」は鳥肉と野生キノコの串焼きをプレゼントしてるでしょ。うちもイベントをやってるわ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "「キャッツテール」なんだから、私たちのおすすめはもちろんモンド風焼き魚よ！",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "さあ、焼き魚を受け取りなさい。時間があったらうちにおいで。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 1529,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Mondstadt Grilled Fish_icon.png",
                      "menu_id": 9,
                      "name": "モンド風焼き魚",
                      "type": "custom_entry"
                    },
                    {
                      "text": "×4を獲得",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "マーガレット：",
                      "type": "text"
                    },
                    {
                      "text": "もう行くの？夜にキャッツテールに来たら、私のところに来てね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
