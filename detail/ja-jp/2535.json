                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3717,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/09/132746206/d4cb7cd958802714c7b1375b1f0ed034_3979326992132817274.png",
                      "menu_id": 10,
                      "name": "ドゥラフ",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "ヨトゥン",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "清泉町の狩人たち。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "ドゥラフはリーダー。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "昼夜共通",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "はぁ…ドゥラフさん…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "こんにちは。狩りのお供を探しているのなら、他の狩人をおすすめするよ…",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:君 ♀:あなた)は？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、僕はエレン…えっと、狩人を目指してる。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "今はドゥラフさんに狩りのコツを学んでるところだよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "会話報酬の分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "狩りのコツについて…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "ドゥラフさんはいろいろ教えてくれたんだ。たとえば匂いでバレないように風向きに注意するとか…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "弓を変えたほうがいいと言って、僕に弓を作ってくれたんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "…話を聞いてくれてありがとう。僕が昔使ってた弓を君に渡すよ、もう使わないからね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 1944,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/weapon/历练的猎弓.png",
                      "menu_id": 4,
                      "name": "歴戦の狩猟弓",
                      "type": "custom_entry"
                    },
                    {
                      "text": "を獲得",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "あまり元気じゃないみたい…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "心配ないよ、昨日狩りに行った時また道に迷っただけだよ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "危うくヒルチャールの拠点に入るところだったけど、なんとか逃げたんだ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "危なかった…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "無事に帰ったのはいいけど、また手ぶらだったから…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "でも…まあ、もう慣れたから…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "お疲れ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "いいんだ、ただよく通りすがりの偵察騎士アンバーさんに助けられるから…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "すごく申し訳ないと思ってる。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "彼女は本当にすごいよ。さすが神の目を持つ人だね…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "エレン：",
                      "type": "text"
                    },
                    {
                      "text": "うん、また。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
