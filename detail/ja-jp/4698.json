      "name": "ギャラリー",
      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "id": "gallery_character76732",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/12/132746206/d802b2ddce3781170a16c7834e5d837f_2005373847758626204.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">主に難破船の近くに現れる兵器。射程範囲内にキャラクターがいると、</span><span style=\"color: #FFE14B\">ロックオンし、攻撃し続けます</span><span style=\"color: #FFFFFF\">。</span></p>",
                "key": "ページ　1/2"
              },
              {
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/12/132746206/ae871fc5c8bd8cd7bd76e6858067f715_8339176824569879736.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">ほとんどの場合、エネルギーの流れに乗って、自律艦砲に欠けている水晶</span><span style=\"color: #FFE14B\">「受信ノード」</span><span style=\"color: #FFFFFF\">を探すことができます。受信ノードを艦砲のベースに</span><span style=\"color: #FFE14B\">組み込み</span><span style=\"color: #FFFFFF\">、それに対して</span><span style=\"color: #FFE14B\">マンマルタコ亜種のエネルギーを放出し続ける</span><span style=\"color: #FFFFFF\">と、艦砲の</span><span style=\"color: #FFE14B\">支配権</span><span style=\"color: #FFFFFF\">に介入して乗っ取り、キャラクターへの攻撃を辞めさせることも可能です。また、それを手動で制御することもできるようになります。</span></p>",
                "key": "ページ　2/2"
              }
            ],
            "pic": ""
          }
        }
      ]
