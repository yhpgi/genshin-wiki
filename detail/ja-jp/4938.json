                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/17/171031298/60c9c277139b43907167e6452d409874_1063086786422347307.png",
                      "menu_id": 9,
                      "name": "レシピ：獣肉シチュー",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 1644,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Moonchase Charm_icon.png",
