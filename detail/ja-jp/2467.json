                {
                  "content": [
                    {
                      "text": "ダインスレイヴ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
