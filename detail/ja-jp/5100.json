      "components": [
        {
          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/27/132746206/f61b93cae8a6df5013bd0fe9533c3782_6163961984600683997.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">沈玉の谷の山野や河川には、「濛気」と呼ばれる奇怪な現象が昔から存在します。一般人がこれを吸い込んでしまうと、数日にも及ぶ頭痛や胸やけに見舞われます。</span></p>",
                "key": "ページ　1/2"
              },
              {
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/27/132746206/2431bec741a50666f0c2a2d40325c0cd_6678188969079349313.png",
                "imgDesc": "<p><span style=\"color: #FFFFFF\">「濛気」が人類に致命的な損傷を与えることはありませんが、長くその中を徘徊する野獣や魔物には大きな影響を与えます。その影響を受けた魔物は、通常より凶暴になり、強い魔物ほど、より深刻な影響を受けます。</span><span style=\"color: #FFE14B\">魔物のリーダー</span><span style=\"color: #FFFFFF\">を倒せば、芋づる式にそのエリアの</span><span style=\"color: #FFE14B\">「濛気」の発生源</span><span style=\"color: #FFFFFF\">を突き止めることができるので、仙力で浄化しましょう。</span></p>",
                "key": "ページ　2/2"
              }
            ],
