                      "ep_id": 4227,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/09/224893084/7a4364ee7ecfbf1eb2b78fbf7b6607ed_2098411216815631111.png",
                      "menu_id": 10,
                      "name": "アン",
