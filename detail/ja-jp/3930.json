    {
      "id": "68",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "平仄が…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "はあ、下句はどうすればいいんだ…あっ、こんにちは。",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "冒険挑戦",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "七聖召喚対戦へ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "対戦の勝敗で分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "勝利時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "ああ…豪気溢れる腕前だ！あなたさえ嫌でなければ、この素晴らしい対戦をテーマに詩を書いてもいいだろうか？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "敗北時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "たまたま運が回ってきただけさ。本当の勝敗はまだわからない…もう一局どうだろう？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:君 ♀:あなた)は？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "私は清昼、詩人だよ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "でもあと数年で家業を継ぐことになっているんだ、父とそう約束したからね。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "だからまだ若いうちに、璃月を回って詩を作ることにしたんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "ハハッ、自分の詩人としての才能を試したかったんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "旅について",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "岩王の聖跡はほとんど行ったし、自然の景色にも心を動かされた。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "璃月の絶妙な山水のほとんどは深秘なところにある。だからこそ「匣中琉璃雲間月」という言葉があるんだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "次は仙人を訪ねようとするかな。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "璃月は各地に仙人飛昇の伝説があるんだ。「雲海仙島を訪れると、長い年月天地を去る」という言葉もある。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "つまり、そこに行くと雲間に消えると言うことだ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "へへへへ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "作品はある？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "「百戦に、万劫の苦と、涙あり」",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "「罪消しに、剣を振るうさ、王のため」",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "これはある仙人に関する詩だ。なぜかここで詠むのに相応しいと思ってしまうよ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "ハハッ、気にしないでおくれ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "さようなら。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "清昼：",
                      "type": "text"
                    },
                    {
                      "text": "ああ、見送りができなくてすまない。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
