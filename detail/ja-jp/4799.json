    {
      "id": "93",
      "name": "詳細",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "会話内容",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "待機中：",
                      "type": "text"
                    },
                    {
                      "text": "一生の心血を尽くしても…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "なんだ？",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "決闘対戦",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "七聖召喚対戦へ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "対戦の勝敗で分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "勝利時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "今回の対戦で、武器作りのアイデアがひらめいた…恩に着る。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "敗北時",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "コンディションを調整できたのなら、時間の無駄ではない。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "(♂:君は？♀:あなたは？)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "名はどうでも良い、大事なのは作品だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "冷刃は聞いたことあるだろう？あの大陸に名を馳せた冒険者へルマンの剣が、この手で打った物。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "…大勢の人から高評価されているかもしれぬが、俺が作った作品の中で極普通な一本に過ぎない。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "俺にとって、一番大切なのは次の武器…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "その武器こそ俺の名と共に世間に知られる資格がある。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "どうしてここに？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "ある武器のために、すべての心に永遠に刻まれし武器のため…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "平凡な武器は何本作っても意味がない。鉄を打つばかりだと、それは鍛冶屋だ、武器職人ではない。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "本物の職人には、名を知らせた武器1本で十分だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "俺は自分のすべてをかけてもその武器を作り出すぞ…その時、全テイワットの人間が「それ」と俺の名を銘記するだろう。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "…そのために、俺はここにやってきた。この山に俺がずっと探している「素材」がある。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "会話報酬の分岐が発生",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:#37ffff"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "素材？",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "俺は今までありとあらゆる素材で武器を作ってきたが、完成した武器はどれも平凡なものだった。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "普通の鉱石と材料には限界があると思い知らされたよ…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "この槍を持っていってくれ。俺が昔作った「試作品」だ。一般人が使うには十分なレベルの武器だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2059,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/weapon/黑缨枪.png",
                      "menu_id": 4,
                      "name": "黒纓槍",
                      "type": "custom_entry"
                    },
                    {
                      "text": "を獲得",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "旅人：",
                      "type": "text"
                    },
                    {
                      "text": "特に用件はない。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "ウルバン：",
                      "type": "text"
                    },
                    {
                      "text": "用件がないならさっさと去れ、時間の無駄だ。",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
