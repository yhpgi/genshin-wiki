          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">通常攻撃</span></p><p><span style=\"color: rgb(255, 255, 255)\">物理ダメージ</span>を2与える。</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/17/346851886/47817b4476bcd8b44c86c87debf042f2_8991603152845713654.png",
