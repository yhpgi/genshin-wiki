                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Hydro DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Duration (Rounds)</span></strong></p><p>Each time you reach the end of a Round, <span style=\"color: rgb(255, 255, 255)\">Duration (Rounds) </span>-1.</p><p>This card will be discarded immediately once <span style=\"color: rgb(255, 255, 255)\">Duration (Rounds)</span> runs out.</p>",
