    {
      "id": "25",
      "name": "Additional Information",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": null,
                "desc": "<p><strong>Message</strong></p><p>&#34;Darn! I lost the bet again, so they forced me to propose to Flora!&#34;</p><p>&#34;But those idiots didn&#39;t say how I was supposed to propose, so here I am! No one would know who I am, I&#39;m such a genius! Take that, you idiots!&#34;</p><p>&#34;Anyway... Flora, I like you. There you go.&#34;<br><br><strong>Cat&#39;s Tail&#39;s reply</strong></p><p>Finally, a proposal of love on the message board! We&#39;re touched, and wish you the best, no matter who you are.</p><p>By the way, we have the perfect thing for you at Cat&#39;s Tail if you ever decide you need the courage to propose face-to-face. With love.</p>",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/10/22/194600931/2e9386550fe8d8b8b9e55fc6c40f213d_5531566944687945321.png",
                "title": "[Message] Cat's Tail Message Board"
              }
            ]
          }
        }
