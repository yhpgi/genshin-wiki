                  "content": [
                    {
                      "text": "4-piece set: When the value of a Bond of Life increases or decreases, this character deals 18% increased DMG for 6s. Max 3 stacks.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
