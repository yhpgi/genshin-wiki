                "desc": "<p><span style=\"color: #FFD780\">Elemental Burst</span></p><p>Deals 1 <span style=\"color: #FFACFF\">Electro DMG</span>, summons 1 <span style=\"color: #FFFFFF\">Tengu Juurai: Stormcluster</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/25/35428890/2185a287c1725779bdfe00b0fe84353e_6418757558738920704.png",
