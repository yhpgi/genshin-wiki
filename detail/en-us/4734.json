                  }
                ],
                "talent_img": "",
                "title": "Decimating Lash"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elemental Burst</span></p><p>Deals 6 <span style=\"color: #FF9999\">Pyro DMG</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/5779f79888d140f222ce693c329228d8_1908745315394674744.png",
                "id": "talent33306",
                "key": "Whirling Blaze",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Whirling Blaze"
              },
              {
                "attributes": [],
                "desc": "<p>Applies Cryo and can trigger the following Elemental Reactions:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Melt</span>: DMG +2 for this instance</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Superconduct</span>: DMG+1 for this instance, deal 1 Piercing DMG to all opposing characters except the target</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Frozen</span>: DMG +1 for this instance, the target is unable to perform any Actions this Round (Can be removed in advance after the target receives Physical or Pyro DMG, in which case they will take +2 DMG)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/4bcc4b82a9d7ee22770f60afa54e9919_4961876985681063340.png",
                "id": "talent38004",
                "key": "Cryo DMG",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Cryo DMG"
              },
              {
                "attributes": [],
                "desc": "<p>Applies Pyro and can trigger the following Elemental Reactions:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Melt</span>: DMG +2 for this instance</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Vaporize</span>: DMG +2 for this instance</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Overloaded</span>: DMG +2 for this instance, the target is forcibly switched to the next character</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Burning</span>: DMG +1 for this instance, creates a [<span style=\"color: rgb(255, 255, 255)\">Burning Flame</span>] that will deal 1 Pyro DMG at the end of the Round (Takes effect once, max 2 stacks)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/d714b3b669cc08d1d8e34464fd7a3630_5534121370609038658.png",
                "id": "talent14270",
                "key": "Pyro DMG",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Pyro DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Usage(s)</span></strong><br>After this card's effect is triggered, 1 <span style=\"color: rgb(255, 255, 255)\">Usage </span>of it will be consumed.<br>This card will be discarded immediately once it has 0 <span style=\"color: rgb(255, 255, 255)\">Usages </span>remaining.</p>",
