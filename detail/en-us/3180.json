          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Attack</span></p><p>Deals 1 <span style=\"color: #80C0FF\">Hydro DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/1ce09211f025bf5470682189e0837732_3515133883493942339.png",
                "id": "talent70207",
