              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Attack</span></p><p>Deals 1 <span style=\"color: #FF9999\">Pyro DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/35428890/1ce09211f025bf5470682189e0837732_3323740261544474437.png",
