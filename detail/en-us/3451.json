                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Relationships",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7487,
                      "icon_url": "",
                      "name": "Youkai",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Hanyuuda Chizuru is a Tsukumogami, a youkai that emerged from the pair of hagoita and assumed a human form outside of her own body.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7428,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/02/05/237301566/c857e595da1ff6a514746f47ea9941f0_6870104529343939000.png",
                      "menu_id": 20,
                      "name": "Mikawa Flower Festival",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Hanyuuda Chizuru was born at the Mikawa Flower Festival, so a love of fun was in her nature.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Yanagibashi Takuto",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "A mortal samurai whose friendship with the youkai Kamai was discovered by Chizuru when she had not yet acquired the power of a youkai.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Kamai Kenji",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "A youkai and friend of the mortal samurai. His power awakened the consciousness within the pair of hagoita that Kamai and the samurai played Akitsu",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Yae Miko_icon.png",
                      "name": "Яэ Мико",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "A kitsune, who saw the birth of Chizuru's consciousness inside the pair of hagoita. She convinced Chizuru of the value of human-youkai friendship.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2263,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Shikanoin Heizou_icon.png",
                      "name": "Shikanoin Heizou",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "A detective, who guessed Hanyuuda Chizuru's true identity right",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3450,
                      "icon_url": "",
                      "name": "Каппа",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3449,
                      "icon_url": "",
                      "name": "Ёко",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3448,
                      "icon_url": "",
                      "name": "Хитоцумэ-кодзо",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Little youkai whom Chizuru wanted to protect",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
