            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Attack</span></p><p>Deals 1 <span style=\"color: rgb(128, 192, 255)\">Hydro DMG.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/03/248396191/1ce09211f025bf5470682189e0837732_4258305118430456111.png",
