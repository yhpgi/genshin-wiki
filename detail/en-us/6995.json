                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "\"Children of Echoes\"",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/237301566/6c48ae89d8db5b20336b711e28c6225b_3579915534308771014.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "August 17, 2024",
                      "type": "text"
                    },
                    {
                      "text": "Hello, Traveler!",
                      "type": "text"
                    },
                    {
                      "text": "Today, we'll be introducing the \"Children of Echoes,\" one of Natlan's six tribes. Word has it that the mines near the tribes hide a lot of treasure!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
