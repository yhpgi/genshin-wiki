                "key": "Golden Blood-Tide",
                "string_values": [
                  "<p>ATK is increased by <span style=\"color: #37FFFF\">16%/20%/24%/28%/32%</span>. When current HP increases or decreases, Normal Attack DMG will be increased by <span style=\"color: #37FFFF\">16%/20%/24%/28%/32%</span> and Charged Attack DMG will be increased by <span style=\"color: #37FFFF\">14%/17.5%/21%/24.5%/28%</span> for 4s. Max 3 stacks. This effect can be triggered once every 0.3s. When the wielder has 3 stacks, ATK SPD will be increased by <span style=\"color: #37FFFF\">8%/10%/12%/14%/16%</span>.</p>"
                ]
              },
