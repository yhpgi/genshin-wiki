                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Swirling Squall"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elemental Burst</span></p><p>Deals 2 <span style=\"color: rgb(128, 255, 215)\">Anemo DMG</span>. <span style=\"color: rgb(255, 255, 255)\">Discard</span> all <span style=\"color: rgb(255, 255, 255)\">Bonecruncher's Energy Block</span> cards in your Hand. Double the DMG dealt once for every 2 cards you <span style=\"color: rgb(255, 255, 255)\">Discard</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/15/35428890/1d8d506cdab76fd7660ea285c094d231_7152395937166958613.png",
                "id": "talent24445",
                "key": "Scattershot Vortex",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Scattershot Vortex"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Passive Skill</span></p><p>(Passive) When battle begins, create 6 <span style=\"color: rgb(255, 255, 255)\">Bonecruncher's Energy Block</span> and place them evenly into your deck.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/15/35428890/1f7f5486da184cb626eb0891eeb2a204_2492357674413873229.png",
                "id": "talent26103",
                "key": "Immortal Remnants: Anemo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Immortal Remnants: Anemo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Event Card</span></p><p>Randomly <span style=\"color: rgb(255, 255, 255)\">Discard</span> 1 card from your Hand with the highest original Cost and create 1 Elemental Die of your active character's Element. (Only 1 such card can be played per Round)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/15/35428890/db13288db6b90ec33f8adc2656d2019f_2709540001864618821.png",
                "id": "talent95363",
                "key": "Bonecruncher's Energy Block",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/15/35428890/531ed6322b0a8f721e6080da7fcd72ce_3907343818334398760.png",
                "title": "Bonecruncher's Energy Block"
              },
              {
                "attributes": [],
                "desc": "<p>Reacts with Elements if they are already applied:<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">Cryo Swirl</span>: Deals 1 Cryo DMG to all opposing chracters except the target<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Hydro Swirl:</span> Deals 1 Hydro DMG to all opposing characters except the target<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Pyro Swirl</span>: Deals 1 Pyro DMG to all opposing characters except the target<br>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Electro Swirl</span>: Deals 1 Electro DMG to all opposing characters except the target</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/15/35428890/c97292d96456bfe4abeca16bfce801e4_1795716802689441206.png",
                "id": "talent63344",
                "key": "Anemo DMG",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Anemo DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Physical DMG</span></strong><br>Physical DMG will not apply any Elements, nor can it engage in Elemental Reactions.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Discard</span></strong><br>Use Action Cards or Character Skill effects to Discard Action Cards from Hand or Deck.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Energy</span></strong><br>Characters must consume Energy to use their Elemental Bursts.<br>When characters use an Elemental Skill or a Normal Attack, they will gain 1 Energy.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/15/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_5736117181594863716.png",
