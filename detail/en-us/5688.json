                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p>Deal 3 <span style=\"color: rgb(128, 255, 215)\">Anemo DMG</span> and draw 1 card.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/15/35428890/c810824214ed1ed7d4c4519a109c0ba5_6641161029607570611.png",
