              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Summon</span></p><p><span style=\"color: rgb(255, 255, 255)\">End Phase: </span>Deal 1 <span style=\"color: rgb(153, 255, 136)\">Dendro DMG</span>.<br><span style=\"color: rgb(255, 255, 255)\">After you deal Burning reaction DMG:</span> This card levels up to become <span style=\"color: rgb(255, 255, 255)\">Lumidouce Case: Level 2</span>.<br><span style=\"color: rgb(255, 255, 255)\">Usage(s): 3</span> (Can stack. Max 6 stacks.)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/27/35428890/db13288db6b90ec33f8adc2656d2019f_2015944976634498064.png",
