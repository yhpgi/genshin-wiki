                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Tavern Challenge: Friendly Fracas - Lament of the Thunder Manifestation",
                      "type": "text"
