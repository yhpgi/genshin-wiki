                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2519,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/19/237301566/24ed91484b6cba0d0f8c7dd916b9f774_2695616478020035984.png",
