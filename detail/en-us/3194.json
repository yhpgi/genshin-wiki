                "title": "Tide and Torrent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Summon</span></p><p>Deal 2 <span style=\"color: rgb(128, 192, 255)\">Hydro DMG</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usage(s): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/35428890/db13288db6b90ec33f8adc2656d2019f_3929528876550255439.png",
                "id": "talent99354",
                "key": "Hydro Mimic Squirrel",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
