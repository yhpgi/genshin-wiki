              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p>Summons 1 <span style=\"color: rgb(255, 255, 255)\">Guoba</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/26fc236bd113d2bcb3ea4b2e946fefe3_8397252360134705021.png",
