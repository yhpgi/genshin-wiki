      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: #FFD780\">Normal Attack</span></p><p>Deals 2 <span style=\"color: #FFFFFF\">Physical DMG</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/06/35428890/47817b4476bcd8b44c86c87debf042f2_6162294515514711302.png",
                "id": "talent41914",
                "key": "Floral-Ring Caress",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Floral-Ring Caress"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p>Deals 3 <span style=\"color: rgb(153, 255, 136)\">Dendro DMG</span>, creates 1 stack of <span style=\"color: rgb(255, 255, 255)\">Spirit-Serpent's Blessing</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Spirit-Serpent's Blessing</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Combat Status</span></p><p><span style=\"color: rgb(255, 255, 255)\">When your Spirit of Omen: Dendro Spirit-Serpent uses Technique:</span> The DMG dealt by this <span style=\"color: rgb(255, 255, 255)\">Technique</span> +1, and does not consume <span style=\"color: rgb(255, 255, 255)\">Usage(s)</span> of Spirit of Omen: Dendro Spirit-Serpent.<br><span style=\"color: rgb(255, 255, 255)\">Usage(s)</span>: 1 (Can stack, no limit)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/06/35428890/3423c1e9b5666ace686ab000fb4449b1_3623961346616444300.png",
                "id": "talent87911",
                "key": "Spiraling Whirl",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Spiraling Whirl"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Burst</span></p><p>Deals 4 <span style=\"color: #99FF88\">Dendro DMG</span>. Once each Match, add 1 <span style=\"color: rgb(255, 255, 255)\">Spirit of Omen: Dendro Spirit-Serpent</span> card to your Hand.<br>(Characters with <span style=\"color: rgb(255, 255, 255)\">Spirit of Omen: Dendro Spirit-Serpent</span> equipped can use the Technique: <span style=\"color: rgb(255, 255, 255)\">Viny Razorscale</span>)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/18/35428890/d0cb9da07f8ecb34459e3d04377976a2_8765965752594670998.png",
                "id": "talent55155",
                "key": "Spirit of Omen's Awakening: Dendro Spirit-Serpent",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Spirit of Omen's Awakening: Dendro Spirit-Serpent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Equipment Card</span><br><span style=\"color: #FFFFFF\">Technique:</span> Viny Razorscale<br><span style=\"color: #FFFFFF\">Usage(s): 2</span><br>(A character can only equip 1 Technique at a time)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/06/35428890/db13288db6b90ec33f8adc2656d2019f_4302099381755098464.png",
                "id": "talent39863",
                "key": "Spirit of Omen: Dendro Spirit-Serpent",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [
                  {
                    "description": "",
                    "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/21/35428890/caeb5aaf82eb3f105c6b3e9f4b29d917_929141275130539867.png"
                  }
                ],
                "title": "Spirit of Omen: Dendro Spirit-Serpent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Technique</span><br>Deals 1 <span style=\"color: #99FF88\">Dendro DMG</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/21/35428890/db13288db6b90ec33f8adc2656d2019f_5876048289282823154.png",
                "id": "talent74908",
                "key": "Viny Razorscale",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Viny Razorscale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Passive Skill</span></p><p>(Passive) <span style=\"color: rgb(255, 255, 255)\">After this character takes DMG:</span> If this character has no more than 7 HP, they gain 1 <span style=\"color: rgb(255, 255, 255)\">Energy</span>. (Once per Round)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/18/35428890/8d8e17a2dc09dd58da1ddeed795d718e_7482336097955989236.png",
                "id": "talent46229",
                "key": "Spirit of Omen's Power",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Spirit of Omen's Power"
              },
              {
                "attributes": [],
                "desc": "<p>Applies Dendro and can trigger the following Elemental Reactions:</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Bloom</span>: DMG +1 for this instance, creates a [<span style=\"color: rgb(255, 255, 255)\">Dendro Core</span>] that greants +2 DMG to the next instance of Pyro or Electro DMG</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Burning</span>: DMG +1 for this instance, creates a [<span style=\"color: rgb(255, 255, 255)\">Burning Flame</span>] that will deal 1 Pyro DMG at the end of the Round (Takes effect once, max 2 stacks)</p><p>[<span style=\"color: rgb(153, 255, 136)\">Dendro </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Quicken</span>: DMG +1 for this instance, creates a [<span style=\"color: rgb(255, 255, 255)\">Catalyzing Field</span>] that grants +1 DMG to the next 2 instances of Dendro or Electro DMG</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/06/35428890/e8cff941b5a0ff248efde360ec9e91fe_3654814106596361062.png",
                "id": "talent94137",
                "key": "Dendro DMG",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Dendro DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Physical DMG</span></strong><br>Physical DMG will not apply any Elements, nor can it engage in Elemental Reactions.</p><p></p><p><strong><span style=\"color: #ECE5D8\">Technique</span></strong><br>When the active character is equipped with a Technique card, they can use the corresponding Technique.<br>Using a Technique counts as a Combat Action. If the character is unable to use Skills due to conditions like Frozen, Petrification, or Stun, they are also unable to use the Technique.<br>Using a Technique is not considered as using a Skill. Therefore, it cannot trigger effects such as \"After using a skill\" or \"After the character triggers an Elemental Reaction.\" Damage dealt by using a Technique is not considered Damage dealt by the character.<br></p><p><strong><span style=\"color: #ECE5D8\">Usage(s)</span></strong><br>After this card's effect is triggered, 1 <span style=\"color: rgb(255, 255, 255)\">Usage</span> of it will be consumed.<br>This card will be discarded immediately once it has 0 <span style=\"color: rgb(255, 255, 255)\">Usages</span> remaining.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Energy</span></strong><br>Characters must consume Energy to use their Elemental Bursts.<br>When characters use an Elemental Skill or a Normal Attack, they will gain 1 Energy.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/06/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_585911083366439833.png",
                "id": "talent70581",
                "key": "Detailed Rules",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Detailed Rules"
              }
            ]
          }
        }
      ]
