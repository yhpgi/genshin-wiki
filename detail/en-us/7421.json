{
  "id": 7421,
  "name": "Atocpan",
  "desc": "<p>Beneath the frequent eruptions of volcanic flames, the warriors of the Collective of Plenty who thrive on fertile lands meet their trials head-on with raw strength.</p>",
  "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/03/17/237301566/8694aaf89d32e75eca416ec7fe41e487_5551208670419788775.png",
