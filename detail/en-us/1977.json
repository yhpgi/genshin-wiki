      "id": "10",
      "name": "Description",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p>A reliable and balanced sword made of fine steel.<br>The one downside is that the partial-tang design renders it less durable than its full-tang counterparts.<br>That said, the partial tang creates space in the hilt for hidden knives, scissors, tinder, and other objects.<br>Hence the name, Traveler's Handy Sword. It contains all sorts of handy items for travelers.</p>",
                "id": "story44052",
                "img": "",
                "title": ""
              }
            ]
          }
        }
