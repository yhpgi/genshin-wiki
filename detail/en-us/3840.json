                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Dominus Lapidis"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p>Deals 3 <span style=\"color: rgb(255, 230, 153)\">Geo DMG</span>, summons 1 <span style=\"color: rgb(255, 255, 255)\">Stone Stele</span>, creates 1<span style=\"color: rgb(255, 255, 255)\"> Jade Shield</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Jade Shield</span></strong></p><p><span style=\"color: #FFD780\">Combat Status</span></p><p>Grants 2 <span style=\"color: #FFFFFF\">Shield points</span> to your active character.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/857631feb4f9832ee5644c9f6faf3a44_2618449771167399150.png",
                "id": "talent79509",
                "key": "Dominus Lapidis: Striking Stone",
                "materials": [],
                "points": [
                  {
                    "point_count": 5,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Dominus Lapidis: Striking Stone"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Burst</span></p><p>Deals 4 <span style=\"color: rgb(255, 230, 153)\">Geo DMG</span>. The target character receives <span style=\"color: rgb(255, 255, 255)\">Petrification</span>.</p><p></p><p><strong><span style=\"color: #ECE5D8\">Petrification</span></strong></p><p><span style=\"color: #FFD780\">Status</span></p><p>Character cannot use Skills. (Lasts until the end of this Round)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/6081ca47e02027c0bb6a6931f17baff1_6229281075062902557.png",
                "id": "talent36017",
                "key": "Planet Befall",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Planet Befall"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Summon</span><br><span style=\"color: #FFFFFF\">End Phase</span>: Deal 1 <span style=\"color: #FFE699\">Geo DMG</span>.</p><p><span style=\"color: #FFFFFF\">Usage(s): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/35428890/db13288db6b90ec33f8adc2656d2019f_3696998767850783296.png",
                "id": "talent79239",
                "key": "Stone Steele",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/25/35428890/905fb3dd007f1806491f7e9df8812d45_4644072303685738827.png",
                "title": "Stone Steele"
              },
              {
                "attributes": [],
                "desc": "<p>Reacts with Elements if they are already applied:<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">Cryo Crystallize</span>: DMG +1 for this instance, your active character gains 1 Shield point (Can stack, max 2 points)<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Hydro Crystallize</span>: DMG +1 for this instance, your active character gains 1 Shield point (Can stack, max 2 points)<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Pyro Crystallize</span>: DMG +1 for this instance, your active character gains 1 Shield point (Can stack, max 2 points)<br>[<span style=\"color: rgb(255, 230, 153)\">Geo</span> + <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Electro Crystallize</span>: DMG +1 for this instance, your active character gains 1 Shield point (Can stack, max 2 points)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/35428890/fd37cbfdd3b1b2c16e6e83fb0aa96889_4927438411776684256.png",
                "id": "talent1036",
                "key": "Geo DMG",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Geo DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Physical DMG</span></strong></p><p>Physical DMG will not apply any Elements, nor can it engage in Elemental Reactions.</p><p></p><p><strong><span style=\"color: #ECE5D8\">Usage(s)</span></strong></p><p>After this card's effect is triggered, 1 <span style=\"color: #FFFFFF\">Usage </span>of it will be consumed.</p><p>This card will be discarded immediately once it has 0 <span style=\"color: #FFFFFF\">Usages </span>remaining.</p><p></p><p><strong><span style=\"color: #ECE5D8\">Shield</span></strong></p><p>This Shield will be consumed to protect the character who equips it from DMG.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/21/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_914399290868916676.png",
