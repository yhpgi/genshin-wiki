              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elemental Skill</span></p><p>Deals 1 <span style=\"color: #FFE699\">Geo DMG</span>, summons 1 <span style=\"color: #FFFFFF\">Stone Stele</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/2d9fc42b7cacede11b5fc6d1efc472e5_5905848648502904298.png",
