                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 1640,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Mini Seelie: Rosé_icon.png",
                      "menu_id": 9,
                      "name": "Малая фея Роза",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 1641,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Mini Seelie: Curcuma_icon.png",
                      "menu_id": 9,
                      "name": "Малая фея Куркума",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Unlike other Seelie, Mini Seelie does not serve to guide others but instead follows them to see the world.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 96,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/object/Treasure-Seeking Seelie_icon.png",
                      "menu_id": 9,
                      "name": "Поисковая фея",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4915,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/03/237301566/4b4d7128bfb0406f9aa42fc63af4ac98_7279103762259581663.png",
