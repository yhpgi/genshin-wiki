      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Envisaged Echoes",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "In a corner of the Theater Lobby, vibrant colors have emerged on a once-blank canvas. When someone touches the canvas, it transports them to different domains, based upon their different experiences…",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Explore the worlds within the painting with specific companions, and perhaps precious memories may be painted into peerless pictures.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Gameplay Details",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Each",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Envisaged Echoes",
                      "type": "text"
                    },
                    {
                      "text": "challenge corresponds to a designated character.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "To participate in the challenge stages, the character must meet 2 conditions.",
