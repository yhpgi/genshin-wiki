                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Visionary Difficulty",
                      "type": "text"
                    },
                    {
                      "text": "in each season of the",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 5832,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/04/41133912/ddcd00db3613c8c39ed4d902cc43cc2e_7623522857361033099.png",
                      "menu_id": 14,
                      "name": "Imaginarium Theater",
                      "type": "custom_entry"
                    },
                    {
                      "text": "to receive",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "1",
                      "type": "text"
                    },
                    {
                      "text": "Key.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Keys must be collected before Imaginarium Theater season refreshes as unclaimed Keys will not be saved.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "4 Keys of Echoes can be stored at once but Travelers will not be able to claim more Keys while at the limit.",
                      "type": "text"
