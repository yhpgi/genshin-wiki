      "id": "10",
      "name": "Description",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p>Separate the dust in the flames with joy, and extract the exquisite from the crude.<br>For all in the universe comes from a single source, and all things may be derived from a single thought.<br>You must pursue that which your elder brother, the one-horned white horse, could not accomplish.<br>Reach the far side of philosophy, and create a new destiny for myself and your brothers...</p>",
                "title": ""
              }
            ]
          }
        }
      ]
