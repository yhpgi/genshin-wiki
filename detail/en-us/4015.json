                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Stage Introduction",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"I feel... like I'm getting the hang of how to play... You don't have to go so easy on me.\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(236, 229, 216)"
                      ],
                      "text": "Special Rule: \"Qiqi\" starts with the Talent Card \"Rite of Resurrection\" equipped.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
