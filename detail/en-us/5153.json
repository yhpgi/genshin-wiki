                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Cryo DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Usage(s)</span></strong><br>After this card's effect is triggered, 1 <span style=\"color: rgb(255, 255, 255)\">Usage</span> of it will be consumed.<br>This card will be discarded immediately once it has 0 <span style=\"color: rgb(255, 255, 255)\">Usages</span> remaining.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_4450222205605711163.png",
