              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Attack</span></p><p>Deals 2 <span style=\"color: rgb(255, 255, 255)\">Physical DMG</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/16/35428890/47817b4476bcd8b44c86c87debf042f2_2100461693601631913.png",
                "id": "talent85476",
