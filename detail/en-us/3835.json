            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Attack</span></p><p>Deals 2 <span style=\"color: #FFFFFF\">Physical DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/ad8a357fa8480f61f3fe665b69d9c263_2096473223043146354.png",
                "id": "talent87068",
