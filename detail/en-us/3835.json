                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Sharpshooter"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elemental Skill</span></p><p>Summons 1 <span style=\"color: #FFFFFF\">Baron Bunny</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/76c87309abe7b2f8ce49af09ba50fa38_7202583330824937547.png",
                "id": "talent65145",
                "key": "Explosive Puppet",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Explosive Puppet"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elemental Burst</span></p><p>Deals 2 <span style=\"color: #FF9999\">Pyro DMG</span>, deals 2 <span style=\"color: #FFFFFF\">Piercing DMG</span> to all opposing characters on standby.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/c1cb087219594f5a54c4fafb433536f7_4925121831489319577.png",
                "id": "talent80406",
                "key": "Fiery Rain",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Fiery Rain"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Summon</span></p><p><span style=\"color: #FFFFFF\">When your active character takes DMG</span>: Decrease DMG taken by 2.</p><p><span style=\"color: #FFFFFF\">Usage(s): 1</span>. When the Usages are depleted, this card will not be discarded.</p><p><span style=\"color: #FFFFFF\">At the End Phase, if Usage(s) have been depleted</span>: Discard this card to deal 2 <span style=\"color: #FF9999\">Pyro DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/db13288db6b90ec33f8adc2656d2019f_4268890119624158580.png",
                "id": "talent51690",
                "key": "Baron Bunny",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/25/35428890/73a2f9790672a39cb2f9a87b5f09ed6b_6774471523085633012.png",
                "title": "Baron Bunny"
              },
              {
                "attributes": [],
                "desc": "<p>Applies Pyro and can trigger the following Elemental Reactions:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Melt</span>: DMG +2 for this instance</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Vaporize</span>: DMG +2 for this instance</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Overloaded</span>: DMG +2 for this instance, the target is forcibly switched to the next character</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Burning</span>: DMG +1 for this instance, creates a [<span style=\"color: rgb(255, 255, 255)\">Burning Flame</span>] that will deal 1 Pyro DMG at the end of the Round (Takes effect once, max 2 stacks)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/d714b3b669cc08d1d8e34464fd7a3630_7788985352269282609.png",
                "id": "talent28532",
                "key": "Pyro DMG",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Pyro DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Physical DMG</span></strong></p><p>Physical DMG will not apply any Elements, nor can it engage in Elemental Reactions.</p><p></p><p><span style=\"color: #FFFFFF\">Usage(s)</span></p><p>After this card's effect is triggered, 1 <span style=\"color: #FFFFFF\">Usage </span>of it will be consumed.</p><p>This card will be discarded immediately once it has 0 <span style=\"color: #FFFFFF\">Usages </span>remaining.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Piercing DMG</span></strong></p><p>Piercing DMG cannot be increased by any bonuses, but cannot be defended against using Shields or DMG Immunity either.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_558133532058569757.png",
                "id": "talent29657",
                "key": "Detailed Rules",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Detailed Rules"
              }
            ]
          }
        }
      ]
