                "desc": "<p><span style=\"color: #FFD780\">Elemental Burst</span></p><p>Deals 2 <span style=\"color: #FF9999\">Pyro DMG</span>, summons 1 <span style=\"color: #FFFFFF\">Spirit of Omen: Pyro Scorpion</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/6d7f53f97097de5265ca596461e914b1_1650850583223755671.png",
                "id": "talent42264",
                "key": "Spirit of Omen's Awakening: Pyro Scorpion",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
