                  }
                ],
                "talent_img": "",
                "title": "Spirit of Omen's Awakening: Pyro Scorpion"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Passive Skill</span><br>(Passive)<span style=\"color: rgb(255, 255, 255)\"> After this character takes DMG: </span>If this character has no greater than 7 HP, they gain 1 <span style=\"color: rgb(255, 255, 255)\">Energy</span>. (Once per Match)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/eb96a0e1f4fd6ddf6d0975dfcf1fed10_9040661836279916218.png",
                "id": "talent46557",
                "key": "Spirit of Omen's Power",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Spirit of Omen's Power"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Summon</span></p><p><span style=\"color: rgb(255, 255, 255)\">End Phase:</span> Deal 1 <span style=\"color: rgb(255, 153, 153)\">Pyro DMG</span>.<br><span style=\"color: rgb(255, 255, 255)\">Usage(s): 2</span><br><span style=\"color: rgb(255, 255, 255)\"><br>When entering play, when the Action Phase starts: </span>Equips Pyro Scorpion: Guardian Stance to your Eremite Scorching Loremaster. (When Spirit of Omen: Pyro Scorpion is in play, the character will take -1 DMG, once per Round.)</p><p></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/db13288db6b90ec33f8adc2656d2019f_2192473068753866611.png",
                "id": "talent11039",
                "key": "Spirit of Omen: Pyro Scorpion",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/f7f4fe5b41d7d7267cc09061873660cc_2846532677854142391.png",
                "title": "Spirit of Omen: Pyro Scorpion"
              },
              {
                "attributes": [],
                "desc": "<p>Applies Pyro and can trigger the following Elemental Reactions:</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Melt</span>: DMG +2 for this instance</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Vaporize</span>: DMG +2 for this instance</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Overloaded</span>: DMG +2 for this instance, the target is forcibly switched to the next character</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Burning</span>: DMG +1 for this instance, creates a [<span style=\"color: rgb(255, 255, 255)\">Burning Flame</span>] that will deal 1 Pyro DMG at the end of the Round (Takes effect once, max 2 stacks)</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/d714b3b669cc08d1d8e34464fd7a3630_4683155020099799092.png",
                "id": "talent58833",
                "key": "Pyro DMG",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Pyro DMG"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Usage(s)</span></strong><br>After this card's effect is triggered, 1 <span style=\"color: rgb(255, 255, 255)\">Usage </span>of it will be consumed.<br>This card will be discarded immediately once it has 0 <span style=\"color: rgb(255, 255, 255)\">Usages </span>remaining.</p><p></p><p><strong><span style=\"color: #ECE5D8\">Energy</span></strong><br>Characters must consume Energy to use their Elemental Bursts.<br>When characters use an Elemental Skill or a Normal Attack, they will gain 1 Energy.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35428890/245c229cf6f7364c7c9a7aea3db1a1ad_4633692865705171278.png",
