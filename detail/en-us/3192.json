              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Normal Attack</span></p><p>Deals 2 <span style=\"color: #FFFFFF\">Physical DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/26b9736a2d14fc4162b2448963f45695_4822303665940922300.png",
