              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Normal Attack</span></p><p>Deals 2 <span style=\"color: #FFFFFF\">Physical DMG</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/30/35428890/c369b96fc6417e8fc2bb607e37297ad4_2446716701394848626.png",
