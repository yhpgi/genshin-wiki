                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Liutian Archery"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p>Deals 1 <span style=\"color: rgb(153, 255, 255)\">Cryo DMG,</span> creates 1 <span style=\"color: rgb(255, 255, 255)\">Ice Lotus</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Ice Lotus</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Combat Status</span><br><span style=\"color: rgb(255, 255, 255)\">When your active character receives DMG</span>: Decrease DMG taken by 1.<br><span style=\"color: rgb(255, 255, 255)\">Usage(s): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/30/35428890/d3562dc7ee1b952be23d991318822774_2521139183377710700.png",
                "id": "talent15939",
