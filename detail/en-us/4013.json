              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Elemental Skill</span></p><p>Summons <span style=\"color: rgb(255, 255, 255)\">Solar Isotoma</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/14/35428890/4c999a92de43cfba640c30b45c782fc9_8810745386437410551.png",
                "id": "talent62302",
