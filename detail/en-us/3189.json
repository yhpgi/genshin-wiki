              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Elemental Burst</span></p><p>Deals 2 <span style=\"color: #99FF88\">Dendro DMG</span>, summons 1 <span style=\"color: #FFFFFF\">Cuilein-Anbar</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396185/203f06aaab30d1a11fe235682c8bf13e_6289507987694219937.png",
