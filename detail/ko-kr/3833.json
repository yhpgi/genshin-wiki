                      "text": "친선 대전",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "스테이지 소개",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "「하하하, 카드 게임도 일종의 전투니까 봐주진 않을게!」",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
