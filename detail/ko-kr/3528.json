              {
                "item_values": [],
                "key": "행적",
                "string_values": [
                  "<p><span class=\"wk-shady\">사마일은 육신은 그대로인 채로 황금빛 꿈에 들어가지만 영혼을 유지해 성현의 전당을 집어 삼키려 한다. 여행자 일행은 출구로 달려가지만 출구가 막혀 결국 제브라엘이 일행이 탈출할 수 있도록 황금빛 꿈에 들어가 함께 자멸한다.</span></p>"
                ]
              }
