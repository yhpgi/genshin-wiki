                "title": "바위 비"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">원소전투 스킬</span><br><span style=\"color: #FFE699\">바위 원소 피해</span>를 1pt 주고 <span style=\"color: #FFFFFF\">암주</span>를 소환한다.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/194600931/bd88dd4e84f0956abd3d34b19442d2c6_9109544120090758257.png",
