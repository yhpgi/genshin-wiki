            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">일반 공격</span><br><span style=\"color: #FFFFFF\">물리 피해</span>를 2pt 준다.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/19/194600931/241eba6e4c00020975cf91170050f435_8103721785023788397.png",
