                          },
                          {
                            "styles": [
                              "color:rgb(255, 225, 75)"
                            ],
                            "text": "원소 코어가 노출된다",
                            "type": "text"
                          },
                          {
                            "text": ".",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
