                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    [
                      {
                        "content": [
                          {
                            "text": "죄 깊은 침례자는",
                            "type": "text"
                          },
                          {
                            "styles": [
                              "color:rgb(255, 153, 153)"
                            ],
                            "text": "불",
