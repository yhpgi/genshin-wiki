          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">일반 공격</span></p><p><span style=\"color: #80C0FF\">물 원소 피해</span>를 1pt 준다.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/194600931/1ce09211f025bf5470682189e0837732_6102080433654507392.png",
                "id": "talent53597",
                "key": "물폭탄",
                "materials": [],
                "points": [
                  {
