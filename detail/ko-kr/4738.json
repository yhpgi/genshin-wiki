              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">일반 공격</span></p><p><span style=\"color: rgb(255, 255, 255)\">물리 피해</span>를 2pt 준다.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/31/24090565/47817b4476bcd8b44c86c87debf042f2_3692854344772637975.png",
