                      "ep_id": 3519,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/88913591/c11e8841d51eca4a0f5877567d0b1b28_8482699589027492011.png",
                      "name": "Bonanus",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3518,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/30/88913591/2a70abcd41f1c25b94da6c18901fc863_1288913184031380055.png",
                      "name": "Menogias",
