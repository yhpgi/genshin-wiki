                      "display_style": "card",
                      "ep_id": 3797,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/26/169177528/5968bc73f375ee1e3704302541c83c7f_8085923692366886863.png",
