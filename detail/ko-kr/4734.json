      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">일반 공격</span></p><p><span style=\"color: rgb(153, 255, 255)\">얼음 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.65)\">를 1pt 준다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/04/302875544/1ce09211f025bf5470682189e0837732_6516990888744833791.png",
                "key": "서릿발 춤",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "서릿발 춤"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">원소전투 스킬</span></p><p><span style=\"color: rgb(153, 255, 255)\">얼음 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.65)\">를 </span><strong><span style=\"color: rgba(255, 255, 255, 0.65)\">2</span></strong><span style=\"color: rgba(255, 255, 255, 0.65)\">pt 주고 대상 캐릭터에게 </span><span style=\"color: rgb(255, 255, 255)\">혹한</span><span style=\"color: rgba(255, 255, 255, 0.65)\">을 부착한다.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">혹한</span></p><p><span style=\"color: rgb(255, 215, 128)\">상태</span></p><p><span style=\"color: rgb(255, 255, 255)\">종료 단계: </span><span style=\"color: rgba(255, 255, 255, 0.65)\">부착 캐릭터에게 </span><span style=\"color: rgb(153, 255, 255)\">얼음 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.65)\">를 1pt 준다.</span><br><span style=\"color: #FFFFFF\">사용 가능 횟수：1</span><br><br><span style=\"color: rgba(255, 255, 255, 0.65)\">부착 캐릭터에게 </span><span style=\"color: rgb(255, 255, 255)\">작열</span><span style=\"color: rgba(255, 255, 255, 0.65)\">이 부착될 시, 해당 효과는 제거된다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/04/302875544/289913e1d0feaab0fa03891032b086c0_8975392305383353566.png",
                "key": "살을 에는 가시",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "살을 에는 가시"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">원소폭발</span></p><p><span style=\"color: rgb(153, 255, 255)\">얼음 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.65)\">를 4pt 주고 본 캐릭터의 HP를 2pt 치유한다. </span><span style=\"color: rgb(255, 255, 255)\">얼음에 봉인된 화염의 마녀</span><span style=\"color: rgba(255, 255, 255, 0.65)\">를 제거하고 본 캐릭터가 영구적으로 </span><span style=\"color: rgb(255, 255, 255)\">「사그라든 화염의 마녀」</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 형태로 전환한다.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">얼음에 봉인된 화염의 마녀</span></p><p><span style=\"color: #FFD780\">상태</span></p><p><span style=\"color: rgb(255, 255, 255)\">「시뇨라」</span><span style=\"color: rgba(255, 255, 255, 0.65)\">는 영구적으로 </span><span style=\"color: rgb(255, 255, 255)\">「사그라든 화염의 마녀」</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 형태로 전환될 수 있다.<br>전환 후 </span><span style=\"color: rgb(255, 255, 255)\">「시뇨라」</span><span style=\"color: rgba(255, 255, 255, 0.65)\">의 원소 타입은 </span><span style=\"color: rgb(153, 255, 255)\">얼음 원소</span><span style=\"color: rgba(255, 255, 255, 0.65)\">에서 </span><span style=\"color: rgb(255, 153, 153)\">불 원소</span><span style=\"color: rgba(255, 255, 255, 0.65)\">로 전환된다.<br>전환 후 이 캐릭터는 </span><span style=\"color: rgb(255, 255, 255)\">「사그라든 화염의 마녀」</span><span style=\"color: rgba(255, 255, 255, 0.65)\">의 스킬을 사용할 수 있으며 기존 </span><span style=\"color: rgb(255, 255, 255)\">「시뇨라」</span><span style=\"color: rgba(255, 255, 255, 0.65)\">의 스킬은 사용할 수 없다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/04/302875544/f819c287507962ff41ad86e68661a707_5628377053951618062.png",
                "key": "홍련의 얼음 고치",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "홍련의 얼음 고치"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">패시브 스킬</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[패시브] 전투 시작 시, 시작부터 </span><span style=\"color: #FFFFFF\">얼음에 봉인된 화염의 마녀</span><span style=\"color: rgba(255, 255, 255, 0.65)\">가 부착된다.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">얼음에 봉인된 화염의 마녀</span></p><p><span style=\"color: #FFD780\">상태</span></p><p><span style=\"color: #FFFFFF\">행동 단계 시작 시: </span><span style=\"color: rgba(255, 255, 255, 0.65)\">만약 부착 캐릭터의 HP가 4pt 이하라면, 해당 효과가 제거된다.<br></span><span style=\"color: #FFFFFF\">부착 캐릭터가 처치될 시: </span><span style=\"color: rgba(255, 255, 255, 0.65)\">해당 효과가 제거되며, 해당 캐릭터는 </span><span style=\"color: #FFFFFF\">처치 면역</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 및 HP를 1pt 회복한다.<br><br></span><span style=\"color: #FFFFFF\">해당 효과가 제거될 시: </span><span style=\"color: rgba(255, 255, 255, 0.65)\">부착 캐릭터가 </span><span style=\"color: #FFFFFF\">「사그라든 화염의 마녀」 </span><span style=\"color: rgba(255, 255, 255, 0.65)\">형태로 전환된다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/04/302875544/fd49675d27422f60ca4f0227ea422dec_2205928868949989658.png",
