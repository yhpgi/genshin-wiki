              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">원소폭발</span></p><p><span style=\"color: #FF9999\">불 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.65)\">를 6pt 준다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/04/302875544/5779f79888d140f222ce693c329228d8_5381687865041297146.png",
                "key": "화염의 소용돌이",
