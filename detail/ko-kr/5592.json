                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "파도 칼날 베기"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">원소전투 스킬</span></p><p><span style=\"color: rgb(128, 192, 255)\">물 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 1pt 주고 </span><span style=\"color: rgb(255, 255, 255)\">회전 물결 칼날</span><span style=\"color: rgba(255, 255, 255, 0.45)\">의 </span><span style=\"color: rgb(255, 255, 255)\">스킬 준비</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 한다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/184356335/09d978772c4b7b95a9b3896de9e32f9a_5574361402352944051.png",
                "id": "talent52360",
                "key": "소용돌이 칼날",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "소용돌이 칼날"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">원소폭발</span></p><p><span style=\"color: #80C0FF\">물 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 3pt 주고 상대방 필드에 </span><span style=\"color: #FFFFFF\">암류의 저주</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 생성한다.</span></p><p></p><p><span style=\"color: rgb(255, 215, 128)\">출전 상태</span></p><p><span style=\"color: #FFFFFF\">소속 진영의 캐릭터가 원소전투 스킬 또는 원소폭발 사용 시:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 원소 주사위 1개를 추가로 소모한다.</span></p><p><span style=\"color: #FFFFFF\">사용 가능 횟수: 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/184356335/d93cfa2833ead49715475616489de21c_7514027007803156593.png",
                "id": "talent32295",
                "key": "진동하는 격류",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "진동하는 격류"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">패시브 스킬</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">[패시브] 전투 시작시, 시작부터 물의 신생이 부착된다.</span></p><p></p><p><span style=\"color: rgb(255, 215, 128)\">상태</span></p><p><span style=\"color: #FFFFFF\">부착 캐릭터가 처치될 시:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 해당 효과가 제거되며 캐릭터 </span><span style=\"color: #FFFFFF\">처치 면역</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 및 해당 캐릭터의 HP를 4pt 회복한다. 해당 효과 발동 후, 캐릭터가 주는 </span><span style=\"color: #FFFFFF\">물리 피해</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 가</span><span style=\"color: #FFFFFF\"> </span><span style=\"color: #80C0FF\">물 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.45)\">로 전환되고 </span><span style=\"color: #80C0FF\">물 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.45)\">+1pt</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/184356335/1bbe84955410406904930648b9a4dd36_4944162965731940261.png",
                "id": "talent14585",
                "key": "물의 신생",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "물의 신생"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">원소전투 스킬</span></p><p><span style=\"color: #80C0FF\">물 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 1pt 준다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/184356335/09d978772c4b7b95a9b3896de9e32f9a_1926815066531166551.png",
                "id": "talent50473",
                "key": "회전 물결 칼날",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "회전 물결 칼날"
              },
              {
                "attributes": [],
                "desc": "<p>물 원소 부착 시 원소 반응이 발생할 수 있다.</p><p>[<span style=\"color: rgb(128, 192, 255)\">물</span>+<span style=\"color: rgb(255, 153, 153)\">불</span>] <span style=\"color: rgb(255, 255, 255)\">증발</span>: 이번 피해+2pt</p><p>[<span style=\"color: rgb(128, 192, 255)\">물</span>+<span style=\"color: rgb(255, 172, 255)\">번개</span>] <span style=\"color: rgb(255, 255, 255)\">감전</span>: 이번 피해+1pt, 대상 이외의 모든 상대 캐릭터에게 관통 피해를 1pt 준다.</p><p>[<span style=\"color: rgb(128, 192, 255)\">물</span>+<span style=\"color: rgb(153, 255, 255)\">얼음</span>] <span style=\"color: rgb(255, 255, 255)\">빙결</span>: 이번 피해+1pt, 이번 턴에 대상을 행동 불가로 만든다. (물리 피해 또는 불 원소 피해를 받으면 조기 해제되지만, 해당 피해로 받는 피해량이 2pt 추가된다)</p><p>[<span style=\"color: rgb(128, 192, 255)\">물</span>+<span style=\"color: rgb(153, 255, 136)\">풀</span>] <span style=\"color: rgb(255, 255, 255)\">개화</span>: 이번 피해+1pt, 다음번 불 원소 또는 번개 원소 피해를 2pt 증가시키는 [<span style=\"color: rgb(255, 255, 255)\">풀 원핵</span>]을 생성한다.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/184356335/a126c6a302d81c07e19cf9a9f1260f90_5598832556677131012.png",
                "id": "talent40499",
                "key": "물 원소 피해",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "물 원소 피해"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 255, 255)\">스킬 준비</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">일부 스킬은 바로 발동할 수 없고, 일정 횟수의 행동 순서 동안 </span><span style=\"color: rgb(255, 255, 255)\">준비</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 해야 한다.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">한 플레이어의 행동 순서가 됐을 때, 해당 플레이어의 「출전 캐릭터」가 현재 스킬을 </span><span style=\"color: rgb(255, 255, 255)\">준비 </span><span style=\"color: rgba(255, 255, 255, 0.45)\">중이면 해당 플레이어의 행동을 건너뛴다. 스킬 </span><span style=\"color: rgb(255, 255, 255)\">준비</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 끝냈을 경우, 캐릭터는 해당 스킬을 즉시 발동한다. (</span><span style=\"color: rgb(255, 255, 255)\">준비</span><span style=\"color: rgba(255, 255, 255, 0.45)\">가 필요한 유형의 스킬은 「스킬 사용 후」 및 「캐릭터가 원소 반응 발동 후」 등의 효과를 발동할 수 없다) 오직 「출전 캐릭터」만 스킬을 </span><span style=\"color: rgb(255, 255, 255)\">준비</span><span style=\"color: rgba(255, 255, 255, 0.45)\">할 수 있다. 만약 스킬을 </span><span style=\"color: rgb(255, 255, 255)\">준비</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 중인 「출전 캐릭터」가 교체되어 대기 상태가 되면, 스킬의 준비가 </span><span style=\"color: rgb(255, 255, 255)\">중단</span><span style=\"color: rgba(255, 255, 255, 0.45)\">된다.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">물리 피해</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">물리 피해는 원소를 부착할 수 없고 원소 반응이 발생하지 않는다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/184356335/245c229cf6f7364c7c9a7aea3db1a1ad_2144040495292848228.png",
