          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">일반 공격</span></p><p><span style=\"color: #FFFFFF\">물리 피해</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 2pt 준다</span>.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/184356335/47817b4476bcd8b44c86c87debf042f2_7199632003710348811.png",
                "id": "talent88036",
                "key": "파도 칼날 베기",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
