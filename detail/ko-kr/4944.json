                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/09/194600931/03b60aec345461dae970832766ebacf8_3753367016203674628.png",
                      "name": "공백의 환영 카드",
                      "type": "custom_entry"
