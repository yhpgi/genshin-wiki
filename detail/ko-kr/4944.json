                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "진지한 승부: 무상의 얼음의 쿵쿵 소리",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
