          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">일반 공격</span></p><p><span style=\"color: rgb(255, 255, 255)\">물리 피해</span>를 2pt 준다.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/194600931/c369b96fc6417e8fc2bb607e37297ad4_5074279961406226204.png",
