              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">소환물</span></p><p><span style=\"color: #FFFFFF\">종료 단계:</span> <span style=\"color: #FFACFF\">번개 원소 피해</span>를 1pt 준다.</p><p><span style=\"color: #FFFFFF\">사용 가능 횟수: 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/25/302875544/db13288db6b90ec33f8adc2656d2019f_4701274513138761803.png",
