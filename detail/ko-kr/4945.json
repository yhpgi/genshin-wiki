      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">일반 공격</span></p><p><span style=\"color: rgb(255, 255, 255)\">물리 피해</span>를 2pt 준다.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/25/302875544/47817b4476bcd8b44c86c87debf042f2_7582997881875695647.png",
                "key": "꼬리 부채질",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "꼬리 부채질"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">원소 전투 스킬</span></p><p><span style=\"color: #FFACFF\">번개 원소 피해</span>를 3pt 준다.</p><p>본 캐릭터에게 이미 <span style=\"color: #FFFFFF\">원류바다 진주</span>가 부착되어 있다면 해당 효과의 <span style=\"color: #FFFFFF\">사용 가능 횟수</span>가 1회 증가한다. (턴당 1회)</p><p></p><p><span style=\"color: #FFFFFF\">원류바다 진주</span></p><p><span style=\"color: #FFD780\">상태</span></p><p><span style=\"color: #FFFFFF\">부착 캐릭터가 피해를 받을 시:</span> 피해를 1pt 상쇄한다. 소환물이 주는 피해를 상쇄할 때 턴마다 1회씩 <span style=\"color: #FFFFFF\">사용 가능 횟수</span>를 소모하지 않는다.</p><p><span style=\"color: #FFFFFF\">사용 가능 횟수: 2</span></p><p></p><p><span style=\"color: #FFFFFF\">아군 종료 선언 시:</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">부착 캐릭터가 「출전 캐릭터」인 경우 카드를 1장 드로우한다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/25/302875544/4512ed5fa47440d951f659ff9f7fb0b3_8639669134837257423.png",
                "key": "춤추는 물고기 떼",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "춤추는 물고기 떼"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">원소폭발</span></p><p><span style=\"color: rgb(255, 172, 255)\">번개 원소 피해</span>를 1pt 주고 본 캐릭터에게 <span style=\"color: rgb(255, 255, 255)\">원류바다 진주</span>를 부작한 뒤 <span style=\"color: rgb(255, 255, 255)\">공명 진주</span>를 소환한다.</p><p></p><p><span style=\"color: rgb(255, 255, 255)\">원류바다 진주</span></p><p><span style=\"color: rgb(255, 215, 128)\">상태</span></p><p><span style=\"color: rgb(255, 255, 255)\">부착 캐릭터가 피해를 받을 시:</span> 피해를 1pt 상쇄한다. 소환물이 주는 피해를 상쇄할 때 턴마다 1회씩 <span style=\"color: rgb(255, 255, 255)\">사용 가능 횟수</span>를 소모하지 않는다.</p><p><span style=\"color: rgb(255, 255, 255)\">사용 가능 횟수: 2</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">아군 종료 선언 시:</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">부착 캐릭터가 「출전 캐릭터」인 경우 카드를 1장 드로우한다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/25/302875544/14274ea236c0c28ce99979f7fceb56a9_3922559382207056945.png",
