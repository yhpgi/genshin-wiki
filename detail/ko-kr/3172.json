              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">일반 공격</span></p><p><span style=\"color: #FFFFFF\">물리 피해</span>를 2pt 준다.<br></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/30/194600931/c369b96fc6417e8fc2bb607e37297ad4_5843783910420275819.png",
