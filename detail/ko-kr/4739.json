      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">일반 공격</span></p><p><span style=\"color: rgb(255, 255, 255)\">물리 피해</span>를 2pt 준다.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/29/302875544/47817b4476bcd8b44c86c87debf042f2_8712639818306588117.png",
                "id": "talent53388",
                "key": "바위 분쇄 충돌",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "바위 분쇄 충돌"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">원소전투 스킬</span></p><p><span style=\"color: rgb(255, 230, 153)\">바위 원소 피해</span><span style=\"color: rgba(255, 255, 255, 0.45)\">를 3pt 주고 결정 반응이 발생하면 캐릭터는 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">해당 원소의 힘을 흡수</span><span style=\"color: rgba(255, 255, 255, 0.45)\">한다. 만약 이번 스킬에서 캐릭터가 원소의 힘을 흡수하지 않을 경우 </span><span style=\"color: rgba(255, 255, 255, 0.85)\">반암백상·원소 응결</span><span style=\"color: rgba(255, 255, 255, 0.45)\">을 부착한다.<br></span></p><p><strong><span style=\"color: rgb(236, 229, 216)\">해당 원소의 힘을 흡수</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">야타용왕은</span> <span style=\"color: rgb(153, 255, 255)\">얼음</span><span style=\"color: rgba(255, 255, 255, 0.45)\">/</span><span style=\"color: rgb(128, 192, 255)\">물</span><span style=\"color: rgba(255, 255, 255, 0.45)\">/</span><span style=\"color: rgb(255, 153, 153)\">불</span><span style=\"color: rgba(255, 255, 255, 0.45)\">/</span><span style=\"color: rgb(255, 172, 255)\">번개</span> <span style=\"color: rgba(255, 255, 255, 0.45)\">원소의 힘을 흡수할 수 있다. (동시에 한 가지만 흡수 가능)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">야타용왕이 상술한 원소의 힘을 흡수했을 시:</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgba(255, 255, 255, 0.45)\">흡수한 원소 타입에 따라 다음 스킬을 획득한다: </span><span style=\"color: rgb(153, 255, 255)\">서리 습격</span><span style=\"color: rgba(255, 255, 255, 0.45)\">/</span><span style=\"color: rgb(128, 192, 255)\">격류 범람</span><span style=\"color: rgba(255, 255, 255, 0.45)\">/</span><span style=\"color: rgb(255, 153, 153)\">화염 잠식</span><span style=\"color: rgba(255, 255, 255, 0.45)\">/</span><span style=\"color: rgb(255, 172, 255)\">벼락 습격</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">반암백상·원소 응결</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">상태</span></p><p><span style=\"color: rgba(255, 255, 255, 0.85)\">캐릭터가</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(153, 255, 255)\">얼음</span><span style=\"color: rgb(255, 255, 255)\">/</span><span style=\"color: rgb(128, 192, 255)\">물</span><span style=\"color: rgb(255, 255, 255)\">/</span><span style=\"color: rgb(255, 153, 153)\">불</span><span style=\"color: rgb(255, 255, 255)\">/</span><span style=\"color: rgb(255, 172, 255)\">번개</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">원소 피해를 받은 후:</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> 캐릭터가 현재 해당 원소의 힘을 흡수하지 않았을 경우, 해당 상태를 제거하고 캐릭터는 해당 원소의 힘을 흡수한다.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/30/302875544/23dddc226f4ebf4ef82138e15f9c20d5_5236500761746199206.png",
