            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">일반 공격</span></p><p><span style=\"color: #FFFFFF\">물리 피해</span>를 2pt 준다.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/02/194600931/47817b4476bcd8b44c86c87debf042f2_801971343874554476.png",
