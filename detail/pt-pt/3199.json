                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Detalhes da Fase",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Miau!\" \"Ouvi dizer que quando o Terrorgumelo Emplumado abre as penas de sua cauda e suas asas, é o momento em que toda sua beleza se mostra. Mas também é o momento mais perigoso...\"",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(204, 191, 173)"
                      ],
                      "text": "[Regra Especial] Terrorgumelo Emplumado é imune à reação Congelado, Atordoamento e Petrificado, e começa equipado com a Carta de Talento \"Crescimento de Esporos\".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Equipe Inimiga",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3199,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/01/35428890/920c7d546361d0b52dd95613517319f9_7937390309938836162.png",
                      "menu_id": 17,
                      "name": "Jadeplume Terrorshroom",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
