                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Arte do Adeptus: Arauto da Floresta"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de </span><span style=\"color: #99FFFF\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">, gera </span><span style=\"color: rgb(255, 255, 255)\">Talismã da Preservação da Fortuna</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Talismã da Preservação da Fortuna</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado de Combate</span></p><p><span style=\"color: rgb(255, 255, 255)\">Após seu personagem usar uma Habilidade:</span><span style=\"color: rgb(191, 191, 191)\"> Se esse personagem não tiver a Vida cheia, cura esse personagem em 2 de Vida.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/22/59559639/900dec327166a00218479cf8616072fc_1040262740790691652.png",
                "id": "talent27859",
                "key": "Arte do Adeptus: Preservador da Fortuna",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Arte do Adeptus: Preservador da Fortuna"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 de <span style=\"color: #99FFFF\">Dano Cryo</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 3</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Quando essa invocação está em campo após Qiqi usar um Ataque Normal:</span> Cura 1 de Vida ao seu personagem com menos Vida.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/22/59559639/db13288db6b90ec33f8adc2656d2019f_5916469190592677072.png",
                "id": "talent7873",
                "key": "Arauto da Floresta",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/22/59559639/971b05c02dd20b662457e953c3c1ce93_1546968785175218187.png",
                "title": "Arauto da Floresta"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Cryo, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Fusão</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual.</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Supercondutor</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo.</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/22/59559639/4bcc4b82a9d7ee22770f60afa54e9919_1026382849064525614.png",
                "id": "talent66859",
                "key": "Dano Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/22/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_3040198584206961548.png",
