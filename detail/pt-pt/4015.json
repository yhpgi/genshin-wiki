              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Invoca </span><span style=\"color: rgb(255, 255, 255)\">Arauto da Floresta</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/22/59559639/2575ddfaacc7015ebab2d17fba4593ea_6173950063459078974.png",
                "id": "talent45121",
                "key": "Arte do Adeptus: Arauto da Floresta",
