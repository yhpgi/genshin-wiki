              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de </span><span style=\"color: #FF9999\">Dano Pyro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/053697dd2072f984e7e9b4e118b3dec9_6213120070758675949.png",
