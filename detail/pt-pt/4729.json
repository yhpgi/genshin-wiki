      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/ad8a357fa8480f61f3fe665b69d9c263_1653427218777040091.png",
                "key": "Arco Invisível Oculto",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Arco Invisível Oculto"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de </span><span style=\"color: #80C0FF\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">. Este personagem ganha 2 acúmulos de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Ruptura</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(191, 191, 191)\">Esse estado começa com 1 acúmulo de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">. Quando reaplicado, adiciona 1 acúmulo de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">. </span><span style=\"color: rgb(255, 255, 255)\">Ruptura </span><span style=\"color: rgb(191, 191, 191)\">pode ter até 3 acúmulos.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(191, 191, 191)\">ganha 1 acúmulo de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Quando o personagem com este efeito aplicado realizar um Ataque Normal: </span><span style=\"color: rgb(191, 191, 191)\">Se tiver 2 de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">, consome 2 acúmulos de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\"> para converter </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\"> em </span><span style=\"color: #80C0FF\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\"> e puxa 1 carta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/b0033b9dfbdff746cfb03c7b73792a34_764940440121222265.png",
                "key": "Rede da Vida Salvadora",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Rede da Vida Salvadora"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">, gera 1 </span><span style=\"color: rgb(255, 255, 255)\">Dado Misterioso</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Dado Misterioso</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado de Combate</span></p><p><span style=\"color: rgb(255, 255, 255)\">Após um Ataque Normal de personagem: </span><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos): 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/f92e763ec4e356d65ffc75d9443b7d22_3940303643911361506.png",
                "key": "Dado das Profundezas Claras",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Dado das Profundezas Claras"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Passiva</span></p><p><span style=\"color: rgb(191, 191, 191)\">(Passiva) No começo do combate, é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Ruptura</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(191, 191, 191)\">Esse estado começa com 1 acúmulo de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">. Quando reaplicado, adiciona 1 acúmulo de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">. </span><span style=\"color: rgb(255, 255, 255)\">Ruptura </span><span style=\"color: rgb(191, 191, 191)\">pode ter até 3 acúmulos.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(191, 191, 191)\">ganha 1 acúmulo de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Quando o personagem com este efeito aplicado realizar um Ataque Normal: </span><span style=\"color: rgb(191, 191, 191)\">Se tiver 2 de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\">, consome 2 acúmulos de </span><span style=\"color: rgb(255, 255, 255)\">Ruptura</span><span style=\"color: rgb(191, 191, 191)\"> para converter </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\"> em </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\"> e puxa 1 carta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/9c5eb94adf31a35a1dcf456b08342b00_5971330896771258887.png",
                "key": "Ruptura",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Ruptura"
              },
              {
                "attributes": [],
                "desc": "<p>Afeta o alvo com Hydro, podendo desencadear as seguintes Reações Elementais:</p><p>[<span style=\"color: rgb(128, 192, 255)\">Hydro</span> + <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Vaporização</span>: Adiciona 2 pontos ao Dano Atual</p><p>[<span style=\"color: rgb(128, 192, 255)\">Hydro</span> + <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Eletricamente Carregado</span>: Adiciona 1 ponto ao Dano Atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</p><p>[<span style=\"color: rgb(128, 192, 255)\">Hydro</span> + <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">Congelado</span>: Adiciona 1 ponto ao Dano Atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</p><p>[<span style=\"color: rgb(128, 192, 255)\">Hydro</span> + <span style=\"color: rgb(153, 255, 136)\">Dendro</span>] <span style=\"color: rgb(255, 255, 255)\">Florescimento</span>: Adiciona 1 ponto ao Dano Atual, cria <span style=\"color: rgb(255, 255, 255)\">\"Núcleo Dendro\"</span> que causa 2 pontos extras de Dano no próximo ataque Pyro/Electro</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/a126c6a302d81c07e19cf9a9f1260f90_2700579427778212137.png",
                "key": "Dano Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Duração (Turnos)</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Na Fase Final de cada turno, </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos) </span><span style=\"color: rgb(191, 191, 191)\">será reduzido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Quando a </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos)</span><span style=\"color: rgb(191, 191, 191)\"> for esgotada, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_2955898866735288743.png",
                "key": "Regras Detalhadas",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Regras Detalhadas"
              }
            ]
          }
        }
      ]
