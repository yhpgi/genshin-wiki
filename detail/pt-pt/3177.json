                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Arte Kamisato: Hyouka"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 4 pontos de</span> <span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">, invoca </span><span style=\"color: rgb(255, 255, 255)\">Granizo Seki no To</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/b3d6af4c2817f35e4e06de8197dd8c07_5781159699865598928.png",
                "id": "talent71424",
                "key": "Arte Kamisato: Soumetsu",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Arte Kamisato: Soumetsu"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Passiva</span></p><p><span style=\"color: rgb(191, 191, 191)\">(Passiva) Quando este personagem troca seu estado para \"Personagem em Combate\", é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Encantamento Cryo</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Encantamento Cryo</span></strong></p><p><span style=\"color: rgb(255, 230, 153)\">Estado</span><br><span style=\"color: rgb(191, 191, 191)\">O </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\"> causado pelos personagens afetados é convertido em </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(191, 191, 191)\">(Dura até o final do turno)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/7359eeec791acae26196aa72a0621268_535850436468437554.png",
                "id": "talent88576",
                "key": "Arte Kamisato: Senho",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Arte Kamisato: Senho"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Granizo Seki no To</span></strong></p><p><span style=\"color: rgb(255, 230, 153)\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: #BFBFBF\">Causa 2 pontos de </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/db13288db6b90ec33f8adc2656d2019f_3479637781148359873.png",
                "id": "talent97949",
                "key": "Granizo Seki no To",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/1447ebe24c4e7bd955c4b795be517cd3_3755091543872843884.png",
                "title": "Granizo Seki no To"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Cryo, podendo desencadear as Reações Elementais:</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Fusão</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual.</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Supercondutor</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo.</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/4bcc4b82a9d7ee22770f60afa54e9919_986649249757346296.png",
                "id": "talent83765",
                "key": "Dano Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: #BFBFBF\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: #BFBFBF\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: #FFFFFF\">Usos </span><span style=\"color: #BFBFBF\">será consumido em 1;</span></p><p><span style=\"color: #BFBFBF\">Após todos os</span><span style=\"color: rgb(191, 191, 191)\"> </span><span style=\"color: #FFFFFF\">Usos </span><span style=\"color: #BFBFBF\">serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/19/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_7336813831172077357.png",
