                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de</span> <span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/c815c3f7cfd5d0658dd94a1e28beda8b_8005184246849976461.png",
                "id": "talent27974",
