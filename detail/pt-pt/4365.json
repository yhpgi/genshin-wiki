                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: #80FFD7\">Dano Anemo</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/20/59559639/1ce09211f025bf5470682189e0837732_7216442622585819815.png",
                "id": "talent13131",
