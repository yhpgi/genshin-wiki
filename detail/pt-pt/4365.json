                ],
                "talent_img": "",
                "title": "Tocar da Bandeira Trêmula"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: #80FFD7\">Dano Anemo</span><span style=\"color: rgb(191, 191, 191)\">, este personagem é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Postura do Vento</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Postura do Vento</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando seu personagem com este efeito aplicado realiza um Ataque Normal:</span><span style=\"color: rgb(191, 191, 191)\"> +2 de Dano causado. Se o oponente tiver personagens em espera, estão esta Habilidade causará dano ao próximo personagem adversário em espera em vez disso.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/20/59559639/052cd901b44cef8359f0bebb98404194_9168517927358590719.png",
                "id": "talent87577",
                "key": "Pluma Ilustrada: Canção Graciosa",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Pluma Ilustrada: Canção Graciosa"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 7 pontos de </span><span style=\"color: rgb(128, 255, 215)\">Dano Anemo</span><span style=\"color: rgb(191, 191, 191)\">, se o personagem tiver o efeito </span><span style=\"color: rgb(255, 255, 255)\">Postura do Vento</span><span style=\"color: rgb(191, 191, 191)\"> aplicado, remove-o e aumenta o Dano em 1.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Postura do Vento</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando seu personagem com este efeito aplicado realiza um Ataque Normal:</span><span style=\"color: rgb(191, 191, 191)\"> +2 de Dano causado. Se o oponente tiver personagens em espera, estão esta Habilidade causará dano ao próximo personagem adversário em espera em vez disso.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/10/20/59559639/5a55e705974f27b8bb86c628019d5ad9_2807330300463892873.png",
                "id": "talent18498",
                "key": "Kyogen: Cinco Atos",
