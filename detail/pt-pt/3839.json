                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Detalhes da Fase",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Interessante. Talvez se nós dois levarmos isso um pouco mais a sério, esse jogo possa ser ainda mais prazeroso...\"",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(204, 191, 173)"
                      ],
                      "text": "[Regra Especial] Xiao começa equipada com a Carta de Talento \"Conquistador do Mal - Guardião Yaksha\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
