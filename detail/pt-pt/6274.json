                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/21/237301566/ea5f0394e15a4e00d3a95314d25110ac_797685623316495224.png"
