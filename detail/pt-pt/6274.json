                      ],
                      "text": "Simulanka",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/21/237301566/ce72c0c5794716c8d44d018affee7f0e_5073265370691369390.gif"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "12 de julho, 2024",
                      "type": "text"
                    },
                    {
                      "text": "A magia criou um mundo de conto de fadas",
                      "type": "text"
                    },
                    {
                      "text": "Em que borboletas de papel voam",
                      "type": "text"
                    },
                    {
                      "text": "E pássaros cantam suavemente",
                      "type": "text"
                    },
                    {
                      "text": "Um castelo feito de blocos de montar",
                      "type": "text"
                    },
                    {
                      "text": "Uma torre que penetra as nuvens",
                      "type": "text"
                    },
                    {
                      "text": "Engrenagens que giram suavemente",
                      "type": "text"
                    },
                    {
                      "text": "Trazendo alegria e risos",
                      "type": "text"
                    },
                    {
                      "text": "Venha, venha",
                      "type": "text"
                    },
                    {
                      "text": "Caminhar nessa viagem de conto de fadas",
                      "type": "text"
                    },
