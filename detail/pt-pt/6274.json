                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/09/42646513/94ca3d100fc27da3041bde3d067e6646_4697089882086428382.jpg"
