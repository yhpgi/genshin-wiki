                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/09/42646513/1533276bc22ebf676870ba59a7450d2c_306243146470676618.jpg"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "22 de julho, 2024",
                      "type": "text"
                    },
                    {
                      "text": "A região por tempo limitado Reino das Fadas \"Simulanka\" já está disponível!",
                      "type": "text"
