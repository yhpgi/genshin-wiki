      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: #99FF88\">Dano Dendro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/16/59559639/1ce09211f025bf5470682189e0837732_4733669279389889862.png",
