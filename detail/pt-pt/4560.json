              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 de <span style=\"color: #FFACFF\">Dano Electro</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 1</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/16/59559639/db13288db6b90ec33f8adc2656d2019f_4332998086032148018.png",
