                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Chuva Geo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p>Causa 1 ponto de <span style=\"color: rgb(255, 230, 153)\">Dano Geo</span>, Invoca <span style=\"color: rgb(255, 255, 255)\">Estela de Pedra</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Estela de Pedra</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 ponto de <span style=\"color: rgb(255, 230, 153)\">Dano Geo.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos</span>: 2</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/31/101132274/bd88dd4e84f0956abd3d34b19442d2c6_1526988332215195738.png",
                "id": "talent46540",
                "key": "Dominus Lapidis",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Dominus Lapidis"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p>Causa 3 pontos de <span style=\"color: rgb(255, 230, 153)\">Dano Geo</span>, invoca <span style=\"color: rgb(255, 255, 255)\">Estela de Pedra</span>, gera <span style=\"color: rgb(255, 255, 255)\">Escudo de Jade</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Estela de Pedra</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 ponto de <span style=\"color: rgb(255, 230, 153)\">Dano Geo.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos</span>: 2</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Escudo de Jade</span></strong></p><p><span style=\"color: #FFD780\">Estado de Combate</span></p><p><span style=\"color: rgb(191, 191, 191)\">Concede 2</span><span style=\"color: rgb(255, 255, 255)\"> pontos de Escudo</span><span style=\"color: rgb(191, 191, 191)\"> ao seu Personagem em Combate.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/31/101132274/857631feb4f9832ee5644c9f6faf3a44_1477102917815996331.png",
                "id": "talent78527",
                "key": "Dominus Lapidis: Rocha Aniquiladora",
                "materials": [],
                "points": [
                  {
                    "point_count": 5,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Dominus Lapidis: Rocha Aniquiladora"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span></p><p>Causa 4 pontos de <span style=\"color: rgb(255, 230, 153)\">Dano Geo</span>, o personagem algo é afetado por<span style=\"color: rgb(255, 255, 255)\"> Petrificação.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Petrificação</span></strong></p><p><span style=\"color: #FFD780\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">O personagem não pode usar habilidades.</span> (Dura até o final deste Turno)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/31/101132274/c701cbbd15b971aaee458b19e71b4ced_174148689537359360.png",
                "id": "talent19131",
                "key": "Chuva Estelar",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Chuva Estelar"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span><br><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 ponto de <span style=\"color: rgb(255, 230, 153)\">Dano Geo</span><span style=\"color: rgb(191, 191, 191)\">.<br></span><span style=\"color: rgb(255, 255, 255)\">Usos:</span><span style=\"color: rgb(191, 191, 191)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/31/101132274/db13288db6b90ec33f8adc2656d2019f_2788536377829042199.png",
                "id": "talent91149",
                "key": "Estela de Pedra",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/31/101132274/905fb3dd007f1806491f7e9df8812d45_7315748230717161829.png",
                "title": "Estela de Pedra"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Gera Reações Elementais em alvos já afetados:</span></p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização(Cryo)</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</span></p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Hydro)</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</span></p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Pyro)</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</span></p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Electro)</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/31/101132274/fd37cbfdd3b1b2c16e6e83fb0aa96889_6579533113885966122.png",
                "id": "talent15560",
                "key": "Dano Geo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Geo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Escudo</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Este Escudo será consumido para que o personagem que equipá-lo se proteja de Dano.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os Usos serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/11/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_2010090027661018530.png",
