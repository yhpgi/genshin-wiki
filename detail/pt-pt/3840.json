          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p>Causa 2 pontos de <span style=\"color: rgb(255, 255, 255)\">Dano Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/31/101132274/241eba6e4c00020975cf91170050f435_1682106461358838519.png",
                "id": "talent25630",
                "key": "Chuva Geo",
                "materials": [],
