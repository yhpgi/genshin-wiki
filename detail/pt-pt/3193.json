                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span></p><p>Causa 1 Ponto de <span style=\"color: rgb(128, 255, 215)\">Dano Anemo</span>, invoca <span style=\"color: rgb(255, 255, 255)\">Grande Espírito do Vento</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/16935775/28de70f699de4ba7cf0f77f2fcfb1483_8136871312310398620.png",
                "id": "talent22571",
                "key": "Criação Proibida do Espírito do Vento: Isomórfico-75 Tipo II",
