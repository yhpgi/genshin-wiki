    {
      "id": "48",
      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de</span> <span style=\"color: rgb(255, 255, 255)\">Dano Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/20/16935775/d576e47ec29592a74d7f18040459665c_8627589361623776428.png",
                "id": "talent84376",
                "key": "Lenda do Combate",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Lenda do Combate"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 1 de </span><span style=\"color: rgb(255, 230, 153)\">Dano Geo</span><span style=\"color: rgb(191, 191, 191)\">, invoca</span> <span style=\"color: rgb(255, 255, 255)\">Ushi</span><span style=\"color: rgb(191, 191, 191)\"> e este personagem é afetado por Superforça Superlativa.</span><br><br><strong><span style=\"color: rgb(236, 229, 216)\">Superforça Superlativa</span></strong><br><span style=\"color: #FFD780\">Estado</span><br><span style=\"color: rgb(255, 255, 255)\">Quando o personagem afetado realizar Ataque Carregado:</span><span style=\"color: rgb(191, 191, 191)\"> causa +1 de Dano. Se tiver pelo menos 2 de Usos, o consumo de </span><span style=\"color: rgb(255, 255, 255)\">Elemento Indefinido</span><span style=\"color: rgb(191, 191, 191)\"> será reduzido em 1.<br></span><span style=\"color: rgb(255, 255, 255)\">Usos: 1</span><span style=\"color: rgb(191, 191, 191)\"> (Acumulável, pode ser acumulado até 3 vezes)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/20/16935775/c75ed9237fb342dae8cd65729ddc0bba_5859073949063839205.png",
                "id": "talent42944",
                "key": "Masatsu Zetsugi: Explosão Akaushi!",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Masatsu Zetsugi: Explosão Akaushi!"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span><br>Causa 5 pontos de <span style=\"color: rgb(255, 230, 153)\">Dano Geo</span>, este personagem é afetado por <span style=\"color: rgb(255, 255, 255)\">Rei Oni Furioso</span>.</p><p><br><strong><span style=\"color: rgb(236, 229, 216)\">Rei Oni Furioso</span></strong><br><span style=\"color: #FFD780\">Estado</span><br><span style=\"color: rgb(191, 191, 191)\">Os </span><span style=\"color: rgb(255, 255, 255)\">ataques Normais </span><span style=\"color: rgb(191, 191, 191)\">do personagem afetado causam +2 de Dano e o </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\"> causado é convertido em </span><span style=\"color: rgb(255, 230, 153)\">Dano Geo</span><span style=\"color: rgb(191, 191, 191)\">.<br></span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos): 2</span><span style=\"color: rgb(191, 191, 191)\"> </span><br><span style=\"color: rgb(255, 255, 255)\">Após o personagem afetado usar um Ataque Normal:</span><span style=\"color: rgb(191, 191, 191)\"> Tem </span><span style=\"color: rgb(255, 255, 255)\">Superforça Surpelativa</span><span style=\"color: rgb(191, 191, 191)\"> aplicado em si. (1 vez por turno)</span><br><br><strong><span style=\"color: rgb(236, 229, 216)\">Superforça Superlativa</span></strong><br><span style=\"color: #FFD780\">Estado</span><br><span style=\"color: rgb(255, 255, 255)\">Quando o personagem afetado realizar Ataque Carregado:</span><span style=\"color: rgb(191, 191, 191)\"> causa +1 de Dano. Se tiver pelo menos 2 de Usos, o consumo de </span><span style=\"color: rgb(255, 255, 255)\">Elemento Indefinido</span><span style=\"color: rgb(191, 191, 191)\"> será reduzido em 1.<br></span><span style=\"color: rgb(255, 255, 255)\">Usos: 1</span><span style=\"color: rgb(191, 191, 191)\"> (Acumulável, pode ser acumulado até 3 vezes)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/20/16935775/d5b0f60e30da0341b4165d1a76b3c73b_8142827397336642186.png",
                "id": "talent43609",
                "key": "Descendência Real: Contemplem, Itto, o Maligno!",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Descendência Real: Contemplem, Itto, o Maligno!"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span><br><span style=\"color: rgb(191, 191, 191)\">Quando seu Personagem em Combate sofrer Dano: reduz 1 ponto de Dano.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos</span>: 1<span style=\"color: rgb(255, 255, 255)\">. </span><span style=\"color: rgb(191, 191, 191)\">Quando os Usos esgotarem, essa carta não será descartada.<br></span><span style=\"color: rgb(255, 255, 255)\">Pode desencadear uma vez quando estiver invocada:</span><span style=\"color: rgb(191, 191, 191)\"> depois de seu Personagem em Combate sofrer Dano, afetará</span><span style=\"color: rgb(255, 255, 255)\"> Superforça Superlativa</span><span style=\"color: rgb(191, 191, 191)\"> com Arataki Itto.</span><br><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(191, 191, 191)\">descarta essa carta e causa 1 de </span><span style=\"color: rgb(255, 230, 153)\">Dano Geo</span><span style=\"color: rgb(255, 255, 255)\">.</span><br></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Superforça Superlativa</span></strong><br><span style=\"color: #FFD780\">Estado</span><br><span style=\"color: rgb(255, 255, 255)\">Quando o personagem afetado realizar Ataque Carregado:</span><span style=\"color: rgb(191, 191, 191)\"> causa +1 de Dano. Se tiver pelo menos 2 de Usos, o consumo de </span><span style=\"color: rgb(255, 255, 255)\">Elemento Indefinido</span><span style=\"color: rgb(191, 191, 191)\"> será reduzido em 1.<br></span><span style=\"color: rgb(255, 255, 255)\">Usos: 1</span><span style=\"color: rgb(191, 191, 191)\"> (Acumulável, pode ser acumulado até 3 vezes)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/20/16935775/db13288db6b90ec33f8adc2656d2019f_1914777358486188628.png",
                "id": "talent95478",
                "key": "Ushi",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/20/16935775/ea059a3f7bee2dea6bcee851752339c3_2017007028474010832.png",
                "title": "Ushi"
              },
              {
                "attributes": [],
                "desc": "<p>Gera Reações Elementais em alvos já afetados:</p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização(Cryo)</span>: Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Hydro)</span>: Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Pyro)</span>: Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Electro)</span>: Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/20/16935775/fd37cbfdd3b1b2c16e6e83fb0aa96889_2309334087401064729.png",
                "id": "talent96300",
                "key": "Dano Geo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Geo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.<br></span></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Ataque Carregado</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o seu número total de Dados Elementais é par, o \"Ataque Normal\" é considerado como \"Ataque Carregado\".<br></span></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Elemento Indefinido</span></strong><span style=\"color: rgb(191, 191, 191)\"><br>Você pode usar quaisquer Dados Elementais para pagar esse custo.<br><br></span><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os Usos serem consumidos, a carta será automaticamente descartada.<br><br></span><strong><span style=\"color: rgb(236, 229, 216)\">Duração (Turnos)</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Na fase final de cada turno, </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos) </span><span style=\"color: rgb(191, 191, 191)\">será reduzido em 1.</span></p><p><span style=\"color: rgb(191, 191, 191)\">Quando a </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos) </span><span style=\"color: rgb(191, 191, 191)\">for esgotada, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/20/16935775/245c229cf6f7364c7c9a7aea3db1a1ad_2596142046387306061.png",
                "id": "talent85786",
                "key": "Regras Detalhadas",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Regras Detalhadas"
              }
            ]
          }
        }
      ]
