                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Detalhes da Fase",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Hahahahaha! Nunca é tarde para admitir a derrota diante de Arataki \"O Incrível Campeão\" Itto!",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(204, 191, 173)"
                      ],
                      "text": "[Dica] O deck de Arataki Itto possui uma grande ênfase na Carta de Espadão e em Ataques Carregados, permitindo que ele lute armado até o final.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Equipe Inimiga",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
