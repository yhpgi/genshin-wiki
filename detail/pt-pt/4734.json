          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: #99FFFF\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/28/59559639/1ce09211f025bf5470682189e0837732_8476359006894371219.png",
                "id": "talent18114",
                "key": "Tempestade de Granizo da Lâmina Congelante",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Tempestade de Granizo da Lâmina Congelante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">, o personagem alvo é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Frio Extremo</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Frio Extremo</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(191, 191, 191)\">causa 1 ponto de </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\"> ao personagem afetado.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 1</span></p><p></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o personagem é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Calor Escaldante</span><span style=\"color: rgb(191, 191, 191)\">, remove esse efeito.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Calor Escaldante</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(191, 191, 191)\">causa 1 ponto de </span><span style=\"color: rgb(255, 153, 153)\">Dano Pyro</span><span style=\"color: rgb(191, 191, 191)\"> ao personagem afetado.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 1</span></p><p></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o personagem é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Frio Extremo</span><span style=\"color: rgb(191, 191, 191)\">, remove esse efeito.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/28/59559639/289913e1d0feaab0fa03891032b086c0_7227328357323837056.png",
                "id": "talent82050",
                "key": "Fragmentos Congelantes",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Fragmentos Congelantes"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 4 pontos de </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">, cura este personagem em 2 de Vida. Remove </span><span style=\"color: rgb(255, 255, 255)\">Bruxa das Chamas Carmesins Selada no Gelo</span><span style=\"color: rgb(191, 191, 191)\">. Este personagem muda permanentemente para o Estado </span><span style=\"color: rgb(255, 255, 255)\">Bruxa das Chamas Carmesim</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bruxa das Chamas Carmesins Selada no Gelo</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando a Fase de Ação iniciar: </span><span style=\"color: rgb(191, 191, 191)\">se o personagem afetado não tiver mais de 4 de Vida, remove esse efeito.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando o personagem afetado é derrotado: </span><span style=\"color: rgb(191, 191, 191)\">remove esse efeito, garante uma </span><span style=\"color: rgb(255, 255, 255)\">Eliminação Evitada</span><span style=\"color: rgb(191, 191, 191)\"> para o personagem e o Cura em 1 de Vida.</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Quando esse efeito é removido: </span><span style=\"color: rgb(191, 191, 191)\">muda o personagem afetado para o estado </span><span style=\"color: rgb(255, 255, 255)\">Bruxa das Chamas Carmesim</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bruxa das Chamas Carmesim</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(191, 191, 191)\">Signora pode mudar permanentemente para o estado \"Bruxa das Chamas Carmesim\".</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após a mudança, o tipo elemental de muda de </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(191, 191, 191)\"> para </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após a mudança, o personagem poderá usar as habilidades da Bruxa das Chamas Carmesim, mas não poderá mais utilizar as Habilidades Originais de Signora.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/28/59559639/f819c287507962ff41ad86e68661a707_6862961959185181242.png",
                "id": "talent49387",
                "key": "Carmine Chrysalis",
                "materials": [],
                "points": [
