                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 6 pontos de </span><span style=\"color: #FF9999\">Dano Pyro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
