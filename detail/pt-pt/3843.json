            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p>Causa 1 ponto de <span style=\"color: rgb(255, 153, 153)\">Dano Pyro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/04/101132274/1ce09211f025bf5470682189e0837732_4683938743974695239.png",
                "id": "talent9049",
