      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/26b9736a2d14fc4162b2448963f45695_3501317901374529516.png",
                "id": "talent36034",
                "key": "Estilo de Yunlai",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Estilo de Yunlai"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de </span><span style=\"color: rgb(255, 172, 255)\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">, gera a carta </span><span style=\"color: rgb(255, 255, 255)\">Relâmpago Stiletto</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/855f8d96be42fe05d7f7d66b60fad1a6_6977253286809100807.png",
                "id": "talent36424",
                "key": "Restauração Estelar",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Restauração Estelar"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 4 pontos de </span><span style=\"color: rgb(255, 172, 255)\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">, causa 3 pontos de </span><span style=\"color: rgb(255, 255, 255)\">Dano Perfurante</span><span style=\"color: rgb(191, 191, 191)\"> a todos os Personagens Inativos do oponente.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/9950bc530ec62d8e01daf47fe1229216_3523908626562191575.png",
                "id": "talent97928",
                "key": "Passeio Celestial",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Passeio Celestial"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Carta de Evento</span></p><p><span style=\"color: rgb(255, 255, 255)\">Ações de Combate:</span><span style=\"color: rgb(191, 191, 191)\"> Coloca Keqing em campo e usa Restauração Estelar imediatamente. Este uso de Restauração Estelar aplica </span><span style=\"color: rgb(255, 255, 255)\">Encantamento Electro </span><span style=\"color: rgb(191, 191, 191)\">sem criar outro Relâmpago Stiletto.<br>(Quando Keqing usa Restauração Estelar com esta carta na mão: Ao invés de criar outro Relâmpago Stiletto, descarta essa carta e Keqing ganha </span><span style=\"color: rgb(255, 255, 255)\">Encantamento Electro</span><span style=\"color: rgb(191, 191, 191)\">)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Encantamento Electro</span></strong></p><p><span style=\"color: #FFD780\">Estado</span><br><span style=\"color: rgb(191, 191, 191)\">O </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\"> causado pelo personagem afetado é convertido em </span><span style=\"color: rgb(255, 172, 255)\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/db13288db6b90ec33f8adc2656d2019f_4362115935124188926.png",
                "id": "talent79668",
                "key": "Relâmpago Stiletto",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/d6793b3314d1b255f49f2ba1ec500b38_7378701305853749455.png",
                "title": "Relâmpago Stiletto"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Electro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Sobrecarga</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 2 pontos ao Dano atual, o alvo é forçado a trocar para o próximo personagem</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supercondutor</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Eletricamente Carregado</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Aceleração</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, cria \"</span><span style=\"color: rgb(255, 255, 255)\">Área de Catalisação</span><span style=\"color: rgb(191, 191, 191)\">\" que causa 1 ponto extra de Dano nos próximos 3 ataques com Dano Dendro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/11ea6117480145a30b7893f1e8bd7115_1192850797389703922.png",
                "id": "talent97702",
                "key": "Dano Electro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Electro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Perfurante</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Perfurante não pode Receber Bônus de Dano, mas também não pode ser reduzido por Escudos, Imunidade a dano e similares.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Ação de Combate</span></strong></p><p>Após terminar 1 Ação de Combate, será o turno de seu oponente.</p><p><span style=\"color: rgb(255, 255, 255)\">Jogar uma carta de sua mão com esta regra também é uma Ação de Combate, ao invés de uma Ação Rápida.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Duração (Turnos)</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Na Fase Final de cada turno, </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos)</span><span style=\"color: rgb(191, 191, 191)\"> será reduzido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Quando </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos)</span><span style=\"color: rgb(191, 191, 191)\"> for esgotada, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/20/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_6345291205765992996.png",
                "id": "talent85624",
                "key": "Regras Detalhadas",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Regras Detalhadas"
              }
            ]
          }
        }
      ]
    },
