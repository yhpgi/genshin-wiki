              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p>Invoca <span style=\"color: rgb(255, 255, 255)\">Sesshou Sakura</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/101132274/7e9f291d99b3519d86302e803782b2f7_60857246362155681.png",
