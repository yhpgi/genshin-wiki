                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Evocação Yakan: Sesshou Sakura"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span></p><p>Causa 4 pontos de<span style=\"color: rgb(255, 172, 255)\"> Dano Electro.</span> Se houver <span style=\"color: rgb(255, 255, 255)\">Sesshou Sakura</span> ativo, desaparecerá e então gerará <span style=\"color: rgb(255, 255, 255)\">Relâmpago de Kitsune Celestial</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Relâmpago de Kitsune Celestial</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado de Combate</span></p><p><span style=\"color: rgb(255, 255, 255)\">Antes de você escolher sua ação:</span> Causa 3 de <span style=\"color: rgb(255, 172, 255)\">Dano Electro</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/101132274/56f64a44b1ccee62527e2a18a46de27f_3050129009982181753.png",
                "id": "talent71770",
                "key": "Grande Arte Secreta: Tenko Kenshin",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Grande Arte Secreta: Tenko Kenshin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocação</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span>Causa 1 de<span style=\"color: rgb(255, 172, 255)\"> Dano Electro</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 3 </span>(Acumulável, máximo de 6 acúmulos)</p><p><span style=\"color: rgb(255, 255, 255)\">Quando você declarar fim do seu Turno:</span> Se os Usos desta carta forem pelo menos 4, causa 1 de<span style=\"color: rgb(255, 172, 255)\"> Dano Electro</span>. (consome <span style=\"color: rgb(255, 255, 255)\">Usos</span>)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/101132274/db13288db6b90ec33f8adc2656d2019f_8034101678727551972.png",
                "id": "talent2093",
                "key": "Sesshou Sakura",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/101132274/9935fc2ef27a255d96756090578adee7_8103091315634127193.png",
                "title": "Sesshou Sakura"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Electro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Sobrecarga</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 2 pontos ao Dano atual, o alvo é forçado a trocar para o próximo personagem</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supercondutor</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Eletricamente Carregado</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Aceleração</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, cria </span><span style=\"color: rgb(255, 255, 255)\">\"Área de Catalisação\"</span><span style=\"color: rgb(191, 191, 191)\"> que causa 1 ponto extra de Dano nos próximos 2 ataques com Dano Dendro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/101132274/11ea6117480145a30b7893f1e8bd7115_5930380185812840602.png",
