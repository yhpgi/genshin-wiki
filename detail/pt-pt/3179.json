      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de</span> <span style=\"color: rgb(255, 255, 255)\">Dano Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/26b9736a2d14fc4162b2448963f45695_7726745368282128840.png",
                "id": "talent50740",
                "key": "Estilo Guhua",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Estilo Guhua"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 230, 153)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 ponto de </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">, este personagem recebe </span><span style=\"color: rgb(128, 192, 255)\">Aplicação Hydro</span><span style=\"color: rgb(191, 191, 191)\">, gera </span><span style=\"color: rgb(255, 255, 255)\">Chuva das Espadas</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Chuva das Espadas</span></strong></p><p><span style=\"color: #FFD780\">Estado de Combate</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando seu Personagem em Combate recebe Dano de no mínimo 3 pontos:</span></p><p><span style=\"color: rgb(191, 191, 191)\">cancela 1 ponto de Dano.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/bd2e37ed99962256b135c189ea1fdea3_9025917172876213708.png",
                "id": "talent85654",
                "key": "Chuva Torrencial",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Chuva Torrencial"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">, este personagem recebe </span><span style=\"color: rgb(128, 192, 255)\">Aplicação Hydro</span><span style=\"color: rgb(191, 191, 191)\">, gera </span><span style=\"color: rgb(255, 255, 255)\">Poder das Lâminas do Arco-íris</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Poder das Lâminas do Arco-íris</span></strong></p><p><span style=\"color: #FFD780\">Estado de Combate</span></p><p><span style=\"color: rgb(255, 255, 255)\">Após um ataque Normal de personagem:</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(153, 255, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/9172b918a3681c2684b228115e32a819_8974240619174196094.png",
                "id": "talent99588",
                "key": "Retalhador de Chuva",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Retalhador de Chuva"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Hydro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Vaporização</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">] Eletricamente Carregado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Florescimento</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, cria  \"</span><span style=\"color: rgb(255, 255, 255)\">Núcleo Dendro</span><span style=\"color: rgb(191, 191, 191)\">\" que causa 2 pontos extras de Dano no próximo ataque Pyro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/a126c6a302d81c07e19cf9a9f1260f90_5050675313016017109.png",
                "id": "talent42878",
                "key": "Dano Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/19/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_6573069409741655493.png",
