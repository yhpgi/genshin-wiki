                      ],
                      "text": "https://genshin.hoyoverse.com/pt/news/detail/126819",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
