                      "text": "Teaser Versão 3.0 - \"O Alvorecer das Rosas\"",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/10/237301566/befd0c1a72bbada62a348cd949e4eb2f_1158451703374906330.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "13 de Agosto, 2022",
                      "type": "text"
                    },
                    {
                      "text": "O toque verdejante que aparece ao coletar nas montanhas,",
                      "type": "text"
                    },
                    {
                      "text": "as rosas que são amplamente vistas na natureza.",
                      "type": "text"
                    },
                    {
                      "text": "Os pássaros de cor vívida cantam alegremente no alvorecer,",
                      "type": "text"
                    },
                    {
                      "text": "transmitindo a sabedoria que foi passada há milênios.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "X/Twitter:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(55, 255, 255)"
                      ],
                      "text": "https://x.com/BRGenshinImpact/status/1558438229677834240",
