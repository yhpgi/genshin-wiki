    {
      "id": "48",
      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de</span> <span style=\"color: rgb(255, 255, 255)\">Dano Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/16935775/240a7dfccb5e733342507e896ab68a90_1737445719984953145.png",
                "id": "talent62623",
                "key": "Arte Kamisato - Giro",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Arte Kamisato - Giro"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de</span><span style=\"color: rgb(128, 192, 255)\"> Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">, este personagem é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Reflexão Torrencial</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Reflexão Torrencial</span></strong></p><p><span style=\"color: #FFD780\">Estado</span></p><p><span style=\"color: rgb(191, 191, 191)\">Os </span><span style=\"color: rgb(255, 255, 255)\">Ataques Normais</span> <span style=\"color: rgb(191, 191, 191)\">do personagem afetado causam +1 de Dano e o </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span> <span style=\"color: rgb(191, 191, 191)\">causado é convertido em </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">.</span><br><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/16935775/55eb1da26441dc746dcf9b653d2bab47_2870284283260063095.png",
                "id": "talent76290",
                "key": "Arte Kamisato: Beleza Refletida",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Arte Kamisato: Beleza Refletida"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de</span> <span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">, invoca um </span><span style=\"color: rgb(255, 255, 255)\">Jardim Puro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/16935775/2a7181cfb07c093325abc8170e210e45_6111222864732388852.png",
                "id": "talent41746",
                "key": "Arte Kamisato: Jardim Aquático",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Arte Kamisato: Jardim Aquático"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final:</span> <span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span>.<br><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span><br><br><span style=\"color: rgb(255, 255, 255)\">Quando esta invocação estiver em campo: </span><span style=\"color: rgb(191, 191, 191)\">O Ataque Normal de seu personagem causará +1 de Dano.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/16935775/db13288db6b90ec33f8adc2656d2019f_3211298393683289286.png",
                "id": "talent61080",
                "key": "Jardim Puro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/16935775/ad5eb2ee48365d340272b333689f3ebb_1557459709980685060.png",
                "title": "Jardim Puro"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Hydro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Vaporização</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">] Eletricamente Carregado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Florescimento</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, cria \"</span><span style=\"color: rgb(255, 255, 255)\">Núcleo Dendro</span><span style=\"color: rgb(191, 191, 191)\">\" que causa 2 pontos extras de Dano no próximo ataque Pyro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/16935775/a126c6a302d81c07e19cf9a9f1260f90_3949927009457370332.png",
                "id": "talent33444",
                "key": "Dano Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: #ECE5D8\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Quando o efeito desta carta é desencadeado, o número de Usos será consumido em 1;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Após todos os</span><span style=\"color: rgb(191, 191, 191)\"> </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/16935775/245c229cf6f7364c7c9a7aea3db1a1ad_4402091192957620043.png",
