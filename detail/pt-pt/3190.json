      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de</span> <span style=\"color: rgb(255, 255, 255)\">Dano Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/10316b5178d5109d597f415d6e7903dc_5995250855611247656.png",
                "id": "talent8914",
                "key": "Técnica da Espada de Favonius - Empregada",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Técnica da Espada de Favonius - Empregada"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 1 pontos de</span> <span style=\"color: rgb(255, 230, 153)\">Dano Geo</span><span style=\"color: rgb(191, 191, 191)\">, gera </span><span style=\"color: rgb(255, 255, 255)\">Armadura Protetora</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><br><strong><span style=\"color: rgb(236, 229, 216)\">Armadura Protetora</span></strong></p><p><span style=\"color: #FFD780\">Estado de Combate</span></p><p><span style=\"color: rgb(191, 191, 191)\">Concede 2</span><span style=\"color: rgb(255, 255, 255)\"> pontos de Escudo</span><span style=\"color: rgb(191, 191, 191)\"> ao seu Personagem em Combate.<br>Antes desse </span><span style=\"color: rgb(255, 255, 255)\">Escudo </span><span style=\"color: rgb(191, 191, 191)\">ser totalmente consumido, o </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\"> recebido por você será diminuído pela metade.</span></p><p><span style=\"color: rgb(191, 191, 191)\">(Arredondado para cima)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/b6fb31387815c4484390c7fb11891609_5180101063624299693.png",
                "id": "talent31113",
                "key": "Guardião do Coração",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Guardião do Coração"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 4 pontos de </span><span style=\"color: rgb(255, 230, 153)\">Dano Geo</span><span style=\"color: rgb(191, 191, 191)\">, este personagem é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Grande Limpeza</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Grande Limpeza</span></strong></p><p><span style=\"color: #FFD780\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando o personagem usa um Ataque Normal:</span></p><p><span style=\"color: rgb(191, 191, 191)\">Reduz o custo em 1 </span><span style=\"color: rgb(255, 230, 153)\">Dado Geo</span><span style=\"color: rgb(255, 255, 255)\">.</span><span style=\"color: rgb(191, 191, 191)\"> (1 vez por turno)</span><br><span style=\"color: rgb(191, 191, 191)\">O Dano causado pelo </span><span style=\"color: rgb(255, 255, 255)\">Ataque Normal</span><span style=\"color: rgb(191, 191, 191)\"> do personagem é aumentado em 2 pontos, e o </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\"> causado é convertido em </span><span style=\"color: rgb(255, 230, 153)\">Dano Geo</span><span style=\"color: rgb(191, 191, 191)\">.<br></span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/cb9d679d3462bed59d1601663836a019_5087898891553510524.png",
                "id": "talent91428",
                "key": "Grande Limpeza",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Grande Limpeza"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Gera Reações Elementais em alvos já afetados:</span></p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Cryo)</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</span></p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Hydro)</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</span></p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Pyro)</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</span></p><p>[<span style=\"color: rgb(255, 230, 153)\">Geo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Cristalização (Electro)</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, seu Personagem em Combate ganha 1 ponto de Escudo (Pode acumular até 2).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/fd37cbfdd3b1b2c16e6e83fb0aa96889_8488067708568466370.png",
                "id": "talent48072",
                "key": "Dano Geo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Geo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Escudo</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Este Escudo será consumido para que o personagem que equipá-lo se proteja de Dano.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Duração (Turnos)</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Na Fase Final de cada turno, </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos)</span><span style=\"color: rgb(191, 191, 191)\"> será reduzido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Quando </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos)</span><span style=\"color: rgb(191, 191, 191)\"> for esgotada, a carta será automaticamente descartada.</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/26/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_7800741275724085592.png",
                "id": "talent43565",
                "key": "Regras Detalhadas",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Regras Detalhadas"
              }
            ]
          }
        }
      ]
