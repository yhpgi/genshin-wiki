    {
      "id": "48",
      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/26b9736a2d14fc4162b2448963f45695_2265956026731595128.png",
                "key": "Espada do Caminho Radiante",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Espada do Caminho Radiante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Cria 1 </span><span style=\"color: rgb(255, 255, 255)\">Escudo da Cortina do Sono </span><span style=\"color: rgb(191, 191, 191)\">e </span><span style=\"color: rgb(255, 255, 255)\">Estrela Voadora</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Escudo da Cortina do Sono</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado de Combate</span></p><p><span style=\"color: rgb(191, 191, 191)\">Fornece 2 pontos de </span><span style=\"color: rgb(255, 255, 255)\">Escudo</span><span style=\"color: rgb(191, 191, 191)\"> ao seu Personagem em Combate.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Estrela Voadora</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado de Combate</span></p><p><span style=\"color: rgb(255, 255, 255)\">Depois que seu personagem usa a Habilidade: </span><span style=\"color: rgb(191, 191, 191)\">acumula 1 de </span><span style=\"color: rgb(255, 255, 255)\">Estrela Noturna</span><span style=\"color: rgb(191, 191, 191)\">. Se possuir pelo menos 4 </span><span style=\"color: rgb(255, 255, 255)\">Estrelas Noturnas</span><span style=\"color: rgb(191, 191, 191)\">, consome 4 </span><span style=\"color: rgb(255, 255, 255)\">Estrelas Noturnas</span><span style=\"color: rgb(191, 191, 191)\">, causando 1 de </span><span style=\"color: #99FFFF\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">. (A Habilidade que gera esse Estado em Combate também desencadeia esse Efeito)</span></p><p><span style=\"color: rgb(255, 255, 255)\">Ao gerar esse Estado de Combate repetidamente: </span><span style=\"color: rgb(191, 191, 191)\">acumula 2 </span><span style=\"color: rgb(255, 255, 255)\">Estrelas Noturnas</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/de48c78ad3dc782b2dfe98bbe645f7cd_5554762161455904917.png",
                "key": "Noites Solenes",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Noites Solenes"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de </span><span style=\"color: #99FFFF\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">, invoca </span><span style=\"color: rgb(255, 255, 255)\">Esfera de Sonhos Celestes</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/1af1d6edbe77aedd11a2e57551afb598_672052876466693798.png",
                "key": "Sonho das Correntes Estelares",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Sonho das Correntes Estelares"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 de <span style=\"color: #99FFFF\">Dano Cryo</span>. Se <span style=\"color: rgb(255, 255, 255)\">Estrela Voadora </span>estiver em jogo, ganhará 1 <span style=\"color: rgb(255, 255, 255)\">Estrela Noturna</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/db13288db6b90ec33f8adc2656d2019f_3402956915702066440.png",
                "key": "Esfera de Sonhos Celestes",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/8fae1317e614df75bd7911789c244c1f_6533591133501375877.png",
                "title": "Esfera de Sonhos Celestes"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Cryo, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Fusão</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual.</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Supercondutor</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo.</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span> <span style=\"color: rgb(255, 255, 255)\">Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/4bcc4b82a9d7ee22770f60afa54e9919_8977439640448316446.png",
                "key": "Dano Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Escudo</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Este Escudo será consumido para que o personagem que equipá-lo se proteja de Dano.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os Usos serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/26/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_1990627699157677239.png",
