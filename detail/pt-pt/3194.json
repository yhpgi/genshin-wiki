                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/c463e84467f23d8619f9cb815665fea2_7038125165641530008.png",
                "title": "Ave de Rapina"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span></p><p><span style=\"color: rgb(191, 191, 191)\">Quando seu Personagem em Combate recebe Dano:</span></p><p><span style=\"color: rgb(191, 191, 191)\">Cancela 1 ponto de Dano.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2. </span><span style=\"color: rgb(191, 191, 191)\">Essa carta não é descartada após ser completamente consumida.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durante a Fase Final, se Usos for consumido completamente</span><span style=\"color: rgb(191, 191, 191)\">:</span></p><p><span style=\"color: rgb(191, 191, 191)\">Descarta essa carta, causa 2 pontos de </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/db13288db6b90ec33f8adc2656d2019f_9056012916557052274.png",
                "id": "talent61863",
                "key": "Sapo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/72565a324bfe5f1bd45b24dd92aa105f_647829925241476721.png",
                "title": "Sapo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Hydro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Vaporização</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">] Eletricamente Carregado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Florescimento</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, cria </span><span style=\"color: rgb(255, 255, 255)\">\"Núcleo Dendro\"</span><span style=\"color: rgb(191, 191, 191)\"> que causa 2 pontos extras de Dano no próximo ataque Pyro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/a126c6a302d81c07e19cf9a9f1260f90_7765611182083575264.png",
                "id": "talent13006",
                "key": "Dano Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Escudo</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Este Escudo será consumido para que o personagem que equipá-lo se proteja de Dano.</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/26/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_431690579409122736.png",
