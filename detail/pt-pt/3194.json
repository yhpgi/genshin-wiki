                "desc": "<p><span style=\"color: #FFD780\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 ponto de <span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/db13288db6b90ec33f8adc2656d2019f_5264573233699928425.png",
                "id": "talent49535",
                "key": "Ave de Rapina",
                "materials": [],
