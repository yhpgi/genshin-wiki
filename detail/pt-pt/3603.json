      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 1 pontos de </span><span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/16/16935775/1ce09211f025bf5470682189e0837732_1049496093497217527.png",
                "id": "talent65459",
                "key": "Forma da Água",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Forma da Água"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Este personagem ganha uma </span><span style=\"color: rgb(128, 192, 255)\">Aplicação Hydro</span><span style=\"color: rgb(191, 191, 191)\"> e invoca </span><span style=\"color: rgb(255, 255, 255)\">Bake-Kurage</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/16/16935775/b33ca2371d6c02d581a1a89570bc6fb8_981736034351639985.png",
                "id": "talent52786",
                "key": "Juramento Kurage",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Juramento Kurage"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 3 ponto de</span><span style=\"color: rgb(128, 192, 255)\"> Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">, este personagem é afetado por</span> <span style=\"color: rgb(255, 255, 255)\">Vestimenta Cerimonial</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Vestimenta Cerimonial</span></strong></p><p><span style=\"color: #FFD780\">Estado</span></p><p><span style=\"color: rgb(191, 191, 191)\">O </span><span style=\"color: rgb(255, 255, 255)\">Ataque Normal</span><span style=\"color: rgb(191, 191, 191)\"> do personagem que recebe este efeito causa +1 de Dano.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando esse personagem realiza um Ataque Normal</span><span style=\"color: rgb(191, 191, 191)\">, todos os seus personagens curam 1 de Vida.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos): 2</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/16/16935775/47fcf95dc439392467286728a046b049_8174866406970549110.png",
                "id": "talent19993",
                "key": "Cerimônia Kaijin",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Cerimônia Kaijin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 ponto de <span style=\"color: rgb(128, 192, 255)\">Dano Hydro</span>, cura seu Personagem em Combate em 1 ponto.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/16/16935775/db13288db6b90ec33f8adc2656d2019f_1154624136963716670.png",
                "id": "talent58623",
                "key": "Bake-Kurage",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/16/16935775/0e046eb8f7da357cc6b2ee42e058526a_2117247880933869696.png",
                "title": "Bake-Kurage"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Hydro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Vaporização</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">] Eletricamente Carregado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Florescimento</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, cria \"</span><span style=\"color: rgb(255, 255, 255)\">Núcleo Dendro</span><span style=\"color: rgb(191, 191, 191)\">\" que causa 2 pontos extras de Dano no próximo ataque Pyro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/16/16935775/a126c6a302d81c07e19cf9a9f1260f90_1130553210466363122.png",
                "id": "talent48935",
                "key": "Dano Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de Usos será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Duração (Turnos)</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Na fase final de cada turno,</span><span style=\"color: rgb(255, 255, 255)\"> Duração (Turnos) </span><span style=\"color: rgb(191, 191, 191)\">será reduzido em 1.</span></p><p><span style=\"color: rgb(191, 191, 191)\">Quando a </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos)</span><span style=\"color: rgb(191, 191, 191)\"> for esgotada, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/16/16935775/245c229cf6f7364c7c9a7aea3db1a1ad_984173967549146530.png",
