                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: #FF9999\">Dano Pyro</span><span style=\"color: rgb(191, 191, 191)\">, invoca </span><span style=\"color: rgb(255, 255, 255)\">Espírito Ominoso: Escorpião de Fogo</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/16/59559639/6d7f53f97097de5265ca596461e914b1_2745165182697944696.png",
                "key": "O Despertar do Espírito Ominoso: Escorpião de Fogo",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
