                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Que Comece o Espetáculo ♪"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Cura 4 pontos de Vida de todos os seus personagens.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/bae3085f162716c905447f4c84f2bcf8_2732290986303794917.png",
                "id": "talent85739",
                "key": "Milagre Brilhante ♪",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Milagre Brilhante ♪"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: <span style=\"color: rgb(191, 191, 191)\">Cura 1 ponto de Vida de todos os seus personagens e afeta o Personagem em Combate com</span> <span style=\"color: rgb(128, 192, 255)\">Aplicação Hydro</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/db13288db6b90ec33f8adc2656d2019f_7290173379932915492.png",
                "id": "talent83879",
                "key": "Círculo Melódico",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/2f913e4b976b65b1d93dd9a3606ce58a_2634429596561470560.png",
                "title": "Círculo Melódico"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Hydro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Vaporização</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">] Eletricamente Carregado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Florescimento</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto ao Dano atual, cria \"</span><span style=\"color: rgb(255, 255, 255)\">Núcleo Dendro</span><span style=\"color: rgb(191, 191, 191)\">\" que causa 2 pontos extras de Dano no próximo ataque Pyro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/a126c6a302d81c07e19cf9a9f1260f90_5350480087367733361.png",
                "id": "talent58211",
                "key": "Dano Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de Usos será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/20/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_3293085480407953477.png",
