              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: rgb(153, 255, 255)\">Dano Hydro</span><span style=\"color: rgb(191, 191, 191)\">, gera</span> <span style=\"color: rgb(255, 255, 255)\">Círculo Melódico</span>.</p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/31/16935775/6ce6beac71091e13fe09094e6af6b210_6629975218472563911.png",
