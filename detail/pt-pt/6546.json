                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/10/42646513/364393e4cd8cbbb647938b022750dbdb_7119089958970091562.jpg"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "22 de agosto, 2024",
                      "type": "text"
                    },
                    {
                      "text": "Olá, Viajantes! Hoje estaremos trazendo para vocês a nova arma da Versão 5.0! Venham conferir conosco!",
                      "type": "text"
                    }
