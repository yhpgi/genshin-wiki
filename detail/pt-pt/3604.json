    {
      "id": "48",
      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p><span style=\"color: rgb(155, 156, 159)\">Causa 2 ponto de </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(156, 163, 175)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/03/16935775/10316b5178d5109d597f415d6e7903dc_6974213933459638990.png",
                "id": "talent52620",
                "key": "Técnica da Espada de Favonius - Nobreza",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Técnica da Espada de Favonius - Nobreza"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(155, 156, 159)\">Causa 2 ponto de </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span><span style=\"color: rgb(155, 156, 159)\">, caso este personagem não esteja afetado por</span><span style=\"color: rgb(156, 163, 175)\"> </span><span style=\"color: rgb(255, 255, 255)\">Coração Impassível</span><span style=\"color: rgb(156, 163, 175)\">,</span><span style=\"color: rgb(155, 156, 159)\"> afeta-o com</span><span style=\"color: rgb(156, 163, 175)\"> </span><span style=\"color: rgb(255, 255, 255)\">Coração Impassível</span><span style=\"color: rgb(156, 163, 175)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Coração Impassível</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando o personagem que ganha esse efeito usa Vórtice Gelado</span><span style=\"color: rgb(155, 156, 159)\">, ele sai desse estado e causa +3 de Dano.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/03/16935775/78b526224710dda639b49972145339a9_81175119265156946.png",
                "id": "talent48411",
                "key": "Vórtice Gelado",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Vórtice Gelado"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span></p><p><span style=\"color: rgb(155, 156, 159)\">Causa 2 ponto de </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span><span style=\"color: rgb(155, 156, 159)\">, invoca </span><span style=\"color: rgb(255, 255, 255)\">Espada Luminosa</span><span style=\"color: rgb(156, 163, 175)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/03/16935775/72b7716be67efac4ec94efde16957180_3751081821036138625.png",
                "id": "talent82626",
                "key": "Espada das Ondas Congeladas",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Espada das Ondas Congeladas"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando Eula usa um Ataque Normal ou Habilidade Elemental</span><span style=\"color: rgb(155, 156, 159)\">, essa carta acumula 2 cargas de energia, mas Eula não ganha energia em si.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(155, 156, 159)\">Esta carta é descartada para infligir 3 pontos de </span><span style=\"color: rgb(255, 255, 255)\">Dano físico</span><span style=\"color: rgb(155, 156, 159)\">. Para cada carga de energia armazenada, causa +1 de dano.</span></p><p><span style=\"color: rgb(155, 156, 159)\">Efeitos que afetam o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(155, 156, 159)\">nesta carta serão aplicados a </span><span style=\"color: rgb(255, 255, 255)\">cargas de energia armazenada</span><span style=\"color: rgb(155, 156, 159)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/03/16935775/db13288db6b90ec33f8adc2656d2019f_8766157566634752316.png",
                "id": "talent52405",
                "key": "Espada Luminosa",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/03/16935775/3f07051befd3fcb50000df92021710d6_8860312114380837284.png",
                "title": "Espada Luminosa"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Cryo, podendo desencadear as Reações Elementais:</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Fusão</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual.</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Supercondutor</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo.</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/03/16935775/4bcc4b82a9d7ee22770f60afa54e9919_2480112608955295894.png",
                "id": "talent67382",
                "key": "Dano Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/03/16935775/245c229cf6f7364c7c9a7aea3db1a1ad_4782062144883757749.png",
                "id": "talent85103",
                "key": "Regras Detalhadas",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Regras Detalhadas"
              }
            ]
          }
        }
      ]
