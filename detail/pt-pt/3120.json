            "list": [
              {
                "artifactPos": "",
                "audios": [],
                "desc": "<p><span style=\"color: #BFBFBF\">O alvo desta vez é um gatinho preto e branco chamado \"Lale\". Tente procurá-lo utilizando a língua dos gatos, \"Miau... Miaau, miau.\". Lembre-se que primeiro é um tom descendente e depois um ascendente. Este último deve ser muito agudo.</span></p>",
                "id": "Outras informações6228",
                "img": "",
                "title": "Versão do Lale"
              },
              {
                "artifactPos": "",
                "audios": [],
                "desc": "<p><span style=\"color: #BFBFBF\">O alvo desta vez é um gatinho de cor cinza-escuro chamado \"Nargis\". Tente procurá-lo utilizando a língua dos gatos, \"Miau... Miaau, miau.\". Lembre-se que você deve enfatizar o primeiro \"miau\" e pronunciar os outros bem rápido.</span></p>",
                "id": "Outras informações81852",
                "img": "",
                "title": "Versão do Nargis"
              },
              {
                "artifactPos": "",
                "audios": [],
                "desc": "<p><span style=\"color: #BFBFBF\">O alvo desta vez é um gatinho com listras cinzas e pretas chamado \"Rozan\". Tente procurá-lo utilizando a língua dos gatos, \"Miau... Miaau, miau.\". Lembre-se de falar todos esses \"miaus\" muito rápido.</span></p>",
                "id": "Outras informações33693",
                "img": "",
                "title": "Versão do Rozan"
              }
            ]
          }
        }
