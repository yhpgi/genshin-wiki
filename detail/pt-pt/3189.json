              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(153, 255, 136)\">Dano Dendro</span><span style=\"color: rgb(191, 191, 191)\">, invoca </span><span style=\"color: rgb(255, 255, 255)\">Collambei</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/b1519a139b4737aaa5e6844da801d167_66901758468583259.png",
