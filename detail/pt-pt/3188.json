                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Asas da Vigilância Noturna"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Supremo</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 4 pontos de </span><span style=\"color: rgb(255, 172, 255)\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">, causa 2 pontos de </span><span style=\"color: rgb(255, 255, 255)\">Dano Perfurante</span><span style=\"color: rgb(191, 191, 191)\"> a todos os Personagens Inativos do oponente.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/aa84d77a03ee4e755a8df65d62146b13_5596260969497222656.png",
                "id": "talent43759",
                "key": "Ilusão Noturna",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ilusão Noturna"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 ponto de <span style=\"color: rgb(255, 172, 255)\">Dano Electro</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/db13288db6b90ec33f8adc2656d2019f_6633056012710245454.png",
                "id": "talent36167",
                "key": "Oz",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/6a5ec549833ce08e3439c207909b0bdb_7469946669538156318.png",
                "title": "Oz"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Electro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Sobrecarga</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 2 pontos ao Dano atual, o alvo é forçado a trocar para o próximo personagem</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supercondutor</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Eletricamente Carregado</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Aceleração</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, cria </span><span style=\"color: rgb(255, 255, 255)\">\"Área de Catalisação\"</span><span style=\"color: rgb(191, 191, 191)\"> que causa 1 ponto extra de Dano nos próximos 2 ataques com Dano Dendro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/11ea6117480145a30b7893f1e8bd7115_4712728114814082691.png",
                "id": "talent89852",
                "key": "Dano Electro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Electro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Perfurante</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">O Dano Perfurante não pode Receber Bônus de Dano, mas também não pode ser reduzido por Escudos, Imunidade a dano e similares.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/20/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_6563473865937997411.png",
