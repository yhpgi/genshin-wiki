              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: rgb(255, 172, 255)\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">, invoca</span><span style=\"color: rgb(255, 230, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Oz</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/7521cde834fa3119ec5a1a10ea5bce58_7239869356588650365.png",
