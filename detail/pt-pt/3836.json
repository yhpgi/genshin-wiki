          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p>Causa 2 pontos de <span style=\"color: rgb(255, 255, 255)\">Dano Físico.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/01/101132274/241eba6e4c00020975cf91170050f435_4698615926637267977.png",
                "id": "talent62393",
