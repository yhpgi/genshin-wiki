                      "text": "Desafio do Chamado Sagrado dos Sete",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Desafio da Taverna: Partida Amistosa - Sussurro do Hypostasis Electro",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Detalhes da Fase",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "\"Miau.\" \"Nossos sentidos são muito aguçados, e quando o perigo se aproxima, nós praticamente podemos 'ouvir' o som de apuros chegando. Assim, todos nós gatos tendemos a evitar aqueles sujeitos quadrados e roxos!\"",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(204, 191, 173)"
                      ],
                      "text": "Regra Especial: O Hypostasis Electro é imune a Congelado, Atordoamento, Petrificação, e começa com o efeito \"Formas de Vidas Elementais: Electro\". Ao ativar o \"Núcleo de Cristal Electro\", ele curará o Hypostasis Electro até que alcance 6 de Vida. Este efeito adicional pode ser ativado até duas vezes no início da Fase de Ação do Hypostasis. Se o Hypostasis Electro não tiver o efeito \"Núcleo de Cristal Electro\", ele pode reaplicar \"Núcleo de Cristal Electro\".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Equipe Inimiga",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3844,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/59559639/a18a61786bc99b67ad9fde145786cbe3_5238600346463245455.png",
                      "menu_id": 17,
                      "name": "Hypostasis Electro",
                      "type": "custom_entry"
