    {
      "id": "10",
      "name": "História",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "artifactPos": "",
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">A água borbulhante uma vez se infiltrou nas areias douradas, mas essa é uma história de muito tempo atrás.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Os poderosos entraram no deserto enquanto seguiam o som da terra e do destino, mas no final poucos sobreviveram.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">O peixe que uma vez disparou direto pelo espaço como uma flecha atirada pelo imenso lago nos planaltos,</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">era como uma lança disparada diretamente ao local sagrado.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">O riacho gradualmente infiltrou-se na areia e se reduziu a uma poça.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Até que no fim, essa poça retorcida ficou à mercê dos peregrinos viajantes.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">O que esta história nos conta é o seguinte:</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Se tiver piedade e se dedicar ao bem, você pode conseguir peixes, mesmo no deserto.</span></p>",
                "img": "",
                "title": "Águas Secas"
              }
            ]
          }
        }
      ]
    },
