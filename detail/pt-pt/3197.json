              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: rgb(128, 255, 215)\">Dano Anemo</span>.<br><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/03/16935775/db13288db6b90ec33f8adc2656d2019f_4775097529954105111.png",
