                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/03/16935775/01ccafbe27188aef259b0286fd0b4545_7312016445251496650.png",
                "title": "Espada Sombra - Vento Solitário"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final:</span><span style=\"color: rgb(191, 191, 191)\"> Causa 1 ponto de </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span>.<br><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/03/16935775/db13288db6b90ec33f8adc2656d2019f_289202371010976480.png",
                "id": "talent19903",
                "key": "Espada Sombra - Gelo Galopante",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/03/16935775/e7a414623d5d709d441b0ca6779155bf_1400381757781408743.png",
                "title": "Espada Sombra - Gelo Galopante"
              },
              {
                "attributes": [],
                "desc": "<p>Gera Reações Elementais em alvos já afetados:</p><p>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span>] <span style=\"color: rgb(255, 255, 255)\">Redemoinho (Cryo)</span>: Causa 1 ponto de Dano Cryo a todos os personagens inimigos, exceto o alvo</p><p>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Redemoinho (Hydro)</span>: Causa 1 ponto de Dano Hydro a todos os personagens inimigos, exceto o alvo</p><p>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Redemoinho (Pyro)</span>: Causa 1 ponto de Dano Pyro a todos os personagens inimigos, exceto o alvo</p><p>[<span style=\"color: rgb(128, 255, 215)\">Anemo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Redemoinho (Electro)</span>: Causa 1 ponto de Dano Electro a todos os personagens inimigos, exceto o alvo</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/03/16935775/c97292d96456bfe4abeca16bfce801e4_2599634188520916913.png",
                "id": "talent51519",
                "key": "Dano Anemo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Anemo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Cryo, podendo desencadear as Reações Elementais:</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span>] <span style=\"color: rgb(255, 255, 255)\">Fusão</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 2 pontos ao Dano atual.</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span>] <span style=\"color: rgb(255, 255, 255)\">Supercondutor</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo.</span></p><p>[<span style=\"color: rgb(153, 255, 255)\">Cryo </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span>] <span style=\"color: rgb(255, 255, 255)\">Congelado</span>: <span style=\"color: rgb(191, 191, 191)\">Adiciona 1 ponto de Dano atual, o alvo não pode se mover neste turno (Será removido ao receber Dano Físico ou Dano Pyro, mas aumenta o Dano em 2 pontos)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/28/59559639/4bcc4b82a9d7ee22770f60afa54e9919_1722782805186324648.png",
                "key": "Dano Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/28/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_5183785881056148721.png",
                "key": "Regras Detalhadas",
