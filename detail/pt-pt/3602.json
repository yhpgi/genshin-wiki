                ],
                "talent_img": "",
                "title": "Subjugação: Koukou Sendou"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span><br><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: rgb(255, 172, 255)\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">, seu Personagem em Combate é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Proteção da Pena do Corvo</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 1</span><br></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Proteção da Pena do Corvo</span></strong><br><span style=\"color: rgb(191, 191, 191)\">O dano causado pela </span><span style=\"color: rgb(255, 255, 255)\">Habilidade Elemental</span><span style=\"color: rgb(191, 191, 191)\"> e pelo </span><span style=\"color: rgb(255, 255, 255)\">Supremo</span> <span style=\"color: rgb(191, 191, 191)\">do personagem afetado é aumentado em 1 ponto.</span><br><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/25/16935775/db13288db6b90ec33f8adc2656d2019f_1932468388433564336.png",
                "id": "talent86216",
                "key": "Tengu Juurai: Emboscada",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/25/16935775/1ce18b0d1d4b2b162276892a85feea79_2920961820366411659.png",
                "title": "Tengu Juurai: Emboscada"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocações</span><br><span style=\"color: rgb(255, 255, 255)\">Fase Final: </span><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(255, 172, 255)\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">, seu personagens em Combate é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Proteção da pena do Corvo</span><span style=\"color: rgb(191, 191, 191)\">.</span><br><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span><br><br><strong><span style=\"color: rgb(236, 229, 216)\">Proteção da Pena do Corvo</span></strong><br><span style=\"color: rgb(191, 191, 191)\">O dano causado pela </span><span style=\"color: rgb(255, 255, 255)\">Habilidade Elemental</span><span style=\"color: rgb(191, 191, 191)\"> e pelo </span><span style=\"color: rgb(255, 255, 255)\">Supremo</span> <span style=\"color: rgb(191, 191, 191)\">do personagem afetado é aumentado em 1 ponto.</span><br><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/25/16935775/db13288db6b90ec33f8adc2656d2019f_1510202875234942504.png",
                "id": "talent46874",
                "key": "Tengu Juurai: Aglomerado de Tempestades",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/25/16935775/7a1026e18244fc72af3873f6a6dc44ab_6644100814079305298.png",
                "title": "Tengu Juurai: Aglomerado de Tempestades"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Electro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Sobrecarga</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 2 pontos ao Dano atual, o alvo é forçado a trocar para o próximo personagem</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supercondutor</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Eletricamente Carregado</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Aceleração</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, cria </span><span style=\"color: rgb(255, 255, 255)\">\"Área de Catalisação\"</span><span style=\"color: rgb(191, 191, 191)\"> que causa 1 ponto extra de Dano nos próximos 2 ataques com Dano Dendro/Electro</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/25/16935775/11ea6117480145a30b7893f1e8bd7115_7478432787518301562.png",
                "id": "talent36218",
                "key": "Dano Electro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Electro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/25/16935775/245c229cf6f7364c7c9a7aea3db1a1ad_263599115882011460.png",
