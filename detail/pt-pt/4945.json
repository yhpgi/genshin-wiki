      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/23/59559639/47817b4476bcd8b44c86c87debf042f2_6115439464457952651.png",
                "key": "Golpe de Cauda",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Golpe de Cauda"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de </span><span style=\"color: #FFACFF\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">. </span></p><p><span style=\"color: rgb(191, 191, 191)\">Se o personagem já estiver afetado por </span><span style=\"color: rgb(255, 255, 255)\">Pérola Primordial</span><span style=\"color: rgb(191, 191, 191)\">, ganha +1 de </span><span style=\"color: rgb(255, 255, 255)\">Usos</span><span style=\"color: rgb(191, 191, 191)\">. (Uma vez por Turno)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Pérola Primordial</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando o personagem com este efeito sofre Dano: </span><span style=\"color: rgb(191, 191, 191)\">Nega 1 de Dano. Uma vez por Turno, cancela o Dano de Invocações, não consumindo </span><span style=\"color: rgb(255, 255, 255)\">Usos</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando você declarar o fim do seu Turno: </span><span style=\"color: rgb(191, 191, 191)\">Se o personagem afetado for o Personagem em Combate, saque 1 carta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/23/59559639/4512ed5fa47440d951f659ff9f7fb0b3_2763871988315021853.png",
                "key": "Cardume Rodopiante",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Cardume Rodopiante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span><br><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: rgb(255, 172, 255)\">Dano Electro</span><span style=\"color: rgb(191, 191, 191)\">, aplica </span><span style=\"color: rgb(255, 255, 255)\">Pérola Primordial</span><span style=\"color: rgb(191, 191, 191)\"> a este personagem e invoca </span><span style=\"color: rgb(255, 255, 255)\">Orbe de Coral Ressonante</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Pérola Primordial</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando o personagem com este efeito sofre Dano: </span><span style=\"color: rgb(191, 191, 191)\">Nega 1 de Dano. Uma vez por Turno, cancela o Dano de Invocações, não consumindo </span><span style=\"color: rgb(255, 255, 255)\">Usos</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando você declarar o fim do seu Turno: </span><span style=\"color: rgb(191, 191, 191)\">Se o personagem afetado for o Personagem em Combate, saque 1 carta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/23/59559639/14274ea236c0c28ce99979f7fceb56a9_4587272582214789469.png",
                "key": "Trovão do Mar Primordial",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Trovão do Mar Primordial"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Passiva</span><br><span style=\"color: rgb(191, 191, 191)\">(Passivo) Quando a batalha começa, aplica </span><span style=\"color: rgb(255, 255, 255)\">Pérola Primordial</span><span style=\"color: rgb(191, 191, 191)\"> a este personagem.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Pérola Primordial</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando o personagem com este efeito sofre Dano: </span><span style=\"color: rgb(191, 191, 191)\">Nega 1 de Dano. Uma vez por Turno, cancela o Dano de Invocações, não consumindo </span><span style=\"color: rgb(255, 255, 255)\">Usos</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando você declarar o fim do seu Turno: </span><span style=\"color: rgb(191, 191, 191)\">Se o personagem afetado for o Personagem em Combate, saque 1 carta.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/23/59559639/fa578f3705c431012e2d1447eda1f030_6616924618877703647.png",
                "key": "Armadura de Pérola",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Armadura de Pérola"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocações</span></p><p><span style=\"color: rgb(255, 255, 255)\">Fase Final</span>: Causa 1 ponto de <span style=\"color: #FFACFF\">Dano Electro</span>.</p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/23/59559639/db13288db6b90ec33f8adc2656d2019f_7553109262285873843.png",
                "key": "Orbe de Coral Ressonante",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/23/59559639/ee6e71485195ca50df31411b1c344717_1710293916975210547.png",
                "title": "Orbe de Coral Ressonante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o alvo com Electro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Sobrecarga</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 2 pontos ao Dano atual, o alvo é forçado a trocar para o próximo personagem</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supercondutor</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Eletricamente Carregado</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, causa 1 ponto de Dano Perfurante a todos os personagens inimigos, exceto o alvo</span></p><p><span style=\"color: rgb(191, 191, 191)\">[</span><span style=\"color: rgb(255, 172, 255)\">Electro </span><span style=\"color: rgb(191, 191, 191)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(191, 191, 191)\">] </span><span style=\"color: rgb(255, 255, 255)\">Aceleração</span><span style=\"color: rgb(191, 191, 191)\">: Adiciona 1 ponto ao Dano atual, cria \"</span><span style=\"color: rgb(255, 255, 255)\">Área de Catalisação</span><span style=\"color: rgb(191, 191, 191)\">\" que causa 1 ponto extra de Dano nos próximos 2 ataques com Dano Dendro/Electro</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/23/59559639/11ea6117480145a30b7893f1e8bd7115_8647469906321457976.png",
                "key": "Dano Electro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Electro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os Usos serem consumidos, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/23/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_6508781677467539047.png",
