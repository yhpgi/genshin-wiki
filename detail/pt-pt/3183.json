      "name": "Habilidade",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Ataque Normal</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 2 pontos de</span> <span style=\"color: rgb(255, 255, 255)\">Dano Físico</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/c369b96fc6417e8fc2bb607e37297ad4_5680882031779557088.png",
                "id": "talent45295",
                "key": "Pirotecnia",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Pirotecnia"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Este Personagem é afetado por </span><span style=\"color: rgb(255, 255, 255)\">Niwabi Enshou</span><span style=\"color: rgb(191, 191, 191)\">. (Esta habilidade não gera Carga)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Niwabi Enshou</span></strong></p><p><span style=\"color: #FFD780\">Estado</span><br><span style=\"color: rgb(191, 191, 191)\">O personagem afetado tem aumento de 1 ponto de Dano em </span><span style=\"color: rgb(255, 255, 255)\">Ataque Normal</span><span style=\"color: rgb(191, 191, 191)\">. O </span><span style=\"color: rgb(255, 255, 255)\">Dano Físico</span><span style=\"color: rgb(191, 191, 191)\"> causado é convertido em </span><span style=\"color: rgb(255, 153, 153)\">Dano Pyro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/9fb70e06b7a56894f130c6394d8c6915_3115078138916113068.png",
                "id": "talent40165",
                "key": "Dança de Fogo Niwabi",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Dança de Fogo Niwabi"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Supremo</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 3 pontos de </span><span style=\"color: rgb(255, 153, 153)\">Dano Pyro</span><span style=\"color: rgb(191, 191, 191)\">, gera </span><span style=\"color: rgb(255, 255, 255)\">Flama Dourada</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Flama Dourada</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Estado de Combate</span><br><span style=\"color: rgb(191, 191, 191)\">Após qualquer um de seus personagens além de Yoimiya usar uma habilidade: Causa 1 ponto de </span><span style=\"color: rgb(255, 153, 153)\">Dano Pyro</span><span style=\"color: rgb(191, 191, 191)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos): 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/26b28348d7d58e4a29a39d14cf4a81a8_1318718381944654356.png",
                "id": "talent46884",
                "key": "Saxifraga Ryukin",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Saxifraga Ryukin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(191, 191, 191)\">Afeta o Alvo com Pyro, podendo desencadear as Reações Elementais:</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Fusão </span>: Adiciona 2 pontos ao Dano atual</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Vaporização</span>: Adiciona 2 pontos ao Dano atual</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Electro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Sobrecarga</span>: Adiciona 2 pontos ao Dano atual, o alvo é forçado a trocar para o próximo personagem</p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Queimaduras</span>: Adiciona 1 ponto ao Dano atual, cria \"<span style=\"color: rgb(255, 255, 255)\">Chamas Ardentes</span>\" que causam 1 ponto de Dano Pyro ao fim do turno (Usos: 1, pode acumular até 2)</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/30/16935775/d714b3b669cc08d1d8e34464fd7a3630_1395588777470536795.png",
                "id": "talent89654",
                "key": "Dano Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Dano Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Dano Físico</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Dano Físico não tem efeito Elemental e também não provoca Reações Elementais.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Usos</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Quando o efeito desta carta é desencadeado, o número de </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">será consumido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Após todos os </span><span style=\"color: rgb(255, 255, 255)\">Usos </span><span style=\"color: rgb(191, 191, 191)\">serem consumidos, a carta será automaticamente descartada.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Duração (Turnos)</span></strong></p><p><span style=\"color: rgb(191, 191, 191)\">Na Fase Final de cada turno, </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos)</span><span style=\"color: rgb(191, 191, 191)\"> será reduzido em 1;</span></p><p><span style=\"color: rgb(191, 191, 191)\">Quando </span><span style=\"color: rgb(255, 255, 255)\">Duração (Turnos)</span><span style=\"color: rgb(191, 191, 191)\"> for esgotada, a carta será automaticamente descartada.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/20/59559639/245c229cf6f7364c7c9a7aea3db1a1ad_4793113692785028731.png",
                "id": "talent39058",
                "key": "Regras Detalhadas",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Regras Detalhadas"
              }
            ]
          }
        }
      ]
