              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Causa 1 ponto de </span><span style=\"color: rgb(153, 255, 255)\">Dano Cryo</span><span style=\"color: rgb(191, 191, 191)\">, gera</span> <span style=\"color: rgb(255, 255, 255)\">Lótus de Gelo</span>.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Lótus de Gelo</span></strong></p><p><span style=\"color: #FFD780\">Estado de Combate</span></p><p><span style=\"color: rgb(255, 255, 255)\">Quando seu personagem em Combate recebe Dano:</span></p><p><span style=\"color: rgb(191, 191, 191)\">cancela 1 ponto de Dano.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Usos: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/12/16791688/d3562dc7ee1b952be23d991318822774_8094380890180089338.png",
