                "desc": "<p><span style=\"color: #FFD780\">Habilidade Elemental</span></p><p><span style=\"color: rgb(191, 191, 191)\">Invoca </span><span style=\"color: rgb(255, 255, 255)\">Guoba</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/02/16935775/26fc236bd113d2bcb3ea4b2e946fefe3_5135575034038664066.png",
