          "data": {
            "circlet_of_logos": {
              "desc": "Налобная повязка. Является гордостью искателя приключений, хоть и пропитана потом и пылью.",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/circlet_of_logos_icon.png",
              "position": "Корона разума",
              "title": "Повязка искателя приключений"
            },
            "flower_of_life": {
              "desc": "Цветок, переживший жёсткий климат руин древнего города. Можно носить в качестве броши.",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/flower_of_life_icon.png",
              "position": "Цветок жизни",
              "title": "Цветок искателя приключений"
            },
            "goblet_of_eonothem": {
              "desc": "Трофей, привезённый искателем приключений из какой-то экспедиции. Хорошая находка, хоть и немного повреждена.",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/goblet_of_eonothem_icon.png",
              "position": "Кубок пространства",
              "title": "Кубок искателя приключений"
            },
            "plume_of_death": {
              "desc": "Перо экзотической птицы, которую на этом континенте не встретить.",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/plume_of_death_icon.png",
              "position": "Перо смерти",
              "title": "Перо искателя приключений"
            },
            "sands_of_eon": {
              "desc": "Зачастую искатели приключений забывают о времени, спускаясь в глубины тёмной бездны или затерянных городов.",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Adventurer/sands_of_eon_icon.png",
              "position": "Пески времени",
              "title": "Часы искателя приключений"
            }
