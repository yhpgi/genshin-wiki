                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "элементальный урон",
                      "type": "text"
                    },
                    {
                      "text": "всей команды, что подойдёт ей как персонажу",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
