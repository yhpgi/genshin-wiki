              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 6924,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/26/70239714/e98fd98de17f8fdcd7ac62f05b5fa80b_4269021383334104389.png",
                      "menu_id": 2,
                      "name": "Шилонен",
