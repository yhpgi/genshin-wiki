                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Лучшее оружие для Шилонен, так как значительно повысит",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
