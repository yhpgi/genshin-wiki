    {
      "id": "39",
      "name": "Рекомендации по персонажам",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4577,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/01/07/70239714/a846729f31f16a987a8696466ebabcc0_4201736875484063474.png",
                      "name": "Шеврёз",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Одно из лучших копий для Шеврёз, так как обладает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "достаточно высокой базовой атакой",
                      "type": "text"
                    },
                    {
                      "text": ", что повысит её урон, увеличит",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "HP",
                      "type": "text"
                    },
                    {
                      "text": ", от которого зависит",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "лечение",
                      "type": "text"
                    },
                    {
                      "text": "и повышение",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "силы атаки",
                      "type": "text"
                    },
                    {
                      "text": "Шеврёз, и восстановит",
                      "type": "text"
                    },
