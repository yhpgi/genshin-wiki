                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Подходящий момент"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Взрыв стихии</span></p><p>Наносит <span style=\"color: #FF9999\">Пиро урон</span>, 5 ед.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396187/9d7849a60fd861aa8dd811f90ab22d02_8074463806357599875.png",
                "id": "talent31277",
