            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Обычная атака</span></p><p>Наносит <span style=\"color: #FFFFFF\">Физический урон</span>, 2 ед.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396187/47817b4476bcd8b44c86c87debf042f2_596123879415941396.png",
