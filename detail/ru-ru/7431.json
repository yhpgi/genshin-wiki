                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 6,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Eula_icon.png",
                      "menu_id": 2,
                      "name": "Эола",
                      "type": "custom_entry"
                    },
                    {
                      "text": ". В отряд входит геодезист",
