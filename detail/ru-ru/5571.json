      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p>К востоку от горы Сюаньлянь находится глиняный плот, который может плавать без воды. На плоту растёт странное растение с большими листьями и корнями, будто они маленькие дети. Это растение зовут Сян Цзюнь, и его звучание похоже на детский голос. Оно путешествует вместе с плотом, улыбается, когда видит людей, и отпугивает зло.</p>",
                "title": ""
              }
