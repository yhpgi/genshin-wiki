    {
      "id": "10",
      "name": "Описание",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "Это - самый весомый аргумент в любом споре, всегда добавляет веса сказанному.</br>Неважно, насколько сильно не желает внимать вам оппонент, дубина переговоров убедит любого, даже камень.</br>На любое ваше изречение ответят: «Золотые слова».</br>В конце концов, производство было остановлено из-за многочисленных протестов.</br>Что называется, голос толпы - страшная сила.</br>",
                "title": ""
              }
            ]
          }
        }
      ]
