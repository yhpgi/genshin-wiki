            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Обычная атака</span></p><p>Наносит <span style=\"color: #FFFFFF\">Физический урон</span>, 2 ед.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/51635400/241eba6e4c00020975cf91170050f435_5197949917905946794.png",
