                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "элементальные частицы",
                      "type": "text"
                    },
                    {
                      "text": "и повышать",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силу атаки",
