                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/02/14/237301566/e29d24e7e811e8e885154a01816cd37d_9095028829844290544.png"
