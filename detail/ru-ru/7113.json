                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "заряженные атаки",
                      "type": "text"
                    },
                    {
                      "text": ", поэтому характеристики меча будут ей полезны. Для полной реализации пассивной способности рекомендуется использовать персонажа, накладывающего",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "щит",
                      "type": "text"
                    },
                    {
                      "text": "(например,",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 2859,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/11/70239714/48a495acadaf37f12d0a7f653d85bd83_6907628283096428128.png",
                      "menu_id": 2,
                      "name": "Лайла",
                      "type": "custom_entry"
                    },
                    {
                      "text": "или",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 44,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Diona_icon.png",
                      "menu_id": 2,
                      "name": "Диона",
                      "type": "custom_entry"
                    },
                    {
                      "text": ").",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах стоит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
