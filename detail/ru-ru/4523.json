    {
      "id": "24",
      "name": "Описание",
      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "<p>Женевьева - сотрудница Исследовательского института Фонтейна, отстранённая от работы за фальсификацию данных научных экспериментов и нападению на другого сотрудника. Она имеет очень вспыльчивый характер и любит колоть дрова, чтобы успокоиться, что помогло ей на турнире по Панкратиону.</p><p></p><p>Женевьева хочет выйти из тюрьмы и продолжить свои исследования.</p>",
                "title": "Женевьева"
              }
            ]
          }
        }
      ]
