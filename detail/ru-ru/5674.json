                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5596,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/23/70239714/ac3059e7db5d6f2b20725f84257081be_1412557833159587247.png",
                      "menu_id": 2,
