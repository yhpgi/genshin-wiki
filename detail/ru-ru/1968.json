    {
      "id": "39",
      "name": "Рекомендации по персонажам",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Рогатка может быть хорошим оружием в начале игры, пока нет более подходящих 4★ или 5★ луков.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 15,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Yoimiya_icon.png",
                      "name": "Ёимия",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Ёимия чаще всего использует",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "обычные атаки",
                      "type": "text"
                    },
                    {
                      "text": ", поэтому может реализовать пассивную способность, а дополнительная характеристика будет ей очень полезна и позволит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силе атаки",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "крит. уроне",
                      "type": "text"
                    },
                    {
                      "text": "в артефактах. Лучше всего подходит при использовании персонажей, повышающих",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силу атаки",
                      "type": "text"
                    },
                    {
                      "text": "и/или",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "урон обычных атак",
                      "type": "text"
                    },
                    {
                      "text": "(например,",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 26,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Bennett_icon.png",
                      "name": "Беннет",
                      "type": "custom_entry"
                    },
                    {
                      "text": "и/или",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 4,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Yun Jin_icon.png",
                      "name": "Юнь Цзинь",
