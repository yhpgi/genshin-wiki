                      ],
                      "text": "Анимация «Знакомство с племенами Натлана»",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/237301566/60094afc2111c06296aee0d8612ef2fd_6097913331375178884.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "17 августа 2024",
                      "type": "text"
                    },
                    {
                      "text": "Воины стадиона Священного пламени готовы к состязанию.",
                      "type": "text"
                    },
                    {
                      "text": "Пока соревнования ещё не начались,",
                      "type": "text"
                    },
                    {
                      "text": "давайте послушаем рассказ трёх наших друзей о жизни в племенах.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Заметки Качины: «Заврианы-спутники Натлана»",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/237301566/65b1403954ff9fc25946aec7ec525a94_6773493571863860084.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "28 августа 2024",
                      "type": "text"
                    },
                    {
                      "text": "Во время приключений в Натлане вы столкнётесь с самыми разными заврианами.",
                      "type": "text"
                    },
                    {
                      "text": "Окунитесь в захватывающие дух пейзажи Натлана, странствуя вместе с заврианами.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Иллюстрации",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
