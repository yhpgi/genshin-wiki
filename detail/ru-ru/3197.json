                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Морозная тень"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Взрыв стихии</span></p><p>Наносит <span style=\"color: #80FFD7\">Анемо урон</span>, 4 ед., вызывает эффекты всех <span style=\"color: #FFFFFF\">Теневых мечей</span> (не расходует их применения).</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396187/0d7c96d3e920a99c58744d15b1b20d0b_140737638530368121.png",
