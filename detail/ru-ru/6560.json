                    {
                      "text": "\"«Книгу... лучше отдать исследователю!»",
                      "type": "text"
                    },
                    {
                      "text": "Да, это и в самом деле отличная книга, но мне бы и в голову не пришло, что чтецам такое может понравиться.\"",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "«Мерцающий свет» - Памятный трейлер",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
