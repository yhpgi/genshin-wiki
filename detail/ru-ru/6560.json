                      "display_style": "card",
                      "ep_id": 6559,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/23/237301566/1b4813ee4ee058cd0428721d3301de69_8896134130540367131.png",
                      "menu_id": 10,
