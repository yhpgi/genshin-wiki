                      "name": "Сайно",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Даёт важный бонус",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "мастерства стихий",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силы атаки",
                      "type": "text"
                    },
                    {
                      "text": "(необходим",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Дендро",
                      "type": "text"
                    },
                    {
                      "text": "персонаж",
                      "type": "text"
                    },
                    {
                      "text": "в отряде), позволяя сконцентрироваться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "крит. уроне",
                      "type": "text"
                    },
