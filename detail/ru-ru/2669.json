          "component_id": "gallery_character",
          "data": {
            "list": [
              {
                "id": "gallery_character91719",
                "img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/04/237301566/791d321578f1a99989c57bf57e6ed227_624876022797226791.png",
                "imgDesc": "<p>До второго возвышения</p>",
