                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Лучшее оружие для Нёвиллета, так как даёт важный",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "крит. урон",
                      "type": "text"
                    },
                    {
                      "text": ", повышает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "HP",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "урон заряженной атаки",
                      "type": "text"
                    },
                    {
                      "text": "и восстанавливает",
                      "type": "text"
                    },
