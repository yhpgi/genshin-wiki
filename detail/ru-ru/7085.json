    {
      "id": "80",
      "name": "Подробности",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Известные Сошедшие",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4897,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/08/237301566/513d51e0ebfd54f5da34a9f85dfaf61f_4818954959690057221.png",
                      "menu_id": 10,
                      "name": "Изначальный",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Первый престол, возникший в Тейвате и победивший",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 7084,
                      "icon_url": "",
                      "name": "Элементальные драконы",
                      "type": "custom_entry"
                    },
                    {
                      "text": ". Является создателем людей.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Второй престол",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Инопланетные захватчики, принёсшие запретное знание в Тейват.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Третий Сошедший",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Из останков Третьего Сошедшего Изначальный и ещё один пришелец создали",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 4935,
                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2024/01/10/f7baa7786d24234f0e6a0064e2b2e091_8031973212194725733.png",
                      "menu_id": 20,
                      "name": "Сердце Бога",
                      "type": "custom_entry"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 20,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/16/70239714/f00d18b57acb4aa37bf2fc39bf67ddd0_830350480334963652.gif",
                      "menu_id": 2,
                      "name": "Путешественник",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Четвёртый Сошедший.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Связи",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4811,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/11/237301566/93cd2bc9b90c8b87b1f8cbdbe95b4b9d_705904275694017757.png",
                      "menu_id": 22,
                      "name": "Каэнри'ах",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В Каэнри'ах существовал детский приют, где хотели вырастить Сошедшего.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Путница из далёких миров",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Путница, странствующая между мирами, которую привлёк свет мира Тейвата, когда там правили драконы. Когда она вновь вернулась, Изначальный уже захватил мир, а Нибелунг исчез. Путница нарушила правила и спустилась в мир, поместив своё сознание в тело юноши. В Тейвате она встретила первого ангела, которая влюбилась в неё. Вместе они решили пойти против законов, установленных небесным порядком, за что все ангелы были прокляты.",
                      "type": "text"
                    },
                    {
                      "text": "Неизвестно, является ли Путница Сошедшей.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7489,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2025/02/19/237301566/596896f7ea3d51d7b1f6e504094f9d97_6875065463103513399.png",
                      "menu_id": 10,
                      "name": "Нибелунг",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Владыка драконов, правивший миром до появления Изначального. После того как драконы проиграли войну первому престолу, Нибелунг получил чёрную силу за границами мира и повёл элементальных драконов на восстание против порядка, установленного чужаками. В Тейвате началась страшная война, приведшая к небывалым разрушениям.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Неизвестно, является ли Нибелунг Сошедшим.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Близнец Путешественника",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Путешественник/ца и его/её близнец прибыли в Тейват из другого мира. Хотя близнец является иномирцем, информация о ней/нём записана в",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 7087,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/12/237301566/aa06aa829f5a3a926aef88750adb81f2_208058611950951154.png",
                      "menu_id": 20,
                      "name": "Ирминсуль",
                      "type": "custom_entry"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 7106,
                      "icon_url": "",
                      "name": "Фатуи",
                      "type": "custom_entry"
                    },
                    {
                      "text": ", изучающие Сошедших, не причисляют к ним близнеца.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Пришелец",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Вместе с Изначальным создал Сердца Бога из останков Третьего Сошедшего.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 4601,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/16/237301566/90f57df4396a9aa89cee2704bafdac6d_681464755020305606.png",
                      "menu_id": 10,
                      "name": "Нарциссенкрейц",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Нарциссенкрейц искал способ стать Сошедшим, чистой волей, способной защитить, удержать, разрушить и создать целый мир.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7106,
                      "icon_url": "",
                      "name": "Фатуи",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Фатуи ведут записи о Сошедших и собирают Сердца Бога, являющиеся останками одного из них.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Связанные предметы",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5202,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/15/237301566/eebe3d494c8e1fcae1905ec185dc3f56_7346634510704197289.png",
                      "menu_id": 12,
                      "name": "Переньери",
                      "type": "custom_entry"
                    },
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7572,
                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2025/03/17/bf39402f87db1168263c7c0898c8ab0c_4434336707917443666.png",
                      "menu_id": 5,
                      "name": "Финал галерей глубин",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
