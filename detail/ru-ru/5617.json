                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 5618,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/04/237301566/8387f718bf24a2a128af2225335160c5_3631573680954842438.png",
                      "menu_id": 10,
