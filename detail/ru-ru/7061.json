    {
      "id": "48",
      "name": "Навык",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Обычная атака</span></p><p>Наносит <span style=\"color: rgb(255, 255, 255)\">Физический урон</span>, 2 ед.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/15/70239714/26b9736a2d14fc4162b2448963f45695_1300632695322165044.png",
                "id": "talent63856",
                "key": "Ткущий клинок",
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_imgs": [],
                "title": "Ткущий клинок"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Элементальный навык</span></p><p>Выберите 1 помощника, <span style=\"color: rgb(255, 255, 255)\">Куклы-автоматоны Тиори</span>, из 3.<br><br><span style=\"color: rgb(255, 255, 255)\">Куклы-автоматоны Тиори</span><br>Разнообразные куклы-автоматоны Тиори, которые могут не только автономно атаковать, но и предоставлять различные бонусы.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/15/70239714/32d719dee7506a0029e782750dcb9637_6956515675097604394.png",
                "id": "talent39056",
                "key": "Порхание хасодэ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "talent_imgs": [],
                "title": "Порхание хасодэ"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Помощник</span></p><p><span style=\"color: rgb(255, 255, 255)\">Финальная фаза</span>: наносит <span style=\"color: #FFE699\">Гео урон</span>, 1 ед.</p><p><span style=\"color: rgb(255, 255, 255)\">Кол-во применений: 2</span></p><p><span style=\"color: rgb(255, 255, 255)\">Во время розыгрыша этой карты, когда ваш персонаж (кроме Тиори) использует навык: </span>наносит <span style=\"color: #FFE699\">Гео урон</span>, 1 ед. Только 1 раз за раунд.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/10/15/70239714/db13288db6b90ec33f8adc2656d2019f_5029612042230766248.png",
                "id": "talent22472",
                "key": "Легко превосходящая соперников Тамото",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "talent_imgs": [
                  {
