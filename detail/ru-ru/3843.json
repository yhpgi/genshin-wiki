              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Обычная атака</span></p><p>Наносит <span style=\"color: #FF9999\">Пиро урон</span>, 1 ед.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/20/51635400/1ce09211f025bf5470682189e0837732_6849993081609677472.png",
