                      ],
                      "text": "Прохождение задания",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Путешественник/ца и Паймон находят древний монумент в зале Ваншань...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Шаги",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Прохождение",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "1. Двигайтесь дальше",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "По завершении задания мира",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 5541,
                      "icon_url": "",
                      "name": "Древние свитки и искусство меча Гухуа",
                      "type": "custom_entry"
                    },
                    {
                      "text": "уровень воды понизится и откроется доступ на нижний этаж. По пути станет доступна одна из точек телепортации, отсутствующих на карте.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/10/124137736/ad9df44ccbe6707952f334a3d6e7642e_7924769707925064302.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "2. Поговорите с Паймон",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Проследуйте к платформе в центре зала для прохождения испытания.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "3. Исследуйте механизм",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Взаимодействуйте с монументом. Прикоснитесь к табличке, чтобы начать испытание.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/10/124137736/69176b57c9434f3efefddb8faf3814ed_6191562675276046292.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "4. Завершите испытание",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Завершите испытание, победив всех противников. Уворачивайтесь от лезвий - их траектория будет обозначена красными полосами на платформе.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "5. Двигайтесь дальше",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Продолжайте движение по коридору. В конце туннеля Вас будут ждать каменная табличка и древний меч.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/10/124137736/f1e948aa53ff76eaf9a51cb6f6fef735_7810758399907206209.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "6. Исследуйте древний меч",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Задание мира завершится после диалога с Паймон. В конце будут получены",
                      "type": "text"
                    },
                    {
                      "amount": 0,
                      "display_style": "text",
                      "ep_id": 5007,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/11/124137736/60c9c277139b43907167e6452d409874_7074600124613251156.png",
                      "name": "Рецепт: Густой суп из рыбы и козлятины",
                      "type": "custom_entry"
                    },
                    {
                      "text": "и достижение «Высшая тайна».",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Достижение",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Название",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Способ получения",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Высшая тайна",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Завершите задание мира",
                      "type": "text"
                    }
