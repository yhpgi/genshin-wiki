            },
            "goblet_of_eonothem": {
              "desc": "<p>Серьги из янтаря и золота, инкрустированные самоцветом, чарующе переливаются.</p>",
              "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/10/51635400/999a78b73235c08ca4a0664a23e7079f_8604463220285748626.png",
