    {
      "id": "39",
      "name": "Рекомендации по персонажам",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3336,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/70239714/25249dd20b86c775fb35bdbbd805d9ec_5630956628455162356.png",
                      "name": "Аль-Хайтам",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Лучшее оружие, так как повышает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "крит. урон",
                      "type": "text"
                    },
                    {
                      "text": ",",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "шанс крит. попадания",
                      "type": "text"
                    },
                    {
                      "text": ",",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "урон обычных атак",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "элементальных навыков",
                      "type": "text"
                    },
                    {
                      "text": ". Так как при наличии зеркал аль-Хайтам получает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Дендро инфузию",
                      "type": "text"
                    },
                    {
                      "text": ", он полностью реализует пассивную способность.",
                      "type": "text"
                    },
                    {
                      "text": "Кроме того, урон аль-Хайтама зависит от",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "мастерства стихий",
                      "type": "text"
                    },
                    {
                      "text": ", поэтому эффект Лиственного выреза даёт достаточно большой бонус урона.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
