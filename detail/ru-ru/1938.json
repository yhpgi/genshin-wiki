      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Данное оружие может быть хорошим вариантом для некоторых персонажей, пока нет более подходящих 4★ или 5★ мечей.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 9,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/05/237301566/2d1ae4bdb66364c3763790171e7a486e_3588216901547060069.png",
                      "name": "Кэйа",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Бонус силы атаки",
                      "type": "text"
                    },
                    {
                      "text": "повысит наносимый",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "урон",
                      "type": "text"
                    },
                    {
                      "text": "Кэйи. Пассивная способность лучше всего реализуется в командах с",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Заморозкой",
                      "type": "text"
                    },
                    {
                      "text": ", когда на врагах всегда есть статус",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Крио",
                      "type": "text"
                    },
                    {
                      "text": ". Подойдёт, если Кэйа находится в роли",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "основного",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Крио урона",
                      "type": "text"
                    },
                    {
                      "text": "в команде.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах стоит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "крит. уроне",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "шансе крит. попадания",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 27,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Jean_icon.png",
                      "name": "Джинн",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Урон",
                      "type": "text"
                    },
                    {
                      "text": "и",
