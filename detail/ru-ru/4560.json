                  }
                ],
                "talent_img": "",
                "title": "Дотошность Алькасар-сарая"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Помощник</span></p><p><span style=\"color: #FFFFFF\">Финальная фаза:</span> наносит <span style=\"color: #FFACFF\">Электро урон</span>, 1 ед.</p><p><span style=\"color: #FFFFFF\">Кол-во применений: 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/51635400/db13288db6b90ec33f8adc2656d2019f_728173404635597883.png",
                "key": "Снаряд гарантийного обслуживания",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/51635400/4dc11b7dc5d87f85d5124e37b423a947_2411352207891760575.png",
                "title": "Снаряд гарантийного обслуживания"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Помощник</span></p><p><span style=\"color: #FFFFFF\">Финальная фаза:</span> у активного персонажа восстанавливается 2 HP и <span style=\"color: #FFFFFF\">Энергия </span>(1 ед.).</p><p><span style=\"color: #FFFFFF\">Кол-во применений: 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/51635400/db13288db6b90ec33f8adc2656d2019f_5007635174613952980.png",
                "key": "Джинн",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/51635400/67b7fdfa996e64de9630aa9be8af9b7b_5644164231590969990.png",
                "title": "Джинн"
              },
              {
                "attributes": [],
                "desc": "<p>Создаёт эффект <span style=\"color: rgb(255, 172, 255)\">Электро </span>и вызывает следующие реакции:<br><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 172, 255)\">Электро </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Пиро</span><span style=\"color: rgb(255, 255, 255)\">] Перегрузка: </span>урон +2 (в этот раз), делает активным следующего персонажа противника<br><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 172, 255)\">Электро </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Крио</span><span style=\"color: rgb(255, 255, 255)\">] Сверхпроводник: </span>урон +1 (в этот раз), наносит проникающий урон 1 ед. для всех персонажей противника, кроме цели<br><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 172, 255)\">Электро </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Гидро</span><span style=\"color: rgb(255, 255, 255)\">] Заряжен: </span>урон +1 (в этот раз), наносит проникающий урон 1 ед. для всех персонажей противника, кроме цели<br><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 172, 255)\">Электро </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Дендро</span><span style=\"color: rgb(255, 255, 255)\">] Стимуляция: </span>урон +1 (в этот раз), создаёт<span style=\"color: rgb(255, 255, 255)\"> область катализа,</span> которая увеличит следующие два Дендро или Электро урона на 1 ед.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/51635400/11ea6117480145a30b7893f1e8bd7115_4019631163765126092.png",
                "key": "Электро урон",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Электро урон"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Физический урон</span></strong><br>Физический урон не создаёт элементальных эффектов и не вступает в реакции.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Кол-во применений</span></strong><br>Когда срабатывает эффект этой карты, расходуется 1 <span style=\"color: rgb(255, 255, 255)\">применение</span>.<br>Когда <span style=\"color: rgb(255, 255, 255)\">применения </span>кончаются, карта исчезает.</p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Энергия</span></strong><br>Персонаж должен использовать энергию, чтобы вызывать взрыв стихии.<br>За использование обычной атаки или элементального навыка персонаж получает 1 энергию.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/51635400/245c229cf6f7364c7c9a7aea3db1a1ad_3781463548719227634.png",
