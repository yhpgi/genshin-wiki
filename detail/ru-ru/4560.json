              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Взрыв стихии</span></p><p>Наносит <span style=\"color: #FFACFF\">Электро урон</span>, 1 ед. Призывает помощника: <span style=\"color: #FFFFFF\">Джинн</span>.</p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/51635400/9858bca5debb2537f7499d5999cf8424_8257955430237733100.png",
