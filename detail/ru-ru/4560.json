                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Элементальный навык</span></p><p>Наносит <span style=\"color: rgb(255, 172, 255)\">Электро урон</span>, 2 ед. Призывает помощника: <span style=\"color: rgb(255, 255, 255)\">Снаряд гарантийного обслуживания</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/07/51635400/3cb2c89592400bfe33db1c94218adcb0_7381985979957110382.png",
