      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 24,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Yanfei_icon.png",
                      "name": "Янь Фэй",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Если Янь Фэй играет через реакцию",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Перегрузка",
                      "type": "text"
                    },
                    {
                      "text": ", ей будет очень полезно",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "мастерство стихий",
                      "type": "text"
                    },
                    {
                      "text": ", а для реакций",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Пар",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Таяние",
                      "type": "text"
                    },
                    {
                      "text": "будут полезны и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "мастерство стихий",
                      "type": "text"
                    },
                    {
                      "text": ", и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "сила атаки",
                      "type": "text"
                    },
                    {
                      "text": "от пассивной характеристики. Кроме того, пассивная характеристика увеличит",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силу атаки",
                      "type": "text"
                    },
                    {
                      "text": "другим членам отряда.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах стоит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "шансе крит. попадания",
                      "type": "text"
                    },
                    {
                      "text": ",",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "крит. уроне",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "силе атаки",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2850,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/10/28/70239714/f29490bddc56b4a6773b6c5003bbb853_5866014545552401401.png",
                      "name": "Нахида",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Нахиде очень важно",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "мастерство стихий",
                      "type": "text"
                    },
                    {
                      "text": ", так как от него зависит и собственный урон Нахиды, и урон от реакций. Пассивная способность повысит",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силу атаки",
                      "type": "text"
                    },
                    {
                      "text": "Нахиде и другим членам отряда.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
