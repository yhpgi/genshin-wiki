                      "name": "Сяо",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Урон Сяо зависит от",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силы атаки",
                      "type": "text"
                    },
                    {
                      "text": ", поэтому ему будут полезны характеристики копья. Для полной реализации пассивной способности рекомендуется иметь персонажа, способного периодически лечить Сяо. Стоит использовать",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "взрыв стихии",
                      "type": "text"
                    },
                    {
                      "text": "после накопления всех меток.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах стоит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
