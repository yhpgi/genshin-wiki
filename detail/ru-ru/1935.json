                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "основного урона",
                      "type": "text"
                    },
                    {
                      "text": "через",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "заряженные атаки",
                      "type": "text"
                    },
                    {
                      "text": ", ей будет полезна и дополнительная характеристика, и пассивная способность, которую она может полностью реализовать. Для удобства попадания в",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "слабые места",
                      "type": "text"
                    },
                    {
                      "text": "рекомендуется играть через",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 255)"
                      ],
                      "text": "Заморозку",
                      "type": "text"
                    },
                    {
                      "text": "и/или использовать",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "щит",
                      "type": "text"
                    },
                    {
                      "text": ".",
