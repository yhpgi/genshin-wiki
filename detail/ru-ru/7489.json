                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2025/03/17/bf39402f87db1168263c7c0898c8ab0c_4434336707917443666.png",
                      "menu_id": 5,
                      "name": "Финал галерей глубин",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
