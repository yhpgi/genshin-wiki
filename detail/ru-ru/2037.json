    {
      "id": "39",
      "name": "Рекомендации по персонажам",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Металлическая тень может подходить некоторым персонажам в начале игры. Рекомендуется использовать, если нет других более подходяших вариантов.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 3463,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/24/70239714/65b22311e1e38ffa45a4928d4005ecee_591137848457706557.png",
                      "name": "Дэхья",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Урон",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "отведение урона",
                      "type": "text"
                    },
                    {
                      "text": "Дэхьи зависят, в том числе, от её макс.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "HP",
                      "type": "text"
                    },
                    {
                      "text": ", так что дополнительная характеристика может быть ей полезна, особенно на позиции",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "поддержки",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "отведения урона",
                      "type": "text"
                    },
                    {
                      "text": ". Пассивная способность не реализуется, так как Дэхья не использует",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "заряженные атаки",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах стосит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "HP",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "мастерстве стихий",
                      "type": "text"
                    },
                    {
                      "text": ", если Дэхья активирует реакции.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 2269,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/08/70239714/6539bea71efd0f839db897cfc4094362_3785464122785425096.png",
                      "name": "Дори",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Бонус",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "HP",
                      "type": "text"
                    },
                    {
                      "text": "увеличивает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "лечение",
                      "type": "text"
                    },
                    {
                      "text": "Дори, поэтому дополнительная характеристика может быть ей полезна. Пассивная способность не реализуется, так как Дори не использует",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "заряженные атаки",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах стосит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
