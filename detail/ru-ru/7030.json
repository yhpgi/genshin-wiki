                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Основной урон Ка Мин составляют",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "атаки в падении",
                      "type": "text"
                    },
                    {
                      "text": ", зависящие от",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "силы атаки",
                      "type": "text"
                    },
