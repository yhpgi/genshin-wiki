                      "ep_id": 7351,
                      "icon_url": "https://act-webstatic.hoyoverse.com/event-static-hoyowiki-admin/2024/12/26/6c535148317ed9d8ecda0afd5ffdbd77_5095437906811194859.png",
                      "menu_id": 9,
                      "name": "Древнее имя из обсидиана",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
