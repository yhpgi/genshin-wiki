    {
      "id": "39",
      "name": "Рекомендации по персонажам",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 49,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Raiden Shogun_icon.png",
                      "name": "Райдэн",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Райдэн будет полезна как дополнительная характеристика, так и пассивная способность оружия. Для лучшей реализации пассивной способности стоит использовать Режущий волны плавник в отрядах, где у всех членов достаточно",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "высокое потребление энергии",
                      "type": "text"
                    },
                    {
                      "text": "для",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "взрыва стихий",
                      "type": "text"
                    },
                    {
                      "text": ". Рекомендуется использовать при максимальном пробуждении.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах стоит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "восстановлении энергии",
                      "type": "text"
                    },
                    {
                      "text": ",",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "шансе крит. попадания",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "крит. уроне",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 50,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Xiangling_icon.png",
                      "name": "Сян Лин",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Взрыв стихий",
                      "type": "text"
                    },
                    {
                      "text": "Сян Лин является её основным навыком, поэтому увеличение его урона очень важно. Кроме того, повышение",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силы атаки",
                      "type": "text"
                    },
                    {
                      "text": "позволит сконцентрироваться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "восстановлении энергии",
                      "type": "text"
                    },
                    {
                      "text": ",",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
