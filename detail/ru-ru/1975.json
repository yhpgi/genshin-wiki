                      "type": "text"
                    },
                    {
                      "text": "может наносить дополнительный урон. Нагината имеет достаточно высокую",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
