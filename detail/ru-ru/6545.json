    {
      "id": "39",
      "name": "Рекомендации по персонажам",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 6317,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/16/70239714/93db1447f03ff091d7663dbe3a098bc3_1299666708963311411.png",
                      "menu_id": 2,
                      "name": "Кинич",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Лучшее оружие для Кинича, поскольку обладает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "самой высокой базовой атакой",
                      "type": "text"
                    },
                    {
                      "text": ", повышает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "шанс крит. попадания",
                      "type": "text"
                    },
                    {
                      "text": "и увеличивает урон. Так как Кинич обычно играет с",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#99ff88"
                      ],
                      "text": "Дендро",
                      "type": "text"
                    },
                    {
                      "text": "и, возможно,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#80c0ff"
                      ],
                      "text": "Гидро",
                      "type": "text"
                    },
                    {
                      "text": "персонажами в отряде, пассивная способность полностью выполняется. Рекомендуется использовать",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "взрыв стихии",
                      "type": "text"
                    },
                    {
                      "text": "после",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "элементального навыка",
                      "type": "text"
                    },
                    {
                      "text": "для повышения урона.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах стоит сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "шансе крит. попадания",
                      "type": "text"
                    },
                    {
                      "text": ",",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "крит. уроне",
                      "type": "text"
                    },
                    {
                      "text": ",",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "силе атаки",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "мастерстве стихий",
                      "type": "text"
                    },
