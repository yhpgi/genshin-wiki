              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Взрыв стихии</span></p><p>Наносит <span style=\"color: #FFE699\">Гео урон</span>, 4 ед. Урон увеличивается на 1 ед. за каждый поглощённый ранее элемент.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/70239714/d294a6656674929ea911a9bf72835e76_1408946921672756533.png",
                "id": "talent53903",
                "key": "Разрушительный камнепад",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
