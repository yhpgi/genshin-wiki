          "data": {
            "circlet_of_logos": {
              "desc": "Ритуальный головной убор того, кому в древние времена доверяли церемонию жертвоприношения. Он обладает высоким сопротивлением к холоду благодаря годам пронзающего обледенения.",
              "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/reliquary/Prayers to Springtime/circlet_of_logos_icon.png",
              "position": "Корона разума",
              "title": "Тиара холода"
            },
            "flower_of_life": {},
            "goblet_of_eonothem": {},
