                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Обычная атака</span><br>Наносит <span style=\"color: rgb(255, 153, 153)\">Пиро урон</span>, 1 ед.</p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/70239714/1ce09211f025bf5470682189e0837732_5943766358582535467.png",
