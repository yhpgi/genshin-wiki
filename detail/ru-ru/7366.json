              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 7300,
                      "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/11/26/70239714/188578a56ba75d147d6c8a14285e4a77_8371295332940317502.png",
                      "menu_id": 2,
                      "name": "Ситлали",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Лучшее оружие для Ситлали, поскольку значительно повышает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "мастерство стихий",
                      "type": "text"
                    },
                    {
                      "text": ", от которого зависит её",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:#ffd780"
                      ],
                      "text": "щит",
                      "type": "text"
