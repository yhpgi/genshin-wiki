                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Элементальный навык</span></p><p>Наносит <span style=\"color: #99FFFF\">Крио урон</span>, 3 ед.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/04/248396187/c815c3f7cfd5d0658dd94a1e28beda8b_6687536648539996998.png",
