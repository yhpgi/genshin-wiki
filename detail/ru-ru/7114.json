                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Дополнительная характеристика позволит чаще использовать",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "взрыв стихии",
                      "type": "text"
                    },
                    {
                      "text": ", а пассивная способность даст большую прибавку к макс.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "HP",
                      "type": "text"
                    },
                    {
                      "text": ", от которого зависит",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "урон",
                      "type": "text"
                    },
