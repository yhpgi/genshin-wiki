      "name": "Рекомендации по персонажам",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 2813,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/24/70239714/e09e2bda5e022611fad0dea1bb6518bb_3921227929686782989.png",
                      "name": "Сайно",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Лучший выбор для Сайно, так как даёт важный",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "шанс крит. попадания",
                      "type": "text"
                    },
                    {
                      "text": "и увеличивает",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силу атаки",
                      "type": "text"
                    },
                    {
                      "text": ". Сайно обычно играет через реакции и нуждается в",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "мастерстве стихий",
                      "type": "text"
                    },
                    {
                      "text": ", поэтому пассивная способность полностью реализуется. Для увеличения",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "мастерства стихий",
                      "type": "text"
                    },
                    {
                      "text": "можно взять в отряд",
                      "type": "text"
                    },
                    {
                      "amount": 1,
                      "display_style": "text",
                      "ep_id": 2674,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/23/169177528/04f769b0b1671b5ffbbafefd7286b4b2_82393981492429578.png",
                      "name": "Путешественник (Дендро)",
                      "type": "custom_entry"
                    },
                    {
                      "text": "и/или",
                      "type": "text"
                    },
                    {
                      "amount": 1,
                      "display_style": "text",
                      "ep_id": 2268,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/22/70239714/37a18b6b6865c59063003a9380f08225_1506165806794491631.png",
                      "name": "Коллеи",
                      "type": "custom_entry"
                    },
                    {
                      "text": "(при активированном 4 созвездии).",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
