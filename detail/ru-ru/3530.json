                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Лилупар является матерью джиннов.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
