      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 29,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Shenhe_icon.png",
                      "name": "Шэнь Хэ",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Таланты Шэнь Хэ зависят от",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силы атаки",
                      "type": "text"
                    },
                    {
                      "text": ", поэтому дополнительная характеристика ей полезна. Недошедший ветер полностью реализуется в отрядах, играющих через реакции (лучше всего подойдёт",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Таяние",
                      "type": "text"
                    },
                    {
                      "text": "). В остальных случаях рекомендуется, если нет более подходящих вариантов.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Рекомендуется сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "восстановлении энергии",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силе атаки",
                      "type": "text"
                    },
                    {
                      "text": "в артефактах.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 2813,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/09/24/70239714/e09e2bda5e022611fad0dea1bb6518bb_3921227929686782989.png",
                      "name": "Сайно",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Сайно обычно играет через реакции, а его урон зависит как от",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силы атаки",
                      "type": "text"
                    },
                    {
                      "text": ", так и от",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "мастерства стихий",
                      "type": "text"
                    },
                    {
                      "text": ", поэтому он может полностью использовать пассивную способность копья.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "В артефактах рекомендуется сосредоточиться на",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "шансе крит. попадания",
                      "type": "text"
                    },
                    {
                      "text": "и",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "крит. уроне",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
                      "ep_id": 50,
                      "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/character/Xiangling_icon.png",
                      "name": "Сян Лин",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Урон Сян Лин зависит от",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "силы атаки",
                      "type": "text"
                    },
