                        ],
                        "type": "paragraph"
                      }
                    ],
                    [
                      {
                        "content": [
                          {
                            "styles": [
                              "color:rgb(255, 255, 255)"
                            ],
                            "text": "«Нефрит, о нефрит, исполни моё желание...»",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ]
                  ],
