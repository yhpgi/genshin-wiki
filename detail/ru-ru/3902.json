      "id": "39",
      "name": "Рекомендации по персонажам",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 2265,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/08/23/70239714/d039c6da9285163f46b85f0241f29c17_7884881497095009464.png",
                      "name": "Тигнари",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
