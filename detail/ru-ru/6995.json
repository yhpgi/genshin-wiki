                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Анимация «Знакомство с племенами Натлана»",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/31/237301566/60094afc2111c06296aee0d8612ef2fd_6097913331375178884.png"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "17 августа 2024",
                      "type": "text"
                    },
                    {
                      "text": "Воины стадиона Священного пламени готовы к состязанию.",
                      "type": "text"
                    },
                    {
                      "text": "Пока соревнования ещё не начались,",
                      "type": "text"
                    },
                    {
                      "text": "давайте послушаем рассказ трёх наших друзей о жизни в племенах.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "YouTube:",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Заметки Качины: «Заврианы-спутники Натлана»",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
