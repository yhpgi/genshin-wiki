      "components": [
        {
          "component_id": "story",
          "data": {
            "list": [
              {
                "desc": "Верный и отлично сбалансированный клинок, выкованный из хорошей стали.</br>Его самый крупный недостаток - составная конструкция, из-за которой он серьёзно уступает монолитным собратьям по износостойкости.</br>Такая конструкция позволяет поместить в полую рукоять меча нож, ножницы, хворост и другие мелкие вещи.</br>Интересно, он называется «меч путешественника» потому что в него можно поместить много полезных вещей?..</br>",
                "title": ""
              }
            ]
          }
        }
      ]
