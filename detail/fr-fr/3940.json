    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues de l'évènement \"Cadre mécanique perpétuel: Invoqueurs\" (version 3.7)",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Félix Yogue:",
                      "type": "text"
                    },
                    {
                      "text": "Tout se passe bien, voyageur/euse ? Ca vous dit de jouer avec ce cadre ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "J'ai envie d'essayer...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Félix Yogue:",
                      "type": "text"
                    },
                    {
                      "text": "Hahaha, génial ! Je suis sûr que vous résoudrez le mystère de ce cadre perpétuel en un rien de temps.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Félix Yogue:",
                      "type": "text"
                    },
                    {
                      "text": "Il est par ici. Vous pouvez commencer quand vous voulez.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "J'ai autre chose à faire...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Félix Yogue:",
                      "type": "text"
                    },
                    {
                      "text": "Oh, très bien. N'hésitez pas à revenir plus tard ! Je serai encore là.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
