{
  "id": 6546,
  "name": "Instant surfant",
  "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un objet commémoratif réservé à l'origine au vainqueur du Premier championnat inter-tribus de surf. Étant donné que ce tournoi est actuellement en phase préparatoire, le prix est temporairement conservé à la Bouée oisive et protégé par le propriétaire de l'établissement.</span></p>",
  "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/28/76706780/6ce2e0da75fbdc19fc4b6f9e7bae9049_4726006272988382226.png",
