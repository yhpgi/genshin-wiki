      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/26b9736a2d14fc4162b2448963f45695_2400002151339738073.png",
                "key": "Danse de shamshir",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Danse de shamshir"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Si l'équipe contient uniquement des personnages </span><span style=\"color: rgb(128, 192, 255)\">Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, crée une </span><span style=\"color: rgb(255, 255, 255)\">prime du calice d'or</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Prime du calice d'or</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: #FFFFFF\">Lorsqu'un personnage adverse subit une réaction de Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Vous ne créez plus de </span><span style=\"color: #FFFFFF\">noyaux Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, mais invoquez des </span><span style=\"color: #FFFFFF\">noyaux d'abondance</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> à la place.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/c82a120ef3389c55999b6069de0c8ddc_3495136512643766328.png",
                "key": "Danse des haftkarsvars",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Danse des haftkarsvars"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et inflige un </span><span style=\"color: rgb(255, 255, 255)\">éon persistant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage choisi.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Éon persistant</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 3 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage affecté.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/e701a5d9dee57abe1f108242af52b000_5009839196815218108.png",
                "key": "Danse d'abzendegi : Ruisseau des rêves lointains",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Danse d'abzendegi : Ruisseau des rêves lointains"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 2 pts de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 1 (Peut être cumulé, 3 cumuls maximum)</span></p><p><span style=\"color: #FFFFFF\">Lorsque vous annoncez la fin de votre manche : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Si le nombre d'utilisations de cette carte est supérieur ou égal à 2, inflige 2 pts de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. (Diminue le nombre d'utilisations)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/db13288db6b90ec33f8adc2656d2019f_1088515419471062787.png",
                "key": "Noyau d'abondance",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/ded0956520d3dce12af6dfcbdfab5d01_807484063811452723.png",
                "title": "Noyau d'abondance"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Hydro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Évaporation : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Électrocution :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Gel :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/a126c6a302d81c07e19cf9a9f1260f90_8698057485503473680.png",
                "key": "DGT Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Dendro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Brûlure </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et crée une </span><span style=\"color: rgb(255, 255, 255)\">flamme brûlante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui inflige des DGT Pyro à la fin de la manche (Utilisable 1 fois, 2 cumuls maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Stimulation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et crée un </span><span style=\"color: rgb(255, 255, 255)\">champ catalyseur</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui augmente les 3 prochains coups de DGT Dendro/Électro de 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/e8cff941b5a0ff248efde360ec9e91fe_6294571951074448609.png",
                "key": "DGT Dendro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Dendro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_4773272834348883723.png",
