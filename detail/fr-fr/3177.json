                  }
                ],
                "talent_img": "",
                "title": "École Kamisato : Fleur de glace"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 4 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et invoque un</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(255, 255, 255)\">tourbillon givré</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/158750877/b3d6af4c2817f35e4e06de8197dd8c07_8245336233204444066.png",
                "id": "talent52281",
                "key": "École Kamisato : Givre mortel",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "École Kamisato : Givre mortel"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Capacité passive</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passif) Lorsque ce personnage devient le personnage actif, accorde un</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(255, 255, 255)\">enchantement Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p><p></p><p><strong><span style=\"color: rgb(255, 255, 255)\">Enchantement Cryo</span></strong></p><p><span style=\"color: #FFD780\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">infligés par le personnage affecté sont convertis en</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Dure jusqu'à la fin de la manche)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/158750877/7359eeec791acae26196aa72a0621268_7230536786955243388.png",
                "id": "talent27822",
                "key": "École Kamisato : Sentier de givre",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "École Kamisato : Sentier de givre"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations : 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/158750877/db13288db6b90ec33f8adc2656d2019f_137489474273531758.png",
                "id": "talent38646",
                "key": "Tourbillon givré",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/158750877/1447ebe24c4e7bd955c4b795be517cd3_851029727698292679.png",
                "title": "Tourbillon givré"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Cryo et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: #99FFFF\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: #FF9999\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: #FFFFFF\">Fonte </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: #99FFFF\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: #FFACFF\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: #FFFFFF\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: #99FFFF\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: #80C0FF\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: #FFFFFF\">Gel </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance en subissant des DGT physiques ou Pyro, mais DGT +2)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/158750877/4bcc4b82a9d7ee22770f60afa54e9919_2105250903677369260.png",
                "id": "talent76485",
                "key": "DGT Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Nombre d'utilisations</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: #FFFFFF\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: #FFFFFF\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/158750877/07bae546ac7c69ef6402170b283840c5_7820963250605090916.png",
