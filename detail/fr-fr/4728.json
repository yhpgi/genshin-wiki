    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/26b9736a2d14fc4162b2448963f45695_6010278565810428103.png",
                "id": "talent62859",
                "key": "Épée de radiance",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Épée de radiance"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Crée un </span><span style=\"color: rgb(255, 255, 255)\">rideau de sommeil</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et une </span><span style=\"color: rgb(255, 255, 255)\">étoile filante</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Rideau de sommeil</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Accorde 2 pts de bouclier pour protéger votre personnage actif.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Étoile filante</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: #FFFFFF\">Lorsque votre personnage a utilisé une capacité :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Obtient 1 étoile vespérale.</span></p><p><span style=\"color: #FFFFFF\">Avec au moins 4 étoiles vespérales : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Consomme 4 étoiles vespérales pour infliger 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> (La capacité créant cet état de déploiement déclenche également cet effet).</span></p><p><span style=\"color: #FFFFFF\">En déclenchant à nouveau cet état de déploiement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Obtient 2 étoiles vespérales.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/de48c78ad3dc782b2dfe98bbe645f7cd_6429549511671391602.png",
                "id": "talent65971",
                "key": "Nuits de solennité",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Nuits de solennité"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">invoque une </span><span style=\"color: #FFFFFF\">sphère de rêve céleste</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/1af1d6edbe77aedd11a2e57551afb598_5668139825632325762.png",
                "id": "talent60012",
                "key": "Rêve berçant les étoiles",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Rêve berçant les étoiles"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: #FFFFFF\">Phase finale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Si une étoile filante est sur le terrain, elle obtient 1 étoile vespérale.</span></p><p><span style=\"color: #FFFFFF\">Nombre d'utilisations : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/db13288db6b90ec33f8adc2656d2019f_2631276492835382825.png",
                "id": "talent76864",
                "key": "Sphère de rêve céleste",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/8fae1317e614df75bd7911789c244c1f_1721532451649502954.png",
                "title": "Sphère de rêve céleste"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Cryo et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Gel </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance en subissant des DGT physiques ou Pyro, mais DGT +2)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/4bcc4b82a9d7ee22770f60afa54e9919_5355197729223537990.png",
                "id": "talent76597",
                "key": "DGT Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisations</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_8093508561013834220.png",
