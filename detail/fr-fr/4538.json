    {
      "id": "25",
      "name": "Autres informations",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Le ciel, cette nuit-là, de fleurs, s&#39;est épanoui ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">les étoiles cette nuit-là, telles des abeilles, chantaient ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">en quête d&#39;un bon nectar, et de rêves infinis.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Et nous, cette nuit-là, étions neufs comme la rosée ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">le clair de lune, comme un doux miel se répandit ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">nous, près de la source, nos paroles douces et sucrées.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Je me suis retournée, te laissant dans la nuit ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">le poème dans mon cœur restant inexprimé.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Depuis, dans mes souvenirs presqu&#39;évanouis ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">les étoiles ne scintillent pas, la lune est gelée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Je les cache sous l&#39;eau, au fin fond, bien à l&#39;abri ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">mais tes larmes coulent, et tu finis par les trouver.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\"><br></span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Le désir demeure, mais ce temps n&#39;est plus présent.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Le garçon de la source, bien trop vite, a vieilli.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Quand rêves et ruisseaux s&#39;entremêlent dans l&#39;océan ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">notre voyage, dans une rêverie, se poursuit.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\"><br></span></p>",
                "title": "Poème sur une feuille tombée"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Dans la nuit obscure, la lumière nous éclaire ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">et dans le ruisseau, impassibles sont les pierres.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Si les mots perdurent, si l&#39;amour est sincère ;</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">contre le monde, les petits se redressent, fiers.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Que le clair de lune, à nouveau, vous libère.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\"><br></span></p>",
                "title": "Poème de réponse sur une feuille"
              }
            ]
          }
        }
      ]
    },
