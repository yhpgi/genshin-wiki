    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/35653081/1ce09211f025bf5470682189e0837732_1435963555001018556.png",
                "key": "Phototype à froid",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Phototype à froid"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et applique une </span><span style=\"color: #FFFFFF\">silhouette instantanée </span><span style=\"color: rgba(255, 255, 255, 0.65)\">à la cible.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Silhouette instantanée </span></strong></p><p><span style=\"color: #FFD780\">État</span></p><p><span style=\"color: #FFFFFF\">Phase finale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage affecté. Si le </span><span style=\"color: #FFFFFF\">nombre d'utilisations</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> est égal à 1 et ce personnage est affecté par l'</span><span style=\"color: #99FFFF\">élément Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, ces DGT augmentent de 1.</span></p><p><span style=\"color: #FFFFFF\">Nombre d'utilisations : 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/35653081/54adbd6e0af44cff009737afb67b0409_9213573651092675823.png",
                "key": "Cadrage : Composition gelée ",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Cadrage : Composition gelée "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, soigne tous vos personnages pour 1 pt et invoque un </span><span style=\"color: #FFFFFF\">champ de flash info</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/35653081/d1cf9afd3481f21b5ec894c5c65557fe_8157110171681614058.png",
                "key": "Pose : Corroboration complète",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Pose : Corroboration complète"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Invocation</span></p><p><span style=\"color: #FFFFFF\">Phase finale :</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et soigne votre personnage actif pour 1 pt.</span></p><p><span style=\"color: #FFFFFF\">Nombre d'utilisations : 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/35653081/db13288db6b90ec33f8adc2656d2019f_8337550722421870978.png",
                "key": "Champ de flash info",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/35653081/1e769ee02333d59fa7aa932bc15ee22f_5335455019407116356.png",
                "title": "Champ de flash info"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Cryo et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Gel </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance en subissant des DGT physiques ou Pyro, mais DGT +2)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/35653081/4bcc4b82a9d7ee22770f60afa54e9919_2281078554819461566.png",
                "key": "DGT Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/06/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_3354460280062556665.png",
