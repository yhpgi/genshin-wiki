    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Oh, mais vous êtes l'ami/e de mademoiselle Kamisato !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Ça fait longtemps. Entrez, je vous en prie.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Merci pour la dernière fois.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Je vous en prie. C'est un honneur pour Ogura textiles et kimonos d'avoir pu vous confectionner des vêtements.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Vous devez être proche de mademoiselle Kamisato, car c'est si rare de la voir aussi détendue.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Je suis curieuse de connaitre votre histoire avec elle.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Je suis juste un/e voyageur/euse de passage.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Vous plaisantez encore... Puisque c'est si secret, je ne poserai plus de questions.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Je compte sur mademoiselle Kamisato et vous pour l'avenir de notre boutique.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Comment allez-vous ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Tout va bien, merci.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "De nombreux clients ont passé des commandes de soie liyuéenne récemment avec la réouverture des routes commerciales.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Si vous souhaitiez en acheter aujourd'hui, j'ai bien peur qu'il faille attendre encore quelques mois.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "*soupir* C'est à des moments comme celui-ci que j'aimerais avoir l'aide de mon frère qui est stationné loin d'ici...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, mais je ne devrais pas dire de telles choses à un/e client/e.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Si vous avez la chance de le rencontrer, j'aimerais que vous lui disiez bonjour de ma part.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ogura Mio:",
                      "type": "text"
                    },
                    {
                      "text": "Prenez soin de vous. Transmettez mes salutations à mademoiselle Kamisato.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
