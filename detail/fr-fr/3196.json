                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Opportunité"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 5 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(255, 153, 153)\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/02/35653081/9d7849a60fd861aa8dd811f90ab22d02_3066564732080182719.png",
                "id": "talent51908",
                "key": "Lame incinératrice",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Lame incinératrice"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Capacité passive</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passif) Accorde une </span><span style=\"color: #FFFFFF\">infiltration</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au début du combat.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Infiltration</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT subis par le personnage affecté -1 et DGT qu'il inflige +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/02/35653081/7b7664a897ad4ff44a0fa76b2b5d1507_1158974055427948922.png",
                "id": "talent33769",
                "key": "Expert en infiltration",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Expert en infiltration"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Pyro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Évaporation </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Surcharge </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2 et bascule de force la cible pour le personnage suivant</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Brûlure </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et crée une </span><span style=\"color: rgb(255, 255, 255)\">flamme brûlante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui inflige des DGT Pyro à la fin de la manche (Utilisable 1 fois, 2 cumuls maximum)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/02/35653081/d714b3b669cc08d1d8e34464fd7a3630_5859305030413818024.png",
                "id": "talent13499",
                "key": "DGT Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/02/35653081/07bae546ac7c69ef6402170b283840c5_3277693740578628766.png",
