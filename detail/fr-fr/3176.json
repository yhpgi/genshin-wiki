      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/10316b5178d5109d597f415d6e7903dc_8171090181703060898.png",
                "id": "talent35683",
                "key": "Fléau des démons",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Fléau des démons"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et crée un </span><span style=\"color: #FFFFFF\">champ de givre</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Champ de givre</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les</span><span style=\"color: rgb(255, 255, 255)\"> DGT physiques </span><span style=\"color: rgba(255, 255, 255, 0.65)\">infligés par votre personnage avec épée à une main, à deux mains ou une arme d'hast sont convertis en </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/f17b48b7b6d0a06e1b0ad5fa0799168b_2590781544590835365.png",
                "id": "talent57103",
                "key": "Givre superposé",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Givre superposé"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 7 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.45)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/d98d17703b86282b89569cb7c5dde12c_2977867708435876045.png",
                "id": "talent33570",
                "key": "Chute d'étoiles",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Chute d'étoiles"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Cryo et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Gel </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance en subissant des DGT physiques ou Pyro, mais DGT +2)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/4bcc4b82a9d7ee22770f60afa54e9919_2929333686584769924.png",
                "id": "talent85441",
                "key": "DGT Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span><br><br><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/07bae546ac7c69ef6402170b283840c5_7745806505294371685.png",
                "id": "talent1163",
                "key": "Règles détaillées",
