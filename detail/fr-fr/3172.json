                "title": "Archerie Liutian"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et crée un </span><span style=\"color: #FFFFFF\">lotus de glace</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. </span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Lotus de glace</span></strong></p><p><span style=\"color: #FFD780\">État de déploiement</span><br><span style=\"color: #FFFFFF\">Lorsque votre personnage actif subit des DGT :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Diminue les DGT de 1 pt.</span></p><p><span style=\"color: #FFFFFF\">Nombre d'utilisations : 2 </span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/12/22/158750877/d3562dc7ee1b952be23d991318822774_7040740916200687309.png",
                "id": "talent23344",
                "key": "Trace de Qilin",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Trace de Qilin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et inflige </span><span style=\"color: #FFFFFF\">2 pts de DGT de perforation</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> à tous les personnages ennemis en attente.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/02/35653081/67d6f9d70e695a791caa42953d11e1e3_1543856878936681781.png",
                "id": "talent8731",
