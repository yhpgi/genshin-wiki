    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Excusez-moi, mon brave monsieur/ma brave dame ! Il ne m'est pas difficile de voir que vous savez vous battre. Dites-moi, seriez-vous interressé(e) pour rejoindre les",
                      "type": "text"
                    },
                    {
                      "text": "Érémites ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "J'ai quelque chose à y gagner ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Et comment !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Tout d'abord rejoindre les",
                      "type": "text"
                    },
                    {
                      "text": "Érémites est l'un des rares moyens de pouvoir sortir du village.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Dès que vous aurez quitté ce petit endroit isolé, le monde s'ouvrira devant vous. Quel jeune ambitieux n'a pas envie de partir à la découverte du monde ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Et bien que nos membres soient tous des habitants du désert, on sait tout de même comment gagner l'argent de ceux qui vivent dans les arbres !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "L'Académie est l'endroit le plus riche de tout Sumeru. Les gens là-bas sont de bons payeurs, et ils ne marchandent pas.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Si vous acceptez cette mission vous pourrez faire fortune.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Il n'y a que chez nous que vous gagnerez de l'argent de cette manière.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "J'ai autre chose à faire.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Vraiment ? Y a-t-il un meilleur métier que celui de mercenaire ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Atiyah:",
                      "type": "text"
                    },
                    {
                      "text": "Comme c'est dommage. Revenez me voir si vous changez d'avis.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
