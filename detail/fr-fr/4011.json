    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgb(255, 255, 255)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Si cette capacité est une </span><span style=\"color: rgb(255, 255, 255)\">attaque chargée</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> : Inflige l'état </span><span style=\"color: rgb(255, 255, 255)\">Conductivité</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage actif adverse.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Conductivité</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Cet état commence avec 2 cumuls de conductivité, et chaque nouvelle application rajoute 1 cumul. La conductivité peut être cumulée 4 fois maximum.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Rajoute 1 cumul de conductivité.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage subit des DGT d'Arc fulminant :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Annule l'état et augmente les DGT de 1 pour chaque cumul de conductivité.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/1ce09211f025bf5470682189e0837732_531526377792869863.png",
                "id": "talent73040",
                "key": "Touche d'éclair",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Touche d'éclair"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Si le personnage actif adverse n'est pas affecté par l'effet </span><span style=\"color: rgb(255, 255, 255)\">Conductivité</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, il subit l'effet </span><span style=\"color: rgb(255, 255, 255)\">Conductivité</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Conductivité</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Cet état commence avec 2 cumuls de conductivité, et chaque nouvelle application rajoute 1 cumul. La conductivité peut être cumulée 4 fois maximum.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Rajoute 1 cumul de conductivité.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage subit des DGT d'Arc fulminant :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Annule l'état et augmente les DGT de 1 pour chaque cumul de conductivité.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/af99fb6b223af8aab53e4447b06483ba_3133888488417114450.png",
                "id": "talent85931",
                "key": "Arc fulminant",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Arc fulminant"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et invoque une </span><span style=\"color: rgb(255, 255, 255)\">rose de foudre</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/e225f8fa5e9a435290d33b7b93b4e376_8788115665291327705.png",
                "id": "talent54085",
                "key": "Rose de foudre",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Rose de foudre"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 2 pts de </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/db13288db6b90ec33f8adc2656d2019f_6845485979606540963.png",
                "id": "talent70246",
                "key": "Rose de foudre",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/2b3f9718f47e31a775816000450f000e_908781910664395128.png",
                "title": "Rose de foudre"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Électro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Surcharge </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2 et bascule de force la cible pour le personnage suivant</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Électrocution </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Stimulation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et crée un </span><span style=\"color: rgb(255, 255, 255)\">champ catalyseur</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui augmente les 3 prochains coups de DGT Dendro/Électro de 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/11ea6117480145a30b7893f1e8bd7115_7302899080388588438.png",
                "id": "talent56146",
                "key": "DGT Électro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Électro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisations</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_1316495263563645520.png",
