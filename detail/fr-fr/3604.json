      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/13/35653081/10316b5178d5109d597f415d6e7903dc_4602537840761885888.png",
                "id": "talent10683",
                "key": "Escrime de Favonius - Aristocratie",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Escrime de Favonius - Aristocratie"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Si le personnage n'est pas affecté par un </span><span style=\"color: rgb(255, 255, 255)\">cœur de glace</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, il obtient un </span><span style=\"color: rgb(255, 255, 255)\">cœur de glace</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Cœur de glace</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage affecté utilise Vortex des mers glacées : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Annule cet état et augmente ses DGT de 2.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/13/35653081/78b526224710dda639b49972145339a9_1024026176014055884.png",
                "id": "talent72937",
                "key": "Vortex des mers glacées",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Vortex des mers glacées"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et invoque une </span><span style=\"color: rgb(255, 255, 255)\">épée de lumière</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/13/35653081/72b7716be67efac4ec94efde16957180_1547955849938625719.png",
                "id": "talent33211",
                "key": "Lame de fond",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Lame de fond"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsqu'Eula utilise une attaque normale ou une compétence élémentaire</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> : Cette carte obtient 2 cumuls d'énergie, mais Eula ne peut plus obtenir de charges.</span><br><span style=\"color: rgb(255, 255, 255)\">Phase finale</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, chaque cumul d'énergie augmentant ses DGT de 1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Les effets affectant le </span><span style=\"color: rgb(255, 255, 255)\">nombre d'utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">de cette carte s'appliquent aux </span><span style=\"color: rgb(255, 255, 255)\">cumuls d'énergie</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/13/35653081/db13288db6b90ec33f8adc2656d2019f_3636521919819645306.png",
                "id": "talent94644",
                "key": "Épée de lumière",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/13/35653081/3f07051befd3fcb50000df92021710d6_3514246618744848183.png",
                "title": "Épée de lumière"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Cryo et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Gel </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance en subissant des DGT physiques ou Pyro, mais DGT +2)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/13/35653081/4bcc4b82a9d7ee22770f60afa54e9919_931546277680642573.png",
                "id": "talent35841",
                "key": "DGT Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisations</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/13/35653081/07bae546ac7c69ef6402170b283840c5_1200518407680576466.png",
                "id": "talent29797",
                "key": "Règles détaillées",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Règles détaillées"
              }
            ]
          }
        }
      ]
