    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Licai:",
                      "type": "text"
                    },
                    {
                      "text": "Bienvenue au Pavillon Liuli ! Combien êtes-vous ? Avez-vous une réservation ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Doit-on toujours réserver en l'avance pour manger ici ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Licai:",
                      "type": "text"
                    },
                    {
                      "text": "Oui, excusez-nous d'être victime de notre succès. Il faut réserver au moins trois mois à l'avance pour manger dans le restaurant. C'est d'ailleurs moi qui prends les réservations.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Licai:",
                      "type": "text"
                    },
                    {
                      "text": "C'est long trois mois ? Ici au Pavillon Liuli, nous avons un nombre fixe de tablées par jour ; c'est pour cela que la liste d'attente est longue.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Licai:",
                      "type": "text"
                    },
                    {
                      "text": "Vous savez, trois mois d'attente pour avoir la chance de manger au paradis de la cuisine Li, ce n'est pas si long.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Licai:",
                      "type": "text"
                    },
                    {
                      "text": "Les gens viennent pour déguster les délicieux mets des montagnes. Tout le monde doit attendre son tour, qu'on soit riche ou pauvre.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Licai:",
                      "type": "text"
                    },
                    {
                      "text": "C'est très bien de vouloir commander à emporter, mais vous ratez ce qui fait la magie d'un repas : l'ambiance !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Licai:",
                      "type": "text"
                    },
                    {
                      "text": "Au plaisir de vous revoir ! N'oubliez pas de réserver !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
