              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale :</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">inflige 1 pt de </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et accorde </span><span style=\"color: rgb(255, 255, 255)\">Couverture corvidée</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> à votre personnage actif.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 1</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Couverture corvidée</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT infligés par les </span><span style=\"color: rgb(255, 255, 255)\">compétences élémentaires</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et les </span><span style=\"color: rgb(255, 255, 255)\">déchaînements élémentaires</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> du personnage affecté +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/08/35653081/db13288db6b90ec33f8adc2656d2019f_7868272458938730735.png",
