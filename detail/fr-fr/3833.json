    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/35653081/c369b96fc6417e8fc2bb607e37297ad4_7909202303489917915.png",
                "id": "talent80506",
                "key": "Taille du torrent",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Taille du torrent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Fait passer en </span><span style=\"color: rgb(255, 255, 255)\">état de mêlée</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">État de mêlée</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Convertit les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par le personnage en </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une attaque chargée : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage choisi. DGT infligés par le personnage aux personnages adverses sous l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une capacité contre un personnage sous l'effet Contre-courant :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: rgb(255, 255, 255)\">DGT de perforation</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">au prochain personnage adverse en attente. (2 fois maximum par manche)</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Contre-courant</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage affecté est vaincu :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige l'effet Contre-courant au personnage actif du camp concerné.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque </span><span style=\"color: rgb(255, 255, 255)\">Tartaglia</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, en </span><span style=\"color: rgb(255, 255, 255)\">état de mêlée</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, attaque le personnage affecté : Inflige des DGT supplémentaires.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/04e544f76342ce9857c812b10e4d0f87_8616919912176536243.png",
                "id": "talent1190",
                "key": "Posture du démon : Marée déchaînée",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Posture du démon : Marée déchaînée"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Effectue différentes attaques selon l'état actuel de </span><span style=\"color: rgb(255, 255, 255)\">Tartaglia</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> :</span></p><p><span style=\"color: rgb(255, 255, 255)\">En état à distance, déclenche Éclair de balle maléfique :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 4 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, restaure 2 </span><span style=\"color: rgb(255, 255, 255)\">charges</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et inflige l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage choisi.</span></p><p><span style=\"color: rgb(255, 255, 255)\">En état de mêlée, déclenche Lumière d'élimination :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 7 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">État à distance</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une attaque chargée : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligés l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage choisi.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">État de mêlée</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Convertit les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par le personnage en </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une attaque chargée : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage choisi. DGT infligés par le personnage aux personnages adverses sous l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une capacité contre un personnage sous l'effet Contre-courant :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: rgb(255, 255, 255)\">DGT de perforation</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">au prochain personnage adverse en attente. (2 fois maximum par manche)</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Contre-courant</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage affecté est vaincu :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige l'effet Contre-courant au personnage actif du camp concerné.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque </span><span style=\"color: rgb(255, 255, 255)\">Tartaglia</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, en </span><span style=\"color: rgb(255, 255, 255)\">état de mêlée</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, attaque le personnage affecté : Inflige des DGT supplémentaires.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/b302ce0c0075ea711befbddc08555b75_3008122635846102287.png",
                "id": "talent24349",
                "key": "Ravage : Oblitération",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ravage : Oblitération"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Capacité passive</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passif) Accorde un </span><span style=\"color: rgb(255, 255, 255)\">état à distance</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au début du combat.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsqu'un </span><span style=\"color: rgb(255, 255, 255)\">état de mêlée</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> du personnage affecté prend fin, accorde à nouveau un</span><span style=\"color: rgb(255, 255, 255)\"> état à distance</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">État à distance</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une attaque chargée : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Infligés l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage choisi.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">État de mêlée</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Convertit les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par le personnage en </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une attaque chargée : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage choisi. DGT infligés par le personnage aux personnages adverses sous l'effet </span><span style=\"color: rgb(255, 255, 255)\">Contre-courant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une capacité contre un personnage sous l'effet Contre-courant :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: rgb(255, 255, 255)\">DGT de perforation</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">au prochain personnage adverse en attente. (2 fois maximum par manche)</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Contre-courant</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage affecté est vaincu :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige l'effet Contre-courant au personnage actif du camp concerné.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque </span><span style=\"color: rgb(255, 255, 255)\">Tartaglia</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, en </span><span style=\"color: rgb(255, 255, 255)\">état de mêlée</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, attaque le personnage affecté : Inflige des DGT supplémentaires.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/3e90a55bd72193eae8ddd2475b84577d_6575085265928884305.png",
                "id": "talent49481",
                "key": "Vague au calme",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Vague au calme"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Hydro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Évaporation : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Électrocution :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Gel :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/35653081/a126c6a302d81c07e19cf9a9f1260f90_3449858624615223975.png",
                "id": "talent11603",
                "key": "DGT Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Attaque chargée</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque le total de vos dés élémentaires est un nombre pair, l'attaque normale utilisée est considérée comme une attaque chargée.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">DGT de perforation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT de perforation ne peuvent être augmentés par aucun bonus, mais ne peuvent pas non plus être bloqués par l'utilisation de boucliers ou immunités au DGT.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Charge</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les personnages doivent consommer des charges pour utiliser leur déchaînements élémentaires.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque les personnages utilisent une compétence élémentaire ou une attaque normale, ils gagnent 1 charge.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/22/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_1104782538042742908.png",
