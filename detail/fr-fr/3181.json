      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/14/35653081/10316b5178d5109d597f415d6e7903dc_211776623645097866.png",
                "id": "talent29961",
                "key": "Épée trempée",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Épée trempée"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: #FF9999\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Lors de la troisième utilisation de cette capacité à chaque manche, DGT +2.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/14/35653081/d0e27bc7054292e95c673e6f491ff677_8154882260820834773.png",
                "id": "talent5014",
                "key": "Assaut brûlant",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Assaut brûlant"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 8 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: #FF9999\">DGT Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et accorde un </span><span style=\"color: rgb(255, 255, 255)\">enchantement Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">au personnage. </span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Enchantement Pyro</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les</span><span style=\"color: rgb(255, 255, 255)\"> DGT physiques </span><span style=\"color: rgba(255, 255, 255, 0.65)\">infligés par le personnage affecté sont convertis en </span><span style=\"color: #FF9999\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/14/35653081/7f35364dc83b6694a3200aae53f6670f_3522333952172424387.png",
                "id": "talent57242",
                "key": "Aurore",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Aurore"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Pyro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Évaporation </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Surcharge </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2 et bascule de force la cible pour le personnage suivant</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Brûlure </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et crée une </span><span style=\"color: #FFFFFF\">flamme brûlante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui inflige des DGT Pyro à la fin de la manche (Utilisable 1 fois, 2 cumuls maximum)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/14/35653081/d714b3b669cc08d1d8e34464fd7a3630_601780917202346196.png",
                "id": "talent48809",
                "key": "DGT Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/14/35653081/07bae546ac7c69ef6402170b283840c5_5054916559276286031.png",
