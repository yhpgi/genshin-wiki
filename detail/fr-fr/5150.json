{
  "id": 5150,
  "name": "Uraku Misugiri",
  "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Cette lame célèbre a été créée par la main d'Urakusai, le lettré renommé. La légende raconte qu'elle n'a coupé aucune créature vivante depuis ces centaines d'années.</span></p>",
  "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/12/76706780/97083537849c199bc3fa7fed8a49d010_167442555900073857.png",
