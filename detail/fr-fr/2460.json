    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Vers les étoiles et au-delà ! Bienvenue à la Guilde des aventuriers.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "[Récupérer les récompenses de missions quotidiennes (pas entièrement complétées)]",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Désolée, mais tu n'as pas encore terminé assez de missions.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "[Récupérer les récompenses de missions quotidiennes (entièrement complétées)]",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Merci d'avoir terminé les missions d'aujourd'hui ! Voilà les récompenses pour ton travail.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "italic"
                      ],
                      "text": "[Récupérer les récompenses de missions quotidiennes (déjà complétées)]",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Tu as déjà récupéré les récompenses d'aujourd'hui. Reviens demain !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir. Merci de ton éternel soutien à la Guilde des aventuriers !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Dialogues spécifiques à la région",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "text": "Mondstadt",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Qui êtes-vous ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Je suis Catherine, la réceptionniste de la Guilde des aventuriers.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Mon travail consiste à envoyer les aventuriers de Mondstadt en mission et à les assister avec mes renseignements.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "La Guilde des aventuriers ne prend jamais de vacances ! Elle est ouverte tous les jours de l'année.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Quel est le travail de la Guilde des aventuriers ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "La Guilde des aventuriers est une organisation qui a été créée dans le but d'aider tous les aventuriers à travers Teyvat.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Nous aidons les nouveaux membres à s'ajuster à leur nouvelle vie d'aventurier, tout en faisant en sorte de faciliter le travail de nos membres vétérans...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Nous rassemblons aussi les nombreuses demandes et informations obtenues de bouche-à-oreille pour constituer des missions sur lesquelles nous envoyons des aventuriers.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Liyue",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Catherine ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Exact. Je suis Catherine, la réceptionniste de la Guilde des aventuriers.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Mon travail consiste à envoyer les aventuriers en mission et à les assister avec mes renseignements, 7 jours sur 7.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Ca va ? Vous avez l'air surpris/e.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Qu'est-ce que vous faites ici ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Excusez-moi, mais je ne comprends pas ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Tout le monde à la Guilde des aventuriers devrait savoir que c'est moi la réceptionniste ici. La branche liyuéenne en a aussi besoin d'une, non ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Cela explique donc votre présence.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Des questions ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Inazuma",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Euh, bonjour ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Bonjour, je suis Catherine, la réceptionniste de la Guilde des aventuriers. Mon travail consiste à donner des quêtes aux aventuriers et à leur apporter du soutien avec des renseignements.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Je suis là en permanence, alors pas de panique.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Une autre Catherine...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Une autre ? Tu as déjà rencontré plus d'une Catherine à la fois ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Si ce n'est pas le cas, alors c'est moi que tu as vu à chaque fois. Pour répondre aux besoins des aventuriers du monde entier, j'utilise un objet spécial pour me téléporter et travailler dans plusieurs endroits à la fois.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Moi aussi, je veux me téléporter !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Oh, tu y as vraiment cru ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Je suis désolée, c'était une blague. S'il te plaît, ne le prends pas mal.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Et puis de toute manière, tu sais comment utiliser les points de téléportation, pas vrai ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Sumeru",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "C'était donc bien toi, Catherine !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Bonjour, je suis bien Catherine, la réceptionniste de la Guilde des aventuriers. Mon travail consiste à donner des quêtes aux aventuriers et à leur apporter du soutien avec des renseignements.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Vous savez sûrement comment la Guilde des aventuriers fonctionne, donc je m'abstiendrai de répéter tous ces détails.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Tu me suis depuis tout ce temps ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Héhé, si on m'avait proposé de faire ces déplacements tous frais payés, je n'aurais pas refusé.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Malheureusement, mon travail de réceptionniste m'occupe 24 heures sur 24 et 7 jours sur 7 toute l'année, donc je n'ai pas ce genre de chance.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Dialogue supplémentaire ajouté après avoir fini la quête d'Archons Chapitre III - Acte 3: \"Rêves, futilité et tromperie\"",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Ton corps... Tout va bien ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Mon corps ? Pourquoi ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Pardon, je ne me souviens pas très bien de ce qui s'est passé, mais puisque je suis ici saine et sauve, je suppose que tout va bien.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "(Catherine n'a aucun souvenir. Est-ce parce qu'elle a changé de marionnette ?)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Fontaine",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Toujours un plaisir de te voir, Catherine.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Bonjour. Tout le plaisir est pour moi.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Je m'appelle Catherine, je suis la réceptionniste de la Guilde des aventuriers. Mon travail consiste à donner des quêtes aux aventuriers et à leur apporter du soutien avec des renseignements.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Que mes services te soient utiles et que ton séjour à Fontaine soit inoubliable.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Tu es aussi une marionnette mécanique, Catherine ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Haha. C'est une très bonne question.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Catherine:",
                      "type": "text"
                    },
                    {
                      "text": "Penses-tu que je suis un chef-d'œuvre de l'Institut de recherche de Fontaine ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
