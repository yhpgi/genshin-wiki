      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/26b9736a2d14fc4162b2448963f45695_1771285844944396941.png",
                "id": "talent80490",
                "key": "Escrime de Favonius - Blanche",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Escrime de Favonius - Blanche"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Invoque une </span><span style=\"color: rgb(255, 255, 255)\">aura solaire</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/4c999a92de43cfba640c30b45c782fc9_5919967579282441090.png",
                "id": "talent18925",
                "key": "Genèse : Aura solaire",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Genèse : Aura solaire"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 4 pts de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. SI une </span><span style=\"color: #FFFFFF\">aura solaire</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> est sur le terrain, DGT +2.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/42d2ae5af0169e6938febe18de57d31a_1958123559480855086.png",
                "id": "talent57934",
                "key": "Transformation : Reflux Géo",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Transformation : Reflux Géo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 3</span></p><p><span style=\"color: #FFFFFF\">Lorsque cette invocation est sur le terrain :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> l'</span><span style=\"color: #FFFFFF\">attaque plongeante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> de votre personnage dépense 1 dé d'</span><span style=\"color: #FFFFFF\">élément neutre</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">en moins. (1 fois par manche)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/db13288db6b90ec33f8adc2656d2019f_4415214347456458832.png",
                "id": "talent99702",
                "key": "Aura solaire",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/02297af9d3309f3e4e40eca8911a19f6_7983000873426083845.png",
                "title": "Aura solaire"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Réagit avec les éléments déjà appliqués pour déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Cryo : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Hydro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Pyro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Électro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/fd37cbfdd3b1b2c16e6e83fb0aa96889_1602634592098638234.png",
                "id": "talent11168",
                "key": "DGT Géo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Géo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Attaque plongeante</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après avoir basculé un personnage en personnage actif, si sa prochaine action de combat dans la manche est une attaque normale, elle est considérée comme une attaque plongeante.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/15/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_6462791407734460989.png",
                "id": "talent45381",
                "key": "Règles détaillées",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Règles détaillées"
              }
            ]
          }
        }
      ]
