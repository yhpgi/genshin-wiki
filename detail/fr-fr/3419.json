      "name": "Invocation des Sept : Défis d'aventure",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Duel: Asfand",
                      "type": "text"
                    }
                  ],
                  "level": 2,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "Présentation du niveau",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "« Je vois... Et bien, comme Dehya est votre amie, je vais faire une partie contre vous.",
                      "type": "text"
                    },
                    {
                      "text": "»",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Asfand ouvre son coffret d'arcanes pour révéler un deck construit autour de [Yoimiya], [Xingqiu] et du [Champieffroi panaché].",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "color:rgb(204, 191, 173)"
                      ],
                      "text": "Astuce : Après le début du combat, accorde 1 charge à tous les personnages de chaque camp.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Alignement adverse",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
