    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Wakamurasaki:",
                      "type": "text"
                    },
                    {
                      "text": "Bonjour ! Souhaitez-vous à nouveau utiliser l'Omnifilet d'ubiquité ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Alors, voilà comme ça se passe avec l'Omnifilet d'ubiquité...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Wakamurasaki:",
                      "type": "text"
                    },
                    {
                      "text": "Je suis encore en train d'étudier l'utilisation de ce filet, mais je n'ai jusqu'à présent fait aucun progrès.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Wakamurasaki:",
                      "type": "text"
                    },
                    {
                      "text": "Que ce soit sa solidité, son côté pratique ou d'autres propriétés, il n'arrive pas au niveau de ce que m'avait annoncé Sango...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Wakamurasaki:",
                      "type": "text"
                    },
                    {
                      "text": "*soupir* D'où peut bien provenir le problème...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Wakamurasaki:",
                      "type": "text"
                    },
                    {
                      "text": "Non, c'est impossible que Sango ait mal retenu la technique.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Wakamurasaki:",
                      "type": "text"
                    },
                    {
                      "text": "Je devrais aller lui poser la question à l'occasion...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Wakamurasaki:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir, faites attention à vous.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
