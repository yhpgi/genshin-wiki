              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Une oracle originaire de l'un des nombreux groupes de mercenaires venus du désert. Après avoir subi une certaine quantité de DGT, elle libère l'esprit sinistre du scorpion ardent contenu dans son corps, passant ainsi </span><span style=\"color: #FFE14B\">en forme démoniaque</span><span style=\"color: rgba(255, 255, 255, 0.85)\">. Une fois </span><span style=\"color: #FFE14B\">l'esprit de scorpion vaincu</span><span style=\"color: rgba(255, 255, 255, 0.85)\">, elle entre dans un état affaibli pendant un certain temps.</span></p>"
                ]
