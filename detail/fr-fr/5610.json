                "item_values": [],
                "key": "Type",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Bêtes mystiques</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Cet ancien golem est imprégné d'une volonté qui s'appuie sur son corps de marbre robuste pendant les combats. Vous devrez utiliser les </span><span style=\"color: #FFE14B\">éléments réagissant avec l'élément Géo</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> pour neutraliser ses défenses.</span></p>"
                ]
              }
            ]
