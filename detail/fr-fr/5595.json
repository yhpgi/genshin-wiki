    {
      "id": "30",
      "name": "Autres informations",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [
                  {
                    "id": "Autres informations23516",
                    "name": "Arlecchino",
                    "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki-voice/2024/05/17/29705491/96f131159540271d9e6b6c35aa1ecc95_1989315228468582275.mp3"
                  }
                ],
                "desc": "",
                "title": "Thème musical du combat"
              },
              {
                "audios": [],
                "desc": "<custom-post posts=\"27604025\"></custom-post>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/24/29705491/477cf9f5bfbeb91d0bf7ec4a95d174bf_6590532649823117011.png",
                "title": "Nouvel ennemi puissant : Arlecchino"
              },
              {
                "audios": [],
                "desc": "<p>Présentation du nouvel ennemi puissant (YouTube Shorts)</p><p></p><p><strong><span style=\"color: rgb(255, 153, 153)\">YouTube:</span></strong> <span style=\"color: rgb(55, 255, 255)\">https://youtube.com/shorts/z3e6DB_4NsM?si=RYUfnSMssAkRBadY</span></p>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/24/29705491/a5885a16caf1c1c6fd87ab0e20069410_9137351072443072996.png",
                "title": "Présentation du nouvel ennemi puissant (YouTube Shorts)"
              },
              {
                "audios": [],
                "desc": "<p>Le nouvel ennemi puissant « Arlecchino » entre en scène ! (Twitter)</p><p></p><p><strong><span style=\"color: rgb(128, 192, 255)\">Twitter :</span></strong> <span style=\"color: rgb(55, 255, 255)\">https://twitter.com/genshinimpactfr/status/1783423052459507926?t=uAp6KV902nuV1Kxc6lmylg&s=19</span></p>",
                "title": "Le nouvel ennemi puissant « Arlecchino » entre en scène !"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Cette performance de la musique « Adieu de lumière et d&#39;ombre » de la version 4.6 de Genshin Impact a été enregistrée au Tokyo Metropolitan Theatre. L&#39;Orchestre philharmonique de Tokyo, des chœurs et une chanteuse mezzo-soprano interprètent ensemble « Sequentia Sequelarum » et « Absolutio Absoluta Absolutissime ».</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Production : HOYO-MiX</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Compositeur : Dimeng Yuan @HOYO-MiX</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Chanteuse mezzo-soprano : Huiling Zhu</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Chœur d&#39;adultes : Time Office</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Chœur d&#39;enfants : Free Wave</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Interprétation : Orchestre philharmonique de Tokyo</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Piano : Yui Morishita</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Batterie : Jun Mochizuki</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Guitare électrique : Kohei Ebata</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Orgue : Yuka Ishikawa-Mangeol</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Lieu de l&#39;enregistrement : Tokyo Metropolitan Theatre</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Merci à P.I.C.S. et Sony Music Entertainment (Japan) Inc. pour leur soutien à l&#39;enregistrement et à la production.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">(Remarque : cette vidéo peut provoquer des réactions chez les personnes photosensibles et sujettes à l&#39;épilepsie. Veuillez visionner en connaissance de cause.)</span></p><p></p><p><strong><span style=\"color: rgb(255, 153, 153)\">YouTube:</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(55, 255, 255)\">https://www.youtube.com/watch?v=0ZNqBF3M7-8</span></p><custom-post posts=\"27712962\"></custom-post>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/04/29/29705491/bc802b8f18b28ffd34c9a2379332e767_687808881851578337.png",
                "title": "Absolutio Absoluta Absolutissime : Vidéo promotionnelle d'« Adieu de lumière et d'ombre »"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Dans l&#39;ancienne Khaenri&#39;ah, il existait des coutumes non écrites. Avant une admission à l&#39;orphelinat, la traversée d&#39;une cheminée obscure était obligatoire, comme le symbole du passage entre deux mondes guidé par les étoiles. Ainsi, la renaissance pouvait avoir lieu.</span></p><p></p><p><strong><span style=\"color: #FF9999\">YouTube :</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: #37FFFF\">https://www.youtube.com/watch?v=-ulocKe61mg</span></p><custom-post posts=\"27892355\"></custom-post>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/17/29705491/d7cd1893a0c2983a51335ae4ede5cf05_1495540785666060864.jpg",
                "title": "Genshin Impact - Cinématique : Cendres des flammes de deux mondes"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">La mort n&#39;est pas la seule conséquence d&#39;une exécution. Ou peut-être pourrait-on dire qu&#39;il n&#39;y a pas qu&#39;une seule façon de mourir. Le moment venu, la meilleure décision sera prise.</span></p><p></p><p><strong><span style=\"color: #FF9999\">YouTube:</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: #37FFFF\">https://www.youtube.com/watch?v=oBfO93ROWRo&t=55s</span></p><custom-post posts=\"27892487\"></custom-post>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/17/29705491/61aee52fb0b6dd7267aedef5682802e9_7752431876941110135.png",
                "title": "Genshin Impact - Cinématique : Exécution"
              }
            ]
          }
        }
      ]
    },
