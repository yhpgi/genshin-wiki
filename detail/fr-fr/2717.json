      "id": "11",
      "name": "Attributs",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "Nom",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Arbre foudroyé</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Type",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Bêtes mystiques</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Une plante prédatrice de la même espèce que les Arbres congelés et enflammés. Cette créature peut créer un organe qui ressemble à un</span><span style=\"color: rgb(255, 215, 128)\">&nbsp;</span><span style=\"color: rgb(255, 225, 75)\">noyau Électro</span><span style=\"color: rgb(255, 215, 128)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">sur ses racines ou sa corolle. Lorsque ce type d'organe commence à bouger, son état change, se condensant en un pistil en croissance ou en déclin. Lorsque les deux types de pistils sont présents en même temps, ils</span><span style=\"color: rgb(255, 225, 75)\">&nbsp;s'attirent puis déclenchent une puissante explosion électrique lorsqu'ils entrent en contact</span><span style=\"color: rgba(255, 255, 255, 0.85)\">. Détruire rapidement ces pistils est la clé pour un combat plus facile…</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
