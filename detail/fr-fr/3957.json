    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/01/35653081/241eba6e4c00020975cf91170050f435_6630669460027429423.png",
                "id": "talent52947",
                "key": "Lance étincelante (Posture protectrice)",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Lance étincelante (Posture protectrice)"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Accorde un </span><span style=\"color: rgb(255, 255, 255)\">bouclier de la héronne</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage et </span><span style=\"color: rgb(255, 255, 255)\">prépare la capacité</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> : </span><span style=\"color: rgb(255, 255, 255)\">Frappe de la héronne</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier de la héronne</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lors de son prochain tour, le personnage utilise directement la capacité : </span><span style=\"color: rgb(255, 255, 255)\">Frappe de la héronne</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Pendant la préparation de la capacité : Accorde 2 pts de </span><span style=\"color: #FFFFFF\">bouclier</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage affecté.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/03/35653081/93ab629528ecee5857a14f427422bbb3_6022470017645944062.png",
                "id": "talent25591",
                "key": "Liturgie : Sanctuaire de la héronne",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Liturgie : Sanctuaire de la héronne"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et crée une </span><span style=\"color: rgb(255, 255, 255)\">prière de couronne cramoisie</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Prière de couronne cramoisie</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT infligés par les </span><span style=\"color: rgb(255, 255, 255)\">attaques normales</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> de vos personnages +1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les</span><span style=\"color: rgb(255, 255, 255)\"> DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par vos personnages armés d'une épée à une main, à deux mains ou d'une arme d'hast sont convertis en </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Après que vous basculez de personnage : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. (1 fois par manche)</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/03/35653081/28ae761238404c68bd54c08344cb9c72_834150040380089591.png",
                "id": "talent50209",
                "key": "Liturgie : Marée de la bergeronnette",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Liturgie : Marée de la bergeronnette"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Hydro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Évaporation : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Électrocution :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Gel :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/01/35653081/a126c6a302d81c07e19cf9a9f1260f90_4178361294709465432.png",
                "id": "talent72791",
                "key": "DGT Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un bouclier qui absorbe les DGT reçus par le personnage qu'il protège.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Préparation de capacité</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Certaines capacité ne peuvent pas être utilisées directement. Au lieu de cela, il est nécessaire de les </span><span style=\"color: rgb(255, 255, 255)\">préparer</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> pendant un certain nombre de tours.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque c'est le tour d'un joueur et que son personnage actif est en train de </span><span style=\"color: rgb(255, 255, 255)\">préparer</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> une capacité, le tour est sauté. Si la </span><span style=\"color: rgb(255, 255, 255)\">préparation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est terminée, le personnage utilise directement la capacité à ce moment-là. (Les capacités nécessitant une </span><span style=\"color: rgb(255, 255, 255)\">préparation</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> ne peuvent pas activer les effets déclenchés lorsque vous avez «&nbsp;utilisé une capacité.&nbsp;»)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Seul le personnage actif peut </span><span style=\"color: rgb(255, 255, 255)\">préparer</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> une capacité. Si un personnage actif en train de </span><span style=\"color: rgb(255, 255, 255)\">préparer </span><span style=\"color: rgba(255, 255, 255, 0.65)\">une capacité passe en attente, la </span><span style=\"color: rgb(255, 255, 255)\">préparation</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> est interrompue.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/07/01/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_8637058734654935710.png",
                "id": "talent83058",
                "key": "Règles détaillées",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Règles détaillées"
              }
            ]
          }
        }
      ]
