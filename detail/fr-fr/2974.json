    {
      "id": "37",
      "name": "Propriétés",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Source",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "items": [
                    [
                      {
                        "content": [
                          {
                            "text": "Teyvat :",
                            "type": "text"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ]
                  ],
                  "ordered": true,
                  "type": "list"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 255, 255)"
                      ],
                      "text": "Tutoriel",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#8a6d48"
                      ],
                      "text": "À propos du noyau élémentaire",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Le noyau élémentaire de l'Hypostase Dendro est toujours",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Dendro",
                      "type": "text"
                    },
                    {
                      "text": "lorsqu'il est exposé.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#8a6d48"
                      ],
                      "text": "Attaques Basiques",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "L'Hypostase Dendro attaque 4 fois avec des lianes poussant depuis le sol. Les vignes révèlent leurs épines après leur croissance. Les lianes peuvent être",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "brûlées",
                      "type": "text"
                    },
                    {
                      "text": "par l'élément",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Pyro",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Pendant cette attaque,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "le noyau élémentaire sera exposé",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/14/125691367/d3ef4d12dc3ac1c30c3355d5be5e5e0e_3284230079989987872.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "L'Hypostase Dendro tire 3 fois des",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "projectiles Dendro",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "(1ère : 2 projectiles, 2ème : 3 projectiles, 3ème : 4 projectiles)",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Le projectile Dendro crée une petite zone lorsqu'il touche le sol, et peut endommager les personnages qui se trouvent dans cette zone.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Une fois cette attaque terminée,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "le noyau élémentaire sera exposé",
                      "type": "text"
                    },
                    {
                      "text": "pendant un moment.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/14/125691367/0a7234e1ad695c1f2467b6ffc980c50b_2529056931087789891.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "L'Hypostase Dendro se couvre de lianes, et répète le saut et le plongeon 3 fois pour attaquer. La 3ème attaque est plus large et plus forte que la 1ère et la 2ème.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Si les lianes ont été brûlées par l'élément",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Pyro",
                      "type": "text"
                    },
                    {
                      "text": ", cette attaque sera arrêtée et",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "le noyau élémentaire sera exposé",
                      "type": "text"
                    },
                    {
                      "text": "pendant un moment.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/14/125691367/7e896a2ace4bb33d092863bacfdeb276_3252199249684522635.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "L'Hypostase Dendro devient une sorte de fouet, et se balance 3 fois en utilisant tout son corps.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Une fois cette attaque terminée,",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "le noyau élémentaire sera exposé",
                      "type": "text"
                    },
                    {
                      "text": "pendant un moment.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/14/125691367/2db927d2396a21db8ccc4269c33441f5_5209867356695570836.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Après s'être téléporté au centre de la zone, l'Hypostase Dendro commence à charger sa puissance.",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Le noyau élémentaire",
                      "type": "text"
                    },
                    {
                      "text": "sera exposé pendant la charge.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Des lianes poussant du sol rendront la zone centrale progressivement plus étroite.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Les lianes peuvent être",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "brûlées",
                      "type": "text"
                    },
                    {
                      "text": "par l'élément",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 153, 153)"
                      ],
                      "text": "Pyro",
                      "type": "text"
                    },
                    {
                      "text": ", et permettent au personnage d'échapper au pouvoir chargé de l'Hypostase Dendro.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "alignment": "center",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/14/125691367/313a32f06f294550d203a22caec0b475_3420148894193517442.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#8a6d48"
                      ],
                      "text": "Quand les PV sont faibles",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Lorsque les PV sont faibles",
                      "type": "text"
                    },
                    {
                      "text": ", l'Hypostase Dendro se téléporte au centre de la zone et",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "libère 3 zistes réparateurs",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Afin de purifier l'Hypostase Dendro pour l'éliminer, les",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "zistes réparateurs",
                      "type": "text"
                    },
                    {
                      "text": "doivent être activés par l'élément",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Dendro",
                      "type": "text"
                    },
                    {
                      "text": ", puis peuvent être attaqués par l'élément",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 172, 255)"
                      ],
                      "text": "Électro",
                      "type": "text"
                    },
                    {
                      "text": "pour améliorer l'efficacité de la purification.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/14/125691367/859eaf525ca334332b9bb847215d7352_1410370955728005178.png"
                    },
                    {
                      "text": "Un",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "ziste réparateur",
                      "type": "text"
                    },
                    {
                      "text": "qui a été activé par l'élément",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(153, 255, 136)"
                      ],
                      "text": "Dendro",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "alignment": "right",
                      "type": "custom_image",
                      "url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2022/11/14/125691367/4058e536b23222b4252635da7f661270_8875584188156888265.png"
                    },
                    {
                      "text": "Un",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "ziste réparateur",
                      "type": "text"
                    },
                    {
                      "text": "activé qui a été attaqué par l'élément",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 172, 255)"
                      ],
                      "text": "Électro",
                      "type": "text"
                    },
                    {
                      "text": ".",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
