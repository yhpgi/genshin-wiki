          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/30/35653081/1ce09211f025bf5470682189e0837732_982510367083341887.png",
                "id": "talent34141",
                "key": "Acupuncture dorée",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Acupuncture dorée"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et invoque un </span><span style=\"color: rgb(255, 255, 255)\">esprit de gaze</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/30/35653081/02943d17a2ad29f325fdac70651d2bae_6460954277147174749.png",
                "id": "talent34848",
                "key": "Diagnostic universel",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Diagnostic universel"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Crée une </span><span style=\"color: rgb(255, 255, 255)\">ordonnance impulsive</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et un </span><span style=\"color: rgb(255, 255, 255)\">bouclier aseptique</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Ordonnance impulsive</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgb(255, 255, 255)\">Au début de la phase d'action : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Crée un bouclier aseptique.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier aseptique</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Accorde </span><span style=\"color: rgb(255, 255, 255)\">1 pt de bouclier</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> pour protéger votre personnage actif.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque l'effet est annulé ou déclenché à nouveau :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et soigne votre personnage actif pour 1 pt.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/30/35653081/ed10b8e3def17c518055b3421bfcb94a_4776761729133596776.png",
                "id": "talent47478",
                "key": "Reviviscence holistique",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Reviviscence holistique"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et soigne votre personnage actif pour 1 pt.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/30/35653081/db13288db6b90ec33f8adc2656d2019f_816671622768363280.png",
                "id": "talent6785",
                "key": "Esprit de gaze",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/30/35653081/3b1270b14533441ff3b963844df50569_2400115138400122448.png",
                "title": "Esprit de gaze"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Dendro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Brûlure </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et crée une </span><span style=\"color: rgb(255, 255, 255)\">flamme brûlante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui inflige des DGT Pyro à la fin de la manche (Utilisable 1 fois, 2 cumuls maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Stimulation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et crée un </span><span style=\"color: rgb(255, 255, 255)\">champ catalyseur</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui augmente les 3 prochains coups de DGT Dendro/Électro de 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/30/35653081/e8cff941b5a0ff248efde360ec9e91fe_3310147474994375327.png",
                "id": "talent27248",
                "key": "DGT Dendro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Dendro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un bouclier qui absorbe les DGT reçus par le personnage qu'il protège.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/11/30/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_3425396546502392875.png",
