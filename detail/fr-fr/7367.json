                ]
              },
              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">La Spiritoratrice excentrique isolée invoque des reflets radiants identiques pour se dissimuler parmi eux. Vous devrez alors </span><span style=\"color: #FFE14B\">détruire les égides élémentaires de tous les reflets radiants</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> pour révéler et affaiblir le vrai corps. De plus, les iktomisaures et les membres des Maitres du vent nocturne peuvent </span><span style=\"color: #FFE14B\">utiliser un appui long pour viser les reflets radiants</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> afin d'arrêter leur mouvement pendant un court moment...</span></p>"
                ]
              }
            ]
          }
        }
      ]
