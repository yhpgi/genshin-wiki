      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/35653081/c369b96fc6417e8fc2bb607e37297ad4_2916148067340768455.png",
                "id": "talent33578",
                "key": "Archerie divine",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Archerie divine"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">et crée une </span><span style=\"color: rgb(255, 255, 255)\">bourrasque</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bourrasque</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque votre personnage (hormis Venti) a utilisé une compétence élémentaire </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Dépense 1 dé élémentaire en moins.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/27/35653081/5462e680a1901ee99a16d6f6476e47a9_513610548628621835.png",
                "id": "talent74180",
                "key": "Sonnet des Vents célestes",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Sonnet des Vents célestes"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et invoque un </span><span style=\"color: #FFFFFF\">œil de la tempête</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/27/35653081/4e6c64424bb066f0f74936bf7fbc1b5a_3508537115945855998.png",
                "id": "talent66013",
                "key": "Ode au Vent",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ode au Vent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 2 pts de </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et bascule l'adversaire pour le </span><span style=\"color: rgb(255, 255, 255)\">personnage le plus proche de votre personnage actif</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsqu'un de vos personnages ou invocations a déclenché une réaction de Dispersion :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Convertit le type élémentaire de cette carte et modifie les DGT infligés en l'élément dispersé. (Ne peut être utilisé qu'une seule fois avant de quitter le terrain)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/35653081/db13288db6b90ec33f8adc2656d2019f_857391790501852542.png",
                "id": "talent32720",
                "key": "Œil de la tempête",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/35653081/481ff844d1ba46461024c9ade7a0e5db_5063162405999118.png",
                "title": "Œil de la tempête"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Réagit avec les éléments déjà appliqués pour les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Cryo à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Hydro à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Pyro à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo </span>+ <span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Électro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Électro à tous les personnages adverses autres que la cible</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/35653081/c97292d96456bfe4abeca16bfce801e4_3805048645401128888.png",
                "id": "talent78363",
                "key": "DGT Anémo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Anémo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Personnage le plus proche de votre personnage actif</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Le «&nbsp;personnage le plus proche de votre personnage actif&nbsp;» correspond au personnage adverse dont l'emplacement est le plus proche de celui de votre personnage actif.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Si plusieurs de ces personnages existent, celui avec l'emplacement le plus avancé est considéré comme étant le plus proche.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/23/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_8288306799184477828.png",
