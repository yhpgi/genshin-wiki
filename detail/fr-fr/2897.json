                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Un monstre à l'intelligence basique ayant évolué à partir de spores. Lorsqu'il est touché pour la première fois par une</span><span style=\"color: rgb(236, 228, 217)\">&nbsp;</span><span style=\"color: rgb(255, 225, 75)\">attaque Électro ou Pyro</span><span style=\"color: rgb(236, 228, 217)\">,</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> il entre en état activé ou calciné, selon le type d'attaque élémentaire utilisé. Éliminez ce Fongus transformé pour obtenir différentes récompenses...</span></p>"
                ]
