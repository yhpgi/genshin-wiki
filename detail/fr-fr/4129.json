    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Xana:",
                      "type": "text"
                    },
                    {
                      "text": "Si vous avez des choses qui brillent, échangez-les-moi !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Des choses qui brillent ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Xana:",
                      "type": "text"
                    },
                    {
                      "text": "Oui des composants qui brillent ! Comme celui-ci !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Xana:",
                      "type": "text"
                    },
                    {
                      "text": "Si j'en rassemble plein, je pourrai construire une super grande machine qui surpassera Elynas en taille. J'ai hâte rien que d'y penser !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Xana:",
                      "type": "text"
                    },
                    {
                      "text": "Parfois, je collecte des choses ternes à l'extérieur du village et je trouve un moyen de les rendre brillantes ensuite !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Xana:",
                      "type": "text"
                    },
                    {
                      "text": "En tout cas, plus j'ai de choses brillantes et mieux c'est ! Comme je vous l'ai dit, il est possible de venir les échanger ici !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Je ne vous ai jamais vue auparavant...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Xana:",
                      "type": "text"
                    },
                    {
                      "text": "Hmm ? Oh, j'étais à l'Institut de recherche de Fontaine. Il n'y a pas de meilleur endroit pour apprendre à fabriquer des Mékas horlogoïdes.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Xana:",
                      "type": "text"
                    },
                    {
                      "text": "Il y a une énorme machine super cool là-bas aussi... Mais un jour je vais fabriquer quelque chose d'encore plus grand !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Xana:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir ! N'oubliez pas de revenir me rendre visite !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
