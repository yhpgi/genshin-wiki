    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Bienvenue au Langage des fleurs. Que puis-je faire pour toi ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "A propos de Stormterror...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "C'est un soulagement de ne pas avoir à m'inquiéter que les fleurs de ma boutique soient emportées par le vent.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Ceci dit, on ne peut pas en dire autant des graines de pissenlit qui ont été dispersées dans toute la région. Peut-être qu'ils fleuriront un peu partout...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Avec cette perspective, la tempête ne me semble plus aussi effrayante.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Les fleurs de cette boutique...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Nous proposons une large sélection de fleurs. Lesquelles t'intéresseraient ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Parle-moi des pissenlits.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Les pissenlits sont mes fleurs préférées, ils sont légers et duveteux.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Je crois que Jean est aussi connue sous le nom de Chevalier au Pissenlit.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Ses pouvoirs Anémo lui viennent probablement de ces plantes, hihi.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Pourquoi aimes-tu autant les pissenlits ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Bonne question... Peut-être que j'ai trop lu",
                      "type": "text"
                    },
                    {
                      "text": "« La Renarde qui nageait dans la mer de pissenlits » !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Tiens, prends ce livre. Si ça se trouve, tu vas aussi te mettre à aimer les pissenlits après l'avoir lu.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Parle-moi des fleurs sucrantes.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Tu veux en savoir plus sur les fleurs sucrantes ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Elles sont jolies, mais on les utilise plutôt pour la cuisine.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Si jamais tu en vois dans le jardin de quelqu'un...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Elles sont sans doute là pour leur sucre.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Parle-moi des cécilias.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Les cécilias ? Tu as bon goût, dis donc.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Les cécilias poussent dans des lieux froids et venteux. Une légende raconte qu'ils ne fleurissent que dans le plus grand calme.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Les cultiver n'est pas vraiment facile...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Autant cultiver des fleurs de brume à la place !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Pardon pour le dérangement.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Oh, tu pars déjà ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Flora:",
                      "type": "text"
                    },
                    {
                      "text": "Pas de problème, je continuerai à te parler de fleurs une prochaine fois.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
