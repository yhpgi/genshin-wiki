              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Une forme de vie aquatique qui s'est engagée dans une voie évolutive unique en raison des caractéristiques environnementales de Fontaine. Sous les effets de l'</span><span style=\"color: #FFE14B\">élément Pyro</span><span style=\"color: rgba(255, 255, 255, 0.85)\">, il peut déclencher des attaques élémentaires plus féroces et possède de meilleures capacités défensives. Si vous utilisez des </span><span style=\"color: #FFE14B\">réactions élémentaires</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgba(255, 255, 255, 0.85)\">pour contrer son bouclier, vous vous faciliterez les choses...</span></p>"
                ]
              }
            ]
