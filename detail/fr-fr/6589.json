              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Un étrange monstre qui doit constamment absorber de l'énergie thermique pour survivre, bien qu'en absorber trop puisse le blesser.</span> <span style=\"color: #FFE14B\">Utiliser des attaques Pyro</span> <span style=\"color: rgba(255, 255, 255, 0.85)\">vous permettra de le faire passer en état de brûlure excessive et de le désintégrer rapidement.</span></p>"
