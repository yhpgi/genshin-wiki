          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/26b9736a2d14fc4162b2448963f45695_6334243753701087065.png",
                "id": "talent16559",
                "key": "Passe d'armes",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Passe d'armes"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/2efa0cba0a06e11bae77666bb6beb952_1114389164478330220.png",
                "id": "talent85122",
                "key": "Attaque givrée",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Attaque givrée"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et crée une </span><span style=\"color: rgb(255, 255, 255)\">stalactite</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Stalactite</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgb(255, 255, 255)\">Après que vous basculez de personnage : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 3</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/8c97595e1862a7f3d9d0b707c3143148_2560533507466171362.png",
                "id": "talent21231",
                "key": "Valse glaciale",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Valse glaciale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Cryo et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Gel </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance en subissant des DGT physiques ou Pyro, mais DGT +2)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/4bcc4b82a9d7ee22770f60afa54e9919_1811990836055164210.png",
                "id": "talent94259",
                "key": "DGT Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/07bae546ac7c69ef6402170b283840c5_3885890085235808311.png",
                "id": "talent42157",
