{
  "id": 2122,
  "name": "Chiot de faille géophile",
  "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une bête au sang démoniaque capable d'éroder les frontières du monde. L'« Or » les classait comme « Alfisol ».<br>Elles suivent l'abîme envahissant pour dévorer les éléments. Heureusement, il en reste peu dans ce monde.</span></p>",
  "icon_url": "https://bbs.hoyolab.com/hoyowiki/picture/enemy/Rockfond Rifthound Whelp_icon.png",
  "header_img_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/06/14/29705491/1aa661db18472420360570ef5e9c1485_4493398028307867288.png",
