    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/10316b5178d5109d597f415d6e7903dc_2371860060515992398.png",
                "id": "talent61306",
                "key": "Escrime de Favonius : Servante",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Escrime de Favonius : Servante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et crée une </span><span style=\"color: rgb(255, 255, 255)\">armure complète</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Armure complète</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Accorde </span><span style=\"color: rgb(255, 255, 255)\">2 pts de bouclier </span><span style=\"color: rgba(255, 255, 255, 0.65)\">à votre personnage actif.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Avant que ce </span><span style=\"color: rgb(255, 255, 255)\">bouclier </span><span style=\"color: rgba(255, 255, 255, 0.65)\">ne soit épuisé, les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques </span><span style=\"color: rgba(255, 255, 255, 0.65)\">que vous subissez diminuent de moitié. (Arrondi à l'entier supérieur)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/b6fb31387815c4484390c7fb11891609_622026376668115465.png",
                "id": "talent99245",
                "key": "Armure de cœur",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Armure de cœur"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 4 pts de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et accorde un </span><span style=\"color: rgb(255, 255, 255)\">grand ménage </span><span style=\"color: rgba(255, 255, 255, 0.65)\">au personnage.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Grand ménage</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque le personnage utilise une attaque normale : Dépense 1 dé Géo en moins. (1 fois par manche)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT infligés par l'</span><span style=\"color: #FFFFFF\">attaque normal </span><span style=\"color: rgba(255, 255, 255, 0.65)\">du personnage +2 et les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés sont convertis en </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/cb9d679d3462bed59d1601663836a019_3097442665952550497.png",
                "id": "talent17822",
                "key": "Grand ménage",
                "materials": [],
                "points": [
                  {
                    "point_count": 4,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Grand ménage"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Réagit avec les éléments déjà appliqués pour déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Cryo : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Hydro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Pyro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Électro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/fd37cbfdd3b1b2c16e6e83fb0aa96889_309627997382509528.png",
                "id": "talent40154",
                "key": "DGT Géo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Géo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un bouclier qui absorbe les DGT reçus par le personnage qu'il protège.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/07bae546ac7c69ef6402170b283840c5_4597780404347785146.png",
                "id": "talent83700",
                "key": "Règles détaillées",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Règles détaillées"
              }
            ]
          }
        }
      ]
