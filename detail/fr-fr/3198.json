                  }
                ],
                "talent_img": "",
                "title": "Movo Lawa"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 5 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/06/35653081/36768cf2c0fc7aafe7c6c956fee29fba_4026824676284708612.png",
                "id": "talent79389",
                "key": "Upa Shato",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Upa Shato"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Capacité passive</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passif) Accorde une </span><span style=\"color: rgb(255, 255, 255)\">peau-pierre </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et une </span><span style=\"color: rgb(255, 255, 255)\">force de pierre </span><span style=\"color: rgba(255, 255, 255, 0.65)\">au début du combat.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Peau-pierre</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage affecté subit des DGT </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Diminue les DGT de 1 pt. Lorsque des DGT Géo sont diminués, consomme le </span><span style=\"color: rgb(255, 255, 255)\">nombre d'utilisation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">pour 1 plus.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 3</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Force de pierre</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les</span><span style=\"color: rgb(255, 255, 255)\"> DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par le personnage sont convertis en</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Une fois par manche</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> : DGT infligés par le personnage +1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une fois la peau-pierre du personnage annulée : Annule également cet état.</span></p><p></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/06/35653081/370c275e0af4838e7689aa8e24bc36c7_1934684282178650547.png",
                "id": "talent38478",
                "key": "Peau-pierre infusée",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Peau-pierre infusée"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Réagit avec les éléments déjà appliqués pour déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Cryo : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Hydro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Pyro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Électro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/06/35653081/fd37cbfdd3b1b2c16e6e83fb0aa96889_3180923933012323938.png",
                "id": "talent83742",
                "key": "DGT Géo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Géo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/06/35653081/07bae546ac7c69ef6402170b283840c5_2458564458520513843.png",
