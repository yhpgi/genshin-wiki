    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Takashi:",
                      "type": "text"
                    },
                    {
                      "text": "Oui ?  Qu'est-ce qu'il y a ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Je veux ouvrir un coffre.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Takashi:",
                      "type": "text"
                    },
                    {
                      "text": "Tant que vous avez des conques pour moi, vous êtes libre de faire votre choix.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Pourquoi collectionnez-vous ces conques ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Takashi:",
                      "type": "text"
                    },
                    {
                      "text": "Héhé, eh bien... Pour faire des affaires, bien sûr.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Takashi:",
                      "type": "text"
                    },
                    {
                      "text": "\"Une conque affectée par le Tatarigami\"... Haha, c'est sûr que ça va se vendre à bon prix !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Takashi:",
                      "type": "text"
                    },
                    {
                      "text": "Ahem ! Quoi qu'il en soit, vous fournissez des conques, je fournis des coffres. Marché conclu ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Cette maison... Elle m'a l'air familière...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Takashi:",
                      "type": "text"
                    },
                    {
                      "text": "Ah bon ? C'est... Waouh, quelle coïncidence, haha.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Takashi:",
                      "type": "text"
                    },
                    {
                      "text": "Mais même si cette mason ressemble à une autre, le travail que je fais ici est unique.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Takashi:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir... Et n'oubliez pas: qui dit conques dit coffres, haha.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
