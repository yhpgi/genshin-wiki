    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Hé ! Vous avez l'air d'un(e) aventurier/ère. Vous possédez un",
                      "type": "text"
                    },
                    {
                      "text": "œil divin ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Non.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Dommage ! Les aventuriers qui n'en ont pas tombent dans l'oubli.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Vous savez pourquoi ? Grâce à cet objet, ils peuvent vaincre le mal avec le pouvoir des éléments et deviennent des légendes !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Ça leur donne aussi plein d'autres avantages ! Tous les aventuriers légendaires sur qui on écrit des livres sont détenteurs d'un",
                      "type": "text"
                    },
                    {
                      "text": "œ",
                      "type": "text"
                    },
                    {
                      "text": "il divin.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Ne rêvez pas de devenir une grande héroïne si vous n'en avez pas.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Je peux contrôler les éléments sans ça.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Impossible ! Vous mentez. J'ai lu des tonnes de livres sur le sujet et personne ne peut manipuler les éléments sans",
                      "type": "text"
                    },
                    {
                      "text": "œil divin !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Vous croyez pouvoir me mentir parce que je ne suis qu'une enfant ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Pourquoi ça t'importe tant ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Parce que j'en veux un.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Je deviendrai si riche et influente que papa et maman reviendront au village. Ils n'auront plus besoin de travailler à Liyue.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Tous mes amis veulent aussi un",
                      "type": "text"
                    },
                    {
                      "text": "œil divin depuis que je leur en ai parlé.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Je ne dirai rien.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Petite Liu:",
                      "type": "text"
                    },
                    {
                      "text": "Pff, c'est pas comme si j'en avais jamais vu.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
