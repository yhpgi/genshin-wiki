    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Bonjour, vous cherchez quelque chose en particulier ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "La mort du Souverain de la Roche...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Liyue n'aurait jamais pu prospérer sans lui. Même la monnaie de Teyvat, le mora, est nommée après lui.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Tous les commerçants le vénèrent, et lui attribuent toutes leurs transactions.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Sa disparition bouleversera le monde des affaires, si ça ne l'a pas déjà bouleversé...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Vous êtes ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Je m'appelle Changshun. Je suis commerçante et chercheuse en sciences commerciales liyuéennes.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Je peux faire quelque chose pour vous ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Sciences commerciales liyuéennes ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Pour vous simplifier les choses, je fais des recherches sur une façon de s'enrichir d'après les principes des commerçants de Liyue.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Aujourd'hui, on ne peut pas juste se jeter à corps perdu dans la course au profit. Il faut adopter une stratégie commerciale efficace grâce à des connaissances du milieu.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Comment vont les affaires ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Pas trop mal. La Pente Feiyun est l'endroit le plus propice de Liyue pour faire des affaires.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Quel dommage que le Souverain de la Roche n'ait jamais pu visiter ma boutique...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Il n'en a pas eu l'occasion, car elle est assez récente.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Tous les commerces qui ont eu la chance de le recevoir sont très prospères. Certains d'entre eux existent même depuis des siècles !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "*soupir* Mais tout ça échappe à ma volonté de toute façon...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Changshun:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir ! Bon courage dans vos affaires !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
