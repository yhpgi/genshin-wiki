    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#ffffff"
                      ],
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:#bfbfbf"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "Nara Voyageur/euse et Paimon, les amies d'Ararycan. Ararycan est heureux de vous voir à Vanarana.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "A propos de la forêt...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "Sans les choses mauvaises, la forêt ne sera plus malade.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "Ararycan va rester à Vanarana avec plein d'autres aranaras, et n'aura plus besoin de faire la rencontre de naras bizarres.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "Merci, nara Voyageur/euse.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Parle moi de Jazari...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "Nara Jazari aussi, c'est un nara étrange. Il crie fort et comme quelqu'un de malade. Mais Ararycan ne pense pas qu'il soit un mauvais nara.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "S'il pouvait voir Ararycan, il serait sûrement un ami d'Ararycan lui aussi.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "Nara Voyageur/euse, Ararycan espère que nara Jazari et toi deviendrez de très bons amis.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "Ararycan espère aussi que les cris étranges de nara Jazari ne t'effraieront pas.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Ararycan:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir, amis/es d'Ararycan, la forêt veillera sur vous.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
