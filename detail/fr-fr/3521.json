                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "L'un des 5 Yakshas les plus puissants,",
                      "type": "text"
                    },
                    {
                      "text": "le seul encore vivant aujourd'hui",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "text": "Nom de Yaksha : Alatus",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "alignment": "center",
                  "content": [
                    {
                      "amount": 0,
                      "display_style": "card",
                      "ep_id": 3518,
                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/01/43281454/2a70abcd41f1c25b94da6c18901fc863_834907582884265592.png",
                      "name": "Ménogias",
                      "type": "custom_entry"
                    }
                  ],
                  "type": "paragraph"
