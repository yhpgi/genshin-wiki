{
  "id": 3983,
  "name": "La première grande magie",
  "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un accessoire de scène autrefois utilisé par une « grande magicienne », l'ultime secret de cette dernière étant qu'il s'agissait en fait d'une arme.</span></p>",
  "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/08/11/158750877/150d6ae6dec75c2af1e4c37a084bf80f_8152864594678932826.png",
