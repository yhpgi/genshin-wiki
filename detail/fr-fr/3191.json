      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgb(255, 255, 255)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/1ce09211f025bf5470682189e0837732_1432328916941846152.png",
                "id": "talent68133",
                "key": "Géo-dispersion",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Géo-dispersion"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et crée une </span><span style=\"color: rgb(255, 255, 255)\">paravent d'astrolabe</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Paravent d'astrolabe</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque votre personnage actif subit au moins 2 pts de DGT </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Diminue les DGT de 1 pt.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/2a1c2baa706dfc49f86033be36f170e9_2865198713122191273.png",
                "id": "talent59551",
                "key": "Paravent d'astrolabe",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Paravent d'astrolabe"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 6 pts de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Si un </span><span style=\"color: rgb(255, 255, 255)\">paravent d'astrolabe </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est sur le terrain, DGT +2.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Paravent d'astrolabe</span></strong></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque votre personnage actif subit au moins 2 pts de DGT </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Diminue les DGT de 1 pt.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/55dfd3944aa4091c2684c17412739558_1694840071104010068.png",
                "id": "talent97122",
                "key": "Éclatement des étoiles",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Éclatement des étoiles"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Réagit avec les éléments déjà appliqués pour déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Cryo : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Hydro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Pyro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation </span><span style=\"color: #FFFFFF\">Électro</span><span style=\"color: rgb(255, 255, 255)\"> : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/fd37cbfdd3b1b2c16e6e83fb0aa96889_7360458587715927411.png",
                "id": "talent47303",
                "key": "DGT Géo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Géo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/07bae546ac7c69ef6402170b283840c5_2640803613342047289.png",
