    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "C'est bien ça, Baguette, bonne fifille... Pfiou.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Qu'est-ce que vous faites ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Oh, pardon. Je suis juste... vraiment fatigué en ce moment. Je ne vous avais pas remarqué/e.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Très peu de gens me parlent au travail, car l'inspection des cargaisons n'implique pas vraiment l'équipage.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Et comme vous pouvez le voir, c'est ce que je fais.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Bien qu'en pratique, celui qui inspecte les choses, c'est ma chienne, ma Baguette. Je suis juste là pour m'occuper d'elle.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "À propos de votre chienne...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, ma Baguette est une fille sérieuse qui se consacre à son travail. Je l'aime vraiment beaucoup.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Elle a un sens de l'odorat très développé, et elle peut sentir toutes sortes de produits de contrebande et d'objets interdits.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Aucun inspecteur humain ne peut la battre à cet égard, mais...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Si ma Baguette est infatigable au travail, elle l'est tout autant lorsqu'il s'agit de saccager la maison.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "*soupir* Si seulement elle pouvait être aussi calme à la maison.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "À propos de la prophétie...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Je voudrais encore vous remercier pour la pochette magique que vous m'avez donnée ! Elle m'a vraiment été d'une grande aide.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Heureusement, j'y avais déjà rangé tous mes objets de valeur. Lorsque la catastrophe est arrivée, les opérations de secours sont devenues la priorité absolue. Il n'y avait pas le temps de s'occuper de quoi que ce soit d'autre.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "Mais je n'ai pas encore sorti tout ce que j'y avais rangé, haha... À vrai dire, c'est plutôt utile pour empêcher Baguette de tout casser.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Etienne:",
                      "type": "text"
                    },
                    {
                      "text": "*soupir* Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
