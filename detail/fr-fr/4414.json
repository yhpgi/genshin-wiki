    {
      "id": "68",
      "name": "Dialogues ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Afshin:",
                      "type": "text"
                    },
                    {
                      "text": "J'ai des marchandises de bonne qualité et des histoires fascinantes pour mes invités, si ça vous intéresse.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Écouter.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Afshin:",
                      "type": "text"
                    },
                    {
                      "text": "La fleur se dresse fièrement au sommet des montagnes de Liyue, vacillant sous le vent glacial des hauteurs. Elle est aussi pâle que les cheveux de la déesse qui l'a touchée...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Afshin:",
                      "type": "text"
                    },
                    {
                      "text": "Aussi extraordinaire soit-elle, elle est au prix modeste de 80 000 moras.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Afshin:",
                      "type": "text"
                    },
                    {
                      "text": "Une jarre à vin centenaire et qui a été bénie par le bourdonnement de l'Archon Anémo. Buvez-en, et vous aussi, vous pourrez chanter des poèmes mélodieux...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Afshin:",
                      "type": "text"
                    },
                    {
                      "text": "Aussi incroyable qu'elle soit, vous pourrez l'acquérir pour la modique somme de 200 000 moras.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "J'y vais.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Afshin:",
                      "type": "text"
                    },
                    {
                      "text": "Quel dommage.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
