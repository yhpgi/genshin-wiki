    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Pam:",
                      "type": "text"
                    },
                    {
                      "text": "Vous voulez acheter du poisson frais ? Avec ça, vous pourrez faire plein de bons plats pour accompagner vos vins !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Vous êtes...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Pam:",
                      "type": "text"
                    },
                    {
                      "text": "Je suis une vendeuse de poisson indépendante. Mon commerce est petit, alors je dois vendre beaucoup pour espérer toucher quelques maigres profits.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Pam:",
                      "type": "text"
                    },
                    {
                      "text": "Il s'agit de tirer le meilleur parti des ressources locales pour subvenir à ses besoins, pour résumer.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Pam:",
                      "type": "text"
                    },
                    {
                      "text": "Chaque jour, je pêche des poissons, des crustacés et des algues dans la mer, non seulement pour remplir mon ventre, mais aussi pour gagner de l'argent et faire vivre ma famille.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Pam:",
                      "type": "text"
                    },
                    {
                      "text": "Grâce à la mer, je peux vivre une vie paisible.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Pam:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir et bonne journée. Venez me voir si vous voulez des fruits de mer frais !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
