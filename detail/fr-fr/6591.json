    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/29/35653081/1ce09211f025bf5470682189e0837732_277014500306863700.png",
                "id": "talent57960",
                "key": "Murmures floraux au vent",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Murmures floraux au vent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, crée une </span><span style=\"color: rgb(255, 255, 255)\">échelle céleste</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et applique une </span><span style=\"color: rgb(255, 255, 255)\">vague de nuage flottant</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> à ce personnage.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Échelle céleste</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: #FFFFFF\">Lorsque vous effectuez un changement de personnage :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Dépense 1 dé élémentaire en moins.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation : 1</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> (Peut être cumulé, 2 cumuls maximum)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Vague de nuage flottant</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: #FFFFFF\">Lorsque vous avez basculé pour le personnage affecté :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation : 1</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> (Peut être cumulé, 2 cumuls maximum)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/29/35653081/79d2dc0ab0f7a0c36587bd40a2ba09b7_7076133446043717858.png",
                "id": "talent16815",
                "key": "Nuages blanc à l'aube",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Nuages blanc à l'aube"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, soigne touts vos personnages pour 1 pt et crée une carte [</span><span style=\"color: rgb(255, 255, 255)\">Étoileur d'osier</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] dans votre main.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Les personnages équipés avec [</span><span style=\"color: rgb(255, 255, 255)\">Étoileur d'osier</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] peuvent utiliser l'habilité : </span><span style=\"color: rgb(255, 255, 255)\">Aide adeptale</span><span style=\"color: rgba(255, 255, 255, 0.65)\">)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/29/35653081/aff71fb8cfbf5594ea7f4fa18f456273_8398261584069153631.png",
                "id": "talent87083",
                "key": "Étoiles réunies au crépuscule",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Étoiles réunies au crépuscule"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Carte d'équipement</span></p><p><span style=\"color: #FFFFFF\">Habilité </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Aide adeptable</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: #FFFFFF\">2 </span><span style=\"color: rgba(255, 255, 255, 0.65)\">(Un personnage peut équiper au maximum 1 habilité)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/29/35653081/db13288db6b90ec33f8adc2656d2019f_7254662604779346701.png",
                "id": "talent94145",
                "key": "Étoileur d'osier",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/29/35653081/82c711b2a1c8eb2bb4bc97a0f6f3aeb3_8210494548390595696.png",
                "title": "Étoileur d'osier"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: #FFD780\">Habilité</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Soigne le personnage affecté pour 2 pts, considère sa prochaine attaque normale comme une </span><span style=\"color: rgb(255, 255, 255)\">attaque plongeante</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, augmente les DGT de 1 et, après le calcul de la capacité, inflige 1 pt de </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/29/35653081/0a55f17c8440010076312cb5bb6073be_1715073756687756930.png",
                "id": "talent88610",
                "key": "Aide adeptable",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "white"
                  }
                ],
                "talent_img": "",
                "title": "Aide adeptable"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Réagit avec les éléments déjà appliqués pour les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Cryo à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Hydro à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Pyro à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo </span>+ <span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Électro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Électro à tous les personnages adverses autres que la cible</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/29/35653081/c97292d96456bfe4abeca16bfce801e4_6097393590745537428.png",
                "id": "talent94629",
                "key": "DGT Anémo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Anémo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Attaque plongeante</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après avoir basculé un personnage en personnage actif, si sa prochaine action de combat dans la manche est une attaque normale, elle est considérée comme une attaque plongeante.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Habilité</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque le personnage actif est équipé d'une carte d'habilité, il peut utiliser l'habilité correspondante. Utiliser une habilité est considéré comme une action de combat. Si le personnage ne peut pas utiliser de capacités à cause des effets de Gel, d'Étourdissement, de Pétrification ou autre, il ne peut pas non plus utiliser d'habilité.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Utiliser une habilité n'est pas considéré comme utiliser une capacité et ne peut donc pas activer les effets déclenchés lorsque vous avez « utilisé une capacité » ou « déclenché une réaction élémentaire » ou autre effets du genre. Les DGT infligés lorsqu'un personnage utilise une habilité ne sont pas considérés comme des DGT infligés par le personnage.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/08/29/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_4560533926767761982.png",
