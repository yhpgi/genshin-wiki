      "name": "Attributs",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "Nom",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Crococornu sacralisé</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Type",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Bêtes mystiques</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Une créature rampante qui a été déformée et transformée après avoir consommé la chair d'une puissante forme de vie. Au combat, elle entre dans l'état Phagocytose, ce qui permet à certaines de ses attaques de déclencher des blocs d'énergie phagocytaire. Vous devez </span><span style=\"color: rgb(255, 225, 75)\">utiliser les attaques élémentaires correspondantes pour détruire ces blocs d'énergie</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> et absorber la puissance qu'ils contiennent, qui peut ensuite être libérée lorsque vous attaquez le Crococornu sacralisé, infligeant d'importants DGT et paralysant temporairement la créature.</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
