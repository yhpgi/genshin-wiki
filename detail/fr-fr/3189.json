                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "Brosse florale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: #99FF88\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et invoque un </span><span style=\"color: rgb(255, 255, 255)\">Cuilein-Anbar</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/b1519a139b4737aaa5e6844da801d167_4601351582341345151.png",
                "id": "talent71922",
                "key": "Atout félin",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Atout félin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 2 pts de </span><span style=\"color: #99FF88\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/db13288db6b90ec33f8adc2656d2019f_9192414060826498237.png",
                "id": "talent34405",
                "key": "Cuilein-Anbar",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/e4c575a9b78928d6dd760a34a0bd9681_5025328804288995933.png",
                "title": "Cuilein-Anbar"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Dendro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Brûlure </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et crée une </span><span style=\"color: rgb(255, 255, 255)\">flamme brûlante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui inflige des DGT Pyro à la fin de la manche (Utilisable 1 fois, 2 cumuls maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Stimulation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et crée un </span><span style=\"color: rgb(255, 255, 255)\">champ catalyseur</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui augmente les 3 prochains coups de DGT Dendro/Électro de 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/e8cff941b5a0ff248efde360ec9e91fe_9187740295001508799.png",
                "id": "talent60139",
                "key": "DGT Dendro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Dendro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/07bae546ac7c69ef6402170b283840c5_4692024060184880265.png",
