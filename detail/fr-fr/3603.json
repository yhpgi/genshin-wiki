      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgb(128, 192, 255)\"> DGT Hydro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/08/35653081/1ce09211f025bf5470682189e0837732_7002822358411643683.png",
                "id": "talent87252",
                "key": "Forme de l'eau",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Forme de l'eau"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgb(128, 192, 255)\">Applique l'élément Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage et invoque une </span><span style=\"color: #FFFFFF\">méduse fantôme</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/08/35653081/b33ca2371d6c02d581a1a89570bc6fb8_1667513249107429058.png",
                "id": "talent9329",
                "key": "Serment de Kurage",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Serment de Kurage"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et accorde une </span><span style=\"color: rgb(255, 255, 255)\">parure cérémoniale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Parure cérémoniale</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT infligés par l'</span><span style=\"color: rgb(255, 255, 255)\">attaque normale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> du personnage affecté +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a effectué une attaque normale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> : Soigne tous vos personnages pour 1 pt.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/08/35653081/47fcf95dc439392467286728a046b049_9217848960516981895.png",
                "id": "talent67901",
                "key": "Ascension de la néréide",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Ascension de la néréide"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et soigne votre personnage actif pour 1 pt.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/08/35653081/db13288db6b90ec33f8adc2656d2019f_588861185178175702.png",
                "id": "talent57698",
                "key": "Méduse fantôme",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/08/35653081/0e046eb8f7da357cc6b2ee42e058526a_6684553697378446831.png",
                "title": "Méduse fantôme"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Hydro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Évaporation : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Électrocution :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Gel :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/08/35653081/a126c6a302d81c07e19cf9a9f1260f90_8936224646061479928.png",
                "id": "talent48042",
                "key": "DGT Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(128, 192, 255)\">Application Hydro</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque l'élément Hydro est appliqué sans infliger de DGT, la réaction élémentaire déclenchée ignore les effets de DGT :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Évaporation : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Aucun effet</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Électrocution : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Aucun effet</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Gel : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Crée un </span><span style=\"color: rgba(255, 255, 255, 0.85)\">noyau Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/03/08/35653081/07bae546ac7c69ef6402170b283840c5_3669071809762093806.png",
