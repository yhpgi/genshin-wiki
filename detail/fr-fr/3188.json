              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et invoque un </span><span style=\"color: rgb(255, 255, 255)\">Oz</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/7521cde834fa3119ec5a1a10ea5bce58_8093854162764010735.png",
                "id": "talent63322",
