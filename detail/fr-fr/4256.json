    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Hubel:",
                      "type": "text"
                    },
                    {
                      "text": "Bienvenue, bienvenue dans ce bel océan de mots !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Et vous êtes...?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Hubel:",
                      "type": "text"
                    },
                    {
                      "text": "Vous pouvez m'appeler le... propriétaire temporaire de ce kiosque à journaux.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Hubel:",
                      "type": "text"
                    },
                    {
                      "text": "Je dis « temporaire », car je rêve de rejoindre L'Oiseau de vapeur !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Hubel:",
                      "type": "text"
                    },
                    {
                      "text": "Je travaille dur tous les jours, peaufinant mes scripts, améliorant ma rhétorique, et j'apprends constamment l'art du langage !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Hubel:",
                      "type": "text"
                    },
                    {
                      "text": "Un jour, je partagerai tout ce que j'ai vu et lu, et mes étonnantes compétences littéraires feront la une des journaux !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Hubel:",
                      "type": "text"
                    },
                    {
                      "text": "Nous actualisons régulièrement notre gamme, alors revenez bientôt !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
