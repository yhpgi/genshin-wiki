    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "Il y a encore beaucoup de choses à faire aujourd'hui...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, bonjour ! En quoi puis-je vous être utile ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "À propos du Village Mérusea...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "Hmm ? C'est la première fois que vous venez ici ? Eh bien, dans ce cas, bienvenue !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "C'est notre maison, à nous, les mélusines, mais... Comme vous pouvez le voir, en raison de l'emplacement, nous ne recevons pas beaucoup de visiteurs humains.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "Surtout, n'hésitez pas à me faire savoir si vous rencontrez des problèmes ici, ou si vous avez besoin de quoi que ce soit.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "C'est vous la cheffe du village ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "La cheffe du village... Vous voulez dire une personne responsable de tout le monde ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "Je ne pense pas, non. Je suis juste un peu plus âgée que les autres. En tant que grande sœur de tout le monde, il est de ma responsabilité d'aider avec les problèmes quotidiens.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "C'est vrai, je dois m'occuper de tout le monde.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "Hmm, au revoir ! Surtout, n'hésitez pas à me faire savoir si je peux vous être utile en quoi que ce soit.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Serene:",
                      "type": "text"
                    },
                    {
                      "text": "Hmm, au revoir ! Surtout, n'hésitez pas à me faire savoir si vous avez besoin de quoi que ce soit.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
