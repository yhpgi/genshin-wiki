    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Pourquoi les matériaux que j'ai commandés ne sont toujours pas arrivés...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, encore vous. Comment ça va ? Vous souhaitez acheter des accessoires ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Comment va la fabrication de peinture ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "On est toujours dans la phase finale d'ajustement. Ça devrait être vite fini !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Ça prend quand même plus de temps que je ne le pensais... Mais c'est pareil qu'avec les gemmes : je dois créer des peintures parfaites.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Si ce n'est pas parfait, ça ne vaut pas le coup de le faire. *soupir* Si seulement Puca pouvait comprendre...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Vous parliez de matériaux ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Oui, je parle des gemmes que j'ai commandées à un marchand de Fontaine...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Tout comme c'est le cas avec les matériaux de fabrication de peinture que vous m'avez montrés avant...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Moi qui travaille les gemmes, j'ai besoin de matériaux pour pouvoir commencer mon travail...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, j'aimerais juste que les marchandises arrivent plus vite...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sluasi:",
                      "type": "text"
                    },
                    {
                      "text": "Oui, au revoir !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
