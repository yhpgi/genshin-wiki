    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards - Jour",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "Vous voulez du poisson ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "300 moras la pièce, 1000 moras les trois.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Euh... Pourquoi c'est plus cher quand on en prend davantage ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "C'est mon poisson, c'est moi qui décide !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "Regardez comme il est frais... Si vous en prenez un seul, vous y gagnez ; deux, vous faites une affaire ; et trois, je vends à perte ! Vous comprenez ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "Et puis si vous m'en prenez un, j'en ai un de moins à vendre, le reste devient plus rare, et ce qui est rare est cher ! Et vous osez vous plaindre ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "Tsss... Moi à ce genre d'attitude, je réponds : « Achetez ou partez » !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Non merci, au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "Vous regardez juste ? Ah ! Tant pis pour vous alors !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Dialogues standards - Nuit",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "Hé, vieux frère, les recettes sont bonnes aujourd'hui ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Sun:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, Lao Gao, ton plan était vraiment parfait !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "Haha, tous ces types ne suspectent rien, comme je l'avais prévu !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Sun:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, Lao Gao, tu es vraiment quelqu'un de pas ordinaire ! Qui pourrait se douter qu'on est ensemble... Celui qui compare nos prix doit sûrement se dire qu'il fait une bonne affaire !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "Hahahaha, allez, trinquons !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Sun:",
                      "type": "text"
                    },
                    {
                      "text": "Laisse-moi te remplir ton verre !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Gao:",
                      "type": "text"
                    },
                    {
                      "text": "C'est décidé, ce soir on se saoule à mort !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Lao Sun:",
                      "type": "text"
                    },
                    {
                      "text": "Assez parlé, buvons !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
