                  }
                ],
                "talent_img": "",
                "title": "Frappe enflammée"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: #FF9999\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et invoque l'</span><span style=\"color: #FFFFFF\">esprit sinistre du scorpion ardent</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/6d7f53f97097de5265ca596461e914b1_7665196939218908578.png",
                "id": "talent30267",
                "key": "Éveil d'esprit sinistre du scorpion ardent",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Éveil d'esprit sinistre du scorpion ardent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Capacité passive</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passif)</span> <span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a subi des DGT :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Il obtient 1 </span><span style=\"color: #FFFFFF\">charge</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> s'il a 7 PV ou moins. (Limité à 1 fois par partie)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/eb96a0e1f4fd6ddf6d0975dfcf1fed10_3849265111663853497.png",
                "id": "talent40361",
                "key": "Puissance d'esprit sinistre",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Puissance d'esprit sinistre"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: rgb(255, 153, 153)\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations : 2</span></p><p><span style=\"color: rgb(255, 255, 255)\">En arrivant sur le terrain et au début de la phase d'action :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Applique un Scorpion ardent : Posture protectrice à votre Lettrée incandescente des Érémites. (1 fois par manche lorsque l'Esprit sinistre du scorpion ardent est sur le terrain, les DGT subis par le personnage diminuent de 1)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/db13288db6b90ec33f8adc2656d2019f_4587577554931335793.png",
                "id": "talent34520",
                "key": "Esprit sinistre du scorpion ardent",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/f7f4fe5b41d7d7267cc09061873660cc_1185195399160048083.png",
                "title": "Esprit sinistre du scorpion ardent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Pyro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Évaporation </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Surcharge </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2 et bascule de force la cible pour le personnage suivant</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Brûlure </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et crée une </span><span style=\"color: rgb(255, 255, 255)\">flamme brûlante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui inflige des DGT Pyro à la fin de la manche (Utilisable 1 fois, 2 cumuls maximum)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/d714b3b669cc08d1d8e34464fd7a3630_4235414854197121416.png",
                "id": "talent68315",
                "key": "DGT Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisations</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_3888782744236776875.png",
