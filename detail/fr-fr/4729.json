    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/c369b96fc6417e8fc2bb607e37297ad4_4755474279917501576.png",
                "id": "talent73524",
                "key": "Sagette furtive",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Sagette furtive"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et</span><span style=\"color: rgb(255, 215, 128)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">accorde 2 cumuls de </span><span style=\"color: #FFFFFF\">percée </span><span style=\"color: rgba(255, 255, 255, 0.65)\">au personnage.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Percée </span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Cet état commence avec 1 cumul de </span><span style=\"color: #FFFFFF\">percée</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, et chaque nouvelle application rajoute 1 cumul. La </span><span style=\"color: #FFFFFF\">percée</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> peut être cumulée 3 fois maximum. </span></p><p><span style=\"color: #FFFFFF\">Phase finale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Rajoute 1 cumul de percée.</span></p><p><span style=\"color: #FFFFFF\">Lorsque le personnage affecté utilise une attaque normale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Avec au moins 2 cumuls de percée, consomme 2 cumuls de percée pour convertir les </span><span style=\"color: #FFFFFF\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés en </span><span style=\"color: #80C0FF\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et pioche 1 carte.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/b0033b9dfbdff746cfb03c7b73792a34_8253867093313293173.png",
                "id": "talent97682",
                "key": "Ligne vitale persistante",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Ligne vitale persistante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et crée un </span><span style=\"color: rgb(255, 255, 255)\">dé exquis</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Dé exquis</span></strong></p><p><span style=\"color: #FFFFFF\">Lorsque votre personnage a utilisé une attaque normale :</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span> <span style=\"color: #80C0FF\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span> </p><p><span style=\"color: #FFFFFF\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/f92e763ec4e356d65ffc75d9443b7d22_750679492998775443.png",
                "id": "talent30689",
                "key": "Dé exquis des profondeurs",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Dé exquis des profondeurs"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Capacité passive</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passif) Applique une </span><span style=\"color: rgb(255, 255, 255)\">percée</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au début du combat.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Percée</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Cet état commence avec 1 cumul de </span><span style=\"color: rgb(255, 255, 255)\">percée</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, et chaque nouvelle application rajoute 1 cumul. La </span><span style=\"color: rgb(255, 255, 255)\">percée</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> peut être cumulée 3 fois maximum.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Rajoute 1 cumul de </span><span style=\"color: #FFFFFF\">percée</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage affecté utilise une attaque normale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Avec au moins 2 cumuls de percée, consomme 2 cumuls de percée pour convertir les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés en </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et pioche 1 carte.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/9c5eb94adf31a35a1dcf456b08342b00_4018969139951559491.png",
                "id": "talent95474",
                "key": "Percée",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Percée"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Hydro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Évaporation : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Électrocution :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Gel :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/a126c6a302d81c07e19cf9a9f1260f90_5647821616437267357.png",
                "id": "talent54669",
                "key": "DGT Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_1168984266355756454.png",
