                {
                  "content": [
                    {
                      "text": "Obtenez la victoire en 6 manches ou moins",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "amount": 1,
                      "display_style": "card",
