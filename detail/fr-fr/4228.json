    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Canotila:",
                      "type": "text"
                    },
                    {
                      "text": "Puisque les souvenirs peuvent devenir des récits de livres, l'inverse peut aussi être possible...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Canotila:",
                      "type": "text"
                    },
                    {
                      "text": "Hmm... Qu'est-ce qu'il y a ? Vous avez une question ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "A propos du livre des révélations...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Canotila:",
                      "type": "text"
                    },
                    {
                      "text": "Hmm, j'ai beau y penser sous tous les angles, transformer des souvenirs en livre est un véritable exploit...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Canotila:",
                      "type": "text"
                    },
                    {
                      "text": "Le créateur de cet ouvrage a pu y arriver parce qu'il considérait sans doute les émotions qu'il a éprouvées dans ses souvenirs comme la chose la plus précieuse du monde.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Canotila:",
                      "type": "text"
                    },
                    {
                      "text": "Mais ça ne change pas le fait que son contenu soit très difficile à comprendre...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "J'ai une nouvelle page sur moi...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Canotila:",
                      "type": "text"
                    },
                    {
                      "text": "Oh, si vous trouvez une page ou plus, n'hésitez pas à les mettre à l'intérieur du livre. Voyons ce qui va se passer !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Pas vraiment.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Canotila:",
                      "type": "text"
                    },
                    {
                      "text": "D'accord... Ah, si vous vous sentez triste, venez méditer avec moi. Peut-être que ça vous remontera le moral.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
