    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sania:",
                      "type": "text"
                    },
                    {
                      "text": "*soupir* Que dois-je faire...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Vous allez bien ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sania:",
                      "type": "text"
                    },
                    {
                      "text": "Maintenant, ça va encore, mais qu'en sera-t-il de demain ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sania:",
                      "type": "text"
                    },
                    {
                      "text": "Avec un mari comme le mien, j'ai du mal à joindre les deux bouts tous les jours.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sania:",
                      "type": "text"
                    },
                    {
                      "text": "Je n'attends pas de lui qu'il gagne beaucoup d'argent, mais au moins qu'il ait un revenu régulier.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sania:",
                      "type": "text"
                    },
                    {
                      "text": "Hormis la cuisine, il ne sait rien faire.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sania:",
                      "type": "text"
                    },
                    {
                      "text": "Le Village d'Aaru n'est pas très peuplé, et les gens d'ici sont obligés de cuisiner chez eux pour s'en sortir. Qui voudrait dépenser de l'argent pour manger dehors ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sania:",
                      "type": "text"
                    },
                    {
                      "text": "Et même ça, ça serait acceptable...Si en plus il ne donnait pas aux gens la nourriture qu'il prépare !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Sania:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir... Je dois voir si je peux économiser de l'argent sur mes autres dépenses...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
