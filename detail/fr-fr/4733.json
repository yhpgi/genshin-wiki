    {
      "id": "48",
      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/26b9736a2d14fc4162b2448963f45695_2679398961245507103.png",
                "id": "talent35109",
                "key": "Raisonnement abductif",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Raisonnement abductif"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgb(153, 255, 136)\"> DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et applique un </span><span style=\"color: rgb(255, 255, 255)\">miroir de diffraction</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Miroir de diffraction</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par le personnage sont convertis en </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une attaque normale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Si cette capacité est une </span><span style=\"color: rgb(255, 255, 255)\">attaque chargée</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, la </span><span style=\"color: #FFFFFF\">durée en manches</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> de cet état augmente de 1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2 (Peut être cumulé jusqu'à 3 manches maximum)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/8491b6dd997a8a4878767f1191a2b6aa_5641477360821653530.png",
                "id": "talent33122",
                "key": "Universalité : Élaboration de forme",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  }
                ],
                "talent_img": "",
                "title": "Universalité : Élaboration de forme"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 4 pts de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, consomme le</span><span style=\"color: rgb(255, 255, 255)\"> miroir de diffraction</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et augmente les DGT selon la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> du </span><span style=\"color: rgb(255, 255, 255)\">miroir de diffraction</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> consommé.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Si la </span><span style=\"color: #FFFFFF\">durée en manches</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> du </span><span style=\"color: rgb(255, 255, 255)\">miroir de diffraction</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> consommé est de 0/1/2, le personnage obtient un </span><span style=\"color: rgb(255, 255, 255)\">miroir de diffraction</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> avec une </span><span style=\"color: rgb(255, 255, 255)\">durée en manches</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> respective de 3/2/1.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Miroir de diffraction</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par le personnage sont convertis en </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage a utilisé une attaque normale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: rgb(153, 255, 136)\">DGT Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. Si cette capacité est une </span><span style=\"color: rgb(255, 255, 255)\">attaque chargée</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> de cet état augmente de 1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2 (Peut être cumulé jusqu'à 3 manches maximum)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/a3b3108e0046cb101533a3bf6dcbe717_2611628518238703176.png",
                "id": "talent87140",
                "key": "Champ particulier : Liens de phénomène",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "dendro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Champ particulier : Liens de phénomène"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Dendro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Brûlure </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et crée une </span><span style=\"color: rgb(255, 255, 255)\">flamme brûlante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui inflige des DGT Pyro à la fin de la manche (Utilisable 1 fois, 2 cumuls maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 136)\">Dendro </span><span style=\"color: rgb(255, 255, 255)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Stimulation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et crée un </span><span style=\"color: rgb(255, 255, 255)\">champ catalyseur</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui augmente les 3 prochains coups de DGT Dendro/Électro de 1</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/e8cff941b5a0ff248efde360ec9e91fe_9079351165507985867.png",
                "id": "talent6515",
                "key": "DGT Dendro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Dendro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Attaque chargée</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque le total de vos dés élémentaires est un nombre pair, l'attaque normale utilisée est considérée comme une attaque chargée.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_8513546759472293121.png",
                "id": "talent81756",
                "key": "Règles détaillées",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Règles détaillées"
              }
            ]
          }
        }
      ]
