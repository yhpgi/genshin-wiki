              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Une créature mythique qui se terre au plus profond des montagnes. Utiliser des réactions élémentaires pour la geler, avant d'utiliser</span> <span style=\"color: rgb(255, 225, 75)\">Brise-glace, Fonte ou d'autres réactions élémentaires</span> <span style=\"color: rgba(255, 255, 255, 0.85)\">pour briser la glace, l'immobilisera temporairement.</span></p>"
