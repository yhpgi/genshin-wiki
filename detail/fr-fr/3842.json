      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/1ce09211f025bf5470682189e0837732_6736504037214888245.png",
                "id": "talent60352",
                "key": "Pyramide cryoluciole",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Pyramide cryoluciole"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et invoque une </span><span style=\"color: #FFFFFF\">Cryoluciole</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/09/35653081/1a979041a9881649ba69332b20dd5820_1224568613260586736.png",
                "id": "talent78320",
                "key": "Appel brumeux",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Appel brumeux"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 5 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, </span><span style=\"color: rgb(153, 255, 255)\">applique l'élément Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage et crée un </span><span style=\"color: rgb(255, 255, 255)\">bouclier de luciole</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier de luciole</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Accorde </span><span style=\"color: rgb(255, 255, 255)\">1 pt de bouclier </span><span style=\"color: rgba(255, 255, 255, 0.65)\">à votre personnage actif.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lors de la création : Si une </span><span style=\"color: rgb(255, 255, 255)\">Cryoluciole</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> est sur votre terrain, accorde des points de </span><span style=\"color: rgb(255, 255, 255)\">bouclier </span><span style=\"color: rgba(255, 255, 255, 0.65)\">supplémentaires selon son </span><span style=\"color: rgb(255, 255, 255)\">nombre d'utilisations</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. (Peut accorder un maximum de 3 pts supplémentaires de </span><span style=\"color: rgb(255, 255, 255)\">bouclier</span><span style=\"color: rgba(255, 255, 255, 0.65)\">)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/09/35653081/8d60085e1f79ee9a2bb87006d7f2d32c_2746983791101163959.png",
                "id": "talent35032",
                "key": "Givre de fleurs blanches",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Givre de fleurs blanches"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: #99FFFF\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2 (peut être cumulé, 3 cumuls maximum)</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsqu'un Mage cryoluciole des Fatui a effectué une attaque normale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> </span><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">de cette carte +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque votre personnage a subi des DGT d'une réaction élémentaire déclenchée : Nombre d'utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">de cette carte -1.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/db13288db6b90ec33f8adc2656d2019f_2967749440060953346.png",
                "id": "talent23128",
                "key": "Cryoluciole",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/1467dd7dd3fec80047e77cc996621508_2637408387772128258.png",
                "title": "Cryoluciole"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Cryo et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Gel </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance en subissant des DGT physiques ou Pyro, mais DGT +2)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/4bcc4b82a9d7ee22770f60afa54e9919_5307963747345984133.png",
                "id": "talent97642",
                "key": "DGT Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(153, 255, 255)\">Applique l'élément Cryo</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque l'élément Cryo est appliqué sans infliger de DGT, la réaction élémentaire déclenchée ignore les effets de DGT :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Font : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Aucun effet</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Supracondution : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Aucun effet</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Gel : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">Immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un bouclier qui absorbe les DGT reçus par le personnage qu'il protège.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_3192140217281319811.png",
