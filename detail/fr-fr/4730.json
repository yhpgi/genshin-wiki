      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/c369b96fc6417e8fc2bb607e37297ad4_7295779178199621919.png",
                "id": "talent36365",
                "key": "Cartomagie",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Cartomagie"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(255, 153, 153)\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoque un </span><span style=\"color: rgb(255, 255, 255)\">chapeau félinois </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et accorde 1 cumul de </span><span style=\"color: #FFFFFF\">fantasmagorie</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Si le personnage a 6 PV ou plus, il subit 1 pt de </span><span style=\"color: rgb(255, 255, 255)\">DGT de perforation</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Fantasmagorie</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">La fantasmagorie peut être cumulée 3 fois maximum. </span></p><p><span style=\"color: #FFFFFF\">Lorsque le personnage utilise les Lumières de fioriture :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Chaque cumul de fantasmagorie augmente les DGT de 1 ; après le calcul de la capacité, la fantasmagorie est consommée et chaque cumul soigne le personnage pour 1 pt.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/67d6f9d70e695a791caa42953d11e1e3_1610290928661320442.png",
                "id": "talent97423",
