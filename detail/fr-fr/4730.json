              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de </span><span style=\"color: rgb(255, 153, 153)\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, invoque un </span><span style=\"color: rgb(255, 255, 255)\">chapeau félinois </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et accorde 1 cumul de </span><span style=\"color: rgb(255, 255, 255)\">fantasmagorie</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Fantasmagorie</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">La fantasmagorie peut être cumulée 3 fois maximum.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque le personnage utilise les Lumières de fioriture :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Chaque cumul de fantasmagorie augmente les DGT de 1 ; après le calcul de la capacité, la fantasmagorie est consommée et chaque cumul soigne le personnage pour 1 pt.</span></p><p></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/1f6d82b825fc55a454fe56d6bb68239e_1617238322510409863.png",
                "id": "talent31333",
                "key": "Clou du spectacle : Parade prodigieuse",
                "materials": [],
