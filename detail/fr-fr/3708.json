      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/18/35653081/26b9736a2d14fc4162b2448963f45695_1038176673127315297.png",
                "key": "École Kamisato : Transition",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "École Kamisato : Transition"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et accorde une </span><span style=\"color: rgb(255, 255, 255)\">réflexion torrentielle</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Réflexion torrentielle</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT infligés par l'</span><span style=\"color: rgb(255, 255, 255)\">attaque normale</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> du personnage affecté augmentent de 1 et ses </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques </span><span style=\"color: rgba(255, 255, 255, 0.65)\">infligés sont convertis en </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/18/35653081/55eb1da26441dc746dcf9b653d2bab47_9136168011254936511.png",
                "key": "École Kamisato : Beauté réfléchie",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "École Kamisato : Beauté réfléchie"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et invoque un </span><span style=\"color: rgb(255, 255, 255)\">jardin de pureté</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/18/35653081/2a7181cfb07c093325abc8170e210e45_847729759923359641.png",
                "key": "École Kamisato : Jardin d'eau",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "École Kamisato : Jardin d'eau"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p><p></p><p><span style=\"color: #FFFFFF\">Lorsque cette invocation est sur le terrain :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT infligés pas les attaques normales de votre personnage +1.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/18/35653081/db13288db6b90ec33f8adc2656d2019f_9043688520901730000.png",
                "key": "Jardin de pureté",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/18/35653081/ad5eb2ee48365d340272b333689f3ebb_4546316571936076534.png",
                "title": "Jardin de pureté"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Hydro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Évaporation : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Électrocution :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Gel :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/18/35653081/a126c6a302d81c07e19cf9a9f1260f90_6907395779375774633.png",
                "key": "DGT Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/04/18/35653081/07bae546ac7c69ef6402170b283840c5_1172942569189104403.png",
                "key": "Règles détaillées",
