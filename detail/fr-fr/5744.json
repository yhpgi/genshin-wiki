                      ],
                      "text": "Peintures de Paimon 33",
                      "type": "text"
                    }
                  ],
                  "level": 3,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "alignment": "left",
                      "type": "custom_image",
                      "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/07/14/170542231/b0f20b210ba06abebf1955c8c442457c_2508066082760314278.png"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(255, 215, 128)"
                      ],
                      "text": "12/06/2024",
                      "type": "text"
                    },
                    {
                      "text": "Bonjour, voyageurs ! Les nouvelles émoticônes de Genshin Impact sont disponibles sur HoYoLAB !",
                      "type": "text"
                    },
                    {
                      "text": "Les Peintures de Paimon regroupent une collection d'émoticônes chibi à l'effigie de différents personnages de Genshin Impact. Nous espérons qu'ils vous plaisent !",
                      "type": "text"
                    }
