    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Ah ! Ça faisait longtemps qu'un animal ne m'avait pas adressé la parole !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Euh, « animal » ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Mon nom est Chloris ! Je suis botaniste, la seule et l'unique connue dans tout Mondstadt !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Je viens me promener dans la nature tous les jours, avec la flore pour me tenir compagnie. Mais je ne cracherais pas sur quelques animaux pour discuter un peu.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Si tu n'as rien d'autre à faire, parlons un moment, d'accord ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Euh, OK... Tu as de la famille ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "De la famille ? Hum, tu as peut-être entendu parlé de ma petite sœur Flora ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Elle adore les fleurs ; d'ailleurs elle a ouvert une fleuristerie à Mondstadt.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Moi j'aime la flore en générale ; tant que c'est végétal ça m'intéresse, en particulier si ça sort de l'ordinaire.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "On peut dire que ça se voit que c'est moi l'aînée...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Euh, « animal » ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Mon nom est Chloris ! Je suis botaniste, la seule et l'unique connue dans tout Mondstadt !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Je viens me promener dans la nature tous les jours, avec la flore pour me tenir compagnie. Mais je ne cracherais pas sur quelques animaux pour discuter un peu.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Si tu n'as rien d'autre à faire, parlons un moment, d'accord ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Je ne te dérange pas plus alors.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Hé ! Tu fais exprès ?!",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Chloris:",
                      "type": "text"
                    },
                    {
                      "text": "Ah... Tu t'en vas déjà ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
