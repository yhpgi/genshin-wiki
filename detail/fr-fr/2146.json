              {
                "item_values": [],
                "key": "Tutoriels",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Une machine des ruines qui peut prendre plusieurs formes différentes. En combat, la Matrice mécanique perpétuelle entre en état Défense absolue en se divisant et en invoquant plusieurs types de Sentinelles des ruines. </span><span style=\"color: rgb(255, 225, 75)\">Éliminez les Sentinelles des ruines améliorées</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> pour briser l'état Défense absolue et affaiblir la Matrice.</span></p>"
                ]
              }
            ]
          }
        }
