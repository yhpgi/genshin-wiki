      "name": "Attributs",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "Nom",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Lustrateur inique</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Type",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Ordre de l'Abîme</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Un monstre de l'Ordre de l'Abîme qui manipule plusieurs éléments à la fois et utilise les boucliers des éléments correspondants pour se défendre contre les DGT. Au combat, il crée des anneaux élémentaires, à travers lesquels il canalise une attaque puissante. Utilisez donc les réactions élémentaires pour détruire ces anneaux afin d'éviter une catastrophe imminente...</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
