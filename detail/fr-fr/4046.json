      "id": "11",
      "name": "Attributs",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "Nom",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Mek de reconnaissance</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Type",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Automates</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Une machine créée à partir de l'union entre les technologies complexes et les techniques énergétiques spéciales de Fontaine. Selon qu'elle dégage une signature énergétique </span><span style=\"color: #FFE14B\">ousia ou pneuma</span><span style=\"color: rgba(255, 255, 255, 0.85)\">, elle fonctionne différemment au combat. Lorsque son énergie est épuisée suite à des </span><span style=\"color: #FFE14B\">attaques énergétiques opposées</span><span style=\"color: rgba(255, 255, 255, 0.85)\">, la machine subit une surcharge et se désactive, ce qui l'oblige à utiliser son alimentation d'urgence pour n'effectuer que des actions de combat basiques.</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
