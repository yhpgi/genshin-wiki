            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgb(255, 255, 255)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/1ce09211f025bf5470682189e0837732_5927493876454135196.png",
                "id": "talent97543",
                "key": "Projection de cristal Électro",
                "materials": [],
                "points": [
                  {
