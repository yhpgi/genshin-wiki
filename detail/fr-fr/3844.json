                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Projection de cristal Électro"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et </span><span style=\"color: rgb(255, 255, 255)\">Préparation de capacité</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> : </span><span style=\"color: rgb(255, 255, 255)\">Pierre-feuille-ciseaux : Ciseaux</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et </span><span style=\"color: rgb(255, 255, 255)\">Pierre-feuille-ciseaux : Feuille</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Pierre-feuille-ciseaux : Ciseaux</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgb(255, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et </span><span style=\"color: rgb(255, 255, 255)\">préparation de capacité </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: </span><span style=\"color: rgb(255, 255, 255)\">Pierre-feuille-ciseaux : Feuille</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Pierre-feuille-ciseaux : Feuille</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/09/35653081/0e809f0cd877c453ef4eb86e7d1b8cbf_9021222543437900434.png",
                "id": "talent43044",
                "key": "Pierre-feuille-ciseaux",
                "materials": [],
                "points": [
                  {
                    "point_count": 5,
                    "point_type": "electro"
                  }
                ],
                "talent_img": "",
                "title": "Pierre-feuille-ciseaux"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et invoque une </span><span style=\"color: #FFFFFF\">chaîne du tonnerre protecteur</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/09/35653081/4baa599d0dc30449e310756e218280e2_7441176329918392790.png",
                "id": "talent69764",
                "key": "Verrou de foudre",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "electro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Verrou de foudre"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Capacité passive</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passif) Accorde un </span><span style=\"color: rgb(255, 255, 255)\">noyau cristallin Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au début du combat.</span></p><p></p><p><strong><span style=\"color: #ECE5D8\">Noyau cristallin Électro</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: #FFFFFF\">Lorsque le personnage affecté est éliminé :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> L'effet est annulé et le personnage </span><span style=\"color: #FFFFFF\">évite l'élimination</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> tout en récupérant 1 PV.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/09/35653081/e810a8c5cbf997dc227fbf2bafa2512b_2826352615320985959.png",
                "id": "talent62509",
                "key": "Noyau cristallin Électro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Noyau cristallin Électro"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p><p></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque cette invocation est sur le terrain :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> L'adversaire dépense 1 dé élémentaire de plus lors du changement de personnage. (1 fois par manche)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/06/09/35653081/db13288db6b90ec33f8adc2656d2019f_6579198236201536634.png",
                "id": "talent24603",
                "key": "Chaîne du tonnerre protecteur",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/6f0d7b0b3f0cda9d42d38485a7202bcc_4203382571238097667.png",
                "title": "Chaîne du tonnerre protecteur"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Électro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Surcharge </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2 et bascule de force la cible pour le personnage suivant</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Électrocution </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Stimulation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et crée un </span><span style=\"color: rgb(255, 255, 255)\">champ catalyseur</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui augmente les 3 prochains coups de DGT Dendro/Électro de 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/11ea6117480145a30b7893f1e8bd7115_7118251054509626663.png",
                "id": "talent12288",
                "key": "DGT Électro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Électro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Préparation de capacité</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Certaines capacité ne peuvent pas être utilisées directement. Au lieu de cela, il est nécessaire de les </span><span style=\"color: rgb(255, 255, 255)\">préparer</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> pendant un certain nombre de tours.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsque c'est le tour d'un joueur et que son personnage actif est en train de </span><span style=\"color: rgb(255, 255, 255)\">préparer</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> une capacité, le tour est sauté. Si la </span><span style=\"color: rgb(255, 255, 255)\">préparation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est terminée, le personnage utilise directement la capacité à ce moment-là. (Les capacités nécessitant une </span><span style=\"color: rgb(255, 255, 255)\">préparation</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> ne peuvent pas activer les effets déclenchés lorsque vous avez «&nbsp;utilisé une capacité.&nbsp;»)</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Seul le personnage actif peut </span><span style=\"color: rgb(255, 255, 255)\">préparer</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> une capacité. Si un personnage actif en train de </span><span style=\"color: rgb(255, 255, 255)\">préparer </span><span style=\"color: rgba(255, 255, 255, 0.65)\">une capacité passe en attente, la </span><span style=\"color: rgb(255, 255, 255)\">préparation</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> est interrompue.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Évite l'élimination</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Certains effets accordent aux personnages une immunité contre la mort lorsque leurs PV tombent à zéro, les soignant alors pour un certaine quantité de PV. Lorsque cela se produit, les personnages ne sont pas considérés comme ayant été éliminés. (Ainsi, les équipements et les états du personnages affecté ne sont pas défaussés, et ses charges ne sont pas supprimées.)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisations</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/24/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_1968800321107094606.png",
