                      "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/19/158750877/bf4ef5696afdf695a26fab9510228060_2355936445354568601.png",
                      "menu_id": 4,
                      "name": "Lumière d’incision foliaire",
