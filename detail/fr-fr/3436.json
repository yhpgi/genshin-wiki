    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Qu'est-ce que je vous sers aujourd'hui ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "A propos de Stormterror...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Je n'ai rien à dire sur le sujet. C'est désormais du passé !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "La vie n'est pas aussi douce qu'un jus de fruits. Parfois, elle peut-être aussi amère que de l'alcool... Ce genre d'expérience fait la richesse de nos parcours.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Au lieu de se demander pourquoi certaines choses nous arrivent, il vaudrait mieux aller de l'avant et accepter l'amertume de la vie comme un adulte.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Lorsque tu seras prêt/e, je te préparerai une boisson spéciale pour fêter ça !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Des suggestions ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Je te conseille le cidre de pomme du Domaine de l'Aurore, qui est exclusivement servi qu'ici.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Sinon, tu peux aussi goûter à mon cocktail spécial. C'est la maison qui offre le verre pour les nouveaux clients.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Quelle est la meilleure liqueur ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Si tu les aimes fortes, je te recommanderais bien une mort de l'après-midi. Il s'agit de la boisson préférée de Kaeya.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Mais la plus forte que je connaisse s'appelle l'Eau de feu.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Elle a été introduite à Mondstadt par des marchands de Snezhnaya, mais maître Diluc a cessé d'en importer car elle n'était pas au goût des Mondstadtois.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "La seule bouteille qui nous reste sert seulement de décoration. Si tu veux en goûter, il faudra te rendre à Snezhnaya.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Parlez-moi de vous.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Ma vie t'intéresse ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Ça doit bien faire plus de dix ans que je suis barman. Comme tous les autres ici, je suis employé par le Domaine de l'Aurore.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Perso, le vin et l'alcool en général ne m'intéresse pas des masses en dehors de mon travail...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Ceci dit, je ne voue pas non plus une haine féroce à l'égard de la boisson, contrairement à Diona de la Queue de Chat.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Maître Diluc, le patron, me remplace au comptoir de temps en temps.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Je lui en suis reconnaissant car c'est toujours bien d'avoir des congés.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Ça ira, merci.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Charles:",
                      "type": "text"
                    },
                    {
                      "text": "Sûrs/Sûres ? Bon, c'est pas plus mal.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
