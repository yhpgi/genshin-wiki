              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: rgb(255, 172, 255)\">DGT Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 1</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/12/01/35653081/db13288db6b90ec33f8adc2656d2019f_3761943465131554671.png",
