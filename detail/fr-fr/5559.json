                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "text": "Augmente la maîtrise élémentaire de 50 pts. Après avoir déclenché une réaction de",
                      "type": "text"
                    },
                    {
                      "styles": [
                        "color:rgb(255, 225, 75)"
                      ],
                      "text": "Brûlure",
                      "type": "text"
                    },
                    {
                      "text": ", de",
