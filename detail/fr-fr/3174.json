                  {
                    "point_count": 1,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Archerie de chasse"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et crée un </span><span style=\"color: #FFFFFF\">bouclier de griffes</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier de griffes</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Accorde </span><span style=\"color: #FFFFFF\">1 pt de bouclier</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> à votre personnage actif.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/e0be64da66db784af5d4f957d93b6fad_6912300593624518104.png",
                "id": "talent79768",
                "key": "Griffes Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  }
                ],
                "talent_img": "",
                "title": "Griffes Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo,</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> soigne ce personnage pour 2 pts et invoque un </span><span style=\"color: rgb(255, 255, 255)\">champ de vapeur d'alcool</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/e4f93c5be05671f9b5a666361ad4812a_2024218026094951602.png",
                "id": "talent9957",
                "key": "Cuvée spéciale",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "cryo"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Cuvée spéciale"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: rgb(153, 255, 255)\">DGT Cryo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et soigne votre personnage actif pour 2 pts.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/db13288db6b90ec33f8adc2656d2019f_6378221277998176751.png",
                "id": "talent86409",
                "key": "Champ de vapeur d'alcool",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/998d17590e24d8a0adee347db3a6940a_2883219120411968122.png",
                "title": "Champ de vapeur d'alcool"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Cryo et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Supraconduction </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">[</span><span style=\"color: rgb(153, 255, 255)\">Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">+ </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">] </span><span style=\"color: rgb(255, 255, 255)\">Gel </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance en subissant des DGT physiques ou Pyro, mais DGT +2)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/4bcc4b82a9d7ee22770f60afa54e9919_1504961144042824495.png",
                "id": "talent11902",
                "key": "DGT Cryo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Cryo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bouclier</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Un bouclier qui absorbe les DGT reçus par le personnage qu'il protège.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/07bae546ac7c69ef6402170b283840c5_6928515137190496752.png",
