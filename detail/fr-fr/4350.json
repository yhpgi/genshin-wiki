    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Topyas:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, bonjour. J'ai continué à pratiquer la Mélodie de Vesta ces jours-ci...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "A propos de la chanson que vous avez jouée à Mamère...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Topyas:",
                      "type": "text"
                    },
                    {
                      "text": "J'ai enfin eu l'occasion de la lui jouer comme cadeau d'adieu avant qu'elle ne quitte le village !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Topyas:",
                      "type": "text"
                    },
                    {
                      "text": "Elle a dit qu'elle pouvait s'imaginer d'imposantes tours et de magnifiques navires en l'écoutant...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Topyas:",
                      "type": "text"
                    },
                    {
                      "text": "Et elle a même évoqué l'idée de s'en inspirer pour peindre un chef-d'œuvre ! Elle m'étonnera toujours !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Topyas:",
                      "type": "text"
                    },
                    {
                      "text": "Quoi qu'il en soit, je vous remercie aussi ! Je n'aurais pas pu lui offrir un si beau cadeau sans votre aide précieuse !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "J'ai autre chose à faire.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Topyas:",
                      "type": "text"
                    },
                    {
                      "text": "Bien sûr. Allez finir ce que vous avez à faire.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
