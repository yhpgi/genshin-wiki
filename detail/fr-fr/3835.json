              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Invoque un </span><span style=\"color: #FFFFFF\">Baron Lapinou</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/05/25/35653081/8a097a3894f79e8b2dd0f81472461771_4345703529825004578.png",
                "id": "talent62204",
