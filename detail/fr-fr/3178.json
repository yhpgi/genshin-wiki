      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgb(128, 192, 255)\"> DGT Hydro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/1ce09211f025bf5470682189e0837732_1847308065542902889.png",
                "id": "talent79357",
                "key": "Ondes du destin",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Ondes du destin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgb(128, 192, 255)\"> DGT Hydro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">et invoque un</span> <span style=\"color: #FFFFFF\">mirage</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/a0074558f99c36e32c2a642c89000de2_481684949863922729.png",
                "id": "talent88293",
                "key": "Mirage aqueux",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Mirage aqueux"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 4 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et crée une </span><span style=\"color: #FFFFFF\">bulle nocturne</span><span style=\"color: rgba(255, 255, 255, 0.85)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bulle nocturne</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgb(255, 255, 255)\">Lorsque vous infligez des DGT en utilisant une capacité </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Annule l'état et double les DGT actuels.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/2e3cc81f7cf69d8fdf351f30e4e0993a_983821056859083136.png",
                "id": "talent19181",
                "key": "Voie divine",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Voie divine"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Capacité passive</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">(Passif) </span><span style=\"color: #FFFFFF\">Lorsque ce personnage est actif et que vous basculez de personnage</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> considère ce changement comme une </span><span style=\"color: #FFFFFF\">action rapide</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, et pas comme une </span><span style=\"color: #FFFFFF\">action de comba</span><span style=\"color: rgba(255, 255, 255, 0.85)\">t</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> (1 fois par manche).</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/a4683772d642e5af6323bd0a51d20fd7_2123563872525037159.png",
                "id": "talent98647",
                "key": "Vicissitude",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Vicissitude"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: #FFFFFF\">Lorsque vote personnage actif subit des DGT </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">diminue les DGT de 1 pt.</span></p><p><span style=\"color: #FFFFFF\">Nombre d'utilisation</span> : <span style=\"color: rgba(255, 255, 255, 0.65)\">1, mais la carte n'est pas défaussée une fois épuisée.</span></p><p><span style=\"color: #FFFFFF\">Phase final </span>:<span style=\"color: rgba(255, 255, 255, 0.65)\"> Défausse cette carte et inflige 1 pt de</span> <span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/db13288db6b90ec33f8adc2656d2019f_7561306242116127460.png",
                "id": "talent45569",
                "key": "Mirage",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/1406b92c5115e3a534938a0d3638eeea_6901729121013808509.png",
                "title": "Mirage"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Hydro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Évaporation </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +2.</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Électrocution : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et inflige 1 pt de DGT de perforation à tous les personnages adverses autre que la cible.</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Gel : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et immobilise la cible pendant la manche actuelle (Peut être annulé en avance subissant des DGT physiques ou Pyro, mais DGT +2)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">] Fleurissement </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: DGT actuels +1 et crée un</span> <span style=\"color: rgb(255, 255, 255)\">noyau Dendro</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">qui augmente le prochain coup de DGT Pyro/Électro de 2.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/a126c6a302d81c07e19cf9a9f1260f90_8196330756689604057.png",
                "id": "talent12948",
                "key": "DGT Hydro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Hydro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Action rapide</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Vous pouvez continuer d'effectuer des actions après avoir effectué 1 action rapide.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Ce n'est qu'après avoir effectué 1 action de combat que le tour passe à votre adversaire.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Action de combat</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après que vous termiez 1 action de combat, c'est au tour de votre adversaire.</span></p><p><span style=\"color: rgb(255, 255, 255)\">J</span><span style=\"color: rgba(255, 255, 255, 0.85)\">ouer une carte de votre main contenant cette règle est considéré comme une action de combat, et non pas comme une action rapide.</span></p><p></p><p><strong><span style=\"color: rgba(255, 255, 255, 0.85)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/11/35653081/07bae546ac7c69ef6402170b283840c5_8057963952424037885.png",
                "id": "talent59724",
                "key": "Règles détaillées",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "Règles détaillées"
              }
            ]
          }
        }
      ]
