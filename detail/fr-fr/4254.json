    {
      "id": "36",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Ah oui, je devrais lui poser des questions sur les effets de certains ingrédients tant qu'elle est là...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Oui ? Qu'est-ce qu'il y a ? Vous avez besoin de quelque chose ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "A propos de vos potions...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Grâce à votre aide, nous avons obtenu beaucoup de données concernant la potion de clairvoyance...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Je suis sûre que la grande potionniste sera en mesure d'améliorer ses potions. Tout ça n'est possible qu'avec votre contribution.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Avez-vous encore besoin d'aide ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Nous n'avons pas d'autres formules à tester pour le moment...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Il y a quelques notes et données qui demandent du tri, mais elles sont peu nombreuses. Je peux le faire moi-même.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Courage !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Merci ! Je veux aider plus de gens et la grande potionniste à préparer des potions plus efficaces.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "A propos de Carabosse...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, Carabosse a souvent des idées intrigantes et impressionnantes. Elle sait vraiment choisir des ingrédients surprenants pour ses potions...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "L'attitude audacieuse, du genre « Je ne suis de toute façon pas celle qui essaye les potions », qu'elle a en créant des formules est des plus enviables.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Il y a tant de choses que je dois apprendre d'elle...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Non, rien...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Vérénata:",
                      "type": "text"
                    },
                    {
                      "text": "Hum, en tout cas, merci d'avoir bien voulu nous aider à tester les potions !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
