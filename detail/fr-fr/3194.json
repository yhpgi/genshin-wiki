          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgb(128, 192, 255)\"> DGT Hydro</span>.</p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/04/35653081/1ce09211f025bf5470682189e0837732_6926901627550527849.png",
                "id": "talent28952",
                "key": "Déferlante",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "hydro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Déferlante"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Invoque aléatoirement un type de </span><span style=\"color: rgb(255, 255, 255)\">Mimiqueur Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. (Priorité accordée aux types différents).</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Mimiqueur Hydro</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il existe 3 types de Mimiqueur Hydro :</span></p><p><span style=\"color: rgb(255, 255, 255)\">Écureuil</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">:</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> pendant la phase finale. Peut être utilisé 2 fois.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Faucon </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> pendant la phase finale. Peut être utilisé 3 fois.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Grenouille </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Peut bloquer 2 pts de DGT, et</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> une fois épuisé.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/04/35653081/ebecad0f977c56c89680ec4012285ba1_9165980764553319509.png",
                "id": "talent53570",
                "key": "Mimétisme océanique",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "hydro"
                  }
                ],
                "talent_img": "",
                "title": "Mimétisme océanique"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Invoque aléatoirement deux types de </span><span style=\"color: rgb(255, 255, 255)\">Mimiqueurs Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">. (Priorité accordée aux types différents).</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Mimiqueur Hydro</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Il existe 3 types de Mimiqueur Hydro :</span></p><p><span style=\"color: rgb(255, 255, 255)\">Écureuil</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">:</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> pendant la phase finale. Peut être utilisé 2 fois.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Faucon </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> pendant la phase finale. Peut être utilisé 3 fois.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Grenouille </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Peut bloquer 2 pts de DGT, et</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">inflige 2 pts de </span><span style=\"color: rgb(128, 192, 255)\">DGT Hydro</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> une fois épuisé.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/02/04/35653081/b94e2c26e1f09a4ad1c7ffc224f6f0ad_1068859059726687905.png",
