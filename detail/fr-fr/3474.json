      "id": "11",
      "name": "Attributs",
      "components": [
        {
          "component_id": "baseInfo",
          "data": {
            "list": [
              {
                "item_values": [],
                "key": "Nom",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Wenut de Setekh</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Type",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Bêtes mystiques</span></p>"
                ]
              },
              {
                "item_values": [],
                "key": "Tutoriel",
                "string_values": [
                  "<p><span style=\"color: rgba(255, 255, 255, 0.85)\">Un prédateur des profondeurs du désert qui peut utiliser l'élément Anémo dans une certaine mesure, ce qui lui permet de quitter le sol au combat pour entrer dans un état flottant. En flottant, il peut tirer des balles de craquelure qui, si elles ne sont pas détruites à temps, sont converties en un rideau haute densité. </span><span style=\"color: #FFE14B\">Les attaques élémentaires pouvant réagir avec l'élément Anémo</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> peuvent détruire les balles de craquelure, ce qui diminue temporairement la RÉS élémentaire correspondante du Wenut de Setekh. Une fois 2 balles de craquelure détruites successivement, le Wenut de Setekh sort de son état flottant.</span></p>"
                ]
              }
            ]
          }
        }
      ]
    },
