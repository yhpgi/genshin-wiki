      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/1ce09211f025bf5470682189e0837732_458172224964925822.png",
                "id": "talent97953",
                "key": "Esprit du vent",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Esprit du vent"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 3 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span> <span style=\"color: rgba(255, 255, 255, 0.65)\">et bascule de force la cible pour le personnage précédent.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/dceff798de3e5575ac1c3dad5718d18e_54055247029795594.png",
                "id": "talent7723",
                "key": "Esprit du vent : Sujet 6308",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  }
                ],
                "talent_img": "",
                "title": "Esprit du vent : Sujet 6308"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 1 pt de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et invoque un </span><span style=\"color: rgb(255, 255, 255)\">Esprit du vent de grande taille</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/28de70f699de4ba7cf0f77f2fcfb1483_4190212829172415978.png",
                "id": "talent16593",
                "key": "Esprit du vent : Isomorphe 75 / Type II",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "anemo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Esprit du vent : Isomorphe 75 / Type II"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 2 pts de </span><span style=\"color: rgb(128, 255, 215)\">DGT Anémo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisation :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 3</span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsqu'un de vos personnages ou invocations ont déclenché une réaction de Dispersion : Convertit le type élémentaire de cette carte et modifie les DGT infligés en élément dispersé. (Ne peut être utilisé une seule fois avant de quitter le terrain)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/db13288db6b90ec33f8adc2656d2019f_5525330141075180435.png",
                "id": "talent46854",
                "key": "Esprit du vent de grande taille",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/b91de96bc6f45b8b9a5b10ab4a127a88_7126294743337710287.png",
                "title": "Esprit du vent de grande taille"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Réagit avec les éléments déjà appliqués pour les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Cryo </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Cryo à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Hydro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Hydro à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo </span>+ <span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Pyro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Pyro à tous les personnages adverses autres que la cible</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(128, 255, 215)\">Anémo </span>+ <span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Dispersion Électro </span><span style=\"color: rgba(255, 255, 255, 0.65)\">: Inflige 1 pt de DGT Électro à tous les personnages adverses autres que la cible</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/c97292d96456bfe4abeca16bfce801e4_2734302127022962871.png",
                "id": "talent63973",
                "key": "DGT Anémo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Anémo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/16/35653081/07bae546ac7c69ef6402170b283840c5_930665737836533349.png",
