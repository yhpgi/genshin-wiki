                "item_values": [],
                "key": "Tutoriels",
                "string_values": [
                  "Une créature élémentaire qui se protège derrière sa carapace ; les attaques ne sont efficaces que lorsque son <span style=\"color:#FFE14BFF\">noyau élémentaire</span> est exposé. Elle est capable de recourir aux <span style=\"color:#FFE14BFF\">orbes élémentaires</span> pour restaurer ses PV ; utilisez les champs de vent pour absorber ces orbes, ou le combat sera autrement plus difficile."
                ]
              }
            ]
          }
