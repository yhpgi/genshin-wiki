      "name": "Compétence",
      "components": [
        {
          "component_id": "talent",
          "data": {
            "list": [
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Attaque normale</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de</span><span style=\"color: rgba(255, 255, 255, 0.85)\"> </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/c369b96fc6417e8fc2bb607e37297ad4_9167293705476815216.png",
                "id": "talent72049",
                "key": "Flambée pyrotechnique",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 2,
                    "point_type": "black"
                  }
                ],
                "talent_img": "",
                "title": "Flambée pyrotechnique"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Accorde un </span><span style=\"color: rgb(255, 255, 255)\">Niwabi Enshou</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> au personnage. (Cette capacité n'accorde pas de charge)</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Niwabi Enshou</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT des</span><span style=\"color: rgb(255, 255, 255)\"> attaques normales</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> du personnage affecté augmentent de 1 et ses </span><span style=\"color: rgb(255, 255, 255)\">DGT physiques </span><span style=\"color: rgba(255, 255, 255, 0.65)\">infligés sont convertis en </span><span style=\"color: rgb(255, 153, 153)\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/9fb70e06b7a56894f130c6394d8c6915_1804316096207213824.png",
                "id": "talent81066",
                "key": "Danse du feu « Niwabi »",
                "materials": [],
                "points": [
                  {
                    "point_count": 1,
                    "point_type": "pyro"
                  }
                ],
                "talent_img": "",
                "title": "Danse du feu « Niwabi »"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 4 pts de</span><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: rgb(255, 153, 153)\">DGT Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span><span style=\"color: rgba(255, 255, 255, 0.65)\">et crée une </span><span style=\"color: rgb(255, 255, 255)\">Flamme Ryuukin</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Flamme Ryuukin</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Lorsqu'un de vos personnages autre que Yoimiya a utilisé une capacité : Inflige 1 pt de </span><span style=\"color: rgb(255, 153, 153)\">DGT Pyro</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/26b28348d7d58e4a29a39d14cf4a81a8_4939914134501416013.png",
                "id": "talent94724",
                "key": "Saxifrage Ryuukin",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "pyro"
                  },
                  {
                    "point_count": 3,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Saxifrage Ryuukin"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Applique l'élément Pyro et peut déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 153, 153)\"> </span><span style=\"color: rgb(255, 255, 255)\">Fonte </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(255, 172, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Évaporation </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Surcharge </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +2 et bascule de force la cible pour le personnage suivant</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(153, 255, 255)\"> </span>+ <span style=\"color: rgb(153, 255, 136)\">Dendro</span><span style=\"color: rgb(255, 255, 255)\">]</span><span style=\"color: rgb(128, 192, 255)\"> </span><span style=\"color: rgb(255, 255, 255)\">Brûlure </span>: <span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et crée une </span><span style=\"color: #FFFFFF\">flamme brûlante</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> qui inflige des DGT Pyro à la fin de la manche (Utilisable 1 fois, 2 cumuls maximum)</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/d714b3b669cc08d1d8e34464fd7a3630_1118823014098426438.png",
                "id": "talent74550",
                "key": "DGT Pyro",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Pyro"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p>",
                "icon_url": "https://upload-static.hoyoverse.com/hoyolab-wiki/2023/01/18/35653081/07bae546ac7c69ef6402170b283840c5_7170425463292223554.png",
