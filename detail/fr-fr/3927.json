    {
      "id": "68",
      "name": "Dialogues",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Dongdong:",
                      "type": "text"
                    },
                    {
                      "text": "Vous êtes un(e) voyageur/euse, n'est-ce pas ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Oui.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Dongdong:",
                      "type": "text"
                    },
                    {
                      "text": "Ouah ! Génial ! Vous avez dû aller dans plein d'endroits et voir plein de trucs trop cools !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Dongdong:",
                      "type": "text"
                    },
                    {
                      "text": "Mon papa est un marin du Crux ! Il parcourt le monde et part à l'aventure tous les jours ! C'est un héros !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Dongdong:",
                      "type": "text"
                    },
                    {
                      "text": "Il n'est pas souvent à la maison, mais il m'envoie toujours des lettres avec des histoires hyper passionnantes de son voyage, héhé.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Dongdong:",
                      "type": "text"
                    },
                    {
                      "text": "Je deviendrai comme lui quand je serai grand ! Je verrai toutes ces merveilles de mes propres yeux !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Dongdong:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir ! J'espère que vous vivrez des aventures aussi palpitantes que mon papa, héhé !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
