    {
      "id": "30",
      "name": "Autres informations",
      "components": [
        {
          "component_id": "textual_research",
          "data": {
            "list": [
              {
                "audios": [
                  {
                    "id": "Autres informations60151",
                    "name": "Shouki no Kami",
                    "url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki-voice/2024/05/17/29705491/16198f9c5ab681b2f8d1c1866bca484e_801499214137368736.mp3"
                  }
                ],
                "desc": "",
                "title": "Thème musical du combat"
              },
              {
                "audios": [],
                "desc": "<custom-post posts=\"13335735\"></custom-post>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/03/13/29705491/04d99b08d8e12dc2015a7cc808e555ae_2477999315705156644.png",
                "title": "Seigneur éternel de la sagesse arcanique : Shouki no Kami, le prodige"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Le projet secret sur lequel les six darshans de l&#39;Académie ont coopéré approche de sa phase finale. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Tant d&#39;efforts, de temps et de ressources porteront certainement leurs fruits. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Mais que le résultat soit à la hauteur de leurs attentes ou non n&#39;est peut-être plus entre leurs mains...</span></p><p></p><p><strong><span style=\"color: #FF9999\">YouTube :</span></strong> <span style=\"color: #37FFFF\">https://www.youtube.com/watch?v=bT3qW-Zgtow</span></p><custom-post posts=\"12926539\"></custom-post>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/18/29705491/0b345dc7ca2d681b63341f34b1359b94_4483825705185830210.png",
                "title": "Genshin Impact - Bande annonce de la version 3.2 Pulsation akashienne & montée de la flamme de kalpa"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">« Que la sagesse de tous se rassemble au nom de l&#39;Archon. » </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Pendant l&#39;affrontement contre Shouki no Kami, l&#39;Akasha a regagné sa fonction primaire. </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Le « Premier sage » de Buer s&#39;en servira pour vaincre la « fausse divinité ». </span></p><p></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Voix : </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Buer, bénie de sagesse, Mahakusaladhamma : Kimberley Anne Campbell </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Seigneur éternel de la sagesse arcanique « Shouki no Kami, le prodige » : Patrick Pedraza </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Paimon : Corina Boettger </span></p><p><span style=\"color: rgba(255, 255, 255, 0.45)\">Aether : Zach Aguilar</span></p><p></p><p><strong><span style=\"color: #FF9999\">YouTube :</span></strong> <span style=\"color: #37FFFF\">https://www.youtube.com/watch?v=ExVzjvMSnTI</span></p><custom-post posts=\"13443421\"></custom-post>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/18/29705491/22cabd345d0cc75559633e7435607b82_5239197073012996571.png",
                "title": "Genshin Impact - Cinématique : Le Premier sage de Buer"
              },
              {
                "audios": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.45)\">Avertissement : cette vidéo peut provoquer des réactions chez les personnes photosensibles et sujettes à l&#39;épilepsie. Veuillez visionner en connaissance de cause. Cette performance de la musique du combat contre « Shouki no Kami » du 2e volume de la bande originale de Sumeru a été enregistrée au Yokohama Minato Mirai Hall. L&#39;Orchestre philharmonique de Tokyo, un chœur et un chanteur d&#39;opéra interprètent ensemble « Polumnia Omnia ». —————————————————— Production : HOYO-MiX Coproduction : Sony Music Entertainment (Japan) Inc. Compositeur : Yu-Peng Chen@HOYO-MiX Chanteur d&#39;opéra : Paolo Andrea Di Pietro Chœur : Time-office Interprétation : Orchestre philharmonique de Tokyo Shakuhachi : Kizan Kawamura Production vidéo : P.I.C.S.</span></p><p></p><p><strong><span style=\"color: #FF9999\">YouTube :</span></strong><span style=\"color: rgba(255, 255, 255, 0.45)\"> </span><span style=\"color: #37FFFF\">https://www.youtube.com/watch?v=CyrsVvea0TM</span></p><custom-post posts=\"17813974\"></custom-post>",
                "img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2024/05/17/29705491/516360f73336ca959a0a00ee0fb44d05_967611014884147528.png",
                "title": "Genshin Impact - Polumnia Omnia : Vidéo promotionnelle de la bande originale de Sumeru Vol.2 (Live)"
              }
            ]
          }
        }
      ]
    },
