    {
      "id": "68",
      "name": "Dialogues ",
      "components": [
        {
          "component_id": "customize",
          "data": {
            "data": {
              "parsed_content": [
                {
                  "content": [
                    {
                      "text": "Dialogues standards",
                      "type": "text"
                    }
                  ],
                  "level": 1,
                  "type": "heading"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Louis:",
                      "type": "text"
                    },
                    {
                      "text": "La nourriture la plus savoureuse du monde, c'est ici ! Venez, cher/ère amie, vous voulez goûter ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Et vous êtes...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Louis:",
                      "type": "text"
                    },
                    {
                      "text": "Ils m'appellent le représentant de la cuisine de rue.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Louis:",
                      "type": "text"
                    },
                    {
                      "text": "Si je devais recevoir un titre prestigieux comme les personnalités, ce serait « Louis le fritier ». Simple et élégant, non ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Avez-vous des recommandations ?",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Louis:",
                      "type": "text"
                    },
                    {
                      "text": "Ah, vous êtes tombé/e sur la bonne personne. Nous servons ici le meilleur poisson-frites de tout Teyvat !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Louis:",
                      "type": "text"
                    },
                    {
                      "text": "Poisson-frites au petit-déjeuner, pour vous réchauffer le matin. Poisson-frites à l'heure du thé, tous les enfant adorent...",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Louis:",
                      "type": "text"
                    },
                    {
                      "text": "Et dois-je mentionner le poisson-frites pour une promenade en ville ? Leur croustillant et leur parfum sont loués par le capitaine de la patrouille de surveillance spéciale et les goélands !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Louis:",
                      "type": "text"
                    },
                    {
                      "text": "Je ne peux pas imaginer ce que deviendrait Fontaine si le poisson-frites n'existait pas !",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Voyageur/euse:",
                      "type": "text"
                    },
                    {
                      "text": "Au revoir.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "content": [
                    {
                      "styles": [
                        "bold",
                        "color:rgb(191, 191, 191)"
                      ],
                      "text": "Louis:",
                      "type": "text"
                    },
                    {
                      "text": "Si jamais vous voulez un bon poisson-frites, vous savez où me trouver.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          }
        }
      ]
    },
