          "data": {
            "list": [
              {
                "desc": "Le nom complet de cette épée est assez peu courant :</br>« Le messager de l'aube triomphant montrant la victoire ».</br>L'épée n'a fait qu'une victime sur le champ de bataille.</br>Cette nuit-là, l'aventurier brandit son arme sur le champ de bataille ;</br>mais la lame réfléchit le clair de lune, brillant comme le jour.</br>Sa position était découverte ;</br>une pluie de flèches s'abattit dans sa direction.</br>",
                "title": ""
              }
            ]
          }
        }
