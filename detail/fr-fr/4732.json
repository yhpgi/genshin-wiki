              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Compétence élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et crée une </span><span style=\"color: rgb(255, 255, 255)\">bannière de général</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bannière de général</span></strong></p><p><span style=\"color: #FFD780\">État de déploiement</span></p><p><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par votre personnage +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2 (Peut être cumulé jusqu'à 3 manches maximum)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/938b4e094906a85cee73a083091b261c_5379539820499252926.png",
                "id": "talent72882",
                "key": "Défense intégrale d'Inuzaka",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  }
                ],
                "talent_img": "",
                "title": "Défense intégrale d'Inuzaka"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Déchaînement élémentaire</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Inflige 2 pts de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\">, crée une </span><span style=\"color: rgb(255, 255, 255)\">bannière de général</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et invoque un </span><span style=\"color: rgb(255, 255, 255)\">prestige de général</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Bannière de général</span></strong></p><p><span style=\"color: rgb(255, 215, 128)\">État de déploiement</span></p><p><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> infligés par votre personnage +1.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Durée en manches :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2 (Peut être cumulé jusqu'à 3 manches maximum)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/07aaa637ba933d0311335db4da950abf_1421407531864647993.png",
                "id": "talent66879",
                "key": "Crocs bestiaux : Vers la victoire",
                "materials": [],
                "points": [
                  {
                    "point_count": 3,
                    "point_type": "geo"
                  },
                  {
                    "point_count": 2,
                    "point_type": "recharge"
                  }
                ],
                "talent_img": "",
                "title": "Crocs bestiaux : Vers la victoire"
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgb(255, 215, 128)\">Invocation</span></p><p><span style=\"color: rgb(255, 255, 255)\">Phase finale :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> Inflige 1 pt de </span><span style=\"color: rgb(255, 230, 153)\">DGT Géo</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> et, si votre équipe a 2 personnages Géo, crée une </span><span style=\"color: #FFFFFF\">Cristallisation</span><span style=\"color: rgba(255, 255, 255, 0.65)\">.</span></p><p><span style=\"color: rgb(255, 255, 255)\">Nombre d'utilisations :</span><span style=\"color: rgba(255, 255, 255, 0.65)\"> 2</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/db13288db6b90ec33f8adc2656d2019f_2084478567349943595.png",
                "id": "talent71555",
                "key": "Prestige de général ",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/19/35653081/e473fedde5cae543bffc4ffb4faeef30_7391423704482437956.png",
                "title": "Prestige de général "
              },
              {
                "attributes": [],
                "desc": "<p><span style=\"color: rgba(255, 255, 255, 0.65)\">Réagit avec les éléments déjà appliqués pour déclencher les réactions élémentaires :</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(153, 255, 255)\">Cryo</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Cryo : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(128, 192, 255)\">Hydro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Hydro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 153, 153)\">Pyro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Pyro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p><p><span style=\"color: rgb(255, 255, 255)\">[</span><span style=\"color: rgb(255, 230, 153)\">Géo</span><span style=\"color: rgb(255, 255, 255)\"> + </span><span style=\"color: rgb(255, 172, 255)\">Électro</span><span style=\"color: rgb(255, 255, 255)\">] Cristallisation Électro : </span><span style=\"color: rgba(255, 255, 255, 0.65)\">DGT actuels +1 et accord 1 pt de bouclier à votre personnage actif (Peut être cumulé, 2 pts maximum)</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/fd37cbfdd3b1b2c16e6e83fb0aa96889_8200186077712553846.png",
                "id": "talent96173",
                "key": "DGT Géo",
                "materials": [],
                "points": [
                  {
                    "point_count": 0,
                    "point_type": ""
                  }
                ],
                "talent_img": "",
                "title": "DGT Géo"
              },
              {
                "attributes": [],
                "desc": "<p><strong><span style=\"color: rgb(236, 229, 216)\">DGT physiques</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Les DGT physiques n'appliquent aucun élément et ne peuvent pas non plus déclencher de réactions élémentaires.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Durée en manches</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">À chaque fin de manche, </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">-1.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois la </span><span style=\"color: rgb(255, 255, 255)\">durée en manches </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisée.</span></p><p></p><p><strong><span style=\"color: rgb(236, 229, 216)\">Nombre d'utilisation</span></strong></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Après le déclenchement de l'effet de cette carte, 1 de ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">est consommée.</span></p><p><span style=\"color: rgba(255, 255, 255, 0.65)\">Une carte est immédiatement défaussée une fois toutes ses </span><span style=\"color: rgb(255, 255, 255)\">utilisations </span><span style=\"color: rgba(255, 255, 255, 0.65)\">épuisées.</span></p>",
                "icon_url": "https://act-upload.hoyoverse.com/event-ugc-hoyowiki/2023/12/17/35653081/245c229cf6f7364c7c9a7aea3db1a1ad_449413469434456687.png",
